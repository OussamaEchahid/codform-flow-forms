
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id          String    @id
  shop        String
  state       String
  isOnline    Boolean   @default(false)
  scope       String?
  expires     DateTime?
  accessToken String
  userId      BigInt?
}

model Form {
  id          String   @id @default(uuid())
  title       String
  description String?
  fields      String // JSON string of form fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shopId      String?  // Optional Shopify shop ID
  isActive    Boolean  @default(true)
  submissions Submission[]
  
  // New field to track product associations
  productId   String? // Optional product ID for direct association
}

model Submission {
  id        String   @id @default(uuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id])
  data      String   // JSON string of form submission data
  createdAt DateTime @default(now())
  status    String   @default("pending") // pending, approved, rejected
  shopId    String?  // Optional Shopify shop ID
  orderId   String?  // Optional Shopify order ID
}

// Model representing the Shopify product-form settings
model ShopifyProductSetting {
  id         String  @id @default(uuid())
  shopId     String
  productId  String
  formId     String
  blockId    String?
  enabled    Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@unique([shopId, productId])
}

// Model for form insertion settings
model ShopifyFormInsertion {
  id              String @id @default(uuid())
  formId          String
  shopId          String
  position        String @default("product-page")
  blockId         String?
  themeType       String @default("auto-detect")
  insertionMethod String @default("auto")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([formId, shopId])
}
