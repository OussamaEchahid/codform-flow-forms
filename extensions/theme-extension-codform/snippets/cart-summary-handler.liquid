{% comment %}
Cart Summary Handler - Modular cart summary functionality
{% endcomment %}

<script>
(function() {
  'use strict';
  
  // Cart Summary Handler Module
  window.CodformCartSummaryHandler = {
    
    // Render cart summary field
    renderCartSummary: function(field, formStyle, formLanguage) {
      if (!field || field.type !== 'cart-summary') return '';
      
      const formDirection = formStyle?.formDirection || (formLanguage === 'ar' ? 'rtl' : 'ltr');
      const baseFontSize = formDirection === 'rtl' ? '13px' : '16px';
      
      // Configuration with defaults
      const config = field.config || {};
      const showSubtotal = config.showSubtotal !== false;
      const showDiscount = config.showDiscount && config.discountAmount > 0;
      const showShipping = config.showShipping !== false;
      const showTotal = config.showTotal !== false;
      
      // Labels with RTL support
      const subtotalLabel = config.subtotalLabel || (formDirection === 'rtl' ? 'المجموع الفرعي' : 'Subtotal');
      const discountLabel = config.discountLabel || (formDirection === 'rtl' ? 'الخصم' : 'Discount');
      const shippingLabel = config.shippingLabel || (formDirection === 'rtl' ? 'الشحن' : 'Shipping');
      const totalLabel = config.totalLabel || (formDirection === 'rtl' ? 'المجموع' : 'Total');
      
      // Styling
      const fieldStyle = field.style || {};
      const labelColor = fieldStyle.labelColor || '#374151';
      const valueColor = fieldStyle.valueColor || '#111827';
      const fontSize = fieldStyle.fontSize || baseFontSize;
      const fontWeight = fieldStyle.fontWeight || '500';
      const backgroundColor = fieldStyle.backgroundColor || '#F9FAFB';
      const borderRadius = fieldStyle.borderRadius || '8px';
      const padding = fieldStyle.padding || '16px';
      
      // Generate unique ID for this cart summary
      const fieldId = field.id || 'cart-summary-' + Math.random().toString(36).substr(2, 9);
      
      return `
        <div class="cart-summary-wrapper" 
             data-cart-summary-id="${fieldId}"
             style="
               direction: ${formDirection};
               background-color: ${backgroundColor};
               border-radius: ${borderRadius};
               padding: ${padding};
               margin-bottom: 16px;
               border: 1px solid #E5E7EB;
             ">
          
          ${showSubtotal ? `
            <div class="cart-summary-row" style="
              display: flex;
              justify-content: space-between;
              align-items: center;
              margin-bottom: 8px;
            ">
              <span style="
                color: ${labelColor};
                font-size: ${fontSize};
                font-weight: ${fontWeight};
                font-family: ${formDirection === 'rtl' ? "'Cairo', sans-serif" : "'Inter', sans-serif"};
              ">${subtotalLabel}</span>
              <span class="cart-subtotal-value" style="
                color: ${valueColor};
                font-size: ${fontSize};
                font-weight: 600;
                font-family: ${formDirection === 'rtl' ? "'Cairo', sans-serif" : "'Inter', sans-serif"};
              ">£0.00</span>
            </div>
          ` : ''}
          
          ${showDiscount ? `
            <div class="cart-summary-row" style="
              display: flex;
              justify-content: space-between;
              align-items: center;
              margin-bottom: 8px;
            ">
              <span style="
                color: ${labelColor};
                font-size: ${fontSize};
                font-weight: ${fontWeight};
                font-family: ${formDirection === 'rtl' ? "'Cairo', sans-serif" : "'Inter', sans-serif"};
              ">${discountLabel}</span>
              <span class="cart-discount-value" style="
                color: #059669;
                font-size: ${fontSize};
                font-weight: 600;
                font-family: ${formDirection === 'rtl' ? "'Cairo', sans-serif" : "'Inter', sans-serif"};
              ">-£0.00</span>
            </div>
          ` : ''}
          
          ${showShipping ? `
            <div class="cart-summary-row" style="
              display: flex;
              justify-content: space-between;
              align-items: center;
              margin-bottom: 8px;
            ">
              <span style="
                color: ${labelColor};
                font-size: ${fontSize};
                font-weight: ${fontWeight};
                font-family: ${formDirection === 'rtl' ? "'Cairo', sans-serif" : "'Inter', sans-serif"};
              ">${shippingLabel}</span>
              <span class="cart-shipping-value" style="
                color: ${valueColor};
                font-size: ${fontSize};
                font-weight: 600;
                font-family: ${formDirection === 'rtl' ? "'Cairo', sans-serif" : "'Inter', sans-serif"};
              ">£0.00</span>
            </div>
          ` : ''}
          
          ${showTotal ? `
            <div class="cart-summary-row cart-total-row" style="
              display: flex;
              justify-content: space-between;
              align-items: center;
              padding-top: 12px;
              border-top: 1px solid #E5E7EB;
              margin-top: 8px;
            ">
              <span style="
                color: ${valueColor};
                font-size: calc(${fontSize} + 2px);
                font-weight: 700;
                font-family: ${formDirection === 'rtl' ? "'Cairo', sans-serif" : "'Inter', sans-serif"};
              ">${totalLabel}</span>
              <span class="cart-total-value" style="
                color: ${valueColor};
                font-size: calc(${fontSize} + 2px);
                font-weight: 700;
                font-family: ${formDirection === 'rtl' ? "'Cairo', sans-serif" : "'Inter', sans-serif"};
              ">£0.00</span>
            </div>
          ` : ''}
        </div>
      `;
    },
    
    // Initialize cart summary with product data
    initializeCartSummary: function(fieldId, productData, formCurrency, config) {
      if (!productData || !productData.price) return;
      
      const container = document.querySelector(`[data-cart-summary-id="${fieldId}"]`);
      if (!container) return;
      
      // Use the external cart summary handler
      if (window.CodformCartSummary && window.CodformCartSummary.updateCartSummary) {
        window.CodformCartSummary.updateCartSummary(
          container, 
          productData, 
          formCurrency || 'GBP', 
          config || {}
        );
      }
    },
    
    // Get real form currency from API data
    getRealFormCurrency: function(data) {
      if (!data) return null;
      
      // Check multiple possible locations for currency
      if (data.form && data.form.currency) {
        console.log('✅ Found form currency in data.form.currency:', data.form.currency);
        return data.form.currency;
      }
      
      if (data.currency) {
        console.log('✅ Found form currency in data.currency:', data.currency);
        return data.currency;
      }
      
      if (data.formSettings && data.formSettings.currency) {
        console.log('✅ Found form currency in data.formSettings.currency:', data.formSettings.currency);
        return data.formSettings.currency;
      }
      
      console.log('⚠️ No form currency found in API response');
      return null;
    }
  };
  
})();
</script>