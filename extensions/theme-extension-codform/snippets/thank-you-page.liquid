{% comment %}
  صفحة الشكر المخصصة لنماذج Codform
{% endcomment %}

<div class="codform-thank-you-container" style="
  max-width: 600px;
  margin: 40px auto;
  padding: 30px;
  text-align: center;
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  direction: {{ shop.locale | default: 'ar' | contains: 'ar' | ? 'rtl' : 'ltr' }};
">
  <div class="thank-you-icon" style="
    font-size: 48px;
    color: #22c55e;
    margin-bottom: 20px;
  ">
    ✅
  </div>
  
  <h1 style="
    color: #1f2937;
    font-size: 24px;
    margin-bottom: 15px;
    font-family: 'Cairo', sans-serif;
  ">
    Thank you for your order!
  </h1>
  
  <p style="
    color: #6b7280;
    font-size: 16px;
    margin-bottom: 20px;
    line-height: 1.6;
    font-family: 'Cairo', sans-serif;
  ">
    Your order has been received successfully! We'll contact you soon to confirm the details. Please keep your phone nearby.
  </p>
  
  {% if request.query.order %}
  <div class="order-info" style="
    background: #f3f4f6;
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
  ">
    <p style="
      margin: 0;
      color: #374151;
      font-weight: 600;
      font-family: 'Cairo', sans-serif;
    ">
      {% if shop.locale contains 'ar' %}
        رقم الطلب: {{ request.query.order }}
      {% else %}
        Order Number: {{ request.query.order }}
      {% endif %}
    </p>
  </div>
  {% endif %}
  
  <div class="action-buttons" style="
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 30px;
  ">
    <a href="{{ shop.url }}" style="
      display: inline-block;
      background: #3b82f6;
      color: white;
      padding: 12px 24px;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      transition: background 0.3s ease;
      font-family: 'Cairo', sans-serif;
    ">
      {% if shop.locale contains 'ar' %}
        العودة للمتجر
      {% else %}
        Back to Store
      {% endif %}
    </a>
    
    <a href="{{ shop.url }}/collections/all" style="
      display: inline-block;
      background: #10b981;
      color: white;
      padding: 12px 24px;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      transition: background 0.3s ease;
      font-family: 'Cairo', sans-serif;
    ">
      {% if shop.locale contains 'ar' %}
        تصفح المنتجات
      {% else %}
        Browse Products
      {% endif %}
    </a>
  </div>
</div>

<script>
// تتبع إعلانات الشكر
document.addEventListener('DOMContentLoaded', function() {
  console.log('🎉 Thank you page loaded');
  
  // تتبع الإعلانات للتحويل المكتمل
  if (window.parent && window.parent.CodformAdvertisingTracking) {
    console.log('📊 Tracking conversion completion');
    
    // تتبع Facebook
    if (window.parent.fbq) {
      window.parent.fbq('track', 'CompleteRegistration');
      window.parent.fbq('track', 'Lead');
    }
    
    // تتبع Snapchat
    if (window.parent.snaptr) {
      window.parent.snaptr('track', 'SIGN_UP');
    }
    
    // تتبع TikTok
    if (window.parent.ttq) {
      window.parent.ttq.track('CompleteRegistration');
    }
  }
  
  // إرسال حدث التحويل المكتمل
  const conversionEvent = new CustomEvent('conversionCompleted', {
    detail: {
      orderNumber: '{{ request.query.order }}',
      timestamp: new Date().toISOString()
    }
  });
  document.dispatchEvent(conversionEvent);
});
</script>

<style>
.codform-thank-you-container a:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

@media (max-width: 768px) {
  .codform-thank-you-container {
    margin: 20px;
    padding: 20px;
  }
  
  .action-buttons {
    flex-direction: column;
    align-items: center;
  }
  
  .action-buttons a {
    width: 100%;
    max-width: 200px;
    text-align: center;
  }
}
</style>