{% comment %}
  Cart Summary Field Partial
  Renders cart summary with subtotal, discount, shipping, and total
{% endcomment %}

{% assign config = field.config | default: blank %}
{% assign showSubtotal = config.showSubtotal | default: true %}
{% assign showDiscount = config.showDiscount | default: true %}
{% assign showShipping = config.showShipping | default: true %}
{% assign showTotal = config.showTotal | default: true %}
{% assign discountValue = config.discountValue | default: 0 %}
{% assign discountType = config.discountType | default: 'percentage' %}
{% assign shippingCost = config.shippingCost | default: 0 %}
{% assign currency = config.currency | default: 'SAR' %}
{% assign autoCalculate = config.autoCalculate | default: false %}

{% comment %} Text direction and labels {% endcomment %}
{% assign direction = config.direction | default: 'auto' %}
{% if direction == 'auto' %}
  {% if config.subtotalText contains 'ا' or config.subtotalText contains 'ع' or config.subtotalText contains 'ر' %}
    {% assign direction = 'rtl' %}
  {% else %}
    {% assign direction = 'ltr' %}
  {% endif %}
{% endif %}

{% comment %} Labels from config with fallbacks {% endcomment %}
{% assign subtotalLabel = config.subtotalText | default: 'المجموع الفرعي' %}
{% assign discountLabel = config.discountText | default: 'الخصم' %}
{% assign shippingLabel = config.shippingText | default: 'الشحن' %}
{% assign totalLabel = config.totalText | default: 'الإجمالي' %}

{% if direction == 'ltr' %}
  {% assign subtotalLabel = config.subtotalText | default: 'Subtotal' %}
  {% assign discountLabel = config.discountText | default: 'Discount' %}
  {% assign shippingLabel = config.shippingText | default: 'Shipping' %}
  {% assign totalLabel = config.totalText | default: 'Total' %}
{% endif %}

{% comment %} Styling from field configuration {% endcomment %}
{% assign labelColor = field.style.labelColor | default: '#374151' %}
{% assign valueColor = field.style.valueColor | default: '#111827' %}
{% assign totalValueColor = field.style.totalValueColor | default: '#059669' %}
{% assign fontSize = field.style.labelFontSize | default: '16px' %}
{% assign valueFontSize = field.style.valueFontSize | default: '16px' %}
{% assign totalFontSize = field.style.totalValueFontSize | default: '18px' %}
{% assign fontFamily = field.style.fontFamily | default: 'Cairo' %}
{% assign fontWeight = field.style.fontWeight | default: '500' %}

<div class="cart-summary-field codform-cart-summary" 
     data-field-id="{{ field.id }}" 
     data-auto-calculate="{{ autoCalculate }}"
     data-currency="{{ currency }}"
     style="
       width: 100%;
       background: {{ field.style.backgroundColor | default: '#f9fafb' }};
       border: 1px solid {{ field.style.borderColor | default: '#e5e7eb' }};
       border-radius: {{ field.style.borderRadius | default: '8px' }};
       padding: 16px;
       margin: 16px 0;
        direction: {{ direction }};
        font-family: {{ fontFamily }}, {{ direction == 'rtl' ? 'Cairo, Tajawal, Arial, sans-serif' : 'Inter, Arial, sans-serif' }};
     ">
  
  {% if showSubtotal %}
  <div class="summary-row" style="
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  ">
    <span class="summary-label" style="
      color: {{ labelColor }};
      font-size: {{ fontSize }};
      font-weight: {{ fontWeight }};
      font-family: {{ fontFamily }};
    ">{{ subtotalLabel }}</span>
    <span class="summary-value subtotal-value" style="
      color: {{ valueColor }};
      font-size: {{ valueFontSize }};
      font-weight: 600;
      font-family: {{ fontFamily }};
    " data-amount="0">{{ currency }} 0.00</span>
  </div>
  {% endif %}

  {% if showDiscount %}
  <div class="summary-row discount-row" style="
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    {% unless discountValue > 0 %}display: none;{% endunless %}
  ">
    <span class="summary-label" style="
      color: {{ labelColor }};
      font-size: {{ fontSize }};
      font-weight: {{ fontWeight }};
      font-family: {{ fontFamily }};
    ">{{ discountLabel }}</span>
    <span class="summary-value discount-value" style="
      color: #dc2626;
      font-size: {{ valueFontSize }};
      font-weight: 600;
      font-family: {{ fontFamily }};
    " data-amount="0">-{{ currency }} 0.00</span>
  </div>
  {% endif %}

  {% if showShipping %}
  <div class="summary-row" style="
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    border-bottom: 1px solid {{ field.style.borderColor | default: '#e5e7eb' }};
    padding-bottom: 8px;
  ">
    <span class="summary-label" style="
      color: {{ labelColor }};
      font-size: {{ fontSize }};
      font-weight: {{ fontWeight }};
      font-family: {{ fontFamily }};
    ">{{ shippingLabel }}</span>
    <span class="summary-value shipping-value" style="
      color: {{ valueColor }};
      font-size: {{ valueFontSize }};
      font-weight: 600;
      font-family: {{ fontFamily }};
    " data-amount="{{ shippingCost }}">
      {% if shippingCost == 0 %}
        {{ formDirection == 'rtl' ? 'مجاني' : 'Free' }}
      {% else %}
        {{ currency }} {{ shippingCost | money_without_currency }}
      {% endif %}
    </span>
  </div>
  {% endif %}

  {% if showTotal %}
  <div class="summary-row total-row" style="
    display: flex;
    justify-content: space-between;
    align-items: center;
  ">
    <span class="summary-label" style="
      color: {{ field.style.totalLabelColor | default: '#111827' }};
      font-size: {{ totalFontSize }};
      font-weight: 700;
      font-family: {{ fontFamily }};
    ">{{ totalLabel }}</span>
    <span class="summary-value total-value" style="
      color: {{ totalValueColor }};
      font-size: {{ totalFontSize }};
      font-weight: 700;
      font-family: {{ fontFamily }};
    " data-amount="0">{{ currency }} 0.00</span>
  </div>
  {% endif %}
</div>