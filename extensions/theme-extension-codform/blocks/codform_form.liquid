{%- liquid
  assign block_id = block.id
  assign section_id = section.id
  assign settings = block.settings
  assign shop_locale = request.locale.iso_code
  assign country_code = shop_locale | slice: 3, 2
  assign form_id = settings.form_id
  assign submit_button_text = settings.submit_button_text
  assign form_style = settings.form_style
  assign show_quantity_offers = settings.show_quantity_offers
  assign show_product_info = settings.show_product_info
  assign product_id = product.id
  assign product_handle = product.handle
  assign product_title = product.title | escape
  assign product_featured_image = product | image_url: width: 200
  assign product_price = product.price | money_without_currency
  assign product_compare_at_price = product.compare_at_price | money_without_currency
-%}

<style>
  #codform-container-{{ block_id }} {
    margin-bottom: 20px;
    border: 1px solid #ddd;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
    direction: rtl;
    font-family: 'Cairo', sans-serif;
  }

  #codform-container-{{ block_id }} h2 {
    text-align: center;
    color: #333;
    margin-bottom: 20px;
  }

  #codform-container-{{ block_id }} label {
    display: block;
    margin-top: 10px;
    color: #555;
  }

  #codform-container-{{ block_id }} input[type="text"],
  #codform-container-{{ block_id }} input[type="email"],
  #codform-container-{{ block_id }} input[type="tel"],
  #codform-container-{{ block_id }} textarea {
    width: 100%;
    padding: 8px;
    margin-top: 5px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 4px;
    box-sizing: border-box;
    font-family: inherit;
  }

  #codform-container-{{ block_id }} textarea {
    height: 100px;
  }

  #codform-container-{{ block_id }} button[type="submit"] {
    background-color: #4CAF50;
    color: white;
    padding: 10px 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
  }

  #codform-container-{{ block_id }} button[type="submit"]:hover {
    background-color: #3e8e41;
  }

  /* Quantity Offers Styling */
  #quantity-offers-before-{{ block_id }} {
    margin-bottom: 20px;
    display: none; /* Hidden by default, shown by JS */
  }

  /* Product Info Styling */
  #product-info-{{ block_id }} {
    text-align: center;
    margin-bottom: 20px;
  }

  #product-info-{{ block_id }} img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 10px;
  }
</style>

{% if show_quantity_offers %}
  <div id="quantity-offers-before-{{ block_id }}">
    <!-- Quantity offers will be dynamically inserted here -->
  </div>
{% endif %}

<div id="codform-container-{{ block_id }}">
  <h2>نموذج الدفع عند الاستلام</h2>
  <div id="codform-{{ block_id }}">
    <!-- Form will be dynamically inserted here -->
  </div>
</div>

{% if show_product_info %}
  <div id="product-info-{{ block_id }}">
    {% if product_featured_image %}
      <img src="{{ product_featured_image }}" alt="{{ product_title }}">
    {% endif %}
    <h3>{{ product_title }}</h3>
    <p>السعر: {{ product_price }}</p>
    {% if product_compare_at_price %}
      <p>السعر الأصلي: {{ product_compare_at_price }}</p>
    {% endif %}
  </div>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const productId = "{{ product.id }}";
  const blockId = "{{ block.id }}";
  const shop = "{{ shop.domain }}";
  
  console.log(`🎯 CLEAN SOLUTION - Loading offers for ${productId} on ${shop}`);
  
  if (!productId || !shop) {
    console.log("❌ Missing required data");
    return;
  }
  
  // انتظار تحميل JavaScript ثم تحميل العروض
  function loadOffers() {
    if (window.CodformQuantityOffers && window.CodformQuantityOffers.load) {
      console.log(`🚀 Loading offers for block ${blockId}`);
      window.CodformQuantityOffers.load(blockId, productId, shop)
        .then(result => {
          if (result.success) {
            console.log(`✅ Offers loaded successfully`);
          } else {
            console.log(`ℹ️ No offers found: ${result.message || 'Unknown'}`);
          }
        })
        .catch(error => {
          console.error(`❌ Error loading offers: ${error.message}`);
        });
    } else {
      // المحاولة مرة أخرى بعد ثانية واحدة
      setTimeout(loadOffers, 1000);
    }
  }
  
  // تحميل فوري
  loadOffers();
});
</script>

{% schema %}
{
  "name": "Codform Form",
  "target": "section",
  "available_if": "{{ product != blank }}",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "default": ""
    },
    {
      "type": "text",
      "id": "submit_button_text",
      "label": "Submit Button Text",
      "default": "أرسل الطلب"
    },
    {
      "type": "select",
      "id": "form_style",
      "label": "Form Style",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "modern",
          "label": "Modern"
        }
      ],
      "default": "default"
    },
    {
      "type": "checkbox",
      "id": "show_quantity_offers",
      "label": "Show Quantity Offers",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_info",
      "label": "Show Product Info",
      "default": false
    }
  ]
}
{% endschema %}
