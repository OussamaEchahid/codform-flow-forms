  function loadCompleteForm() {
    const productId = getProductId();
    const shopDomain = getShopDomain(); // استخدام دالة لجلب المتجر الصحيح
    
    if (!productId) {
      console.log('❌ CODFORM: No product ID found');
      return;
    }

    console.log('🔄 CODFORM: Loading complete form for product:', productId, 'shop:', shopDomain);
    
    // First check if this product has an associated form
    // محاولة البحث عن النموذج المحدد للمنتج أولاً، ثم البحث عن النموذج العام
    fetch(`https://trlklwixfeaexhydzaue.supabase.co/rest/v1/shopify_product_settings?shop_id=eq.${shopDomain}&enabled=eq.true&select=*,forms(*)&or=(product_id.eq.${productId},product_id.eq.auto-detect)`, {
      headers: {
        'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRybGtsd2l4ZmVhZXhoeWR6YXVlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTI3MTE0MTgsImV4cCI6MjA2ODI4NzQxOH0.6p52MXnM2UE0UfiD5ZDDkHWWuR0xcSmqJ85P4xuBd4M',
        'Content-Type': 'application/json'
      }
    })
    .then(response => response.json())
    .then(productSettings => {
      console.log('🔍 CODFORM: Product settings check:', productSettings);
      
      if (!productSettings || productSettings.length === 0) {
        console.log('⚠️ CODFORM: No form associated with this product, hiding form');
        const container = document.querySelector('[data-form-preview-id="form-preview-stable"]');
        if (container) {
          container.style.display = 'none';
        }
        return;
      }
      
      // Product has associated form, continue loading
      const formId = productSettings[0].form_id;
      console.log('✅ CODFORM: Product has associated form:', formId);
      
      loadFormWithValidation(productId, shopDomain, formId);
    })
    .catch(error => {
      console.error('❌ CODFORM: Error checking product settings:', error);
      // Hide form on error
      const container = document.querySelector('[data-form-preview-id="form-preview-stable"]');
      if (container) {
        container.style.display = 'none';
      }
    });
  }
  
  function loadFormWithValidation(productId, shopDomain, formId) {
    console.log('🔄 CODFORM: Loading validated form for product:', productId, 'shop:', shopDomain, 'form:', formId);
    
    // Get current product data from Shopify liquid templates
    const currentProduct = {
      id: productId,
