
{%- comment -%}
CODFORM - نموذج الدفع عند الاستلام
Enhanced version with comprehensive diagnostics
{%- endcomment -%}

<!-- Enhanced CODFORM Loading -->
<script>
  console.log('🎯 CODFORM Block: Starting to load...');
  
  // Load the main CODFORM script
  (function() {
    var script = document.createElement('script');
    script.src = '{{ "codform.js" | asset_url }}';
    script.async = false;
    script.onload = function() {
      console.log('✅ CODFORM: Script loaded successfully');
    };
    script.onerror = function() {
      console.error('❌ CODFORM: Failed to load script');
    };
    document.head.appendChild(script);
  })();
</script>

<!-- Fallback initialization -->
<script>
  // Fallback in case the main script doesn't load
  setTimeout(function() {
    if (typeof window.CODFORM === 'undefined') {
      console.log('⚠️ CODFORM: Main script not detected, trying fallback...');
      
      // Simple fallback handler
      document.addEventListener('click', function(event) {
        var target = event.target;
        if (target && (target.tagName === 'BUTTON' || target.tagName === 'INPUT')) {
          var text = (target.textContent || target.value || '').toLowerCase();
          if (text.includes('add') || text.includes('cart') || text.includes('buy') || 
              text.includes('order') || text.includes('submit') || text.includes('طلب') || 
              text.includes('إضافة') || text.includes('شراء')) {
            
            console.log('🎯 CODFORM Fallback: Button clicked', target);
            
            // Show visual feedback
            var originalText = target.textContent || target.value;
            if (target.textContent !== undefined) {
              target.textContent = 'جاري التحميل...';
            } else {
              target.value = 'جاري التحميل...';
            }
            
            // Restore after delay
            setTimeout(function() {
              if (target.textContent !== undefined) {
                target.textContent = originalText;
              } else {
                target.value = originalText;
              }
            }, 3000);
            
            // Try to trigger the main handler if available
            if (window.CODFORM && window.CODFORM.handleSubmit) {
              window.CODFORM.handleSubmit(event);
            }
          }
        }
      }, true);
    }
  }, 2000);
</script>

<!-- Debug information -->
<div id="codform-debug" style="position: fixed; bottom: 10px; left: 10px; background: rgba(0,0,0,0.8); color: white; padding: 5px; font-size: 10px; z-index: 9999; display: none;">
  CODFORM: Loaded and ready
</div>

<script>
  // Show debug info briefly
  setTimeout(function() {
    var debug = document.getElementById('codform-debug');
    if (debug) {
      debug.style.display = 'block';
      setTimeout(function() {
        debug.style.display = 'none';
      }, 3000);
    }
  }, 1000);
</script>

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "معرف النموذج",
      "info": "معرف النموذج الخاص بك من لوحة التحكم"
    },
    {
      "type": "checkbox",
      "id": "auto_detect",
      "label": "الكشف التلقائي عن الأزرار",
      "default": true,
      "info": "يقوم بالبحث تلقائياً عن أزرار الإرسال في الصفحة"
    },
    {
      "type": "checkbox",
      "id": "debug_mode",
      "label": "وضع التشخيص",
      "default": false,
      "info": "إظهار رسائل تشخيصية مفصلة"
    }
  ]
}
{% endschema %}
