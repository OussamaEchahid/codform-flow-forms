
{% schema %}
{
  "name": "Codform Form",
  "target": "section",
  "settings": [
    {
      "id": "product_id",
      "type": "text",
      "label": "Product ID",
      "info": "Enter the product ID to load the form."
    }
  ]
}
{% endschema %}

<link rel="stylesheet" href="{{ 'codform-styles.css' | asset_url }}">

<script src="{{ 'codform-quantity-offers.js' | asset_url }}"></script>
<script src="{{ 'codform-icons.js' | asset_url }}"></script>
<script src="{{ 'codform-utilities.js' | asset_url }}"></script>
<script src="{{ 'codform-image-field.js' | asset_url }}"></script>
<script src="{{ 'codform-whatsapp-field.js' | asset_url }}"></script>

<div id="codform-popup-button-container" style="display: none;">
  
</div>

<div data-form-preview-id="form-preview-stable">
  
</div>

<script>
(function() {
  'use strict';
  
  console.log('🚀 CODFORM: Form initialization started');
  
  const API_BASE_URL = 'https://lovable-forms-api.netlify.app/.netlify/functions/api-forms';
  const DEFAULT_PRODUCT_ID = 'default';

  {%- comment -%}
  ===============================================================================
  4. UTILITY FUNCTIONS
  ===============================================================================
  {%- endcomment -%}
  function getProductId() {
    try {
      const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || '{{ block.settings.product_id }}' || 'auto-detect';
      console.log('🔍 معرف المنتج المكتشف:', productId);
      return productId.trim();
    } catch (error) {
      console.error('❌ CODFORM: Error getting product ID:', error);
      return 'auto-detect';
    }
  }

  window.getShopDomain = function() {
    try {
      const shopDomain = '{{ shop.domain }}' || '{{ shop.permanent_domain }}' || 'auto-detect';
      console.log('🏪 CODFORM: Using shop domain:', shopDomain);
      return shopDomain;
    } catch (error) {
      console.error('❌ CODFORM: Error getting shop domain:', error);
      return 'auto-detect';
    }
  }

  function getStyleValue(style, property, fallback) {
    if (!style || typeof style !== 'object') return fallback;
    return style[property] || fallback;
  }

  {%- comment -%}
  ===============================================================================
  5. FIELD RENDERING FUNCTIONS
  ===============================================================================
  {%- endcomment -%}
  function renderField(field, formStyle, formLanguage) {
    if (!field || !field.type) return '';
    
    console.log('🎨 Rendering field:', field.type, field.id);
    
    // Check if we're currently rendering inside a popup
    const isInPopup = window.codformCurrentlyInPopup === true;
    
    // Determine form direction - better detection
    let formDirection = 'ltr';
    if (formStyle && formStyle.formDirection) {
      formDirection = formStyle.formDirection;
    } else if (formLanguage === 'ar' || (formLanguage && formLanguage.includes('ar'))) {
      formDirection = 'rtl';
    } else if (field.label && /[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]/.test(field.label)) {
      formDirection = 'rtl';
    }
    
    console.log('🔄 CODFORM: Detected form direction:', formDirection, 'for language:', formLanguage);
    
    // Base styling configuration - Arabic forms use smaller font
    const baseFontSize = formDirection === 'rtl' ? '13px' : getStyleValue(formStyle, 'baseFontSize', '16px');
    const labelStyle = field.style || {};
    const showLabel = getStyleValue(labelStyle, 'showLabel', true);
    const isFloatingLabels = getStyleValue(formStyle, 'floatingLabels', false);
    
    // Label styling
    const labelColor = getStyleValue(labelStyle, 'labelColor', '#333333');
    const labelFontSize = getStyleValue(labelStyle, 'labelFontSize', baseFontSize);
    const labelFontWeight = getStyleValue(labelStyle, 'labelFontWeight', '500');
    
    // Field styling
    const fieldBackgroundColor = '#FFFFFF';
    const fieldBorderColor = getStyleValue(labelStyle, 'borderColor', '#D1D5DB');
    const fieldBorderRadius = '8px';
    const fieldFontSize = baseFontSize;
    const fieldTextColor = '#1F2937';
    const fieldPadding = '12px 16px';
    
    let html = '';
    
    {%- comment -%} Form Title Field {%- endcomment -%}
    if (field.type === 'form-title') {
      const title = field.label || 'Form Title';
      
      const titleColor = getStyleValue(field.style, 'color', '#000000');
      const titleFontSize = getStyleValue(field.style, 'fontSize', '24px');
      const titleFontWeight = getStyleValue(field.style, 'fontWeight', 'bold');
      const titleTextAlign = getStyleValue(field.style, 'textAlign', 'center');
      const paddingTop = getStyleValue(field.style, 'paddingTop', '0px');
      const paddingBottom = getStyleValue(field.style, 'paddingBottom', '0px');
      const paddingLeft = getStyleValue(field.style, 'paddingLeft', '0px');
      const paddingRight = getStyleValue(field.style, 'paddingRight', '0px');
      
      html = `
        <div class="form-title-field w-full" style="
          color: ${titleColor};
          font-size: ${titleFontSize};
          font-weight: ${titleFontWeight};
          font-family: Cairo, Tajawal, Arial, sans-serif;
          text-align: center;
          margin: 0px;
          line-height: 1.4;
          direction: ${formStyle.formDirection || 'ltr'};
          padding: ${paddingTop} ${paddingRight} ${paddingBottom} ${paddingLeft};
          width: 100%;
          display: block;
          background: none;
          border: none;
        ">
          ${title}
        </div>
      `;
    }
    {%- comment -%} Text Input Fields (text, email, phone) {%- endcomment -%}
    else if (['text', 'email', 'phone'].includes(field.type)) {
      const label = field.label || 'Text Field';
      const placeholder = field.placeholder || '';
      const required = field.required || false;
      const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
      
      // Determine input type
      let inputType = 'text';
      if (field.type === 'email') inputType = 'email';
      if (field.type === 'phone') inputType = 'tel';
      
      // Field style configuration
      const fieldStyle = field.style || {};
      const baseFontSize = formDirection === 'rtl' ? '13px' : getStyleValue(formStyle, 'baseFontSize', '16px');
      const defaultLabelSize = formDirection === 'rtl' ? '15px' : '16px';
      const actualLabelColor = getStyleValue(fieldStyle, 'labelColor', '#333333');
      const actualLabelFontSize = getStyleValue(fieldStyle, 'labelFontSize', defaultLabelSize);  
      const actualLabelWeight = getStyleValue(fieldStyle, 'labelFontWeight', '500');
      const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
      
      // Field visual styling
      const actualTextColor = getStyleValue(fieldStyle, 'color', 'rgb(31, 41, 55)');
      const actualBorderColor = getStyleValue(fieldStyle, 'borderColor', getStyleValue(formStyle, 'fieldBorderColor', 'rgb(209, 213, 219)'));
      const actualBorderWidth = getStyleValue(fieldStyle, 'borderWidth', getStyleValue(formStyle, 'fieldBorderWidth', '1px'));
      const actualFontSize = getStyleValue(fieldStyle, 'fontSize', baseFontSize);
      const actualFontFamily = getStyleValue(fieldStyle, 'fontFamily', 'inherit');
      const actualPaddingY = getStyleValue(fieldStyle, 'paddingY', '12px');
      const actualBorderRadius = getStyleValue(fieldStyle, 'borderRadius', getStyleValue(formStyle, 'fieldBorderRadius', '8px'));
      const actualPlaceholder = getStyleValue(fieldStyle, 'placeholder', placeholder);
      const focusBorderColor = getStyleValue(formStyle, 'focusBorderColor', '#3b82f6');
      
      // Icon handling
      const hasIcon = field.icon && field.icon !== 'none' && field.icon !== '';
      const showIconInPreview = getStyleValue(fieldStyle, 'showIconInPreview', hasIcon);
      const showIcon = getStyleValue(fieldStyle, 'showIcon', hasIcon) && showIconInPreview;
      
      let iconHtml = '';
      if (showIcon && hasIcon) {
        const iconPosition = formDirection === 'rtl' ? 'right' : 'left';
        const iconColor = getStyleValue(fieldStyle, 'iconColor', '#6b7280');
        const iconSvg = getIconSvg(field.icon, iconColor);
        iconHtml = `
          <div style="
            position: absolute;
            ${iconPosition}: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: ${iconColor};
            pointer-events: none;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
          ">
            ${iconSvg}
          </div>
        `;
      }
      
      // Padding based on direction and icons
      const paddingLeft = formDirection === 'rtl' ? '12px' : (showIcon && hasIcon ? '40px' : '12px');
      const paddingRight = formDirection === 'rtl' ? (showIcon && hasIcon ? '40px' : '12px') : '12px';
      const paddingTopBottom = '10px';
      
      html = `
        <div class="codform-field-wrapper" style="
          margin-bottom: 4px;
          direction: ${formDirection};
        ">
              ${actualShowLabel && !isFloatingLabels ? `
                <label for="${fieldId}" style="
                  display: block;
                  color: ${actualLabelColor};
                  font-size: ${actualLabelFontSize};
                  font-weight: 500;
                  margin-bottom: 4px;
                  font-family: 'Cairo', sans-serif;
                ">
              ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
            </label>
          ` : ''}
          
          <div style="position: relative;">
            ${iconHtml}
            ${isFloatingLabels && actualShowLabel ? `
              <label for="${fieldId}" style="
                position: absolute;
                left: ${formDirection === 'rtl' ? 'auto' : (showIcon && hasIcon ? '40px' : '12px')};
                right: ${formDirection === 'rtl' ? (showIcon && hasIcon ? '40px' : '12px') : 'auto'};
                top: 50%;
                transform: translateY(-50%);
                color: #9CA3AF;
                font-size: ${actualLabelFontSize};
                font-family: 'Cairo', sans-serif;
                pointer-events: none;
                transition: all 0.2s ease;
                background: white;
                padding: 0 4px;
                z-index: 10;
              " class="floating-label">
                ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
              </label>
            ` : ''}
            <input
              type="${inputType}"
              id="${fieldId}"
              name="${fieldId}"
              placeholder="${isFloatingLabels ? '' : actualPlaceholder}"
              ${required ? 'required' : ''}
              style="
                width: 100%;
                background-color: #FFFFFF;
                border: ${actualBorderWidth} solid ${actualBorderColor};
                border-radius: ${actualBorderRadius};
                padding: ${paddingTopBottom} ${paddingRight} ${paddingTopBottom} ${paddingLeft};
                font-size: ${actualFontSize};
                color: ${actualTextColor};
                font-family: ${actualFontFamily};
                outline: none;
                transition: all 0.2s ease;
                box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
                min-height: 44px;
                box-sizing: border-box;
                direction: ${formDirection};
                text-align: ${formDirection === 'rtl' ? 'right' : 'left'};
              "
              onfocus="this.style.borderColor='${focusBorderColor}'; this.style.boxShadow='0 0 0 3px ${focusBorderColor}20'"
              onblur="this.style.borderColor='${actualBorderColor}'; this.style.boxShadow='rgba(0, 0, 0, 0.05) 0px 1px 2px'"
            />
          </div>
          
          <style>
            .codform-field-wrapper input::placeholder,
            .codform-field-wrapper textarea::placeholder,
            input[type="text"]::placeholder,
            input[type="email"]::placeholder,
            input[type="tel"]::placeholder,
            input[type="number"]::placeholder,
            input[placeholder]::placeholder,
            textarea[placeholder]::placeholder {
              font-family: ${formDirection === 'rtl' ? "'Cairo', 'Noto Sans Arabic', sans-serif" : "'Inter', 'system-ui', '-apple-system', 'BlinkMacSystemFont', sans-serif"} !important;
              font-size: 15px !important;
              opacity: 0.7 !important;
              font-weight: 400 !important;
            }
            
            .codform-field-wrapper input,
            .codform-field-wrapper textarea,
            input[type="text"],
            input[type="email"],
            input[type="tel"],
            input[type="number"] {
              font-family: ${formDirection === 'rtl' ? "'Cairo', 'Noto Sans Arabic', sans-serif" : "'Inter', 'system-ui', '-apple-system', 'BlinkMacSystemFont', sans-serif"} !important;
            }
          </style>
          
          ${field.helpText ? `
            <p style="
              margin-top: 6px;
              font-size: 14px;
              color: #6B7280;
              font-family: 'Cairo', inherit;
            ">${field.helpText}</p>
          ` : ''}
        </div>
      `;
    }
    {%- comment -%} Textarea Field {%- endcomment -%}
    else if (field.type === 'textarea') {
      const label = field.label || 'Text Area';
      const placeholder = field.placeholder || '';
      const required = field.required || false;
      const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
      
      // Field style configuration
      const fieldStyle = field.style || {};
      const baseFontSize = formDirection === 'rtl' ? '13px' : getStyleValue(formStyle, 'baseFontSize', '16px');
      const defaultLabelSize = formDirection === 'rtl' ? '15px' : '16px';
      const actualLabelColor = getStyleValue(fieldStyle, 'labelColor', 'rgb(51, 65, 85)');
      const actualLabelFontSize = getStyleValue(fieldStyle, 'labelFontSize', defaultLabelSize);  
      const actualLabelWeight = getStyleValue(fieldStyle, 'labelFontWeight', '500');
      const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
      
      // Visual styling
      const actualTextColor = getStyleValue(fieldStyle, 'color', 'rgb(31, 41, 55)');
      const actualBorderColor = getStyleValue(fieldStyle, 'borderColor', getStyleValue(formStyle, 'fieldBorderColor', 'rgb(209, 213, 219)'));
      const actualBorderWidth = getStyleValue(fieldStyle, 'borderWidth', getStyleValue(formStyle, 'fieldBorderWidth', '1px'));
      const actualFontSize = getStyleValue(fieldStyle, 'fontSize', baseFontSize);
      const actualFontFamily = getStyleValue(fieldStyle, 'fontFamily', 'inherit');
      const actualPaddingY = getStyleValue(fieldStyle, 'paddingY', '12px');
      const actualBorderRadius = getStyleValue(fieldStyle, 'borderRadius', getStyleValue(formStyle, 'fieldBorderRadius', '8px'));
      const actualPlaceholder = getStyleValue(fieldStyle, 'placeholder', placeholder);
      const focusBorderColor = getStyleValue(formStyle, 'focusBorderColor', '#3b82f6');
      
      html = `
        <div class="codform-field-wrapper" style="
          margin-bottom: 10px;
          direction: ${formDirection};
        ">
          ${actualShowLabel && !isFloatingLabels ? `
            <label for="${fieldId}" style="
              display: block;
              color: ${actualLabelColor};
              font-size: ${actualLabelFontSize};
              font-weight: ${actualLabelWeight};
                  margin-bottom: 4px;
              font-family: 'Cairo', sans-serif;
            ">
              ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
            </label>
          ` : ''}
          
          <div style="position: relative;">
            ${isFloatingLabels && actualShowLabel ? `
              <label for="${fieldId}" style="
                position: absolute;
                left: ${formDirection === 'rtl' ? 'auto' : '12px'};
                right: ${formDirection === 'rtl' ? '12px' : 'auto'};
                top: 20px;
                color: #9CA3AF;
                font-size: ${actualLabelFontSize};
                font-family: 'Cairo', sans-serif;
                pointer-events: none;
                transition: all 0.2s ease;
                background: white;
                padding: 0 4px;
                z-index: 10;
              " class="floating-label">
                ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
              </label>
            ` : ''}
          <textarea
            id="${fieldId}"
            name="${fieldId}"
            placeholder="${isFloatingLabels ? '' : actualPlaceholder}"
            ${required ? 'required' : ''}
            rows="4"
            style="
              width: 100%;
              background-color: #FFFFFF;
              border: ${actualBorderWidth} solid ${actualBorderColor};
              border-radius: ${actualBorderRadius};
              padding: 10px 12px;
              font-size: ${actualFontSize};
              color: ${actualTextColor};
              font-family: ${actualFontFamily};
              outline: none;
              transition: all 0.2s ease;
              box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
              resize: none;
              min-height: 80px;
              height: 80px;
              box-sizing: border-box;
              direction: ${formDirection};
              text-align: ${formDirection === 'rtl' ? 'right' : 'left'};
            "
            onfocus="this.style.borderColor='${focusBorderColor}'; this.style.boxShadow='0 0 0 3px ${focusBorderColor}20'"
            onblur="this.style.borderColor='${actualBorderColor}'; this.style.boxShadow='rgba(0, 0, 0, 0.05) 0px 1px 2px'"
          ></textarea>
          </div>
          
          ${field.helpText ? `
            <p style="
              margin-top: 6px;
              font-size: 14px;
              color: #6B7280;
              font-family: 'Cairo', inherit;
            ">${field.helpText}</p>
          ` : ''}
        </div>
      `;
    }
    {%- comment -%} Submit Button Field {%- endcomment -%}
    else if (field.type === 'submit') {
      const buttonText = field.label || 'Submit';
      const buttonStyle = field.style || {};
      
      // Check if popup is enabled from form settings
      const isPopupMode = formStyle?.popupButton?.enabled || false;
      
      // Animation configuration
      const showAnimation = getStyleValue(buttonStyle, 'animation', false);
      const animationType = getStyleValue(buttonStyle, 'animationType', 'pulse');
      
      let animationClass = '';
      if (showAnimation) {
        switch (animationType) {
          case 'pulse': animationClass = 'pulse-animation'; break;
          case 'bounce': animationClass = 'bounce-animation'; break;
          case 'shake': animationClass = 'shake-animation'; break;
          case 'wiggle': animationClass = 'wiggle-animation'; break;
          case 'flash': animationClass = 'flash-animation'; break;
          default: animationClass = '';
        }
      }
      
      // Determine what settings to use based on context
      let finalButtonText, finalBgColor, finalTextColor, finalFontSize, finalBorderRadius;
      let finalAnimation = '';
      
      // If popup mode is enabled AND we're NOT in the popup (main page button), use popup button settings
      // If we're IN the popup, use normal submit button settings
      // Apply styles for submit button
      if (isPopupMode && !isInPopup && formStyle.popupButton) {
        // Main page popup trigger button - use popup button settings
        finalButtonText = formStyle.popupButton.text || buttonText;
        finalBgColor = formStyle.popupButton.backgroundColor || formStyle?.primaryColor || 'rgb(155, 135, 245)';
        finalTextColor = formStyle.popupButton.textColor || 'rgb(255, 255, 255)';
        finalFontSize = formStyle.popupButton.fontSize || '16px';
        finalBorderRadius = formStyle.popupButton.borderRadius || '8px';
        
        // Apply popup animation if set
        if (formStyle.popupButton.animation && formStyle.popupButton.animation !== 'none') {
          switch (formStyle.popupButton.animation) {
            case 'pulse': finalAnimation = 'pulse-animation'; break;
            case 'bounce': finalAnimation = 'bounce-animation'; break;
            case 'shake': finalAnimation = 'shake-animation'; break;
            case 'wiggle': finalAnimation = 'wiggle-animation'; break;
            case 'flash': finalAnimation = 'flash-animation'; break;
            default: finalAnimation = '';
          }
        }
      } else {
        // Normal submit button OR popup form submit button - use submit button settings
        const baseFontSize = formDirection === 'rtl' ? '13px' : getStyleValue(formStyle, 'baseFontSize', '16px');
        finalButtonText = buttonText;
        finalBgColor = getStyleValue(buttonStyle, 'backgroundColor', formStyle?.primaryColor || 'rgb(155, 135, 245)');
        finalTextColor = getStyleValue(buttonStyle, 'color', 'rgb(255, 255, 255)');
        finalFontSize = getStyleValue(buttonStyle, 'fontSize', baseFontSize);
        finalBorderRadius = getStyleValue(buttonStyle, 'borderRadius', formStyle?.borderRadius || '8px');
        finalAnimation = animationClass;
      }
      
      // Other styling
      const buttonWidth = getStyleValue(buttonStyle, 'width', '100%');
      const buttonMinHeight = getStyleValue(buttonStyle, 'minHeight', '56px');
      const buttonBoxShadow = getStyleValue(buttonStyle, 'boxShadow', 'none');
      const buttonBorderWidth = getStyleValue(buttonStyle, 'borderWidth', '0px');
      const buttonBorderColor = getStyleValue(buttonStyle, 'borderColor', 'transparent');
      // Get padding values directly from field style - respect form builder settings
      // Helper function to ensure proper px format
      const ensurePxFormat = (value, defaultValue) => {
        if (value === undefined || value === null) return defaultValue;
        const strValue = String(value);
        if (strValue.endsWith('px')) return strValue;
        return strValue + 'px';
      };
      
      const buttonPaddingY = ensurePxFormat(field.style?.paddingY, '10px');
      const buttonPaddingX = ensurePxFormat(field.style?.paddingX, '24px');
      
      const buttonBorder = buttonBorderWidth !== '0px' && buttonBorderColor !== 'transparent' 
        ? `${buttonBorderWidth} solid ${buttonBorderColor}` 
        : 'none';
      const buttonPadding = `${buttonPaddingY} ${buttonPaddingX}`;
      
      // Font weight handling
      const labelWeight = getStyleValue(buttonStyle, 'labelWeight', null);
      const fontWeight = getStyleValue(buttonStyle, 'fontWeight', null);
      const actualButtonFontWeight = labelWeight || fontWeight || '700';
      
      // Icon handling
      const hasIcon = field.icon && field.icon !== 'none' && field.icon !== '';
      const showIcon = (isPopupMode && !isInPopup) ? 
        (formStyle.popupButton?.showIcon !== false) : 
        getStyleValue(buttonStyle, 'showIcon', hasIcon);
      const iconColor = getStyleValue(buttonStyle, 'iconColor', '#6b7280');
      
      let iconHtml = '';
      if (showIcon && hasIcon) {
        const iconSvg = getIconSvg(field.icon, iconColor);
        const iconMargin = 'margin-right: 8px;';
        iconHtml = `<span style="${iconMargin} display: inline-flex; align-items: center;">${iconSvg}</span>`;
      }
      
      const buttonContent = `${iconHtml}${finalButtonText}`;
      
      // Button click handler - different for popup vs normal
      // If popup mode is enabled AND we're NOT in popup, this should open popup
      // If we're in popup or no popup mode, this should submit the form
      const clickHandler = (isPopupMode && !isInPopup) ? 
        'onclick="openFormPopup(event)"' : 
        'type="submit"';
      
      html = `
        <div class="codform-submit-wrapper" style="
          margin-top: 20px;
          text-align: center;
        ">
          <button
            ${clickHandler}
            class="codform-submit-btn ${finalAnimation}"
            style="
              background-color: ${finalBgColor} !important;
              color: ${finalTextColor} !important;
              font-size: ${finalFontSize} !important;
              font-weight: ${actualButtonFontWeight} !important;
              padding: ${buttonPadding} !important;
              border: ${buttonBorder};
              border-radius: ${finalBorderRadius};
              cursor: pointer;
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              width: ${buttonWidth};
              min-height: ${buttonMinHeight};
              font-family: ${formDirection === 'rtl' ? "'Cairo', 'Noto Sans Arabic', 'Amiri', sans-serif" : "'Inter', 'system-ui', sans-serif"};
              display: inline-flex;
              align-items: center;
              justify-content: center;
              gap: 8px;
              box-shadow: ${buttonBoxShadow};
              transform: translateY(0);
              position: relative;
              overflow: hidden;
              text-align: center;
            "
            onmouseover="this.style.opacity='0.9';"
            onmouseout="this.style.opacity='1';"
          >
            ${buttonContent}
          </button>
        </div>
      `;
    }
    {%- comment -%} Cart Items Field {%- endcomment -%}
    else if (field.type === 'cart-items') {
      const fieldStyle = field.style || {};
      const borderRadius = formStyle.borderRadius || '0.5rem';
      
      // Get current product from Shopify Liquid
      const productPrice = parseFloat('{{ product.price | divided_by: 100.0 }}') || 29.99;
      const productCurrency = '{{ shop.currency }}' || 'USD';
      const productImage = '{{ product.featured_image | img_url: "300x300" }}' || '';
      const productTitle = '{{ product.title }}' || (formLanguage === 'ar' ? 'عنوان المنتج' : 'Product Title');
      const productVariant = '{{ product.variants.first.title }}' || '';
      const currencySymbol = productCurrency === 'USD' ? '$' : 
                            productCurrency === 'SAR' ? 'ر.س' : 
                            productCurrency === 'MAD' ? 'د.م' : 
                            productCurrency === 'AED' ? 'د.إ' : productCurrency;
      
      // Apply all cart items styling properties
      const hideImage = fieldStyle.hideImage === true;
      const hideTitle = fieldStyle.hideTitle === true;
      const hideQuantitySelector = fieldStyle.hideQuantitySelector === true;
      const hidePrice = fieldStyle.hidePrice === true;
      const showBorders = fieldStyle.showBorders !== false;
      const direction = fieldStyle.direction || formDirection;
      
      // Product styling
      const fontSize = fieldStyle.fontSize || '0.95rem';
      const color = fieldStyle.color || '#1f2937';
      const fontFamily = fieldStyle.fontFamily || 'Cairo, Inter, system-ui, sans-serif';
      const fontWeight = fieldStyle.fontWeight || '600';
      
      // Variant styling
      const descriptionFontSize = fieldStyle.descriptionFontSize || '0.875rem';
      const descriptionColor = fieldStyle.descriptionColor || '#6b7280';
      const descriptionFontFamily = fieldStyle.descriptionFontFamily || 'Cairo, Inter, system-ui, sans-serif';
      const descriptionFontWeight = fieldStyle.descriptionFontWeight || '400';
      
      // Quantity styling
      const quantityBgColor = fieldStyle.quantityBgColor || '#f9fafb';
      const quantityBorderColor = fieldStyle.quantityBorderColor || '#e5e7eb';
