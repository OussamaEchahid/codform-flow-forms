
{% comment %}
  CODFORM - نماذج الدفع عند الاستلام
  
  تضمين نموذج الدفع عند الاستلام في صفحة المنتج
{% endcomment %}

<div
  id="codform-container"
  class="codform-container"
  data-product-id="{{ product.id }}"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-block-id="{{ block.id }}"
  data-is-rtl="{{ block.settings.is_rtl }}"
  {% if block.settings.is_rtl %}dir="rtl"{% else %}dir="ltr"{% endif %}
>
  <div class="codform-loading" style="display: block; text-align: center; padding: 30px;">
    <div class="codform-spinner"></div>
    <p style="{% if block.settings.is_rtl %}text-align: right;{% else %}text-align: left;{% endif %}">
      {{ block.settings.loading_text | default: 'جاري تحميل النموذج...' }}
    </p>
  </div>
  <div id="codform-form" style="display: none;">
    <!-- سيتم تحميل النموذج هنا -->
  </div>
</div>

<style>
  /* أساسيات النموذج */
  .codform-container {
    margin: 20px 0;
    font-family: inherit;
  }
  
  /* مؤشر التحميل */
  .codform-spinner {
    display: inline-block;
    width: 40px;
    height: 40px;
    border: 4px solid rgba(0, 0, 0, 0.1);
    border-radius: 50%;
    border-top-color: #9b87f5;
    animation: codform-spin 1s ease-in-out infinite;
    margin-bottom: 10px;
  }
  
  @keyframes codform-spin {
    to { transform: rotate(360deg); }
  }
  
  /* إصلاح خلفية العنوان */
  .codform-title-container {
    background-color: #9b87f5 !important;
    width: 100% !important;
    box-sizing: border-box !important;
    padding: 16px !important;
    margin-bottom: 16px !important;
    overflow: hidden !important;
    border-radius: 8px !important;
  }
  
  /* تحسين نمط العنوان */
  .codform-form-title {
    color: white !important;
    font-size: 24px !important;
    text-align: center !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
    display: block !important;
  }
  
  .codform-title-description {
    color: rgba(255, 255, 255, 0.9) !important;
    font-size: 14px !important;
    text-align: center !important;
    margin: 6px 0 0 0 !important;
    padding: 0 !important;
    width: 100% !important;
  }
  
  /* دعم RTL */
  [dir="rtl"] .codform-form input,
  [dir="rtl"] .codform-form textarea {
    text-align: right !important;
  }
  
  [dir="rtl"] .codform-form label,
  [dir="rtl"] .codform-form .form-label,
  [dir="rtl"] .codform-form .form-help-text {
    text-align: right !important;
    display: block !important;
  }

  /* تأكد من أن العنوان يظهر بشكل صحيح */
  .codform-title-container h3,
  .codform-title-container p {
    width: 100% !important;
    display: block !important;
  }
</style>

{% schema %}
{
  "name": {
    "en": "COD Form",
    "ar": "نموذج الدفع عند الاستلام"
  },
  "target": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "is_rtl",
      "label": {
        "en": "Right-to-left (RTL) Direction",
        "ar": "اتجاه من اليمين إلى اليسار (RTL)"
      },
      "default": false
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": {
        "en": "Loading Text",
        "ar": "نص التحميل"
      },
      "default": {
        "en": "Loading form...",
        "ar": "جاري تحميل النموذج..."
      }
    }
  ]
}
{% endschema %}
