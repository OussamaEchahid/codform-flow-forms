
{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "stylesheet": "codform.css",
  "javascript": "codform.js",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "معرّف النموذج",
      "info": "أدخل معرف النموذج الذي تريد عرضه. سيظهر النموذج فقط إذا كان مرتبطًا بهذا المنتج."
    },
    {
      "type": "header",
      "content": "إعدادات الزر العائم"
    },
    {
      "type": "checkbox",
      "id": "enable_floating_button",
      "label": "تمكين الزر العائم",
      "default": true,
      "info": "يعرض زرًا في أسفل الشاشة للتنقل السريع إلى النموذج"
    },
    {
      "type": "text",
      "id": "floating_button_text",
      "label": "نص الزر العائم",
      "default": "اطلب الآن"
    },
    {
      "type": "color",
      "id": "floating_text_color",
      "label": "لون النص",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "floating_bg_color",
      "label": "لون الخلفية",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "floating_border_radius",
      "label": "نصف قطر الحواف",
      "default": "4px"
    },
    {
      "type": "checkbox",
      "id": "floating_show_icon",
      "label": "عرض أيقونة",
      "default": true
    },
    {
      "type": "select",
      "id": "floating_icon",
      "label": "نوع الأيقونة",
      "options": [
        {
          "value": "shopping-cart",
          "label": "عربة تسوق"
        },
        {
          "value": "package",
          "label": "طرد"
        },
        {
          "value": "truck",
          "label": "شاحنة"
        },
        {
          "value": "send",
          "label": "إرسال"
        }
      ],
      "default": "shopping-cart"
    },
    {
      "type": "select",
      "id": "floating_animation",
      "label": "تأثير حركي",
      "options": [
        {
          "value": "none",
          "label": "بدون"
        },
        {
          "value": "pulse",
          "label": "نبض"
        },
        {
          "value": "bounce",
          "label": "قفز"
        },
        {
          "value": "shake",
          "label": "اهتزاز"
        },
        {
          "value": "wiggle",
          "label": "تمايل"
        },
        {
          "value": "flash",
          "label": "وميض"
        }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "is_rtl",
      "label": "تخطيط من اليمين لليسار (RTL)",
      "default": true,
      "info": "تفعيل هذا الخيار إذا كان النص بالعربية أو اللغات التي تكتب من اليمين إلى اليسار"
    },
    {
      "type": "text",
      "id": "product_filter",
      "label": "تصفية المنتجات (اختياري)",
      "info": "إذا أردت إظهار النموذج على منتج محدد فقط، أدخل معرّف المنتج هنا"
    }
  ]
}
{% endschema %}

{% comment %}
  CODFORM - نماذج الدفع عند الاستلام

  هذا البلوك يضيف نموذج الدفع عند الاستلام إلى صفحة المنتج
  لاستخدام هذا النموذج، قم فقط بإضافة معرّف النموذج في إعدادات البلوك
{% endcomment %}

{% assign should_display_form = false %}

{% if product and block.settings.form_id != blank %}
  {% if block.settings.product_filter == blank %}
    {% assign should_display_form = true %}
  {% else %}
    {% if product.id == block.settings.product_filter or product.handle contains block.settings.product_filter %}
      {% assign should_display_form = true %}
    {% endif %}
  {% endif %}
{% endif %}

{% if should_display_form %}
<div id="codform-container-{{ block.id }}" class="codform-container" data-product-id="{{ product.id }}" data-form-id="{{ block.settings.form_id }}" data-hide-header="true">
  <div class="codform-form-container">
    <div id="codform-form-loader-{{ block.id }}" class="codform-loader">
      <div class="codform-spinner"></div>
      <p>جاري تحميل النموذج...</p>
    </div>

    <div id="codform-form-{{ block.id }}" class="codform-form" style="display: none;">
      <!-- النموذج سيتم تحميله ديناميكيًا هنا -->
    </div>

    <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none;">
      <div class="codform-success-icon">✓</div>
      <h4>تم إرسال الطلب بنجاح</h4>
      <p>شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام.</p>
    </div>

    <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none;">
      <div class="codform-error-icon">!</div>
      <h4>حدث خطأ</h4>
      <p id="codform-error-message-{{ block.id }}">حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى.</p>
      <button id="codform-retry-{{ block.id }}" class="codform-button">إعادة المحاولة</button>
    </div>

    <div id="codform-not-available-{{ block.id }}" class="codform-error" style="display: none;">
      <h4>هذا النموذج غير متاح لهذا المنتج</h4>
      <p>النموذج المحدد غير متوفر لهذا المنتج، يرجى التحقق من إعدادات النموذج.</p>
    </div>
  </div>
</div>

{% comment %}
  FLOATING BUTTON - يتم التحكم في ظهوره من خلال إعدادات البلوك
{% endcomment %}
<div id="codform-floating-button-{{ block.id }}" class="codform-floating-button-container" style="{% unless block.settings.enable_floating_button %}display: none;{% endunless %}">
  <button
    class="codform-floating-button {% if block.settings.floating_animation != blank and block.settings.floating_animation != 'none' %}{{ block.settings.floating_animation }}-animation{% endif %}"
    style="
      background-color: {{ block.settings.floating_bg_color }};
      color: {{ block.settings.floating_text_color }};
      border-radius: {{ block.settings.floating_border_radius }};
      padding: 12px 24px;
      font-size: 16px;
      font-weight: 500;
      margin-bottom: 20px;
      direction: {% if block.settings.is_rtl %}rtl{% else %}ltr{% endif %};
      border: none;
      min-width: 250px;
    "
    onclick="document.querySelector('#codform-container-{{ block.id }}').scrollIntoView({behavior: 'smooth'});"
  >
    {% if block.settings.is_rtl or block.settings.floating_show_icon == false %}
      <span>{{ block.settings.floating_button_text }}</span>
    {% endif %}
    
    {% if block.settings.floating_show_icon %}
      <span class="codform-floating-button-icon">
        {% case block.settings.floating_icon %}
          {% when 'shopping-cart' %}
            <!-- Shopping cart icon SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
          {% when 'package' %}
            <!-- Package icon SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.89 1.45l8 4A2 2 0 0 1 22 7.24v9.53a2 2 0 0 1-1.11 1.79l-8 4a2 2 0 0 1-1.79 0l-8-4a2 2 0 0 1-1.1-1.8V7.24a2 2 0 0 1 1.11-1.79l8-4a2 2 0 0 1 1.78 0z"></path><polyline points="2.32 6.16 12 11 21.68 6.16"></polyline><line x1="12" y1="22.76" x2="12" y2="11"></line><line x1="7" y1="3.5" x2="17" y2="8.5"></line></svg>
          {% when 'truck' %}
            <!-- Truck icon SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          {% when 'send' %}
            <!-- Send icon SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
          {% else %}
            <!-- Default: Shopping cart icon SVG -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
        {% endcase %}
      </span>
    {% endif %}
    
    {% unless block.settings.is_rtl or block.settings.floating_show_icon == false %}
      <span>{{ block.settings.floating_button_text }}</span>
    {% endunless %}
  </button>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize the form for this specific product
    const container = document.getElementById('codform-container-{{ block.id }}');
    if (container) {
      const formId = container.getAttribute('data-form-id');
      const productId = container.getAttribute('data-product-id');
      
      console.log('COD Form initialized with:', {
        formId: formId,
        productId: productId,
        blockId: '{{ block.id }}'
      });
      
      // Check if form should be shown for this specific product
      fetch(`https://mtyfuwdsshlzqwjujavp.supabase.co/rest/v1/shopify_product_settings?shop_id=eq.{{ shop.permanent_domain }}&product_id=eq.${productId}&select=*`, {
        method: 'GET',
        headers: {
          'Content-Type': 'application/json',
          'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im10eWZ1d2Rzc2hsenF3anVqYXZwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDY0OTYyNTksImV4cCI6MjA2MjA3MjI1OX0.hjwGefZdZFIrYCdcBJ0XWJVt6YWdBR6d77Rsq8F9Szg'
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data && data.length > 0) {
          // Settings exist for this product, check if enabled
          if (data[0].enabled) {
            // Load the form
            loadForm(formId, '{{ block.id }}', productId);
          } else {
            document.getElementById('codform-not-available-{{ block.id }}').style.display = 'block';
            document.getElementById('codform-form-loader-{{ block.id }}').style.display = 'none';
          }
        } else {
          // No specific settings, load the form if there's a form ID
          if (formId) {
            loadForm(formId, '{{ block.id }}', productId);
          } else {
            document.getElementById('codform-not-available-{{ block.id }}').style.display = 'block';
            document.getElementById('codform-form-loader-{{ block.id }}').style.display = 'none';
          }
        }
      })
      .catch(error => {
        console.error('Error checking product settings:', error);
        // Still try to load the form as fallback
        if (formId) {
          loadForm(formId, '{{ block.id }}', productId);
        }
      });
    }
  });
  
  function loadForm(formId, blockId, productId) {
    const formContainer = document.getElementById('codform-form-' + blockId);
    const loaderContainer = document.getElementById('codform-form-loader-' + blockId);
    const errorContainer = document.getElementById('codform-error-' + blockId);
    
    if (!formContainer || !loaderContainer) return;
    
    // Show loader
    loaderContainer.style.display = 'flex';
    
    // Load form
    fetch(`https://mtyfuwdsshlzqwjujavp.supabase.co/rest/v1/forms?id=eq.${formId}&select=*`, {
      method: 'GET',
      headers: {
        'Content-Type': 'application/json',
        'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im10eWZ1d2Rzc2hsenF3anVqYXZwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDY0OTYyNTksImV4cCI6MjA2MjA3MjI1OX0.hjwGefZdZFIrYCdcBJ0XWJVt6YWdBR6d77Rsq8F9Szg'
      }
    })
    .then(response => response.json())
    .then(data => {
      if (data && data.length > 0 && data[0].data) {
        renderForm(data[0], formContainer, blockId, productId);
        loaderContainer.style.display = 'none';
        formContainer.style.display = 'block';
      } else {
        throw new Error('Form not found or invalid data');
      }
    })
    .catch(error => {
      console.error('Error loading form:', error);
      loaderContainer.style.display = 'none';
      errorContainer.style.display = 'block';
      document.getElementById('codform-error-message-' + blockId).textContent = 'تعذر تحميل النموذج: ' + error.message;
      
      // Add retry button functionality
      const retryButton = document.getElementById('codform-retry-' + blockId);
      if (retryButton) {
        retryButton.onclick = function() {
          errorContainer.style.display = 'none';
          loadForm(formId, blockId, productId);
        };
      }
    });
  }
  
  function renderForm(formData, container, blockId, productId) {
    try {
      console.log('Rendering form:', formData.id);
      
      // Create form elements based on formData
      const form = document.createElement('form');
      form.id = 'codform-' + blockId;
      form.className = 'codform';
      form.onsubmit = function(e) {
        e.preventDefault();
        submitForm(e.target, blockId, formData.id, productId);
        return false;
      };
      
      // Add form header if not hidden
      const hideHeader = container.parentElement.parentElement.dataset.hideHeader === 'true';
      if (!hideHeader && formData.title) {
        const header = document.createElement('div');
        header.className = 'codform-header';
        header.style.backgroundColor = formData.style?.primaryColor || '#9b87f5';
        
        const title = document.createElement('h3');
        title.textContent = formData.title;
        header.appendChild(title);
        
        if (formData.description) {
          const description = document.createElement('p');
          description.textContent = formData.description;
          header.appendChild(description);
        }
        
        form.appendChild(header);
      }
      
      // Add form fields based on data
      if (formData.data && Array.isArray(formData.data)) {
        formData.data.forEach(step => {
          if (step.fields && Array.isArray(step.fields)) {
            step.fields.forEach(field => {
              if (field.type !== 'form-title' && field.type !== 'submit') {
                const fieldContainer = document.createElement('div');
                fieldContainer.className = 'codform-field';
                
                // Create label
                const label = document.createElement('label');
                label.setAttribute('for', 'field-' + field.id);
                if (field.required) {
                  const requiredMark = document.createElement('span');
                  requiredMark.className = 'codform-required';
                  requiredMark.textContent = '*';
                  label.appendChild(requiredMark);
                  label.appendChild(document.createTextNode(' '));
                }
                label.appendChild(document.createTextNode(field.label));
                fieldContainer.appendChild(label);
                
                // Create input based on field type
                let input;
                switch (field.type) {
                  case 'textarea':
                    input = document.createElement('textarea');
                    input.rows = 4;
                    break;
                  case 'select':
                    input = document.createElement('select');
                    if (field.options) {
                      field.options.forEach(option => {
                        const optElement = document.createElement('option');
                        optElement.value = option.value;
                        optElement.textContent = option.label;
                        input.appendChild(optElement);
                      });
                    }
                    break;
                  default:
                    input = document.createElement('input');
                    input.type = field.type === 'phone' ? 'tel' : (field.type || 'text');
                }
                
                // Set common attributes
                input.id = 'field-' + field.id;
                input.name = field.id;
                input.className = 'codform-input';
                if (field.required) input.required = true;
                if (field.placeholder) input.placeholder = field.placeholder;
                
                fieldContainer.appendChild(input);
                
                // Add help text if available
                if (field.helpText) {
                  const helpText = document.createElement('div');
                  helpText.className = 'codform-help-text';
                  helpText.textContent = field.helpText;
                  fieldContainer.appendChild(helpText);
                }
                
                form.appendChild(fieldContainer);
              }
            });
          }
        });
      }
      
      // Add submit button
      const submitBtn = document.createElement('button');
      submitBtn.type = 'submit';
      submitBtn.className = 'codform-submit-button';
      submitBtn.textContent = formData.submitbuttontext || 'إرسال الطلب';
      
      // Apply button styles
      if (formData.style) {
        submitBtn.style.backgroundColor = formData.style.primaryColor || '#9b87f5';
        submitBtn.style.borderRadius = formData.style.borderRadius || '0.5rem';
        
        // Add animation if specified in any submit button
        let hasAnimation = false;
        let animationType = '';
        
        if (formData.data && Array.isArray(formData.data)) {
          formData.data.forEach(step => {
            if (step.fields && Array.isArray(step.fields)) {
              step.fields.forEach(field => {
                if (field.type === 'submit' && field.style && field.style.animation) {
                  hasAnimation = true;
                  animationType = field.style.animationType || 'pulse';
                }
              });
            }
          });
        }
        
        if (hasAnimation) {
          submitBtn.classList.add(animationType + '-animation');
        }
      }
      
      form.appendChild(submitBtn);
      
      // Clear and append to container
      container.innerHTML = '';
      container.appendChild(form);
      
    } catch (error) {
      console.error('Error rendering form:', error);
      container.innerHTML = '<div class="codform-error"><p>حدث خطأ أثناء عرض النموذج: ' + error.message + '</p></div>';
    }
  }
  
  function submitForm(form, blockId, formId, productId) {
    // Get all form data
    const formData = new FormData(form);
    const data = {};
    formData.forEach((value, key) => {
      data[key] = value;
    });
    
    // Add product information
    data.product_id = productId;
    data.product_title = document.querySelector('h1')?.innerText || '';
    data.product_url = window.location.href;
    
    // Disable form and show loading state
    form.classList.add('codform-loading');
    const submitButton = form.querySelector('button[type="submit"]');
    const originalButtonText = submitButton.textContent;
    submitButton.disabled = true;
    submitButton.textContent = 'جاري الإرسال...';
    
    // Submit form
    fetch('https://mtyfuwdsshlzqwjujavp.supabase.co/rest/v1/form_submissions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im10eWZ1d2Rzc2hsenF3anVqYXZwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDY0OTYyNTksImV4cCI6MjA2MjA3MjI1OX0.hjwGefZdZFIrYCdcBJ0XWJVt6YWdBR6d77Rsq8F9Szg',
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify({
        form_id: formId,
        data: data,
        shop_id: '{{ shop.permanent_domain }}',
        status: 'pending'
      })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error('Network response was not ok');
      }
      
      // Show success message
      const formContainer = document.getElementById('codform-form-' + blockId);
      const successContainer = document.getElementById('codform-success-' + blockId);
      
      formContainer.style.display = 'none';
      successContainer.style.display = 'block';
      
      // Scroll to success message
      successContainer.scrollIntoView({ behavior: 'smooth' });
    })
    .catch(error => {
      console.error('Error submitting form:', error);
      
      // Reset form state
      form.classList.remove('codform-loading');
      submitButton.disabled = false;
      submitButton.textContent = originalButtonText;
      
      // Show error message
      alert('حدث خطأ أثناء إرسال النموذج. يرجى المحاولة مرة أخرى.');
    });
  }
</script>

<style>
  /* Basic container configuration */
  .codform-container {
    font-family: 'Cairo', sans-serif;
    direction: rtl;
    margin: 20px 0;
    padding: 15px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background-color: #f9fafb;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
    width: 100%;
  }

  /* Form header */
  .codform-header {
    margin-bottom: 20px;
    text-align: right;
    padding: 15px;
    border-radius: 8px;
  }

  .codform-header h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #ffffff;
    line-height: 1.3;
  }

  .codform-header p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
  }

  /* Rest of the CSS styles... */
  /* ... keep existing code */

  /* Animation Effects - Improve animation definitions */
  @keyframes pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
    100% {
      transform: scale(1);
    }
  }

  .pulse-animation {
    animation: pulse 2s infinite !important;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 90% { transform: translateX(-2px); }
    20%, 80% { transform: translateX(4px); }
    30%, 50%, 70% { transform: translateX(-6px); }
    40%, 60% { transform: translateX(6px); }
  }

  .shake-animation {
    animation: shake 0.8s infinite !important;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
  }

  .bounce-animation {
    animation: bounce 2s infinite !important;
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(0); }
    25% { transform: rotate(-5deg); }
