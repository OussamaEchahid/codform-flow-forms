
{% comment %}
  @name: CODFORM Form Block
  @description: Display a cash on delivery form for products
  @supports: product
  @by: OurTeam
{% endcomment %}

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان نجاح الإرسال",
      "default": "تم إرسال الطلب بنجاح"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "رسالة نجاح الإرسال",
      "default": "شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام."
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان رسالة الخطأ",
      "default": "حدث خطأ"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "رسالة الخطأ",
      "default": "حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى."
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    },
    {
      "type": "checkbox",
      "id": "is_rtl",
      "label": "اتجاه النص من اليمين لليسار",
      "default": true
    }
  ]
}
{% endschema %}

<div 
  id="codform-container-{{ block.id }}" 
  class="codform-container" 
  data-product-id="{{ product.id }}"
  data-block-id="{{ block.id }}"
  data-hide-header="true"
  data-enable-icons="true"
>
  <div id="codform-form-loader-{{ block.id }}" class="codform-loader" style="display: flex; justify-content: center; padding: 20px;">
    <div class="codform-spinner"></div>
    <div style="margin-top: 10px;">{{ block.settings.loading_text }}</div>
  </div>
  
  <div id="codform-form-{{ block.id }}" class="codform-form-container" style="display: none;"></div>
  
  <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-success-icon">✓</div>
    <h3>{{ block.settings.success_title }}</h3>
    <p>{{ block.settings.success_message }}</p>
  </div>
  
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-error-icon">!</div>
    <h3>{{ block.settings.error_title }}</h3>
    <p>{{ block.settings.error_message }}</p>
    <button id="codform-retry-{{ block.id }}" class="codform-button">{{ block.settings.retry_button }}</button>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('codform-container-{{ block.id }}');
    const loader = document.getElementById('codform-form-loader-{{ block.id }}');
    const formContainer = document.getElementById('codform-form-{{ block.id }}');
    const errorContainer = document.getElementById('codform-error-{{ block.id }}');
    const successContainer = document.getElementById('codform-success-{{ block.id }}');
    const retryButton = document.getElementById('codform-retry-{{ block.id }}');
    
    if (container && loader) {
      loader.style.display = 'flex';
      
      // إضافة معالج حدث إعادة المحاولة
      if (retryButton) {
        retryButton.addEventListener('click', function() {
          errorContainer.style.display = 'none';
          loader.style.display = 'flex';
          fetchForm();
        });
      }
      
      // بدء تحميل النموذج
      fetchForm();
    }
    
    // وظيفة لجلب النموذج بناءً على معرف المنتج
    function fetchForm() {
      const productId = container.getAttribute('data-product-id');
      const blockId = container.getAttribute('data-block-id');
      const shop = Shopify.shop || window.location.hostname;
      
      if (!productId || !shop) {
        showError("بيانات المنتج أو المتجر غير متوفرة");
        console.error('Missing product ID or shop information');
        return;
      }
      
      console.log('Fetching form with productId:', productId, 'blockId:', blockId, 'shop:', shop);
      
      const apiUrl = `https://mtyfuwdsshlzqwjujavp.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shop)}&productId=${encodeURIComponent(productId)}&blockId=${encodeURIComponent(blockId)}`;
      
      console.log('Request URL:', apiUrl);
      
      // جلب تكوين النموذج
      fetch(apiUrl)
        .then(response => {
          if (!response.ok) {
            console.error('HTTP error:', response.status, response.statusText);
            throw new Error(`HTTP error ${response.status}`);
          }
          return response.json();
        })
        .then(data => {
          if (data && data.form) {
            console.log('Form data received successfully:', data);
            renderForm(data.form, blockId);
          } else {
            console.error('No form data received:', data);
            showError("لا يوجد نموذج متوفر لهذا المنتج");
          }
        })
        .catch(error => {
          console.error('Error fetching form:', error);
          showError("حدث خطأ أثناء تحميل النموذج");
        });
    }
    
    // وظيفة لعرض النموذج - تعتمد على codform.js
    function renderForm(formData, blockId) {
      if (!formContainer) {
        console.error('Form container not found');
        return;
      }
      
      // إخفاء التحميل
      if (loader) {
        loader.style.display = 'none';
      }
      
      console.log('Rendering form with data:', JSON.stringify(formData));
      
      // استخدام الدالة العامة من codform.js
      if (window.renderCodform) {
        try {
          // إنشاء معرف مؤقت للحاوية
          const tempId = `temp-form-${blockId}`;
          formContainer.id = tempId;
          
          // استدعاء دالة العرض
          window.renderCodform(formData, tempId);
          
          // إظهار النموذج
          formContainer.style.display = 'block';
          
          // إعادة تعيين المعرف الأصلي
          formContainer.id = `codform-form-${blockId}`;
          
        } catch (error) {
          console.error('Error rendering form:', error);
          showError("حدث خطأ أثناء عرض النموذج");
        }
      } else {
        console.error('renderCodform function not found');
        showError("لم يتم تحميل مكتبة النموذج بشكل صحيح");
      }
    }
    
    // وظيفة لإظهار رسالة الخطأ
    function showError(message) {
      if (loader) loader.style.display = 'none';
      if (formContainer) formContainer.style.display = 'none';
      if (successContainer) successContainer.style.display = 'none';
      
      if (errorContainer) {
        const errorMessage = errorContainer.querySelector('p');
        if (errorMessage && message) {
          errorMessage.textContent = message;
        }
        errorContainer.style.display = 'block';
      }
    }
  });
</script>

<style>
  /* تنسيقات أساسية للنموذج */
  .codform-container {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    margin: 20px 0;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
    width: 100%;
    font-size: 16px;
    line-height: 1.5;
    padding: 0 15px;
  }
  
  /* أنماط الزر */
  .codform-button {
    background-color: #9b87f5;
    color: white;
    border: none;
    padding: 10px 15px;
    border-radius: 4px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .codform-button:hover {
    opacity: 0.9;
  }
  
  /* أيقونة التحميل */
  .codform-spinner {
    border: 4px solid rgba(0, 0, 0, 0.1);
    border-left-color: #9b87f5;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    animation: spin 1s linear infinite;
  }
  
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  /* أيقونات النجاح والخطأ */
  .codform-success-icon, .codform-error-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 15px;
    border-radius: 50%;
    color: white;
    font-size: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .codform-success-icon {
    background-color: #34c759;
  }
  
  .codform-error-icon {
    background-color: #ff3b30;
  }
</style>
