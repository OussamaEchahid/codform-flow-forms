{% schema %}
{
  "name": "CODFORM - نموذج الطلب",
  "target": "section",
  "available_if": "{{ product != blank }}",
  "settings": [
    {
      "type": "header",
      "content": "إعدادات النموذج"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "عنوان النموذج",
      "default": "اطلب الآن"
    },
    {
      "type": "checkbox",
      "id": "show_quantity_offers",
      "label": "عرض عروض الكمية",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "CODFORM - نموذج الطلب"
    }
  ]
}
{% endschema %}
