{% comment %}
CODFORM Block for Shopify Theme Extension
Renders a customizable form for product pages
{% endcomment %}

{%- liquid
  assign form_id = block.settings.form_id | default: 'default'
  assign product_id = product.id | default: 'auto-detect'
  assign shop_domain = shop.domain | default: shop.permanent_domain
  assign popup_mode = block.settings.popup_mode | default: false
  assign popup_button_text = block.settings.popup_button_text | default: 'Buy with Cash on Delivery'
  assign popup_button_style = block.settings.popup_button_style | default: 'primary'
-%}

<style>
.codform-form-container {
  max-width: 100%;
  margin: 0 auto;
  padding: 20px;
  direction: ltr;
}

.codform-popup-modal {
  display: none;
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.7);
}

.codform-popup-modal.active {
  display: flex;
  align-items: center;
  justify-content: center;
}

.codform-popup-content {
  background-color: white;
  padding: 30px;
  border-radius: 12px;
  width: 90%;
  max-width: 500px;
  max-height: 80vh;
  overflow-y: auto;
  position: relative;
}

.codform-popup-close {
  position: absolute;
  right: 15px;
  top: 15px;
  font-size: 24px;
  background: none;
  border: none;
  cursor: pointer;
  color: #666;
}

.codform-popup-button {
  background-color: #9b87f5;
  color: white;
  border: none;
  padding: 16px 24px;
  font-size: 16px;
  font-weight: 600;
  border-radius: 8px;
  cursor: pointer;
  width: 100%;
  transition: all 0.3s ease;
}

.codform-popup-button:hover {
  background-color: #8b5cf6;
  transform: translateY(-2px);
}

.codform-field-wrapper {
  margin-bottom: 16px;
}

.codform-field-wrapper label {
  display: block;
  margin-bottom: 8px;
  font-weight: 600;
  color: #333;
}

.codform-field-wrapper input,
.codform-field-wrapper textarea {
  width: 100%;
  padding: 12px;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  font-size: 16px;
  font-family: inherit;
}

.codform-field-wrapper input:focus,
.codform-field-wrapper textarea:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
}
</style>

<!-- Main Form Container -->
<div data-form-preview-id="form-preview-stable" class="codform-form-container">
  <div style="text-align: center; padding: 20px; color: #666;">
    Loading form...
  </div>
</div>

<!-- Popup Button (hidden by default) -->
<div id="codform-popup-button-container" style="display: none;">
  <button id="codform-popup-button" class="codform-popup-button" onclick="window.codformOpenPopup && window.codformOpenPopup()">
    {{ popup_button_text }}
  </button>
</div>

<!-- Popup Modal -->
<div id="codform-popup-modal" class="codform-popup-modal">
  <div class="codform-popup-content">
    <button class="codform-popup-close" onclick="window.codformClosePopup && window.codformClosePopup()">&times;</button>
    <div id="codform-popup-form-content">
      <!-- Form content goes here -->
    </div>
  </div>
</div>

<!-- Load the fixed JavaScript -->
<script src="{{ 'codform-fixed.js' | asset_url }}"></script>

<script>
// Simple form loader
(function() {
  var API_BASE_URL = 'https://lovable-forms-api.netlify.app/.netlify/functions/api-forms';
  
  function loadForm() {
    var productId = '{{ product_id }}';
    var shopDomain = '{{ shop_domain }}';
    var container = document.querySelector('[data-form-preview-id="form-preview-stable"]');
    
    if (!container) return;
    
    // Show simple form for now
    container.innerHTML = '<div style="text-align: center; padding: 20px;"><h3>Order Form</h3><p>Form is ready to load</p></div>';
  }
  
  // Load when ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadForm);
  } else {
    loadForm();
  }
})();
</script>

{% schema %}
{
  "name": "CODFORM",
  "target": "section",
  "available_if": "{{ product != blank }}",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "default": "default"
    },
    {
      "type": "checkbox",
      "id": "popup_mode", 
      "label": "Enable Popup Mode",
      "default": false
    },
    {
      "type": "text",
      "id": "popup_button_text",
      "label": "Popup Button Text",
      "default": "Buy with Cash on Delivery"
    }
  ],
  "presets": [
    {
      "name": "CODFORM"
    }
  ]
}
{% endschema %}