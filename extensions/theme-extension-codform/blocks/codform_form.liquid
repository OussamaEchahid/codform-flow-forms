{% comment %}
  @name: CODFORM Form Block
  @description: Display a cash on delivery form for products
  @supports: product
  @by: OurTeam
{% endcomment %}

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان نجاح الإرسال",
      "default": "تم إرسال الطلب بنجاح"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "رسالة نجاح الإرسال",
      "default": "شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام."
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان رسالة الخطأ",
      "default": "حدث خطأ"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "رسالة الخطأ",
      "default": "حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى."
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    }
  ]
}
{% endschema %}

<!-- تحميل ملف CSS -->
{{ 'codform.css' | asset_url | stylesheet_tag }}

<!-- تحميل خط Cairo لضمان تطابق الخطوط -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<div 
  id="codform-container-{{ block.id }}" 
  class="codform-container" 
  data-product-id="{{ product.id }}"
  data-block-id="{{ block.id }}"
>
  <div id="codform-form-loader-{{ block.id }}" class="codform-loader" style="display: flex; justify-content: center; align-items: center; flex-direction: column; padding: 20px;">
    <div class="codform-spinner"></div>
    <div style="margin-top: 10px;">{{ block.settings.loading_text }}</div>
  </div>
  
  <div id="codform-form-{{ block.id }}" class="codform-form-container" style="display: none;"></div>
  
  <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-success-icon">✓</div>
    <h3>{{ block.settings.success_title }}</h3>
    <p>{{ block.settings.success_message }}</p>
  </div>
  
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-error-icon">!</div>
    <h3>{{ block.settings.error_title }}</h3>
    <p>{{ block.settings.error_message }}</p>
    <button id="codform-retry-{{ block.id }}" class="codform-button">{{ block.settings.retry_button }}</button>
  </div>
</div>

<script>
// دالة عرض النموذج - مع إصلاح نهائي لمشكلة اتجاه الأيقونات
function renderCodform(formData, containerId) {
  console.log("🎯 Rendering Codform with ULTIMATE ICON DIRECTION FIX", { formData, containerId });

  try {
    const container = document.getElementById(containerId);
    if (!container) {
      console.error("❌ Container not found:", containerId);
      return false;
    }

    if (!formData || !formData.data) {
      console.error("❌ Invalid form data:", formData);
      container.innerHTML = '<div style="padding: 20px; text-align: center; color: #666;">خطأ في تحميل النموذج - البيانات غير صحيحة</div>';
      return false;
    }

    console.log("✅ Form data is valid, starting render.");
    container.innerHTML = "";

    const style = formData.style || {};
    const primaryColor = style.primaryColor || "#9b87f5";
    const borderRadius = "1.5rem";
    const fontSize = style.fontSize || "1rem";
    
    // إصلاح نهائي: تحديد الاتجاه بناءً على اللغة الفعلية للنموذج
    let formDirection = style.formDirection || 'ltr';
    
    // إذا كان النموذج يحتوي على نصوص عربية، اجعل الاتجاه RTL
    let hasArabicText = false;
    if (formData.data && Array.isArray(formData.data)) {
      formData.data.forEach(step => {
        if (step && step.fields && Array.isArray(step.fields)) {
          step.fields.forEach(field => {
            if (field.label && /[\u0600-\u06FF]/.test(field.label)) {
              hasArabicText = true;
            }
            if (field.placeholder && /[\u0600-\u06FF]/.test(field.placeholder)) {
              hasArabicText = true;
            }
          });
        }
      });
    }
    
    // إذا لم يكن هناك نص عربي واللغة ltr، تأكد من أن الاتجاه ltr
    if (!hasArabicText && formDirection !== 'rtl') {
      formDirection = 'ltr';
    }
    
    const backgroundColor = style.backgroundColor || "#F9FAFB";
    const borderColor = style.borderColor || primaryColor;
    const borderWidth = style.borderWidth || "2px";

    console.log("🔧 ULTIMATE FIX - Form direction determined:", formDirection, "hasArabicText:", hasArabicText);

    const mainContainer = document.createElement("div");
    mainContainer.className = "rounded-lg border shadow-sm overflow-hidden codform-form";
    mainContainer.style.cssText = `
      font-size: ${fontSize};
      border-radius: ${borderRadius};
      background-color: ${backgroundColor};
      border: ${borderWidth} solid ${borderColor};
      padding: 0;
      display: flex;
      flex-direction: column;
      width: 100%;
      box-sizing: border-box;
      direction: ${formDirection};
    `;

    const contentContainer = document.createElement("div");
    contentContainer.className = "codform-form-content";
    contentContainer.style.cssText = `
      direction: ${formDirection};
      padding: ${style.paddingTop || '20px'} ${style.paddingRight || '20px'} ${style.paddingBottom || '20px'} ${style.paddingLeft || '20px'};
      gap: ${style.formGap || '16px'};
      background-color: ${backgroundColor};
      display: flex;
      flex-direction: column;
      width: 100%;
      box-sizing: border-box;
    `;
    
    const fieldsContainer = document.createElement("div");
    fieldsContainer.className = "space-y-4";
    fieldsContainer.style.cssText = `
        display: flex; 
        flex-direction: column; 
        gap: ${style.formGap || '16px'};
    `;
    
    let allFields = [];
    if (Array.isArray(formData.data)) {
      formData.data.forEach(step => {
        if (step && step.fields && Array.isArray(step.fields)) {
          allFields = allFields.concat(step.fields);
        }
      });
    }
    
    console.log(`📝 Processing ${allFields.length} fields with final direction: ${formDirection}`);
    
    if (allFields.length === 0) {
      container.innerHTML = '<div style="padding: 20px; text-align: center; color: #666;">لا توجد حقول في النموذج</div>';
      return false;
    }
    
    allFields.forEach((field, index) => {
      if (!field || !field.type) {
        console.warn("⚠️ Invalid field at index", index, field);
        return;
      }
      
      console.log(`🔧 Rendering field ${index + 1}: ${field.type} with FINAL direction: ${formDirection}`);
      
      const fieldElement = createFieldElement(field, formDirection, primaryColor, style);
      if (fieldElement) {
        fieldsContainer.appendChild(fieldElement);
      }
    });
    
    contentContainer.appendChild(fieldsContainer);
    mainContainer.appendChild(contentContainer);
    container.appendChild(mainContainer);
    
    console.log("✅ Form rendered successfully with ULTIMATE ICON DIRECTION FIX.");
    return true;
    
  } catch (error) {
    console.error("❌ Error in renderCodform:", error);
    const container = document.getElementById(containerId);
    if (container) {
      container.innerHTML = '<div style="padding: 20px; text-align: center; color: #ff0000;">حدث خطأ في عرض النموذج: ' + error.message + '</div>';
    }
    return false;
  }
}

// دالة إنشاء عنصر الحقل
function createFieldElement(field, direction, primaryColor, formStyle = {}) {
  if (!field || !field.type) {
    console.warn("⚠️ Invalid field:", field);
    return null;
  }
  
  switch (field.type) {
    case "form-title":
      return createFormTitle(field, direction);
    case "text":
    case "email":
    case "phone":
      return createTextInput(field, direction, primaryColor, formStyle);
    case "textarea":
      return createTextarea(field, direction, primaryColor, formStyle);
    case "submit":
      return createSubmitButton(field, primaryColor, formStyle);
    case "text/html":
      return createHtmlContent(field);
    default:
      console.warn("⚠️ Unknown field type:", field.type);
      const wrapper = document.createElement("div");
      wrapper.textContent = field.label || `حقل من نوع ${field.type}`;
      wrapper.style.cssText = "padding: 10px; margin-bottom: 16px;";
      return wrapper;
  }
}

// دالة إنشاء عنوان النموذج - مطابقة تماماً للمعاينة
function createFormTitle(field, direction) {
  const titleText = field.content || field.label || "";
  if (!titleText) return null;
  
  const titleWrapper = document.createElement("div");
  titleWrapper.className = "";
  titleWrapper.style.cssText = "";
  
  const titleElement = document.createElement("div");
  titleElement.className = "form-title-field w-full";
  
  const fieldStyle = field.style || {};
  const textColor = fieldStyle.color || "#9b87f5";
  const fontSize = fieldStyle.fontSize || "24px";
  const fontWeight = fieldStyle.fontWeight || "bold";
  
  titleElement.style.cssText = `
    color: ${textColor};
    font-size: ${fontSize};
    font-weight: ${fontWeight};
    font-family: Cairo, Tajawal, Arial, sans-serif;
    text-align: center;
    margin: 0;
    line-height: 1.4;
    direction: ${direction};
    padding: 0;
    width: 100%;
    display: block;
    background: none;
    border: none;
  `;
  
  titleElement.textContent = titleText;
  titleWrapper.appendChild(titleElement);
  return titleWrapper;
}

// دالة إنشاء حقل إدخال نص - مع إصلاح نهائي وجذري للأيقونات
function createTextInput(field, direction, primaryColor, formStyle = {}) {
  const wrapper = document.createElement("div");
  wrapper.className = "";
  wrapper.style.cssText = "background: transparent;";
  wrapper.setAttribute("dir", direction);

  const fieldStyle = field.style || {};
  const formStyles = formStyle || {};

  console.log(`🔧 ULTIMATE ICON FIX: Creating text input for field ${field.id} with direction=${direction}`);

  const showLabel = fieldStyle.showLabel !== false;
  if (showLabel && field.label) {
    const label = document.createElement("label");
    label.htmlFor = `${field.id}-input`;
    label.className = "block mb-2";
    label.textContent = field.label;

    label.style.cssText = `
        color: ${fieldStyle.labelColor || '#333333'};
        font-size: ${fieldStyle.labelFontSize || formStyles.fontSize || '16px'};
        font-weight: ${fieldStyle.labelFontWeight || '600'};
        font-family: 'Cairo', sans-serif;
        margin-bottom: 8px;
        display: block;
        background: transparent;
        padding: 0px;
    `;

    if (field.required) {
      const span = document.createElement("span");
      span.className = "text-red-500";
      span.textContent = " *";
      span.style.color = "rgb(239, 68, 68)";
      label.appendChild(span);
    }
    wrapper.appendChild(label);
  }

  const inputContainer = document.createElement("div");
  inputContainer.className = "relative";
  inputContainer.style.cssText = "position: relative; background: transparent;";

  const hasIcon = field.icon && field.icon !== 'none' && field.style?.showIcon !== false;

  if (hasIcon) {
    const iconElement = document.createElement("div");
    iconElement.className = "absolute codform-field-icon";
    
    // إصلاح نهائي: منطق مبسط وواضح تماماً للأيقونات
    console.log(`🎯 ULTIMATE ICON FIX: Positioning icon for field ${field.id}, direction=${direction}`);
    
    iconElement.style.cssText = `
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 2;
        color: rgb(156, 163, 175);
        display: flex;
        align-items: center;
        justify-content: center;
        ${direction === 'rtl' ? 'right: 12px; left: auto;' : 'left: 12px; right: auto;'}
    `;
    
    console.log(`🎯 Icon positioned for ${field.id}: ${direction === 'rtl' ? 'RIGHT' : 'LEFT'}`);
    
    iconElement.innerHTML = getIconSVG(field.icon);
    inputContainer.appendChild(iconElement);
  }

  const input = document.createElement("input");
  input.type = (field.type === 'email') ? 'email' : (field.type === 'phone') ? 'tel' : 'text';
  input.id = `${field.id}-input`;
  input.name = field.id;
  input.placeholder = field.placeholder || '';
  input.required = field.required || false;
  input.className = "w-full outline-none transition-all codform-input";
  input.setAttribute("aria-label", field.inputFor || field.label || "");

  const textColor = fieldStyle.color || 'rgb(31, 41, 55)';
  const fontSize = fieldStyle.fontSize || formStyles.fontSize || '16px';
  const fontWeight = fieldStyle.fontWeight || '400';
  const backgroundColor = 'rgb(255, 255, 255)';
  const borderColor = fieldStyle.borderColor || 'rgb(209, 213, 219)';
  const borderWidth = fieldStyle.borderWidth || '1px';
  const borderRadius = '1.5rem';
  const paddingY = fieldStyle.paddingY ? `${fieldStyle.paddingY}px` : '10px';

  // إصلاح نهائي: padding واضح ومباشر
  const basePadding = '12px';
  const iconPadding = '40px';
  
  console.log(`🎯 ULTIMATE PADDING FIX: Field ${field.id}, direction=${direction}, hasIcon=${hasIcon}`);
  
  let paddingLeft, paddingRight;
  
  if (direction === 'rtl') {
    paddingLeft = basePadding;
    paddingRight = hasIcon ? iconPadding : basePadding;
    console.log(`🎯 RTL: paddingLeft=${paddingLeft}, paddingRight=${paddingRight}`);
  } else {
    paddingLeft = hasIcon ? iconPadding : basePadding;
    paddingRight = basePadding;
    console.log(`🎯 LTR: paddingLeft=${paddingLeft}, paddingRight=${paddingRight}`);
  }

  input.style.cssText = `
      color: ${textColor};
      font-size: ${fontSize};
      font-weight: ${fontWeight};
      font-family: 'Cairo', sans-serif;
      background-color: ${backgroundColor};
      border-color: ${borderColor};
      border-radius: ${borderRadius};
      border-width: ${borderWidth};
      border-style: solid;
      padding-top: ${paddingY};
      padding-bottom: ${paddingY};
      padding-left: ${paddingLeft};
      padding-right: ${paddingRight};
      box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
      width: 100%;
      height: auto;
      line-height: 1.5;
      min-height: 44px;
      box-sizing: border-box;
      direction: ${direction};
      text-align: ${direction === 'rtl' ? 'right' : 'left'};
      outline: none;
      transition: all 0.2s ease;
      margin: 0px;
  `;

  input.addEventListener('focus', function() {
    this.style.borderColor = primaryColor;
    this.style.boxShadow = `0 0 0 3px rgba(155, 135, 245, 0.2)`;
  });

  input.addEventListener('blur', function() {
    this.style.borderColor = fieldStyle.borderColor || 'rgb(209, 213, 219)';
    this.style.boxShadow = 'rgba(0, 0, 0, 0.05) 0px 1px 2px';
  });

  inputContainer.appendChild(input);
  wrapper.appendChild(inputContainer);

  if (field.helpText) {
    const helpText = document.createElement("p");
    helpText.className = "mt-1 text-xs text-gray-500 codform-help-text";
    helpText.textContent = field.helpText;
    helpText.style.cssText = "margin-top: 6px; font-size: 14px; color: #6b7280; background: transparent; padding: 0;";
    wrapper.appendChild(helpText);
  }

  return wrapper;
}

// دالة إنشاء منطقة نص - مع توحيد borderRadius
function createTextarea(field, direction, primaryColor, formStyle = {}) {
  const wrapper = document.createElement("div");
  wrapper.className = "";
  wrapper.style.cssText = "background: transparent;";
  wrapper.setAttribute("dir", direction);

  const fieldStyle = field.style || {};
  const formStyles = formStyle || {};

  const showLabel = fieldStyle.showLabel !== false;
  if (showLabel && field.label) {
    const label = document.createElement("label");
    label.htmlFor = field.id;
    label.className = "block mb-2";
    label.textContent = field.label;

    label.style.cssText = `
      color: ${fieldStyle.labelColor || '#333333'};
      font-size: ${fieldStyle.labelFontSize || formStyles.fontSize || '16px'};
      font-weight: ${fieldStyle.labelFontWeight || '600'};
      font-family: 'Cairo', sans-serif;
      margin-bottom: 8px;
      display: block;
      background: transparent;
      padding: 0px;
    `;

    if (field.required) {
      const span = document.createElement("span");
      span.className = "text-red-500";
      span.textContent = " *";
      span.style.color = "rgb(239, 68, 68)";
      label.appendChild(span);
    }
    wrapper.appendChild(label);
  }

  const textarea = document.createElement("textarea");
  textarea.id = field.id;
  textarea.name = field.id;
  textarea.placeholder = field.placeholder || '';
  textarea.required = field.required || false;
  textarea.className = "w-full outline-none transition-all codform-input";
  textarea.setAttribute("aria-label", field.inputFor || field.label || "");

  const textColor = fieldStyle.color || 'rgb(31, 41, 55)';
  const fontSize = fieldStyle.fontSize || formStyles.fontSize || '16px';
  const fontWeight = fieldStyle.fontWeight || '400';
  const backgroundColor = 'rgb(255, 255, 255)';
  const borderColor = fieldStyle.borderColor || 'rgb(209, 213, 219)';
  const borderWidth = fieldStyle.borderWidth || '1px';
  const borderRadius = '1.5rem';
  const paddingY = fieldStyle.paddingY ? `${fieldStyle.paddingY}px` : '10px';

  console.log("🔧 Textarea styles:", { fontSize, borderRadius });

  textarea.style.cssText = `
    color: ${textColor};
    font-size: ${fontSize};
    font-weight: ${fontWeight};
    font-family: 'Cairo', sans-serif;
    background-color: ${backgroundColor};
    border-color: ${borderColor};
    border-radius: ${borderRadius};
    border-width: ${borderWidth};
    border-style: solid;
    padding: ${paddingY} 12px;
    box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
    width: 100%;
    min-height: 100px;
    line-height: 1.5;
    box-sizing: border-box;
    direction: ${direction};
    outline: none;
    transition: all 0.2s ease;
    margin: 0px;
    resize: vertical;
  `;

  textarea.addEventListener('focus', function() {
    this.style.borderColor = primaryColor;
    this.style.boxShadow = `0 0 0 3px rgba(155, 135, 245, 0.2)`;
  });

  textarea.addEventListener('blur', function() {
    this.style.borderColor = fieldStyle.borderColor || 'rgb(209, 213, 219)';
    this.style.boxShadow = 'rgba(0, 0, 0, 0.05) 0px 1px 2px';
  });

  wrapper.appendChild(textarea);

  if (field.helpText) {
    const helpText = document.createElement("p");
    helpText.className = "mt-1 text-xs text-gray-500 codform-help-text";
    helpText.textContent = field.helpText;
    helpText.style.cssText = "margin-top: 6px; font-size: 14px; color: #6b7280; background: transparent; padding: 0;";
    wrapper.appendChild(helpText);
  }

  return wrapper;
}

// دالة إنشاء زر الإرسال - مع توحيد الحجم والتقويس
function createSubmitButton(field, primaryColor, formStyle = {}) {
  const wrapper = document.createElement("div");
  wrapper.className = "mt-0";
  wrapper.style.cssText = `
    margin-top: 8px; 
    width: 100%; 
    background: transparent;
    padding: 0px;
  `;

  const button = document.createElement("button");
  button.type = "submit";
  button.textContent = field.label || "Buy with Cash on Delivery";

  const fieldStyle = field.style || {};
  const formStyles = formStyle || {};

  const backgroundColor = fieldStyle.backgroundColor || formStyles.primaryColor || '#9b87f5';
  const color = fieldStyle.color || '#ffffff';
  const fontSize = fieldStyle.fontSize || formStyles.fontSize || '18px';
  const borderRadius = '1.5rem';
  const paddingY = fieldStyle.paddingY || '10px';
  const borderWidth = fieldStyle.borderWidth || '0px';
  const borderColor = fieldStyle.borderColor || 'transparent';
  const animation = fieldStyle.animation;
  const animationType = fieldStyle.animationType || 'pulse';

  console.log("🔧 Submit button styles:", { fontSize, borderRadius, backgroundColor });

  if (animation && animationType) {
    button.className = `form-submit-btn w-full ${animationType}-animation`;
  } else {
    button.className = "form-submit-btn w-full";
  }

  button.style.cssText = `
    background-color: ${backgroundColor};
    color: ${color};
    font-size: ${fontSize};
    border-radius: ${borderRadius};
    padding: ${paddingY} 24px;
    border: ${borderWidth} solid ${borderColor};
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    font-weight: bold;
    text-align: center;
    transition: all 0.2s ease-in-out;
    width: 100%;
    box-sizing: border-box;
    font-family: 'Cairo', system-ui, Arial, sans-serif;
    outline: none;
    min-height: 44px;
  `;

  button.addEventListener('mouseenter', function() {
    this.style.opacity = '0.9';
    this.style.transform = 'translateY(-1px)';
  });

  button.addEventListener('mouseleave', function() {
    this.style.opacity = '1';
    this.style.transform = 'translateY(0)';
  });

  wrapper.appendChild(button);
  return wrapper;
}

// دالة إنشاء محتوى HTML
function createHtmlContent(field) {
  const wrapper = document.createElement("div");
  wrapper.style.cssText = `
    margin-bottom: 16px; 
    width: 100%; 
    background: transparent;
    padding: 0;
  `;
  wrapper.innerHTML = field.content || "<p>محتوى HTML</p>";
  return wrapper;
}

// دالة الحصول على SVG للأيقونات
function getIconSVG(iconName) {
  const icons = {
    'user': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user text-gray-500 codform-icon" aria-hidden="true" style="width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center;"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>',
    'phone': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone text-gray-500 codform-icon" aria-hidden="true" style="width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>',
