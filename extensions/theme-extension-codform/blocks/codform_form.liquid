document.addEventListener('DOMContentLoaded', function() {
  // Handle floating labels
  const inputs = document.querySelectorAll('.codform-dynamic-form input, .codform-dynamic-form textarea');
  
  inputs.forEach(input => {
    const wrapper = input.closest('.codform-field-wrapper');
    const label = wrapper?.querySelector('.floating-label');
    
    if (label) {
      // Function to update label position
      const updateLabel = () => {
        const isTextarea = input.tagName.toLowerCase() === 'textarea';
        if (input.value || input === document.activeElement) {
          label.style.top = isTextarea ? '8px' : '0px';
          label.style.fontSize = '12px';
          label.style.color = '#6366f1';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        } else {
          label.style.top = isTextarea ? '20px' : '50%';
          label.style.fontSize = input.style.fontSize || '16px';
          label.style.color = '#9CA3AF';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        }
      };
      
      // Add event listeners
      input.addEventListener('focus', updateLabel);
      input.addEventListener('blur', updateLabel);
      input.addEventListener('input', updateLabel);
      
      // Initial check
      updateLabel();
    }
  });
});
</script>

