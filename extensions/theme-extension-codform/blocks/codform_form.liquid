                ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
              </label>
            ` : ''}
          html += '<textarea';
          html += ' id="' + fieldId + '"';
          html += ' name="' + fieldId + '"';
          html += ' placeholder="' + (isFloatingLabels ? '' : actualPlaceholder) + '"';
          if (required) html += ' required';
          html += ' rows="4"';
          html += ' style="';
          html += 'width: 100%;';
          html += 'background-color: #FFFFFF;';
          html += 'border: ' + actualBorderWidth + ' solid ' + actualBorderColor + ';';
          html += 'border-radius: ' + actualBorderRadius + ';';
          html += 'padding: 10px 12px;';
          html += 'font-size: ' + actualFontSize + ';';
          html += 'color: ' + actualTextColor + ';';
          html += 'font-family: ' + actualFontFamily + ';';
          html += 'outline: none;';
          html += 'transition: all 0.2s ease;';
          html += 'box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;';
          html += 'resize: none;';
          html += 'min-height: 80px;';
          html += 'height: 80px;';
          html += 'box-sizing: border-box;';
          html += 'direction: ' + formDirection + ';';
          html += 'text-align: ' + (formDirection === 'rtl' ? 'right' : 'left') + ';';
          html += '"';
          html += ' data-focus-border-color="' + focusBorderColor + '"';
          html += ' data-blur-border-color="' + actualBorderColor + '"';
          html += '></textarea>';
          html += '</div>'; // close relative div
          
          if (field.helpText) {
            html += '<p style="';
            html += 'margin-top: 6px;';
            html += 'font-size: 14px;';
            html += 'color: #6B7280;';
            html += 'font-family: Cairo, inherit;';
            html += '">' + field.helpText + '</p>';
          }
          
          html += '</div>'; // close wrapper div
    }
    
    else if (field.type === 'submit') {
      const buttonText = field.label || 'Submit';
      const buttonStyle = field.style || {};
      
      // Animation settings
      const showAnimation = getStyleValue(buttonStyle, 'animation', false);
      const animationType = getStyleValue(buttonStyle, 'animationType', 'pulse');
      
      // Generate animation class based on animation type
      let animationClass = '';
      if (showAnimation) {
        switch (animationType) {
          case 'pulse':
            animationClass = 'pulse-animation';
            break;
          case 'bounce':
            animationClass = 'bounce-animation';
            break;
          case 'shake':
            animationClass = 'shake-animation';
            break;
          case 'wiggle':
            animationClass = 'wiggle-animation';
            break;
          case 'flash':
            animationClass = 'flash-animation';
            break;
          default:
            animationClass = '';
        }
      }
      
      // Get all button styles from field settings to match preview exactly - scale with base font size
      const baseFontSize = getStyleValue(formStyle, 'baseFontSize', '16px');
      const buttonBgColor = getStyleValue(buttonStyle, 'backgroundColor', formStyle?.primaryColor || 'rgb(155, 135, 245)');
      const buttonTextColor = getStyleValue(buttonStyle, 'color', 'rgb(255, 255, 255)');
      const buttonFontSize = getStyleValue(buttonStyle, 'fontSize', baseFontSize);
      const buttonFontWeight = getStyleValue(buttonStyle, 'fontWeight', 'bold');
      const buttonBorderRadius = getStyleValue(buttonStyle, 'borderRadius', formStyle?.borderRadius || '8px');
      const buttonWidth = getStyleValue(buttonStyle, 'width', '100%');
      const buttonMinHeight = getStyleValue(buttonStyle, 'minHeight', '56px');
      const buttonBoxShadow = getStyleValue(buttonStyle, 'boxShadow', 'none');
      
      // الحصول على إعدادات الحدود والحشو من field.style مباشرة
      const buttonBorderWidth = getStyleValue(buttonStyle, 'borderWidth', '0px');
      const buttonBorderColor = getStyleValue(buttonStyle, 'borderColor', 'transparent');
      const buttonPaddingY = getStyleValue(buttonStyle, 'paddingY', '15px');
      const buttonPaddingX = getStyleValue(buttonStyle, 'paddingX', '24px');
      
      // إنشاء border و padding صحيحة
      const buttonBorder = buttonBorderWidth !== '0px' && buttonBorderColor !== 'transparent' 
        ? buttonBorderWidth + ' solid ' + buttonBorderColor 
        : 'none';
      const buttonPadding = buttonPaddingY + ' ' + buttonPaddingX;
      
      // إصلاح الحصول على fontWeight - التحقق من labelWeight أولاً ثم fontWeight
      const labelWeight = getStyleValue(buttonStyle, 'labelWeight', null);
      const fontWeight = getStyleValue(buttonStyle, 'fontWeight', null);
      const actualButtonFontWeight = labelWeight || fontWeight || 'bold';
      
      // Icon handling for submit button
      const hasIcon = field.icon && field.icon !== 'none' && field.icon !== '';
      const showIcon = getStyleValue(buttonStyle, 'showIcon', hasIcon);
      const iconPosition = getStyleValue(buttonStyle, 'iconPosition', 'left');
      const iconColor = getStyleValue(buttonStyle, 'iconColor', buttonTextColor);
      
      let iconHtml = '';
      if (showIcon && hasIcon) {
        const iconSvg = getIconSvg(field.icon, iconColor);
        const iconMargin = iconPosition === 'left' ? 'margin-right: 8px;' : 'margin-left: 8px;';
        iconHtml = '<span style="' + iconMargin + ' display: inline-flex; align-items: center;">' + iconSvg + '</span>';
      }
      
      const buttonContent = iconPosition === 'left' ? 
        iconHtml + buttonText : 
        buttonText + iconHtml;
      
      html = `
        <div class="codform-submit-wrapper" style="
          margin-top: 24px;
          text-align: center;
        ">
          <button
            type="submit"
            class="codform-submit-btn ${animationClass}"
            style="
              background-color: ${buttonBgColor};
              color: ${buttonTextColor};
              font-size: ${buttonFontSize};
              font-weight: ${actualButtonFontWeight};
              padding: ${buttonPadding};
              border: ${buttonBorder};
              border-radius: ${buttonBorderRadius};
              cursor: pointer;
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              width: ${buttonWidth};
              min-height: ${buttonMinHeight};
              font-family: inherit;
              display: inline-flex;
              align-items: center;
              justify-content: center;
              gap: 8px;
              box-shadow: ${buttonBoxShadow};
              transform: translateY(0);
              position: relative;
              overflow: hidden;
              text-align: center;
            "
            onmouseover="
              this.style.opacity='0.9';
            "
            onmouseout="
              this.style.opacity='1';
            "
          >
            ${buttonContent}
          </button>
        </div>
      `;
    }
    
    return html;
  }

