
{% schema %}
{
  "name": "CodMagnet - COD Form",
  "target": "section",
  "settings": [
    {
      "id": "product_id",
      "type": "text",
      "label": "Product ID",
      "info": "Enter the product ID to load the form."
    }
  ]
}
{% endschema %}

<link rel="stylesheet" href="{{ 'codform-styles.css' | asset_url }}">

<!-- تحميل الملفات الأساسية -->
<script src="{{ 'codform-smart-currency-system.js' | asset_url }}"></script>
<script src="{{ 'codform-currency-manager.js' | asset_url }}"></script>
<script src="{{ 'codform-logger-control.js' | asset_url }}"></script>
<script src="{{ 'codform-form-core.js' | asset_url }}"></script>
<script src="{{ 'codform-field-renderer.js' | asset_url }}"></script>
<script src="{{ 'codform-ui-updates.js' | asset_url }}"></script>
<script src="{{ 'codform-quantity-offers-fixed.js' | asset_url }}"></script>
<script src="{{ 'codform-icons.js' | asset_url }}"></script>
<script src="{{ 'codform-utilities.js' | asset_url }}"></script>
<script src="{{ 'codform-image-field.js' | asset_url }}"></script>
<script src="{{ 'codform-whatsapp-field.js' | asset_url }}"></script>
<script src="{{ 'codform-countdown-field.js' | asset_url }}"></script>
<script src="{{ 'codform-arabic-styling.js' | asset_url }}"></script>
<script src="{{ 'codform-cart-summary.v2.js' | asset_url }}?v={{ 'now' | date: '%s' }}"></script>

<script src="{{ 'codform-advertising-tracking.js' | asset_url }}?v={{ 'now' | date: '%s' }}"></script>

{% if request.design_mode %}
  <style>
    .codform-editor-hint { border: 1px solid #E5E7EB; background: #F9FAFB; padding: 16px; border-radius: 8px; margin: 12px 0; font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif; }
    .codform-editor-hint h3 { margin: 0 0 8px; font-size: 14px; color: #111827; }
    .codform-editor-hint p { margin: 4px 0; font-size: 13px; color: #374151; }
  </style>
  <div class="codform-editor-hint">
    <h3>{{ 'codform.editor.help_title' | t }}</h3>
    <p>{{ 'codform.editor.help_line_1' | t }}</p>
    <p>{{ 'codform.editor.help_line_2' | t }}</p>
  </div>
{% endif %}

<div id="codform-popup-button-container" style="display: none;">
  
</div>

<div data-form-preview-id="form-preview-stable">
  
</div>

<script>
(function() {
  'use strict';
  
  // تمرير المتغيرات من Shopify إلى النواة
  window.codformProductId = ('{{ product.id }}' || '{{ product.variants.first.id }}' || '{{ block.settings.product_id }}' || 'auto-detect').trim();
  window.codformShopDomain = '{{ shop.domain }}' || '{{ shop.permanent_domain }}' || 'auto-detect';
  window.CodformShopCurrency = '{{ shop.currency }}';
  
  // ✅ الحصول على معرفات النموذج والمتجر
  const formId = window.codformProductId; // سيتم تحديده بواسطة النظام
  const shopId = window.codformShopDomain;
  
  console.log(`🚀 Initializing Smart Currency System for Form: ${formId}, Shop: ${shopId}`);
  
  // تهيئة CurrencyService
  if (window.parent && window.parent.CurrencyService) {
    window.CurrencyService = window.parent.CurrencyService;
    window.CurrencyServiceStorage = window.parent.CurrencyServiceStorage;
  } else if (window.top && window.top.CurrencyService) {
    window.CurrencyService = window.top.CurrencyService;
    window.CurrencyServiceStorage = window.top.CurrencyServiceStorage;
  }

  // ✅ تشغيل النظام الذكي للعملات
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(async () => {
      if (window.CodformSmartCurrency) {
        const success = await window.CodformSmartCurrency.initialize(formId, shopId);
        if (success) {
          console.log("✅ Smart Currency System: Successfully initialized");
        } else {
          console.log("⚠️ Smart Currency System: Initialization failed, using defaults");
        }
      }
    }, 1000);
  });

  function renderField(field, formStyle, formLanguage) {
    if (!field || !field.type) return '';
    
    const isInPopup = window.codformCurrentlyInPopup === true;
    
    let formDirection = 'ltr';
    if (formStyle && formStyle.formDirection) {
      formDirection = formStyle.formDirection;
    } else if (formLanguage === 'ar' || (formLanguage && formLanguage.includes('ar'))) {
      formDirection = 'rtl';
    } else if (field.label && /[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]/.test(field.label)) {
      formDirection = 'rtl';
    }
    
    // Base styling configuration - Arabic forms use same base size for consistency
    const baseFontSize = getStyleValue(formStyle, 'baseFontSize', '16px');
    const labelStyle = field.style || {};
    const showLabel = getStyleValue(labelStyle, 'showLabel', true);
    const isFloatingLabels = getStyleValue(formStyle, 'floatingLabels', false);
    
    // Label styling
    const labelColor = getStyleValue(labelStyle, 'labelColor', '#333333');
    const labelFontSize = getStyleValue(labelStyle, 'labelFontSize', '16px');
    const labelFontWeight = getStyleValue(labelStyle, 'labelFontWeight', '500');
    
    // Field styling
    const fieldBackgroundColor = '#FFFFFF';
    const fieldBorderColor = getStyleValue(labelStyle, 'borderColor', '#D1D5DB');
    const fieldBorderRadius = '8px';
    const fieldFontSize = baseFontSize;
    const fieldTextColor = '#1F2937';
    const fieldPadding = '12px 16px';
    
    let html = '';
    
    {%- comment -%} Form Title Field {%- endcomment -%}
    if (field.type === 'form-title') {
      html = window.CodformFieldRenderer.renderFormTitleField(field, formStyle);
    }
    {%- comment -%} Text Input Fields (text, email, phone) {%- endcomment -%}
    else if (['text', 'email', 'phone'].includes(field.type)) {
      html = window.CodformFieldRenderer.renderTextInputField(field, formStyle, formDirection, isFloatingLabels);
    }
    {%- comment -%} Textarea Field {%- endcomment -%}
    else if (field.type === 'textarea') {
      const label = field.label || 'Text Area';
      const placeholder = field.placeholder || '';
      const required = field.required || false;
      const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
      
      // Field style configuration
      const fieldStyle = field.style || {};
      const baseFontSize = getStyleValue(formStyle, 'baseFontSize', '16px');
      const defaultLabelSize = '16px';
      const actualLabelColor = getStyleValue(fieldStyle, 'labelColor', 'rgb(51, 65, 85)');
      const actualLabelFontSize = getStyleValue(fieldStyle, 'labelFontSize', defaultLabelSize);  
      const actualLabelWeight = getStyleValue(fieldStyle, 'labelFontWeight', '500');
      const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
      
      // Visual styling
      const actualTextColor = getStyleValue(fieldStyle, 'color', 'rgb(31, 41, 55)');
      const actualBorderColor = getStyleValue(fieldStyle, 'borderColor', getStyleValue(formStyle, 'fieldBorderColor', 'rgb(209, 213, 219)'));
      const actualBorderWidth = getStyleValue(fieldStyle, 'borderWidth', getStyleValue(formStyle, 'fieldBorderWidth', '1px'));
      const actualFontSize = getStyleValue(fieldStyle, 'fontSize', baseFontSize);
      const actualFontFamily = getStyleValue(fieldStyle, 'fontFamily', 'inherit');
      const actualPaddingY = getStyleValue(fieldStyle, 'paddingY', '12px');
      const actualBorderRadius = getStyleValue(fieldStyle, 'borderRadius', getStyleValue(formStyle, 'fieldBorderRadius', '8px'));
      const actualPlaceholder = getStyleValue(fieldStyle, 'placeholder', placeholder);
      const focusBorderColor = getStyleValue(formStyle, 'focusBorderColor', '#3b82f6');
      
      html = `
        <div class="codform-field-wrapper" style="
          margin-bottom: ${getStyleValue(formStyle,'formGap','16px')};
          direction: ${formDirection};
        ">
          ${actualShowLabel && !isFloatingLabels ? `
            <label for="${fieldId}" style="
              display: block;
              color: ${actualLabelColor};
              font-size: ${actualLabelFontSize};
              font-weight: ${actualLabelWeight};
                  margin-bottom: 4px;
              font-family: 'Cairo', sans-serif;
            ">
              ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
            </label>
          ` : ''}
          
          <div style="position: relative;">
            ${isFloatingLabels && actualShowLabel ? `
              <label for="${fieldId}" style="
                position: absolute;
                left: ${formDirection === 'rtl' ? 'auto' : '12px'};
                right: ${formDirection === 'rtl' ? '12px' : 'auto'};
                top: 20px;
                color: #9CA3AF;
                font-size: ${actualLabelFontSize};
                font-family: 'Cairo', sans-serif;
                pointer-events: none;
                transition: all 0.2s ease;
                background: white;
                padding: 0 4px;
                z-index: 10;
              " class="floating-label-${fieldId}">
                ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
              </label>
            ` : ''}
          <textarea
            id="${fieldId}"
            name="${fieldId}"
            placeholder="${isFloatingLabels ? '' : actualPlaceholder}"
            ${required ? 'required' : ''}
            rows="4"
            style="
              width: 100%;
              background-color: #FFFFFF;
              border: ${actualBorderWidth} solid ${actualBorderColor};
              border-radius: ${actualBorderRadius};
              padding: 10px 12px;
              font-size: ${actualFontSize};
              color: ${actualTextColor};
              font-family: ${actualFontFamily};
              outline: none;
              transition: all 0.2s ease;
              box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
              resize: none;
              min-height: 80px;
              height: 80px;
              box-sizing: border-box;
              direction: ${formDirection};
              text-align: ${formDirection === 'rtl' ? 'right' : 'left'};
            "
            onfocus="
              this.style.borderColor='${focusBorderColor}'; 
              this.style.boxShadow='0 0 0 3px ${focusBorderColor}20';
              ${isFloatingLabels ? `
                const label = document.querySelector('.floating-label-${fieldId}');
                if (label) {
                  label.style.top = '-8px';
                  label.style.transform = 'translateY(0)';
                  label.style.fontSize = '12px';
                  label.style.color = '${focusBorderColor}';
                  label.style.backgroundColor = '#FFFFFF';
                }
              ` : ''}
            "
            onblur="
              this.style.borderColor='${actualBorderColor}'; 
              this.style.boxShadow='rgba(0, 0, 0, 0.05) 0px 1px 2px';
              ${isFloatingLabels ? `
                const label = document.querySelector('.floating-label-${fieldId}');
                if (label && this.value === '') {
                  label.style.top = '20px';
                  label.style.transform = 'translateY(0)';
                  label.style.fontSize = '${actualLabelFontSize}';
                  label.style.color = '#9CA3AF';
                  label.style.backgroundColor = 'transparent';
                }
              ` : ''}
            "
            oninput="
              ${isFloatingLabels ? `
                const label = document.querySelector('.floating-label-${fieldId}');
                if (label) {
                  if (this.value !== '') {
                    label.style.top = '-8px';
                    label.style.transform = 'translateY(0)';
                    label.style.fontSize = '12px';
                    label.style.color = '${actualLabelColor}';
                    label.style.backgroundColor = '#FFFFFF';
                  } else {
                    label.style.top = '20px';
                    label.style.transform = 'translateY(0)';
                    label.style.fontSize = '${actualLabelFontSize}';
                    label.style.color = '#9CA3AF';
                    label.style.backgroundColor = 'transparent';
                  }
                }
              ` : ''}
            "
          ></textarea>
          </div>
          
          ${field.helpText ? `
            <p style="
              margin-top: 6px;
              font-size: 14px;
              color: #6B7280;
              font-family: 'Cairo', inherit;
            ">${field.helpText}</p>
          ` : ''}
        </div>
      `;
    }
    {%- comment -%} Submit Button Field {%- endcomment -%}
    else if (field.type === 'submit') {
      const buttonText = field.label || 'Submit';
      const buttonStyle = field.style || {};
      
      // Check if popup is enabled from form settings
      const isPopupMode = formStyle?.popupButton?.enabled || false;
      
      // Animation configuration
      const showAnimation = getStyleValue(buttonStyle, 'animation', false);
      const animationType = getStyleValue(buttonStyle, 'animationType', 'pulse');
      
      let animationClass = '';
      if (showAnimation) {
        switch (animationType) {
          case 'pulse': animationClass = 'pulse-animation'; break;
          case 'bounce': animationClass = 'bounce-animation'; break;
          case 'shake': animationClass = 'shake-animation'; break;
          case 'wiggle': animationClass = 'wiggle-animation'; break;
          case 'flash': animationClass = 'flash-animation'; break;
          default: animationClass = '';
        }
      }
      
      let finalButtonText, finalBgColor, finalTextColor, finalFontSize, finalBorderRadius, finalPaddingY;
      let finalAnimation = '';
      if (isPopupMode && !isInPopup && formStyle.popupButton) {
        finalButtonText = formStyle.popupButton.text || buttonText;
        finalBgColor = formStyle.popupButton.backgroundColor || formStyle?.primaryColor || 'rgb(155, 135, 245)';
        finalTextColor = formStyle.popupButton.textColor || 'rgb(255, 255, 255)';
        finalFontSize = formStyle.popupButton.fontSize || '16px';
        finalBorderRadius = formStyle.popupButton.borderRadius || '8px';
        finalPaddingY = formStyle.popupButton.paddingY || getStyleValue(buttonStyle, 'paddingY', '10px');
        
        if (formStyle.popupButton.animation && formStyle.popupButton.animation !== 'none') {
          switch (formStyle.popupButton.animation) {
            case 'pulse': finalAnimation = 'pulse-animation'; break;
            case 'bounce': finalAnimation = 'bounce-animation'; break;
            case 'shake': finalAnimation = 'shake-animation'; break;
            case 'wiggle': finalAnimation = 'wiggle-animation'; break;
            case 'flash': finalAnimation = 'flash-animation'; break;
            default: finalAnimation = '';
          }
        }
      } else {
        const baseFontSize = formDirection === 'rtl' ? '17px' : getStyleValue(formStyle, 'baseFontSize', '18px');
        finalButtonText = buttonText;
        finalBgColor = getStyleValue(buttonStyle, 'backgroundColor', formStyle?.primaryColor || 'rgb(155, 135, 245)');
        finalTextColor = getStyleValue(buttonStyle, 'color', 'rgb(255, 255, 255)');
        finalFontSize = getStyleValue(buttonStyle, 'fontSize', baseFontSize);
        finalBorderRadius = getStyleValue(buttonStyle, 'borderRadius', formStyle?.borderRadius || '8px');
        finalPaddingY = getStyleValue(buttonStyle, 'paddingY', formDirection === 'rtl' ? '12px' : '15px');
        finalAnimation = animationClass;
        try { console.log('🧪 CODFORM Submit defaults', { direction: formDirection, fontSize: finalFontSize, paddingY: finalPaddingY, iconPositionDefault: 'right', formGap: getStyleValue(formStyle,'formGap','12px') }); } catch(e) {}
      }
      
      const buttonWidth = getStyleValue(buttonStyle, 'width', '100%');
      const buttonMinHeight = getStyleValue(buttonStyle, 'minHeight', 'auto');
      const buttonBoxShadow = getStyleValue(buttonStyle, 'boxShadow', 'none');
      const buttonBorderWidth = getStyleValue(buttonStyle, 'borderWidth', '0px');
      const buttonBorderColor = getStyleValue(buttonStyle, 'borderColor', 'transparent');
      
      const ensurePxFormat = (value, defaultValue) => {
        if (value === undefined || value === null) return defaultValue;
        const strValue = String(value);
        return strValue.endsWith('px') ? strValue : strValue + 'px';
      };
      
      const buttonPaddingY = ensurePxFormat(field.style?.paddingY, '0px');
      const buttonPaddingX = ensurePxFormat(field.style?.paddingX, '24px');
      
      const buttonBorder = buttonBorderWidth !== '0px' && buttonBorderColor !== 'transparent' 
        ? `${buttonBorderWidth} solid ${buttonBorderColor}` : 'none';
      const buttonPadding = `${buttonPaddingY} ${buttonPaddingX}`;
      
      const labelWeight = getStyleValue(buttonStyle, 'labelWeight', null);
      const fontWeight = getStyleValue(buttonStyle, 'fontWeight', null);
      const actualButtonFontWeight = labelWeight || fontWeight || '700';
      
      const actualIcon = field.icon || field.style?.icon;
      const hasIcon = actualIcon && actualIcon !== 'none' && actualIcon !== '';
      const showIcon = (isPopupMode && !isInPopup) ? 
        (formStyle.popupButton?.showIcon !== false) : 
        getStyleValue(buttonStyle, 'showIcon', hasIcon);
      const iconColor = getStyleValue(buttonStyle, 'iconColor', finalTextColor);
      // icon size (strip px if provided)
      const rawIconSize = getStyleValue(buttonStyle, 'iconSize', '18');
      const iconSize = String(rawIconSize).endsWith('px') ? String(rawIconSize).replace('px','') : String(rawIconSize);
      const iconPosition = getStyleValue(buttonStyle, 'iconPosition', 'right');
      
      let iconHtml = '';
      if (showIcon && hasIcon) {
        const iconSvg = getIconSvg(actualIcon, iconColor, iconSize);
        const marginStyle = iconPosition === 'left' 
          ? 'margin-right: 8px; margin-left: 0;'
          : 'margin-left: 8px; margin-right: 0;';
        iconHtml = `<span style="${marginStyle} display: inline-flex; align-items: center;">${iconSvg}</span>`;
      }
      
      const buttonContent = iconPosition === 'left' ? `${iconHtml}${finalButtonText}` : `${finalButtonText}${iconHtml}`;
      const clickHandler = (isPopupMode && !isInPopup) ? 
        'onclick="openFormPopup(event)"' : 'type="submit"';
      
      html = `
        <div class="codform-submit-wrapper" style="
          margin-top: 0px;
          text-align: center;
        ">
          <button
            ${clickHandler}
            class="codform-submit-btn ${finalAnimation}"
            onclick="handleFormSubmit(event); if(window.CodformAdvertisingTracking && window.CodformAdvertisingTracking.track) { window.CodformAdvertisingTracking.track(); }"
            style="
              background-color: ${finalBgColor} !important;
              color: ${finalTextColor} !important;
              font-size: ${finalFontSize} !important;
              font-weight: ${actualButtonFontWeight} !important;
              padding: ${finalPaddingY || buttonPadding} 24px !important;
              border: ${buttonBorder};
              border-radius: ${finalBorderRadius};
              cursor: pointer;
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              width: ${buttonWidth};
              min-height: ${buttonMinHeight};
              font-family: ${formDirection === 'rtl' ? "'Cairo', 'Noto Sans Arabic', 'Amiri', sans-serif" : "'Inter', 'system-ui', sans-serif"};
              display: inline-flex;
              align-items: center;
              justify-content: center;
              gap: 8px;
              box-shadow: ${buttonBoxShadow};
              transform: translateY(0);
              position: relative;
              overflow: hidden;
              text-align: center;
              margin-top: 0px !important;
            "
            onmouseover="this.style.opacity='0.9';"
            onmouseout="this.style.opacity='1';"
          >
            ${buttonContent}
          </button>
        </div>
      `;
    }
    {%- comment -%} Image Field {%- endcomment -%}
    else if (field.type === 'image') {
      html = renderImageField(field, formStyle);
    }
    {%- comment -%} WhatsApp Button Field {%- endcomment -%}
    else if (field.type === 'whatsapp') {
      html = renderWhatsAppField(field, formStyle);
    }
    {%- comment -%} Countdown Timer Field {%- endcomment -%}
    else if (field.type === 'countdown') {
      html = renderCountdownField(field, formStyle, formLanguage);
    }
    {%- comment -%} Cart Summary Field {%- endcomment -%}
    else if (field.type === 'cart-summary') {
      // Cart summary field with inline HTML (no include tag allowed in app blocks)
      const config = field.cartSummaryConfig || field.config || {};
      const currency = config.currency || 'MAD'; // الافتراضي للدرهم المغربي
      
      // ✅ استخدام النصوص المخصصة من تكوين النموذج أولاً، ثم الافتراضيات
      let subtotalLabel, discountLabel, shippingLabel, totalLabel;
      
      if (config.subtotalText || config.subtotalLabel) {
        subtotalLabel = config.subtotalText || config.subtotalLabel;
      } else {
        subtotalLabel = formDirection === 'rtl' ? 'المجموع الفرعي' : 'Subtotal';
      }
      
      if (config.discountText || config.discountLabel) {
        discountLabel = config.discountText || config.discountLabel;
      } else {
        discountLabel = formDirection === 'rtl' ? 'الخصم' : 'Discount';
      }
      
      if (config.shippingText || config.shippingLabel) {
        shippingLabel = config.shippingText || config.shippingLabel;
      } else {
        shippingLabel = formDirection === 'rtl' ? 'الشحن' : 'Shipping';
      }
      
      if (config.totalText || config.totalLabel) {
        totalLabel = config.totalText || config.totalLabel;
      } else {
        totalLabel = formDirection === 'rtl' ? 'الإجمالي' : 'Total';
      }
      
      // Get free shipping text
      const freeShippingText = config.freeShippingText || (formDirection === 'rtl' ? 'مجاني' : 'Free');
      
      html = `
        <div class="cart-summary-field" data-currency="${currency}" style="
          background-color: rgb(249, 250, 251);
          border: 1px solid rgb(229, 231, 235);
          border-radius: 8px;
          padding: 16px;
          direction: ${formDirection};
          font-family: ${formDirection === 'rtl' ? 'Cairo, Tajawal, Arial, sans-serif' : 'Inter, Arial, sans-serif'};
        ">
          <div class="summary-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <span style="color: rgb(55, 65, 81); font-size: 16px; font-weight: 500;">${subtotalLabel}</span>
            <span class="subtotal-value" data-amount="" style="color: rgb(17, 24, 39); font-size: 16px; font-weight: 600; visibility: hidden;">...</span>
          </div>
          
          <div class="summary-row discount-row" style="display: none; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <span style="color: rgb(55, 65, 81); font-size: 16px; font-weight: 500;">${discountLabel}</span>
            <span class="discount-value" data-amount="0" style="color: rgb(239, 68, 68); font-size: 16px; font-weight: 600; visibility: hidden;">-0.00 ${currency}</span>
          </div>
          
          <div class="summary-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; border-bottom: 1px solid rgb(229, 231, 235); padding-bottom: 8px;">
            <span style="color: rgb(55, 65, 81); font-size: 16px; font-weight: 500;">${shippingLabel}</span>
            <span class="shipping-value" data-amount="0" style="color: rgb(17, 24, 39); font-size: 16px; font-weight: 600; visibility: hidden;">${freeShippingText}</span>
          </div>
          
          <div class="summary-row total-row" style="display: flex; justify-content: space-between; align-items: center;">
            <span style="color: rgb(17, 24, 39); font-size: 18px; font-weight: 700;">${totalLabel}</span>
            <span class="total-value" data-amount="" style="color: rgb(5, 150, 105); font-size: 18px; font-weight: 700; visibility: hidden;">...</span>
          </div>
        </div>
      `;
      
      // ✅ NEW: Initialize cart summary with REAL API data (SAME METHOD AS QUANTITY OFFERS)
      setTimeout(async () => {
        if (window.codformCartSummary) {
          console.log('🛒 Initializing cart summary for field:', field);
          
          // ✅ CRITICAL: Use API to get REAL form currency (same as quantity offers)
          const productId = '{{ product.id }}' || 'auto-detect';
          const shopDomain = '{{ shop.permanent_domain }}' || 'auto-detect';
          
          console.log('🌐 Cart Summary - Loading real currency from API:', { productId, shopDomain });
          
          try {
            // ✅ Call the SAME API that quantity offers use for REAL currency
            const apiUrl = `https://trlklwixfeaexhydzaue.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shopDomain)}&product=${encodeURIComponent(productId)}`;
            
            const response = await fetch(apiUrl);
            if (response.ok) {
              const data = await response.json();
              console.log('💰✅ Cart Summary - REAL API Response:', data);
              
              if (data.success && data.currency) {
                // ✅ Save REAL currency from API (same format as quantity offers)
                window.CodformFormData = window.CodformFormData || {};
                window.CodformFormData.currency = data.currency;
                console.log('💰✅ Cart Summary - REAL currency saved:', data.currency);
                
                // ✅ Pass REAL product data if available
                if (data.product) {
                  console.log('🛍️ Cart Summary - Setting REAL product data:', data.product);
                  window.codformCartSummary.setProductData(
                    parseFloat(data.product.price) || 0,
                    data.product.currency || 'USD'
                  );
                }
                
                // ✅ Initialize with REAL API currency
                const cartSummaryFormStyle = {
                  currency: data.currency // Use REAL API currency
                };
                
                console.log('✅ Cart Summary - Initializing with REAL API data:', cartSummaryFormStyle);
                window.codformCartSummary.initialize(field, cartSummaryFormStyle);
                
              } else {
