{%- liquid
  assign block_id = block.id
  assign section_id = section.id
  assign settings = block.settings
  assign shop_locale = request.locale.iso_code
  assign country_code = shop_locale | slice: 3, 2
  assign form_id = settings.form_id
  assign submit_button_text = settings.submit_button_text
  assign form_style = settings.form_style
  assign show_quantity_offers = settings.show_quantity_offers
  assign show_product_info = settings.show_product_info
  assign product_id = product.id
  assign product_handle = product.handle
  assign product_title = product.title | escape
  assign product_featured_image = product | image_url: width: 200
  assign product_price = product.price | money_without_currency
  assign product_compare_at_price = product.compare_at_price | money_without_currency
-%}

<style>
  #codform-container-{{ block_id }} {
    margin-bottom: 20px;
    border: 1px solid #ddd;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
    direction: rtl;
    font-family: 'Cairo', sans-serif;
  }

  #codform-container-{{ block_id }} h2 {
    text-align: center;
    color: #333;
    margin-bottom: 20px;
  }

  #codform-container-{{ block_id }} label {
    display: block;
    margin-top: 10px;
    color: #555;
  }

  #codform-container-{{ block_id }} input[type="text"],
  #codform-container-{{ block_id }} input[type="email"],
  #codform-container-{{ block_id }} input[type="tel"],
  #codform-container-{{ block_id }} textarea {
    width: 100%;
    padding: 8px;
    margin-top: 5px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 4px;
    box-sizing: border-box;
    font-family: inherit;
  }

  #codform-container-{{ block_id }} textarea {
    height: 100px;
  }

  #codform-container-{{ block_id }} button[type="submit"] {
    background-color: #4CAF50;
    color: white;
    padding: 10px 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
  }

  #codform-container-{{ block_id }} button[type="submit"]:hover {
    background-color: #3e8e41;
  }

  /* Quantity Offers Styling */
  #quantity-offers-before-{{ block_id }} {
    margin-bottom: 20px;
    display: none; /* Hidden by default, shown by JS */
  }

  /* Product Info Styling */
  #product-info-{{ block_id }} {
    text-align: center;
    margin-bottom: 20px;
  }

  #product-info-{{ block_id }} img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 10px;
  }
</style>

{% if show_quantity_offers %}
  <div id="quantity-offers-before-{{ block_id }}">
    <!-- Quantity offers will be dynamically inserted here -->
  </div>
{% endif %}

<div id="codform-container-{{ block_id }}">
  <h2>نموذج الدفع عند الاستلام</h2>
  <div id="codform-{{ block_id }}">
    <!-- Form will be dynamically inserted here -->
  </div>
</div>

{% if show_product_info %}
  <div id="product-info-{{ block_id }}">
    {% if product_featured_image %}
      <img src="{{ product_featured_image }}" alt="{{ product_title }}">
    {% endif %}
    <h3>{{ product_title }}</h3>
    <p>السعر: {{ product_price }}</p>
    {% if product_compare_at_price %}
      <p>السعر الأصلي: {{ product_compare_at_price }}</p>
    {% endif %}
  </div>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log('🎯 CODFORM - Simple init');
  
  // بيانات أساسية
  const productId = "{{ product.id }}";
  const blockId = "{{ block.id }}";
  const shop = "{{ shop.domain }}";
  
  if (!productId || !shop) {
    console.log("❌ Missing data - product:", productId, "shop:", shop);
    return;
  }
  
  // تحميل النموذج مباشرة من API
  const apiUrl = `https://trlklwixfeaexhydzaue.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shop)}&product=${encodeURIComponent(productId)}&blockId=${encodeURIComponent(blockId)}`;
  
  fetch(apiUrl)
    .then(response => response.json())
    .then(data => {
      if (data.success && data.form) {
        console.log('✅ Form loaded successfully');
        
        // عرض النموذج
        const container = document.getElementById(`codform-${blockId}`);
        if (container) {
          container.innerHTML = `
            <form id="form-${blockId}" style="direction: rtl; font-family: 'Cairo', sans-serif;">
              <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #333;">الاسم الكامل *</label>
                <input type="text" name="name" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
              </div>
              <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #333;">رقم الهاتف *</label>
                <input type="tel" name="phone" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
              </div>
              <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #333;">العنوان *</label>
                <textarea name="address" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; height: 80px;"></textarea>
              </div>
              <button type="submit" style="width: 100%; padding: 15px; background: #4CAF50; color: white; border: none; border-radius: 5px; font-size: 16px; cursor: pointer;">
                ${data.form.submit_button_text || 'أرسل الطلب'}
              </button>
            </form>
          `;
        }
        
        // عرض عروض الكمية إذا كانت موجودة
        if (data.quantity_offers && data.quantity_offers.offers && data.quantity_offers.offers.length > 0) {
          const offersContainer = document.getElementById(`quantity-offers-before-${blockId}`);
          if (offersContainer) {
            let offersHTML = '<div style="margin-bottom: 20px; direction: rtl;">';
            
            data.quantity_offers.offers.forEach((offer, index) => {
              const isHighlighted = index === 1;
              const price = data.product.price || 0;
              const totalPrice = price * (offer.quantity || 1);
              
              offersHTML += `
                <div style="
                  padding: 15px; 
                  margin-bottom: 10px; 
                  border: 2px solid ${isHighlighted ? '#22c55e' : '#e5e7eb'}; 
                  border-radius: 8px; 
                  background: ${isHighlighted ? '#f0fdf4' : '#ffffff'};
                  display: flex; 
                  justify-content: space-between; 
                  align-items: center;
                  cursor: pointer;
                ">
                  <div>
                    <div style="font-weight: bold; color: #1f2937;">
                      ${offer.text || `اشترِ ${offer.quantity || 1} قطعة`}
                    </div>
                    ${offer.tag ? `<span style="background: #22c55e; color: white; padding: 2px 8px; border-radius: 4px; font-size: 12px;">${offer.tag}</span>` : ''}
                  </div>
                  <div style="text-align: left;">
                    <div style="font-weight: bold; font-size: 18px; color: #dc2626;">
                      ${totalPrice.toFixed(2)} ${data.product.currency || 'USD'}
                    </div>
                  </div>
                </div>
              `;
            });
            
            offersHTML += '</div>';
            offersContainer.innerHTML = offersHTML;
            offersContainer.style.display = 'block';
          }
        }
        
      } else {
        console.log('❌ No form data found');
      }
    })
    .catch(error => {
      console.error('❌ Error loading form:', error);
    });
});
</script>

{% schema %}
{
  "name": "Codform Form",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "default": "default-form-id"
    },
    {
      "type": "text",
      "id": "submit_button_text",
      "label": "Submit Button Text",
      "default": "أرسل الطلب"
    },
    {
      "type": "select",
      "id": "form_style",
      "label": "Form Style",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "modern",
          "label": "Modern"
        }
      ],
      "default": "default"
    },
    {
      "type": "checkbox",
      "id": "show_quantity_offers",
      "label": "Show Quantity Offers",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_info",
      "label": "Show Product Info",
      "default": false
    }
  ]
}
{% endschema %}
