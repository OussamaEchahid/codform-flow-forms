
{%- comment -%}
CODFORM - Form Display Block
{%- endcomment -%}

{%- liquid
  assign block_id = block.id
  assign product_id = product.id
  assign shop_domain = shop.domain
-%}

<div 
  id="codform-container-{{ block_id }}" 
  class="codform-container"
  data-block-id="{{ block_id }}"
  data-product-id="{{ product_id }}"
  data-shop="{{ shop_domain }}"
>
  <div class="codform-loading">
    <div class="codform-spinner"></div>
    <p>جاري تحميل النموذج...</p>
  </div>
</div>

{%- comment -%}
DISABLED - تم تعطيل السكريبتات المتضاربة لمنع التكرار
{%- endcomment -%}

{%- comment -%}
<script>
  // تم تعطيل هذا السكريبت لمنع التكرار
