
{% comment %}
  CODFORM - نماذج الدفع عند الاستلام

  هذا البلوك يضيف نموذج الدفع عند الاستلام إلى صفحة المنتج
  لاستخدام هذا النموذج، قم فقط بإضافة معرّف النموذج في إعدادات البلوك
{% endcomment %}

{% if product %}
<div id="codform-container-{{ block.id }}" class="codform-container" data-product-id="{{ product.id }}" data-form-id="{{ block.settings.form_id }}" data-product-price="{{ product.price | money_without_currency }}" data-hide-header="true">
  {% comment %} تم تعديل تهيئة hide-header لتكون دائما true بدلاً من استخدام block.settings.hide_header {% endcomment %}
  
  <div class="codform-form-container">
    <div id="codform-form-loader-{{ block.id }}" class="codform-loader">
      <div class="codform-spinner"></div>
      <p>{{ block.settings.loading_text | default: 'جاري تحميل النموذج...' }}</p>
    </div>

    <div id="codform-form-{{ block.id }}" class="codform-form" style="display: none;">
      <!-- النموذج سيتم تحميله ديناميكيًا هنا -->
    </div>

    <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none;">
      <div class="codform-success-icon">✓</div>
      <h4>{{ block.settings.success_title | default: 'تم إرسال الطلب بنجاح' }}</h4>
      <p>{{ block.settings.success_message | default: 'شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام.' }}</p>
    </div>

    <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none;">
      <div class="codform-error-icon">!</div>
      <h4>{{ block.settings.error_title | default: 'حدث خطأ' }}</h4>
      <p>{{ block.settings.error_message | default: 'حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى.' }}</p>
      <button id="codform-retry-{{ block.id }}" class="codform-button">{{ block.settings.retry_button | default: 'إعادة المحاولة' }}</button>
    </div>
  </div>
</div>

<style>
  /* تنسيقات الرسوم المتحركة للأزرار - تعديل وتحسين */
  @keyframes pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
    100% {
      transform: scale(1);
    }
  }
  
  .pulse-animation {
    animation: pulse 2s infinite !important;
  }
  
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 90% { transform: translateX(-2px); }
    20%, 80% { transform: translateX(4px); }
    30%, 50%, 70% { transform: translateX(-6px); }
    40%, 60% { transform: translateX(6px); }
  }
  
  .shake-animation {
    animation: shake 0.8s infinite !important;
  }
  
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
  }
  
  .bounce-animation {
    animation: bounce 2s infinite !important;
  }
  
  @keyframes wiggle {
    0%, 100% { transform: rotate(0); }
    25% { transform: rotate(-5deg); }
    50% { transform: rotate(0); }
    75% { transform: rotate(5deg); }
  }
  
  .wiggle-animation {
    animation: wiggle 0.7s ease-in-out infinite !important;
  }
  
  @keyframes flash {
    0%, 50%, 100% {
      opacity: 1;
    }
    25%, 75% {
      opacity: 0.7;
    }
  }
  
  .flash-animation {
    animation: flash 3s infinite !important;
  }
  
  /* تنسيق خط القاهرة */
  @font-face {
    font-family: 'Cairo';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url(https://fonts.gstatic.com/s/cairo/v28/SLXgc1nY6HkvalIkTpu0xg.woff2) format('woff2');
    unicode-range: U+0600-06FF, U+0750-077F, U+0870-088E, U+0890-0891, U+0898-08E1, U+08E3-08FF, U+200C-200E, U+2010-2011, U+204F, U+2E41, U+FB50-FDFF, U+FE70-FE74, U+FE76-FEFC;
  }
  
  @font-face {
    font-family: 'Cairo';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url(https://fonts.gstatic.com/s/cairo/v28/SLXgc1nY6HkvalIkTpu0xg.woff2) format('woff2');
    unicode-range: U+0600-06FF, U+0750-077F, U+0870-088E, U+0890-0891, U+0898-08E1, U+08E3-08FF, U+200C-200E, U+2010-2011, U+204F, U+2E41, U+FB50-FDFF, U+FE70-FE74, U+FE76-FEFC;
  }
  
  /* تأكيد تطبيق خط القاهرة */
  .codform-container * {
    font-family: 'Cairo', sans-serif !important;
  }
  
  /* تحسينات لأزرار الإرسال */
  .codform-submit-btn {
    width: 100% !important;
    padding: 16px 20px !important;
    font-size: 18px !important;
    font-weight: bold !important;
    border-radius: 8px !important;
    margin: 20px 0 !important;
    cursor: pointer !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    gap: 10px !important;
    background-color: #9b87f5 !important;
    color: white !important;
    border: none !important;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15) !important;
    transition: all 0.3s ease !important;
    position: relative !important;
    overflow: hidden !important;
  }
  
  .codform-submit-btn:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15) !important;
    opacity: 0.95 !important;
  }

  .codform-submit-btn span {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
  
  /* محاذاة عناصر RTL بشكل صحيح */
  [dir="rtl"] .codform-submit-btn {
    flex-direction: row-reverse !important;
  }
  
  /* تحسينات لحقول النص والهاتف */
  .codform-field input[type="text"],
  .codform-field input[type="tel"],
  .codform-field input[type="email"],
  .codform-field textarea {
    width: 100% !important;
    padding: 12px 15px !important;
    border: 1px solid #d1d5db !important;
    border-radius: 8px !important;
    font-size: 16px !important;
    margin-bottom: 10px !important;
    direction: rtl !important;
  }
  
  /* تنسيق خاص لعنوان النموذج */
  .codform-title {
    padding: 0 !important;
    margin-bottom: 20px !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }
  
  /* تحسين تنسيق حاوية العنوان للحصول على مظهر متوافق مع المعاينة */
  .codform-title-container {
    padding: 16px !important;
    border-radius: 8px !important;
    margin-bottom: 0 !important;
    background-color: #9b87f5 !important;
    box-sizing: border-box !important;
    width: 100% !important;
  }
  
  /* تحسين تنسيق وصف العنوان */
  .codform-title-description {
    margin-top: 8px !important;
    color: #ffffff !important;
    opacity: 0.9 !important;
    font-size: 0.875rem !important;
    font-weight: normal !important;
    margin-bottom: 0 !important;
  }

  /* تحسينات لمحاذاة العنوان والوصف */
  .codform-field[data-title-align="center"] h3,
  .codform-field[data-title-align="center"] p.codform-title-description {
    text-align: center !important;
  }

  .codform-field[data-title-align="right"] h3,
  .codform-field[data-title-align="right"] p.codform-title-description {
    text-align: right !important;
  }

  .codform-field[data-title-align="left"] h3,
  .codform-field[data-title-align="left"] p.codform-title-description {
    text-align: left !important;
  }

  /* تنسيق خلفية العنوان */
  .codform-field[data-has-bg="true"] {
    padding: 0 !important;
  }

  .codform-field[data-has-bg="true"] > div {
    padding: 16px !important;
    border-radius: 8px !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }
  
  /* تحسين تنسيق حقل العنوان في النموذج */
  .codform-field[data-field-type="form-title"] {
    margin-bottom: 20px !important;
  }
  
  .codform-field[data-field-type="form-title"] h3 {
    font-weight: bold !important;
    margin: 0 !important;
    padding: 0 !important;
    line-height: 1.3 !important;
  }
  
  .codform-field[data-field-type="title"] h3 {
    font-weight: medium !important;
    margin: 0 !important;
    padding: 0 !important;
    line-height: 1.3 !important;
  }
  
  /* تطبيق خصائص العنوان المخصصة */
  .codform-field h3 {
    font-size: attr(data-font-size) !important;
    font-weight: attr(data-font-weight) !important;
  }
  
  /* تطبيق خصائص الوصف المخصصة */
  .codform-field .codform-title-description {
    font-size: attr(data-desc-font-size) !important;
    font-weight: attr(data-desc-font-weight) !important;
  }
  
  /* تصحيح الأحجام وفقًا للبيانات المخصصة */
  .codform-field[data-font-size="1rem"] h3 {
    font-size: 1rem !important;
  }
  
  .codform-field[data-font-size="1.25rem"] h3 {
    font-size: 1.25rem !important;
  }
  
  .codform-field[data-font-size="1.5rem"] h3 {
    font-size: 1.5rem !important;
  }
  
  .codform-field[data-font-size="2rem"] h3 {
    font-size: 2rem !important;
  }
  
  .codform-field[data-desc-font-size="0.75rem"] .codform-title-description {
    font-size: 0.75rem !important;
  }
  
  .codform-field[data-desc-font-size="0.875rem"] .codform-title-description {
    font-size: 0.875rem !important;
  }
  
  .codform-field[data-desc-font-size="1rem"] .codform-title-description {
    font-size: 1rem !important;
  }
  
  .codform-field[data-desc-font-size="1.125rem"] .codform-title-description {
    font-size: 1.125rem !important;
  }
  
  .codform-field[data-font-weight="normal"] h3 {
    font-weight: normal !important;
  }
  
  .codform-field[data-font-weight="medium"] h3 {
    font-weight: 500 !important;
  }
  
  .codform-field[data-font-weight="bold"] h3 {
    font-weight: bold !important;
  }
  
  .codform-field[data-desc-font-weight="normal"] .codform-title-description {
    font-weight: normal !important;
  }
  
  .codform-field[data-desc-font-weight="medium"] .codform-title-description {
    font-weight: 500 !important;
  }
  
  .codform-field[data-desc-font-weight="bold"] .codform-title-description {
    font-weight: bold !important;
  }
  
  /* تحسينات لملخص العربة */
  .codform-cart-summary {
    background-color: #f9fafb !important;
    border-radius: 8px !important;
    padding: 15px !important;
    margin: 15px 0 !important;
    border: 1px solid #e5e7eb !important;
  }
  
  /* تحسينات لعناصر العربة */
  .codform-cart-items {
    border: 1px solid #e5e7eb !important;
    border-radius: 8px !important;
    margin: 15px 0 !important;
  }
  
  .codform-cart-item {
    display: flex !important;
    padding: 15px !important;
    border-bottom: 1px solid #e5e7eb !important;
    align-items: center !important;
  }
  
  /* تحسين صور المنتجات */
  .codform-cart-item img {
    width: 80px !important;
    height: 80px !important;
    border-radius: 4px !important;
    object-fit: cover !important;
    margin-left: 15px !important;
  }
  
  /* تصحيح مشكلة العرض في الهاتف */
  .codform-html-content h3 {
    font-size: 1.3rem !important;
    margin-bottom: 10px !important;
    font-weight: bold !important;
  }
  
  /* الشاشات الصغيرة */
  @media (max-width: 768px) {
    .codform-submit-btn {
      font-size: 16px !important;
      padding: 12px 16px !important;
    }
    
    .codform-cart-item {
      flex-direction: column !important;
    }
    
    .codform-cart-item img {
      margin-left: 0 !important;
      margin-bottom: 10px !important;
    }
  }
  
  /* ضمان تطبيق أنماط أزرار الإرسال بشكل متسق */
  .codform-submit-container {
    width: 100% !important;
    display: flex !important;
    justify-content: center !important;
    margin: 20px 0 !important;
  }
</style>

{% endif %}

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "stylesheet": "codform.css",
  "javascript": "codform.js",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "معرّف النموذج",
      "info": "أدخل معرف النموذج الذي تريد عرضه"
    },
    {
      "type": "text",
      "id": "title",
      "label": "عنوان النموذج",
      "default": "اطلب المنتج الآن - الدفع عند الاستلام"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "وصف النموذج",
      "default": "املأ النموذج التالي لطلب المنتج والدفع عند استلام المنتج."
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان رسالة النجاح",
      "default": "تم إرسال الطلب بنجاح"
    },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "رسالة النجاح",
      "default": "شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام."
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان رسالة الخطأ",
      "default": "حدث خطأ"
    },
    {
      "type": "textarea",
      "id": "error_message",
      "label": "رسالة الخطأ",
      "default": "حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى."
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    }
  ]
}
{% endschema %}
