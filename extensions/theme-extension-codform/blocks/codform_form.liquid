  // أيضاً عند تحميل النافذة
  window.addEventListener('load', () => {
    setTimeout(loadCompleteForm, 1000);
  });
  
  // Form submission handler
  window.handleFormSubmission = async function(event) {
    event.preventDefault();
    
    // Form submission started
    
    // Get form data
    const form = event.target;
    const formData = new FormData(form);
    const submissionData = {};
    
    // Convert FormData to regular object
    for (let [key, value] of formData.entries()) {
      submissionData[key] = value;
    }
    
    // Get additional form data from inputs
    const allInputs = form.querySelectorAll('input, textarea, select');
    allInputs.forEach(input => {
      if (input.name || input.id) {
        const fieldKey = input.name || input.id;
        if (input.type === 'checkbox') {
          submissionData[fieldKey] = input.checked;
        } else if (input.type === 'radio') {
          if (input.checked) {
            submissionData[fieldKey] = input.value;
          }
        } else {
          submissionData[fieldKey] = input.value;
        }
      }
    });
    
    // Collected form data
    
    try {
      // Get current product info from page
      const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || DEFAULT_PRODUCT_ID;
      const shopDomain = getShopDomain(); // استخدام دالة لجلب المتجر الصحيح
      
      // Submitting to shop
      
      // Submit to edge function
      const response = await fetch('https://trlklwixfeaexhydzaue.supabase.co/functions/v1/api-submissions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          formId: productId, // Use product ID as form ID
          shopDomain: shopDomain,
          productId: productId,
          data: submissionData
        })
      });
      
      const result = await response.json();
      
      if (result.success) {
        // Submission successful
        
        // Show success message
        const submitBtn = form.querySelector('.codform-submit-btn');
        if (submitBtn) {
          const originalText = submitBtn.innerHTML;
          submitBtn.innerHTML = '✅ تم الإرسال بنجاح';
          submitBtn.style.backgroundColor = '#22c55e';
          
          setTimeout(() => {
            submitBtn.innerHTML = originalText;
            submitBtn.style.backgroundColor = '';
          }, 3000);
        }
        
        // Redirect to thank you page if provided
        if (result.thankYouUrl) {
          setTimeout(() => {
            window.location.href = result.thankYouUrl;
          }, 1500);
        }
        
      } else {
        console.error('❌ CODFORM: Submission failed:', result.error);
        alert('خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى.');
      }
      
    } catch (error) {
      console.error('❌ CODFORM: Submission error:', error);
      alert('خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى.');
    }
  };
  
})();

// Popup Modal Functions
function openFormPopup(event) {
  if (event) event.preventDefault();
  // Opening form popup
  
  // Create modal overlay
  const overlay = document.createElement('div');
  overlay.id = 'codform-popup-overlay';
  overlay.style.cssText = `
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(5px);
  `;
  
  // Create modal content
  const modal = document.createElement('div');
  modal.style.cssText = `
    background: white;
    border-radius: 12px;
    max-width: 90vw;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    margin: 20px;
    width: 100%;
    max-width: 600px;
  `;
  
  // Create close button
  const closeButton = document.createElement('button');
  closeButton.innerHTML = '✕';
  closeButton.style.cssText = `
    position: absolute;
    top: 15px;
    right: 15px;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #666;
    z-index: 1;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.2s ease;
  `;
  closeButton.onmouseover = () => {
    closeButton.style.backgroundColor = '#f5f5f5';
    closeButton.style.color = '#333';
  };
  closeButton.onmouseout = () => {
    closeButton.style.backgroundColor = 'transparent';
    closeButton.style.color = '#666';
  };
  closeButton.onclick = closeFormPopup;
  
  // Set flag that we're in popup mode
  window.codformCurrentlyInPopup = true;
  
  // Add form content with proper styling for popup
  modal.innerHTML = `
    <div style="padding: 30px; background: white; border-radius: 12px;">
      ${window.codformPopupHTML || '<p>Form not available</p>'}
    </div>
  `;
  modal.appendChild(closeButton);
  
  overlay.appendChild(modal);
  document.body.appendChild(overlay);
  
  // Close on overlay click
  overlay.onclick = (e) => {
    if (e.target === overlay) {
      closeFormPopup();
    }
  };
  
  // Close on escape key
  document.addEventListener('keydown', function escapeHandler(e) {
    if (e.key === 'Escape') {
      closeFormPopup();
      document.removeEventListener('keydown', escapeHandler);
    }
  });
  
  // Focus first input and load quantity offers for popup
  setTimeout(() => {
    const firstInput = modal.querySelector('input, textarea');
    if (firstInput) {
      firstInput.focus();
    }
    
    // تحميل عروض الكمية للنافذة المنبثقة
    console.log('🔄 Starting quantity offers for popup...');
    
    // التأكد من وجود CodformQuantityOffers
    function waitForQuantityOffersPopup() {
      if (window.CodformQuantityOffers) {
        const shopDomain = window.getShopDomain ? window.getShopDomain() : 'astrem.myshopify.com';
        const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || 'auto-detect';
        console.log('🚀 Loading quantity offers for popup with:', { productId, shopDomain });
        
        // إنشاء حاوية للعروض في النافذة المنبثقة
        const popupContainer = document.createElement('div');
        popupContainer.id = 'quantity-offers-before-popup-form';
        popupContainer.style.cssText = 'margin-bottom: 16px;';
        
        // البحث عن submit button في النافذة المنبثقة وإدراج العروض قبلها
        const submitButton = modal.querySelector('button[type="submit"], input[type="submit"], [onclick*="submit"]');
        if (submitButton) {
          submitButton.parentNode.insertBefore(popupContainer, submitButton);
          console.log('✅ Popup quantity offers container created');
          
          window.CodformQuantityOffers.loadAndDisplayOffers('popup-form', productId, shopDomain, 'SAR', window.currentFormData, formDirection);
        } else {
          console.log('❌ Submit button not found in popup');
        }
      } else {
        console.log('⏳ Waiting for CodformQuantityOffers in popup...');
        setTimeout(waitForQuantityOffersPopup, 200);
      }
    }
    
    waitForQuantityOffersPopup();
  }, 500);
}

function closeFormPopup() {
  const overlay = document.getElementById('codform-popup-overlay');
  if (overlay) {
    overlay.remove();
  }
  // Reset popup mode flag
  window.codformCurrentlyInPopup = false;
}

// Floating labels functionality
document.addEventListener('DOMContentLoaded', function() {
  // Handle floating labels
  const inputs = document.querySelectorAll('.codform-dynamic-form input, .codform-dynamic-form textarea');
  
  inputs.forEach(input => {
    const wrapper = input.closest('.codform-field-wrapper');
    const label = wrapper?.querySelector('.floating-label');
    
    if (label) {
      // Function to update label position
      const updateLabel = () => {
        const isTextarea = input.tagName.toLowerCase() === 'textarea';
        if (input.value || input === document.activeElement) {
          label.style.top = isTextarea ? '8px' : '0px';
          label.style.fontSize = '12px';
          label.style.color = '#6366f1';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        } else {
          label.style.top = isTextarea ? '20px' : '50%';
          label.style.fontSize = input.style.fontSize || '16px';
          label.style.color = '#9CA3AF';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        }
      };
      
      // Add event listeners
      input.addEventListener('focus', updateLabel);
      input.addEventListener('blur', updateLabel);
      input.addEventListener('input', updateLabel);
      
      // Initial check
      updateLabel();
    }
  });
});
</script>

<!-- دمج كود عروض الكمية مباشرة -->
<script>
// CODFORM Quantity Offers Handler - مدمج مباشرة
window.CodformQuantityOffers = (function() {
  'use strict';

  // دالة عرض quantity offers
  function displayQuantityOffers(quantityOffersData, blockId, productId, defaultCurrency = 'SAR', productData = null) {
    console.log("🎯 Starting quantity offers display for blockId:", blockId);
    
    if (!quantityOffersData || !quantityOffersData.offers || !Array.isArray(quantityOffersData.offers)) {
      console.log("❌ Invalid quantity offers data");
      return;
    }

    const offers = quantityOffersData.offers;
    if (offers.length === 0) {
      console.log("ℹ️ No offers to display");
      return;
    }

    // البحث عن الحاوية
    let container = document.getElementById(`quantity-offers-before-${blockId}`);
    
    if (!container) {
      console.error("❌ Container not found:", `quantity-offers-before-${blockId}`);
      const anyContainer = document.querySelector('[id*="quantity-offers"]');
      if (anyContainer) {
        console.log("🔧 Using alternative container:", anyContainer.id);
        container = anyContainer;
      } else {
        console.error("❌ No quantity offers container found at all");
        return;
      }
    }

    console.log("✅ Container found:", container.id);

    // مسح المحتوى السابق
    container.innerHTML = '';
    container.style.display = 'block';

    // استخدام البيانات الحقيقية من النموذج مع التأكد من وجود السعر الصحيح
    const realProductData = productData || window.currentFormData || {};
    
    // استخدام السعر من Shopify Liquid مباشرة كقيمة افتراضية صحيحة
    const liquidPrice = parseFloat('{{ product.price | divided_by: 100.0 }}') || 0;
    const liquidCurrency = '{{ shop.currency }}' || 'SAR';
    const liquidImage = '{{ product.featured_image | img_url: "300x300" }}' || '';
    const liquidTitle = '{{ product.title }}' || 'المنتج';
    
    const productPrice = realProductData.price || liquidPrice;
    const productCurrency = realProductData.currency || liquidCurrency;
    const productImage = realProductData.image || realProductData.featuredImage || liquidImage;
    const productTitle = realProductData.title || liquidTitle;
    
    console.log("📦 Product data check:", {
      price: productPrice,
      currency: productCurrency, 
      image: productImage,
      title: productTitle
    });
    
    // تحويل العملة - إصلاح المعدلات
    function convertCurrency(amount, fromCurrency, toCurrency) {
      console.log(`🔄 Converting: ${amount} from ${fromCurrency} to ${toCurrency}`);
      
      const exchangeRates = {
        'USD': { 'SAR': 3.75, 'MAD': 10.0, 'USD': 1, 'AED': 3.67 },
        'SAR': { 'USD': 0.267, 'MAD': 2.67, 'SAR': 1, 'AED': 0.98 },
        'MAD': { 'USD': 0.1, 'SAR': 0.375, 'MAD': 1, 'AED': 0.37 },
        'AED': { 'USD': 0.272, 'SAR': 1.02, 'MAD': 2.7, 'AED': 1 }
      };
      
      if (fromCurrency === toCurrency) return amount;
      const rate = exchangeRates[fromCurrency]?.[toCurrency];
      const converted = rate ? amount * rate : amount;
      console.log(`✅ Converted: ${amount} ${fromCurrency} → ${converted.toFixed(2)} ${toCurrency}`);
      return converted;
    }

    const realPrice = convertCurrency(productPrice, productCurrency, defaultCurrency);
    const currencySymbol = defaultCurrency === 'USD' ? '$' : 
                          defaultCurrency === 'SAR' ? 'ر.س' : 
                          defaultCurrency === 'MAD' ? 'د.م' : defaultCurrency;

    console.log("💰 Using real price:", realPrice, defaultCurrency, "from original:", productPrice, productCurrency);

    // إنشاء العروض
    offers.forEach((offer, index) => {
      const offerElement = document.createElement('div');
      
      let totalPrice = realPrice * (offer.quantity || 1);
      let originalPrice = totalPrice;
      
      const discountValue = parseFloat(offer.discount || offer.discountValue || 0);
      const discountType = offer.discountType || 'percentage';
      
      if (discountType === 'percentage' && discountValue > 0) {
        totalPrice = originalPrice - (originalPrice * discountValue / 100);
      } else if (discountType === 'fixed' && discountValue > 0) {
        totalPrice = Math.max(0, originalPrice - discountValue);
      }

      offerElement.style.cssText = `
        background-color: #ffffff;
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: 'Cairo', system-ui, Arial, sans-serif;
        cursor: pointer;
        direction: rtl !important;
        text-align: right !important;
      `;

      // إضافة إمكانية الاختيار
      offerElement.onclick = function() {
        // إزالة التحديد من العروض الأخرى
        const allOffers = container.querySelectorAll('.quantity-offer-item');
        allOffers.forEach(item => {
          item.style.borderColor = '#e5e7eb';
          item.style.backgroundColor = '#ffffff';
        });
        
        // تحديد العرض المختار
        this.style.borderColor = '#22c55e';
        this.style.backgroundColor = '#f0fdf4';
        
        // حفظ العرض المختار
        window.selectedQuantityOffer = offer;
      };

      offerElement.className = 'quantity-offer-item';

      // إنشاء المحتوى مع الصورة
      let imageHtml = '';
      if (productImage) {
        imageHtml = `
          <div style="width: 48px; height: 48px; background: #f3f4f6; border-radius: 8px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; overflow: hidden; margin-left: 12px;">
            <img src="${productImage}" alt="${productTitle}" 
                 style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;"
                 onerror="this.style.display='none'; this.parentElement.innerHTML='📦';">
          </div>
        `;
      } else {
        imageHtml = `
          <div style="width: 48px; height: 48px; background: #f3f4f6; border-radius: 8px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; margin-left: 12px;">
            📦
          </div>
        `;
      }

      offerElement.innerHTML = `
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <div style="display: flex; align-items: center; gap: 12px;">
            ${imageHtml}
            <div>
              <div style="font-weight: 600; color: #000;">
                ${offer.text || `اشترِ ${offer.quantity || 1} قطعة`}
              </div>
              ${offer.tag ? `<div style="display: inline-block; background-color: #22c55e; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; margin-top: 4px;">${offer.tag}</div>` : ''}
            </div>
          </div>
          <div style="text-align: ${window.currentFormData?.formLanguage === 'en' ? 'left' : 'right'};">
            <div style="font-weight: bold; font-size: 18px; color: #000;">
              ${totalPrice.toFixed(2)} ${currencySymbol}
            </div>
          </div>
        </div>
      `;

      container.appendChild(offerElement);
    });

    console.log("✅ Quantity offers displayed successfully with real prices and images");
  }

  // دالة تحميل وعرض العروض من API
  async function loadAndDisplayOffers(blockId, productId, shop, formCurrency = null, productData = null) {
    try {
      console.log("🌐 Loading quantity offers for:", { blockId, productId, shop });
      
      const apiUrl = `https://trlklwixfeaexhydzaue.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shop)}&product=${encodeURIComponent(productId)}`;
      
      const response = await fetch(apiUrl);
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const data = await response.json();
      console.log("📊 API Response:", data);
      
      if (data.success && data.quantity_offers && data.quantity_offers.offers && data.quantity_offers.offers.length > 0) {
        // ✅ CRITICAL FIX: Extract currency correctly from API response
        const targetCurrency = data.form?.currency || data.currency;
        
        console.log("🔍 Debug currency extraction:", {
          'data.form.currency': data.form?.currency,
          'data.currency': data.currency,
          'targetCurrency': targetCurrency,
          'API response structure': Object.keys(data)
        });
        
        if (!targetCurrency) {
          console.warn("⚠️ No form currency found in API response, skipping quantity offers");
          console.log("❌ Full API response:", data);
          return;
        }
        
        console.log(`✅ Using form currency: ${targetCurrency} for quantity offers`);
        displayQuantityOffers(data.quantity_offers, blockId, productId, targetCurrency, data.product);
      } else {
        console.log("ℹ️ No quantity offers found for this product");
      }
      
    } catch (error) {
      console.error('❌ Error loading quantity offers:', error);
    }
  }

  return {
    displayQuantityOffers,
    loadAndDisplayOffers
  };
})();

