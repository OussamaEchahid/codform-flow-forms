{% comment %}
  @name: CODFORM Form Block
  @description: Display a cash on delivery form for products
  @supports: product
  @by: OurTeam
{% endcomment %}

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان نجاح الإرسال",
      "default": "تم إرسال الطلب بنجاح"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "رسالة نجاح الإرسال",
      "default": "شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام."
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان رسالة الخطأ",
      "default": "حدث خطأ"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "رسالة الخطأ",
      "default": "حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى."
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    }
  ]
}
{% endschema %}

<!-- تحميل ملف CSS -->
{{ 'codform.css' | asset_url | stylesheet_tag }}

<!-- تحميل script التشخيص -->
{{ 'codform-debug.js' | asset_url | script_tag }}

<!-- تحميل script العروض -->
{{ 'codform-quantity-offers.js' | asset_url | script_tag }}

<!-- تحميل الحل الشامل -->
{{ 'codform-comprehensive-fix.js' | asset_url | script_tag }}

<!-- تحميل خط Cairo لضمان تطابق الخطوط -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<!-- Quantity Offers Container - قبل النموذج -->
<div id="quantity-offers-before-{{ block.id }}" class="quantity-offers-container" style="display: none; margin-bottom: 20px;"></div>

<div 
  id="codform-container-{{ block.id }}" 
  class="codform-container" 
  data-product-id="{{ product.id }}"
  data-block-id="{{ block.id }}"
  dir="ltr"
>
  <div id="codform-form-loader-{{ block.id }}" class="codform-loader" style="display: flex; justify-content: center; align-items: center; flex-direction: column; padding: 20px;">
    <div class="codform-spinner"></div>
    <div style="margin-top: 10px;">{{ block.settings.loading_text }}</div>
  </div>
  
  <div id="codform-form-{{ block.id }}" class="codform-form-container" style="display: none;"></div>
  
  <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-success-icon">✓</div>
    <h3>{{ block.settings.success_title }}</h3>
    <p>{{ block.settings.success_message }}</p>
  </div>
  
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-error-icon">!</div>
    <h3>{{ block.settings.error_title }}</h3>
    <p>{{ block.settings.error_message }}</p>
    <button id="codform-retry-{{ block.id }}" class="codform-button">{{ block.settings.retry_button }}</button>
  </div>
</div>

<!-- إضافة تنفيذ Quantity Offers مباشرة بعد تحميل الصفحة -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log("🚀 LOADING OFFERS - Page loaded, starting quantity offers");
  
  // التأكد من وجود العناصر
  const container = document.getElementById('codform-container-{{ block.id }}');
  const offersContainer = document.getElementById('quantity-offers-before-{{ block.id }}');
  
  if (!container || !offersContainer) {
    console.error("❌ Missing containers:", { container: !!container, offersContainer: !!offersContainer });
    return;
  }
  
  // تحميل العروض فوراً
  function loadOffers() {
    if (window.CodformComprehensiveFix && window.CodformComprehensiveFix.loadData) {
      console.log("🚀 AUTO TRIGGER v2.0 - Loading quantity offers for block {{ block.id }}");
      window.CodformComprehensiveFix.loadData("{{ block.id }}")
        .then(result => {
          console.log("✅ Offers loaded successfully:", result);
          // التأكد من ظهور العروض
          setTimeout(() => {
            const container = document.getElementById('quantity-offers-before-{{ block.id }}');
            if (container && container.children.length > 0) {
              console.log("🎉 SUCCESS: Offers are visible in DOM!");
            } else {
              console.error("❌ FAILED: Offers not visible after loading");
            }
          }, 500);
        })
        .catch(error => {
          console.error("❌ Failed to load offers:", error);
        });
    } else {
      console.log("⚠️ CodformComprehensiveFix not ready, retrying in 1 second");
      setTimeout(loadOffers, 1000);
    }
  }
  
  // تحميل فوري
  setTimeout(loadOffers, 100);
});
</script>

<script>
(function() {
  'use strict';
  
  console.log("🚀 RADICAL FIX - Starting codform script for block: {{ block.id }}");
  
  const blockId = "{{ block.id }}";
  let formSubmitted = false;
  
  // دالة إرسال البيانات إلى API
  async function submitToAPI(formData, shopDomain) {
    console.log("📡 RADICAL FIX - Submitting to API:", { formData, shopDomain });
    
    try {
      // إضافة formId إلى URL كما يتطلب API
      const formId = blockId || 'default-form';
      const apiUrl = `https://trlklwixfeaexhydzaue.supabase.co/functions/v1/api-submissions?formId=${formId}`;
      
      const response = await fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          formId: 'default-form',
          shopDomain: shopDomain,
          data: formData
        })
      });
      
      console.log("📨 API Response status:", response.status);
      
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }
      
      const result = await response.json();
      console.log("✅ API Response:", result);
      
      return result;
    } catch (error) {
      console.error("❌ API Error:", error);
      throw error;
    }
  }
  
  // دالة معالجة إرسال النموذج المُحدثة
  function handleFormSubmit() {
    console.log("🎯 RADICAL FIX - Form submit handler called");
    
    if (formSubmitted) {
      console.log("⚠️ Form already submitted, ignoring");
      return;
    }
    
    formSubmitted = true;
    
    // جمع البيانات من الحقول مباشرة بدون FormData
    const container = document.getElementById('codform-form-' + blockId);
    if (!container) {
      console.error("❌ Form container not found!");
      return;
    }
    
    const inputs = container.querySelectorAll('input, textarea, select');
    const data = {};
    
    inputs.forEach(input => {
      const key = input.name || input.id;
      const value = input.type === 'checkbox' || input.type === 'radio' 
        ? (input.checked ? input.value : '') 
        : input.value;
      
      if (key && value) {
        data[key] = value;
      }
    });
    
    console.log("📝 Form data collected:", data);
    
    // إخفاء النموذج وإظهار التحميل
    const formContainer = document.getElementById('codform-form-' + blockId);
    const successContainer = document.getElementById('codform-success-' + blockId);
    const errorContainer = document.getElementById('codform-error-' + blockId);
    const loader = document.getElementById('codform-form-loader-' + blockId);
    
    if (formContainer) formContainer.style.display = 'none';
    if (successContainer) successContainer.style.display = 'none';
    if (errorContainer) errorContainer.style.display = 'none';
    if (loader) loader.style.display = 'flex';
    
    // الحصول على domain المتجر
    const shopDomain = window.location.hostname;
    
    // إرسال البيانات
    submitToAPI(data, shopDomain)
      .then(result => {
        console.log("✅ Submission successful:", result);
        if (loader) loader.style.display = 'none';
        if (successContainer) successContainer.style.display = 'block';
      })
      .catch(error => {
        console.error("❌ Submission failed:", error);
        if (loader) loader.style.display = 'none';
        if (errorContainer) errorContainer.style.display = 'block';
        formSubmitted = false; // إعادة تعيين للمحاولة مرة أخرى
      });
  }
  
  // 🎯 RADICAL FIX - دالة إنشاء زر الإرسال مع ربط الحدث مباشرة
  function createSubmitButton(field, primaryColor, formStyle = {}) {
    console.log("🔧 RADICAL FIX - Creating submit button with direct event binding");
    
    const wrapper = document.createElement("div");
    wrapper.className = "mt-0";
    wrapper.style.cssText = `
      margin-top: 8px; 
      width: 100%; 
      background: transparent;
      padding: 0px;
    `;

    const button = document.createElement("button");
    button.type = "button"; // تغيير إلى button لتجنب إرسال النموذج التلقائي
    button.textContent = field.label || "اطلب الآن";
    button.id = `submit-btn-${blockId}`;

    const fieldStyle = field.style || {};
    const formStyles = formStyle || {};

    const backgroundColor = fieldStyle.backgroundColor || formStyles.primaryColor || '#9b87f5';
    const color = fieldStyle.color || '#ffffff';
    const fontSize = fieldStyle.fontSize || formStyles.fontSize || '18px';
    const borderRadius = '1.5rem';
    const paddingY = fieldStyle.paddingY || '10px';
    const borderWidth = fieldStyle.borderWidth || '0px';
    const borderColor = fieldStyle.borderColor || 'transparent';

    button.style.cssText = `
      background-color: ${backgroundColor};
      color: ${color};
      font-size: ${fontSize};
      border-radius: ${borderRadius};
      padding: ${paddingY} 24px;
      border: ${borderWidth} solid ${borderColor};
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      font-weight: bold;
      text-align: center;
      transition: all 0.2s ease-in-out;
      width: 100%;
      box-sizing: border-box;
      font-family: 'Cairo', system-ui, Arial, sans-serif;
      outline: none;
      min-height: 44px;
    `;

    // 🎯 RADICAL FIX - ربط الحدث مباشرة مع الزر
    button.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      console.log("🎯 RADICAL FIX - Submit button clicked!");
      
      // البحث عن النموذج الأصلي
      const formElement = button.closest('.codform-form') || button.closest('form');
      
      // استدعاء معالج الإرسال بدون تمرير formElement
      console.log("📝 Proceeding with direct submission");
      handleFormSubmit();
    });

    // تأثيرات الماوس
    button.addEventListener('mouseenter', function() {
      this.style.opacity = '0.9';
      this.style.transform = 'translateY(-1px)';
    });

    button.addEventListener('mouseleave', function() {
      this.style.opacity = '1';
      this.style.transform = 'translateY(0)';
    });

    wrapper.appendChild(button);
    return wrapper;
  }
  
  // دوال إظهار النجاح والخطأ
  function showSuccess() {
    const loader = document.getElementById('codform-form-loader-' + blockId);
    const formContainer = document.getElementById('codform-form-' + blockId);
    const successContainer = document.getElementById('codform-success-' + blockId);
    const errorContainer = document.getElementById('codform-error-' + blockId);
    
    if (loader) loader.style.display = 'none';
    if (formContainer) formContainer.style.display = 'none';
    if (errorContainer) errorContainer.style.display = 'none';
    if (successContainer) successContainer.style.display = 'block';
  }
  
  function showError() {
    const loader = document.getElementById('codform-form-loader-' + blockId);
    const formContainer = document.getElementById('codform-form-' + blockId);
    const successContainer = document.getElementById('codform-success-' + blockId);
    const errorContainer = document.getElementById('codform-error-' + blockId);
    
    if (loader) loader.style.display = 'none';
    if (formContainer) formContainer.style.display = 'none';
    if (successContainer) successContainer.style.display = 'none';
    if (errorContainer) errorContainer.style.display = 'block';
    
    formSubmitted = false; // إعادة تعيين للمحاولة مرة أخرى
  }

  // 🎯 RADICAL FIX - Form rendering with ultimate error handling
  function renderCodform(formData, containerId) {
    console.log("🚀 RADICAL FIX - Starting renderCodform", { formData, containerId });

    try {
      const container = document.getElementById(containerId);
      if (!container) {
        console.error("❌ Container not found:", containerId);
        return false;
      }

      // التحقق من صحة البيانات مع دعم التنسيقين القديم والجديد
      if (!formData) {
        console.error("❌ No form data provided");
        container.innerHTML = '<div style="padding: 20px; text-align: center; color: #666;">خطأ في تحميل النموذج - لا توجد بيانات</div>';
        return false;
      }

      // تحويل البيانات إذا كانت بالتنسيق الجديد
      if (formData.fields && !formData.data) {
        console.log("🔄 Converting new format to expected format. Original fields:", formData.fields);
        formData = {
          ...formData,
          data: [{
            id: "1",
            title: "Main Step",
            fields: formData.fields
          }]
        };
        console.log("✅ Conversion completed. New data:", formData.data);
      }

      if (!formData.data || !Array.isArray(formData.data) || formData.data.length === 0) {
        console.error("❌ Invalid form data structure after conversion:", JSON.stringify(formData, null, 2));
        container.innerHTML = '<div style="padding: 20px; text-align: center; color: #666;">خطأ في تحميل النموذج - بنية البيانات غير صحيحة</div>';
        return false;
      }

      // التحقق من وجود حقول في البيانات
      const firstStep = formData.data[0];
      if (!firstStep || !firstStep.fields || !Array.isArray(firstStep.fields)) {
        console.error("❌ No valid fields found in first step:", firstStep);
        container.innerHTML = '<div style="padding: 20px; text-align: center; color: #666;">خطأ في تحميل النموذج - لا توجد حقول صحيحة</div>';
        return false;
      }

      console.log("✅ Form data is valid, starting render process");
      container.innerHTML = "";

      const style = formData.style || {};
      const primaryColor = style.primaryColor || "#9b87f5";
      const borderRadius = "1.5rem";
      const fontSize = style.fontSize || "1rem";
      
      // RADICAL FIX: Determine form direction
      let formDirection = style.formDirection || 'ltr';
      
      let hasArabicText = false;
      if (formData.data && Array.isArray(formData.data)) {
        formData.data.forEach(step => {
          if (step && step.fields && Array.isArray(step.fields)) {
            step.fields.forEach(field => {
              if (field.label && /[\u0600-\u06FF]/.test(field.label)) {
                hasArabicText = true;
              }
              if (field.placeholder && /[\u0600-\u06FF]/.test(field.placeholder)) {
                hasArabicText = true;
              }
            });
          }
        });
      }
      
      if (!hasArabicText && formDirection !== 'rtl') {
        formDirection = 'ltr';
      }
      
      const backgroundColor = style.backgroundColor || "#F9FAFB";
      const borderColor = style.borderColor || primaryColor;
      const borderWidth = style.borderWidth || "2px";

      console.log("🔧 RADICAL FIX - Form direction:", formDirection, "hasArabicText:", hasArabicText);

      const mainContainer = document.createElement("div");
      mainContainer.className = "rounded-lg border shadow-sm overflow-hidden codform-form";
      mainContainer.style.cssText = `
        font-size: ${fontSize};
        border-radius: ${borderRadius};
        background-color: ${backgroundColor};
        border: ${borderWidth} solid ${borderColor};
        padding: 0;
        display: flex;
        flex-direction: column;
        width: 100%;
        box-sizing: border-box;
        direction: ${formDirection};
      `;
      
      // Update main container direction attribute for CSS selectors
      const mainContainerElement = container.closest('.codform-container') || container.parentElement.closest('.codform-container');
      if (mainContainerElement) {
        mainContainerElement.setAttribute('dir', formDirection);
      }

      const contentContainer = document.createElement("div");
      contentContainer.className = "codform-form-content";
      contentContainer.style.cssText = `
        direction: ${formDirection};
        padding: ${style.paddingTop || '20px'} ${style.paddingRight || '20px'} ${style.paddingBottom || '20px'} ${style.paddingLeft || '20px'};
        gap: ${style.formGap || '16px'};
        background-color: ${backgroundColor};
        display: flex;
        flex-direction: column;
        width: 100%;
        box-sizing: border-box;
      `;
      
      const fieldsContainer = document.createElement("div");
      fieldsContainer.className = "space-y-4";
      fieldsContainer.style.cssText = `
          display: flex; 
          flex-direction: column; 
          gap: ${style.formGap || '16px'};
      `;
      
      let allFields = [];
      if (Array.isArray(formData.data)) {
        formData.data.forEach(step => {
          if (step && step.fields && Array.isArray(step.fields)) {
            allFields = allFields.concat(step.fields);
          }
        });
      }
      
      console.log(`📝 RADICAL FIX - Processing ${allFields.length} fields with direction: ${formDirection}`);
      
      if (allFields.length === 0) {
        container.innerHTML = '<div style="padding: 20px; text-align: center; color: #666;">لا توجد حقول في النموذج</div>';
        return false;
      }
      
      allFields.forEach((field, index) => {
        if (!field || !field.type) {
          console.warn("⚠️ Invalid field at index", index, field);
          return;
        }
        
        console.log(`🔧 Rendering field ${index + 1}: ${field.type} with direction: ${formDirection}`);
        
        try {
          const fieldElement = createFieldElement(field, formDirection, primaryColor, style);
          if (fieldElement) {
            fieldsContainer.appendChild(fieldElement);
          }
        } catch (fieldError) {
          console.error(`❌ Error creating field ${index + 1}:`, fieldError);
        }
      });
      
      contentContainer.appendChild(fieldsContainer);
      mainContainer.appendChild(contentContainer);
      container.appendChild(mainContainer);
      
      console.log("🎉 RADICAL FIX - Form rendered successfully");
      return true;
      
    } catch (error) {
      console.error("❌ CRITICAL ERROR in renderCodform:", error);
      const container = document.getElementById(containerId);
      if (container) {
        container.innerHTML = '<div style="padding: 20px; text-align: center; color: #ff0000;">حدث خطأ في عرض النموذج: ' + error.message + '</div>';
      }
      return false;
    }
  }

  // RADICAL FIX: Enhanced field creation with error handling
  function createFieldElement(field, direction, primaryColor, formStyle = {}) {
    if (!field || !field.type) {
      console.warn("⚠️ Invalid field:", field);
      return null;
    }
    
    try {
      switch (field.type) {
        case "form-title":
          return createFormTitle(field, direction);
        case "text":
        case "email":
        case "phone":
          return createTextInput(field, direction, primaryColor, formStyle);
        case "textarea":
          return createTextarea(field, direction, primaryColor, formStyle);
        case "submit":
          return createSubmitButton(field, primaryColor, formStyle);
        case "text/html":
          return createHtmlContent(field);
        default:
          console.warn("⚠️ Unknown field type:", field.type);
          const wrapper = document.createElement("div");
          wrapper.textContent = field.label || `حقل من نوع ${field.type}`;
          wrapper.style.cssText = "padding: 10px; margin-bottom: 16px;";
          return wrapper;
      }
    } catch (error) {
      console.error(`❌ Error creating field element:`, error);
      const errorWrapper = document.createElement("div");
      errorWrapper.textContent = `خطأ في إنشاء حقل: ${field.type}`;
      errorWrapper.style.cssText = "padding: 10px; margin-bottom: 16px; color: #ff0000;";
      return errorWrapper;
    }
  }

  // دالة إنشاء عنوان النموذج
  function createFormTitle(field, direction) {
    const titleText = field.content || field.label || "";
    if (!titleText) return null;
    
    const titleWrapper = document.createElement("div");
    titleWrapper.className = "";
    titleWrapper.style.cssText = "";
    
    const titleElement = document.createElement("div");
    titleElement.className = "form-title-field w-full";
    
    const fieldStyle = field.style || {};
    const textColor = fieldStyle.color || "#9b87f5";
    const fontSize = fieldStyle.fontSize || "24px";
    const fontWeight = fieldStyle.fontWeight || "bold";
    
    titleElement.style.cssText = `
      color: ${textColor};
      font-size: ${fontSize};
      font-weight: ${fontWeight};
      font-family: Cairo, Tajawal, Arial, sans-serif;
      text-align: center;
      margin: 0;
      line-height: 1.4;
      direction: ${direction};
      padding: 0;
      width: 100%;
      display: block;
      background: none;
      border: none;
    `;
    
    titleElement.textContent = titleText;
    titleWrapper.appendChild(titleElement);
    return titleWrapper;
  }

  // RADICAL FIX: Enhanced text input creation
  function createTextInput(field, direction, primaryColor, formStyle = {}) {
    const wrapper = document.createElement("div");
    wrapper.className = "";
    wrapper.style.cssText = "background: transparent;";
    wrapper.setAttribute("dir", direction);

    const fieldStyle = field.style || {};
    const formStyles = formStyle || {};

    console.log(`🔧 RADICAL FIX - Creating text input for field ${field.id} with direction=${direction}`);

    try {
      const showLabel = fieldStyle.showLabel !== false;
      if (showLabel && field.label) {
        const label = document.createElement("label");
        label.htmlFor = `${field.id}-input`;
        label.className = "block mb-2";
        label.textContent = field.label;

        let labelFontSize = fieldStyle.labelFontSize || formStyles.fontSize || '16px';
        if (labelFontSize.includes('rem')) {
          labelFontSize = (parseFloat(labelFontSize) * 16) + 'px';
        }
        
        label.style.cssText = `
            color: ${fieldStyle.labelColor || '#333333'};
            font-size: ${labelFontSize};
            font-weight: ${fieldStyle.labelFontWeight || '600'};
            font-family: 'Cairo', sans-serif;
            margin-bottom: 8px;
            display: block;
            background: transparent;
            padding: 0px;
        `;

        if (field.required) {
          const span = document.createElement("span");
          span.className = "text-red-500";
          span.textContent = " *";
          span.style.color = "rgb(239, 68, 68)";
          label.appendChild(span);
        }
        wrapper.appendChild(label);
      }

      const inputContainer = document.createElement("div");
      inputContainer.className = "relative";
      inputContainer.style.cssText = "position: relative; background: transparent;";

      const hasIcon = field.icon && field.icon !== 'none' && field.style?.showIcon !== false;

      if (hasIcon) {
        const iconElement = document.createElement("div");
        iconElement.className = "absolute codform-field-icon";
        
        console.log(`🎯 RADICAL FIX - Positioning icon for field ${field.id}, direction=${direction}`);
        
        iconElement.style.cssText = `
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 2;
            color: rgb(156, 163, 175);
            display: flex;
            align-items: center;
            justify-content: center;
            ${direction === 'rtl' ? 'right: 12px; left: auto;' : 'left: 12px; right: auto;'}
        `;
        
        iconElement.innerHTML = getIconSVG(field.icon);
        inputContainer.appendChild(iconElement);
      }

      const input = document.createElement("input");
      input.type = (field.type === 'email') ? 'email' : (field.type === 'phone') ? 'tel' : 'text';
      input.id = `${field.id}-input`;
      input.name = field.id;
      input.placeholder = field.placeholder || '';
      input.required = field.required || false;
      input.className = "w-full outline-none transition-all codform-input";
      input.setAttribute("aria-label", field.inputFor || field.label || "");

      const textColor = fieldStyle.color || 'rgb(31, 41, 55)';
      let inputFontSize = fieldStyle.fontSize || formStyles.fontSize || '16px';
      if (inputFontSize.includes('rem')) {
        inputFontSize = (parseFloat(inputFontSize) * 16) + 'px';
      }
      const fontSize = inputFontSize;
      const fontWeight = fieldStyle.fontWeight || '400';
      const backgroundColor = 'rgb(255, 255, 255)';
      const borderColor = fieldStyle.borderColor || 'rgb(209, 213, 219)';
      const borderWidth = fieldStyle.borderWidth || '1px';
      const borderRadius = '1.5rem';
      const paddingY = fieldStyle.paddingY ? `${fieldStyle.paddingY}px` : '10px';

      const basePadding = '12px';
      const iconPadding = '40px';
      
      let paddingLeft, paddingRight;
      
      if (direction === 'rtl') {
        paddingLeft = basePadding;
        paddingRight = hasIcon ? iconPadding : basePadding;
      } else {
        paddingLeft = hasIcon ? iconPadding : basePadding;
        paddingRight = basePadding;
      }

      input.style.cssText = `
          color: ${textColor};
          font-size: ${fontSize};
          font-weight: ${fontWeight};
          font-family: 'Cairo', sans-serif;
          background-color: ${backgroundColor};
          border-color: ${borderColor};
          border-radius: ${borderRadius};
          border-width: ${borderWidth};
          border-style: solid;
          padding-top: ${paddingY};
          padding-bottom: ${paddingY};
          padding-left: ${paddingLeft};
          padding-right: ${paddingRight};
          box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
          width: 100%;
          height: auto;
          line-height: 1.5;
          min-height: 44px;
          box-sizing: border-box;
          direction: ${direction};
          text-align: ${direction === 'rtl' ? 'right' : 'left'};
          outline: none;
          transition: all 0.2s ease;
          margin: 0px;
      `;

      input.addEventListener('focus', function() {
        this.style.borderColor = primaryColor;
        this.style.boxShadow = `0 0 0 3px rgba(155, 135, 245, 0.2)`;
      });

      input.addEventListener('blur', function() {
        this.style.borderColor = fieldStyle.borderColor || 'rgb(209, 213, 219)';
        this.style.boxShadow = 'rgba(0, 0, 0, 0.05) 0px 1px 2px';
      });

      inputContainer.appendChild(input);
      wrapper.appendChild(inputContainer);

      if (field.helpText) {
        const helpText = document.createElement("p");
        helpText.className = "mt-1 text-xs text-gray-500 codform-help-text";
        helpText.textContent = field.helpText;
        helpText.style.cssText = "margin-top: 6px; font-size: 14px; color: #6b7280; background: transparent; padding: 0;";
        wrapper.appendChild(helpText);
      }

      return wrapper;
      
    } catch (error) {
      console.error(`❌ Error creating text input:`, error);
      const errorDiv = document.createElement("div");
      errorDiv.textContent = `خطأ في إنشاء حقل الإدخال: ${field.label || field.id}`;
      errorDiv.style.cssText = "padding: 10px; color: #ff0000;";
      return errorDiv;
    }
  }

  // دالة إنشاء منطقة نص
  function createTextarea(field, direction, primaryColor, formStyle = {}) {
    const wrapper = document.createElement("div");
    wrapper.className = "";
    wrapper.style.cssText = "background: transparent;";
    wrapper.setAttribute("dir", direction);

    const fieldStyle = field.style || {};
    const formStyles = formStyle || {};

    const showLabel = fieldStyle.showLabel !== false;
    if (showLabel && field.label) {
      const label = document.createElement("label");
      label.htmlFor = field.id;
      label.className = "block mb-2";
      label.textContent = field.label;

      let labelFontSize = fieldStyle.labelFontSize || formStyles.fontSize || '16px';
      if (labelFontSize.includes('rem')) {
        labelFontSize = (parseFloat(labelFontSize) * 16) + 'px';
      }
      
      label.style.cssText = `
        color: ${fieldStyle.labelColor || '#333333'};
        font-size: ${labelFontSize};
        font-weight: ${fieldStyle.labelFontWeight || '600'};
        font-family: 'Cairo', sans-serif;
        margin-bottom: 8px;
        display: block;
        background: transparent;
        padding: 0px;
      `;

      if (field.required) {
        const span = document.createElement("span");
        span.className = "text-red-500";
        span.textContent = " *";
        span.style.color = "rgb(239, 68, 68)";
        label.appendChild(span);
      }
      wrapper.appendChild(label);
    }

    const textarea = document.createElement("textarea");
    textarea.id = field.id;
    textarea.name = field.id;
    textarea.placeholder = field.placeholder || '';
    textarea.required = field.required || false;
    textarea.className = "w-full outline-none transition-all codform-input";
    textarea.setAttribute("aria-label", field.inputFor || field.label || "");

    const textColor = fieldStyle.color || 'rgb(31, 41, 55)';
    let textareaFontSize = fieldStyle.fontSize || formStyles.fontSize || '16px';
    if (textareaFontSize.includes('rem')) {
      textareaFontSize = (parseFloat(textareaFontSize) * 16) + 'px';
    }
    const fontSize = textareaFontSize;
    const fontWeight = fieldStyle.fontWeight || '400';
    const backgroundColor = 'rgb(255, 255, 255)';
    const borderColor = fieldStyle.borderColor || 'rgb(209, 213, 219)';
    const borderWidth = fieldStyle.borderWidth || '1px';
    const borderRadius = '1.5rem';
    const paddingY = fieldStyle.paddingY ? `${fieldStyle.paddingY}px` : '10px';

    textarea.style.cssText = `
      color: ${textColor};
      font-size: ${fontSize};
      font-weight: ${fontWeight};
      font-family: 'Cairo', sans-serif;
      background-color: ${backgroundColor};
      border-color: ${borderColor};
      border-radius: ${borderRadius};
      border-width: ${borderWidth};
      border-style: solid;
      padding: ${paddingY} 12px;
      box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
      width: 100%;
      min-height: 100px;
      line-height: 1.5;
      box-sizing: border-box;
      direction: ${direction};
      outline: none;
      transition: all 0.2s ease;
      margin: 0px;
      resize: vertical;
    `;

    textarea.addEventListener('focus', function() {
      this.style.borderColor = primaryColor;
      this.style.boxShadow = `0 0 0 3px rgba(155, 135, 245, 0.2)`;
    });

    textarea.addEventListener('blur', function() {
      this.style.borderColor = fieldStyle.borderColor || 'rgb(209, 213, 219)';
      this.style.boxShadow = 'rgba(0, 0, 0, 0.05) 0px 1px 2px';
    });

    wrapper.appendChild(textarea);

    if (field.helpText) {
      const helpText = document.createElement("p");
      helpText.className = "mt-1 text-xs text-gray-500 codform-help-text";
      helpText.textContent = field.helpText;
      helpText.style.cssText = "margin-top: 6px; font-size: 14px; color: #6b7280; background: transparent; padding: 0;";
      wrapper.appendChild(helpText);
    }

    return wrapper;
  }

  // دالة إنشاء محتوى HTML
  function createHtmlContent(field) {
    const wrapper = document.createElement("div");
    wrapper.style.cssText = `
      margin-bottom: 16px; 
      width: 100%; 
      background: transparent;
      padding: 0;
    `;
    wrapper.innerHTML = field.content || "<p>محتوى HTML</p>";
    return wrapper;
  }

