
{% schema %}
{
  "name": "CodForm",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "Order Form"
    }
  ]
}
{% endschema %}

<style>
.codform-container {
  max-width: 600px;
  margin: 0 auto;
  padding: 20px;
  font-family: 'Cairo', Arial, sans-serif;
}

.codform-loading {
  text-align: center;
  padding: 40px 20px;
}

.codform-spinner {
  border: 4px solid #f3f3f3;
  border-top: 4px solid #3498db;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  animation: spin 2s linear infinite;
  margin: 0 auto 20px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.codform-error {
  background-color: #fee;
  border: 1px solid #fcc;
  color: #c33;
  padding: 15px;
  border-radius: 5px;
  text-align: center;
}

.codform-success {
  background-color: #f0f9ff;
  border: 2px solid #0ea5e9;
  color: #0c4a6e;
  padding: 20px;
  border-radius: 12px;
  text-align: center;
  margin-bottom: 20px;
}
</style>

<!-- Form container -->
<div id="codform-container-{{ block.id }}" class="codform-container">
  <div id="codform-loading-{{ block.id }}" class="codform-loading">
    <div class="codform-spinner"></div>
    <p>جاري تحميل النموذج...</p>
  </div>
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none;">
    <p>حدث خطأ في تحميل النموذج. يرجى المحاولة مرة أخرى.</p>
  </div>
  <div id="codform-form-{{ block.id }}" style="display: none;"></div>
</div>

<script>
(function() {
  const blockId = '{{ block.id }}';
  const productId = '{{ product.id }}';
  const productHandle = '{{ product.handle }}';
  const shopDomain = '{{ shop.domain }}';
  
  console.log('🚀 CODFORM: Starting form initialization', {
    blockId,
    productId,
    productHandle,
    shopDomain
  });

  // Form loading function
  async function loadForm() {
    const container = document.getElementById(`codform-container-${blockId}`);
    const loadingElement = document.getElementById(`codform-loading-${blockId}`);
    const errorElement = document.getElementById(`codform-error-${blockId}`);
    const formElement = document.getElementById(`codform-form-${blockId}`);

    if (!container || !loadingElement || !errorElement || !formElement) {
      console.error('❌ CODFORM: Required elements not found');
      return;
    }

    try {
      console.log('📡 CODFORM: Fetching form data...');
      
      // API call to get form data
      const response = await fetch(`https://trlklwixfeaexhydzaue.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shopDomain)}&product=${encodeURIComponent(productHandle)}`);
      
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const data = await response.json();
      console.log('✅ CODFORM: Form data received', data);

      if (!data.success || !data.form || !data.form.data) {
        throw new Error('No form configured for this product');
      }

      // Hide loading, show form
      loadingElement.style.display = 'none';
      formElement.style.display = 'block';
      
      // Load the main codform script
      const codformScript = document.createElement('script');
      codformScript.src = '{{ "codform.js" | asset_url }}';
      codformScript.onload = () => {
        console.log('📋 CODFORM: Script loaded, rendering form...');
        
        // Check if CODFORM is available
        if (window.CODFORM && window.CODFORM.renderForm) {
          window.CODFORM.renderForm(formElement, data, blockId);
        } else if (window.codform && window.codform.renderForm) {
          window.codform.renderForm(formElement, data, blockId);
        } else {
          console.error('❌ CODFORM: Render function not found');
          throw new Error('Form render function not available');
        }
      };
      
      codformScript.onerror = () => {
        console.error('❌ CODFORM: Script failed to load');
        throw new Error('Failed to load form script');
      };
      
      document.head.appendChild(codformScript);

    } catch (error) {
      console.error('❌ CODFORM: Error loading form:', error);
      loadingElement.style.display = 'none';
      errorElement.style.display = 'block';
      errorElement.innerHTML = `
        <p>حدث خطأ في تحميل النموذج</p>
        <p style="font-size: 12px; color: #666; margin-top: 8px;">${error.message}</p>
        <button onclick="location.reload()" style="margin-top: 12px; padding: 8px 16px; background: #3b82f6; color: white; border: none; border-radius: 6px; cursor: pointer;">
          إعادة المحاولة
        </button>
      `;
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadForm);
  } else {
    loadForm();
  }
})();
</script>
