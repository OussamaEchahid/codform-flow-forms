
{% comment %}
  @name: CODFORM Form Block
  @description: Display a cash on delivery form for products
  @supports: product
  @by: OurTeam
{% endcomment %}

<div 
  id="codform-container-{{ block.id }}" 
  class="codform-container" 
  data-product-id="{{ product.id }}"
  data-block-id="{{ block.id }}"
  data-hide-header="{{ block.settings.hide_header }}"
  data-enable-icons="{{ settings.enable_icons }}"
>
  <div id="codform-form-loader-{{ block.id }}" class="codform-loader" style="display: none; justify-content: center; padding: 20px;">
    <div class="codform-loader-spinner"></div>
  </div>
  
  <div id="codform-form-{{ block.id }}" class="codform-form-container" style="display: none;"></div>
  
  <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none; text-align: center; padding: 20px;">
    <h3>{{ 'codform.success_title' | t }}</h3>
    <p>{{ 'codform.success_message' | t }}</p>
  </div>
  
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none; text-align: center; padding: 20px;">
    <h3>{{ 'codform.error_title' | t }}</h3>
    <p>{{ 'codform.error_message' | t }}</p>
    <button id="codform-retry-{{ block.id }}" class="codform-retry-button">{{ 'codform.retry_button' | t }}</button>
  </div>
</div>

<style>
  .codform-loader-spinner {
    border: 4px solid rgba(0, 0, 0, 0.1);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border-left-color: #09f;
    animation: spin 1s linear infinite;
  }
  
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  .codform-retry-button {
    margin-top: 10px;
    padding: 8px 16px;
    background: #09f;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }
  
  .codform-form textarea,
  .codform-form input[type="text"],
  .codform-form input[type="email"],
  .codform-form input[type="tel"],
  .codform-form input[type="number"] {
    width: 100%;
    padding: 8px 12px;
    margin: 8px 0;
    border: 1px solid #ddd;
    border-radius: 4px;
  }
  
  .codform-form label {
    font-weight: 500;
    display: block;
    margin-bottom: 5px;
  }
  
  .codform-submit-button {
    padding: 10px 20px;
    margin-top: 15px;
    width: 100%;
    border: none;
    cursor: pointer;
    font-weight: 500;
    font-size: 16px;
    color: white;
  }
  
  .codform-required {
    color: #e32;
    margin-left: 4px;
  }

  .codform-field {
    margin-bottom: 15px;
  }
  
  .codform-field-with-icon input,
  .codform-field-with-icon textarea {
    padding-left: 36px !important;
  }
  
  .codform-field-with-icon.rtl input,
  .codform-field-with-icon.rtl textarea {
    padding-left: 12px !important;
    padding-right: 36px !important;
  }
  
  .codform-field-with-icon .codform-field-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: #6b7280;
  }
  
  .codform-field-with-icon.rtl .codform-field-icon {
    left: auto;
    right: 10px;
  }
  
  .codform-help-text {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 4px;
  }
  
  @keyframes pulse-animation {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  
  .pulse-animation {
    animation: pulse-animation 2s infinite ease-in-out;
  }
  
  @keyframes shake-animation {
    0% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
    20%, 40%, 60%, 80% { transform: translateX(5px); }
  }
  
  .shake-animation {
    animation: shake-animation 2s infinite ease-in-out;
  }
  
  @keyframes bounce-animation {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  
  .bounce-animation {
    animation: bounce-animation 2s infinite ease-in-out;
  }
  
  @keyframes wiggle-animation {
    0%, 100% { transform: rotate(0); }
    25% { transform: rotate(-3deg); }
    75% { transform: rotate(3deg); }
  }
  
  .wiggle-animation {
    animation: wiggle-animation 2s infinite ease-in-out;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('codform-container-{{ block.id }}');
    const loader = document.getElementById('codform-form-loader-{{ block.id }}');
    
    if (container && loader) {
      loader.style.display = 'flex';
    }
  });
</script>

{% schema %}
{
  "name": {
    "en": "COD Form",
    "ar": "نموذج الدفع عند الاستلام"
  },
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": {
        "en": "Form Display",
        "ar": "عرض النموذج"
      }
    },
    {
      "id": "hide_header",
      "type": "checkbox",
      "label": {
        "en": "Hide Form Header",
        "ar": "إخفاء عنوان النموذج"
      },
      "default": false,
      "info": {
        "en": "Hide the title and description in the form header",
        "ar": "إخفاء العنوان والوصف في رأس النموذج"
      }
    }
  ]
}
{% endschema %}
