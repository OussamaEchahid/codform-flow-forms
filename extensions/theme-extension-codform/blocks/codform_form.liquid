{% schema %}
{
  "name": "Codform Form",
  "target": "section",
  "settings": [
    {
      "id": "product_id",
      "type": "text",
      "label": "Product ID",
      "info": "Enter the product ID to load the form."
    }
  ]
}
{% endschema %}

<link rel="stylesheet" href="{{ 'codform-styles.css' | asset_url }}">
<script src="{{ 'codform-quantity-offers.js' | asset_url }}"></script>
<script src="{{ 'codform-icons.js' | asset_url }}"></script>
<script src="{{ 'codform-utilities.js' | asset_url }}"></script>
<script src="{{ 'codform-image-field.js' | asset_url }}"></script>
<script src="{{ 'codform-whatsapp-field.js' | asset_url }}"></script>
<script src="{{ 'codform-countdown-field.js' | asset_url }}"></script>
<script src="{{ 'codform-cart-summary.js' | asset_url }}"></script>
<script src="{{ 'codform-main.js' | asset_url }}"></script>

<div id="codform-popup-button-container" style="display: none;"></div>
<div data-form-preview-id="form-preview-stable"></div>

<script>
(function() {
  'use strict';
  
  function getProductId() {
    try {
      const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || '{{ block.settings.product_id }}' || 'auto-detect';
      return productId.trim();
    } catch (error) {
      return 'auto-detect';
    }
  }

  window.getShopDomain = function() {
    try {
      const shopDomain = '{{ shop.domain }}' || '{{ shop.permanent_domain }}' || 'auto-detect';
      return shopDomain;
    } catch (error) {
      return 'auto-detect';
    }
  }

  window.renderField = function(field, formStyle, formLanguage) {
    if (!field || !field.type) return '';
    
    const isInPopup = window.codformCurrentlyInPopup === true;
    
    let formDirection = 'ltr';
    if (formStyle && formStyle.formDirection) {
      formDirection = formStyle.formDirection;
    } else if (formLanguage === 'ar' || (formLanguage && formLanguage.includes('ar'))) {
      formDirection = 'rtl';
    } else if (field.label && /[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]/.test(field.label)) {
      formDirection = 'rtl';
    }
    
    const baseFontSize = formDirection === 'rtl' ? '13px' : '16px';
    let html = '';
    
    if (field.type === 'form-title') {
      const title = field.label || 'Form Title';
      const titleColor = field.style?.color || '#000000';
      const titleFontSize = field.style?.fontSize || '24px';
      const titleFontWeight = field.style?.fontWeight || 'bold';
      
      html = `
        <div class="form-title-field w-full" style="
          color: ${titleColor};
          font-size: ${titleFontSize};
          font-weight: ${titleFontWeight};
          font-family: Cairo, Tajawal, Arial, sans-serif;
          text-align: center;
          margin: 0px;
          line-height: 1.4;
          direction: ${formDirection};
          width: 100%;
          display: block;
        ">${title}</div>
      `;
    }
    else if (['text', 'email', 'phone'].includes(field.type)) {
      const label = field.label || 'Text Field';
      const placeholder = field.placeholder || '';
      const required = field.required || false;
      const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
      
      let inputType = 'text';
      if (field.type === 'email') inputType = 'email';
      if (field.type === 'phone') inputType = 'tel';
      
      const fieldStyle = field.style || {};
      const actualLabelColor = fieldStyle.labelColor || '#333333';
      const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
      
      html = `
        <div class="codform-field-wrapper" style="margin-bottom: 4px; direction: ${formDirection};">
          ${actualShowLabel ? `
            <label for="${fieldId}" style="
              display: block;
              color: ${actualLabelColor};
              font-size: 16px;
              font-weight: 500;
              margin-bottom: 4px;
              font-family: 'Cairo', sans-serif;
            ">${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}</label>
          ` : ''}
          
          <input
            type="${inputType}"
            id="${fieldId}"
            name="${fieldId}"
            placeholder="${placeholder}"
            ${required ? 'required' : ''}
            style="
              width: 100%;
              background-color: #FFFFFF;
              border: 1px solid #D1D5DB;
              border-radius: 8px;
              padding: 12px;
              font-size: ${baseFontSize};
              color: #1F2937;
              outline: none;
              transition: all 0.2s ease;
              box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
              min-height: 44px;
              box-sizing: border-box;
              direction: ${formDirection};
            "
          />
        </div>
      `;
    }
    else if (field.type === 'textarea') {
      const label = field.label || 'Text Area';
      const placeholder = field.placeholder || '';
      const required = field.required || false;
      const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
      
      const fieldStyle = field.style || {};
      const actualLabelColor = fieldStyle.labelColor || '#333333';
      const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
      
      html = `
        <div class="codform-field-wrapper" style="margin-bottom: 10px; direction: ${formDirection};">
          ${actualShowLabel ? `
            <label for="${fieldId}" style="
              display: block;
              color: ${actualLabelColor};
              font-size: 16px;
              font-weight: 500;
              margin-bottom: 4px;
              font-family: 'Cairo', sans-serif;
            ">${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}</label>
          ` : ''}
          
          <textarea
            id="${fieldId}"
            name="${fieldId}"
            placeholder="${placeholder}"
            ${required ? 'required' : ''}
            rows="4"
            style="
              width: 100%;
              background-color: #FFFFFF;
              border: 1px solid #D1D5DB;
              border-radius: 8px;
              padding: 10px 12px;
              font-size: ${baseFontSize};
              color: #1F2937;
              outline: none;
              transition: all 0.2s ease;
              box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
              resize: none;
              min-height: 80px;
              box-sizing: border-box;
              direction: ${formDirection};
            "
          ></textarea>
        </div>
      `;
    }
    else if (field.type === 'submit') {
      const label = field.label || 'Submit';
      const buttonStyle = field.style || {};
      const backgroundColor = buttonStyle.backgroundColor || '#3B82F6';
      const textColor = buttonStyle.color || '#FFFFFF';
      
      html = `
        <button type="submit" style="
          width: 100%;
          background-color: ${backgroundColor};
          color: ${textColor};
          border: none;
          border-radius: 8px;
          padding: 14px 20px;
          font-size: 16px;
          font-weight: 600;
          cursor: pointer;
          transition: all 0.2s ease;
          margin-top: 16px;
          font-family: Cairo, sans-serif;
        ">${label}</button>
      `;
    }
    else if (field.type === 'whatsapp') {
      html = renderWhatsAppField(field, formStyle);
    }
    else if (field.type === 'countdown') {
      html = renderCountdownField(field, formStyle, formLanguage);
    }
    else if (field.type === 'cart-summary') {
      const summaryStyle = field.style || {};
      const showSubtotal = summaryStyle.showSubtotal !== false;
      const showDiscount = summaryStyle.showDiscount !== false;
      const showShipping = summaryStyle.showShipping !== false;
      const showTotal = summaryStyle.showTotal !== false;
      
      const subtotalLabel = formDirection === 'rtl' ? 'المجموع الفرعي' : 'Subtotal';
      const discountLabel = formDirection === 'rtl' ? 'الخصم' : 'Discount';
      const shippingLabel = formDirection === 'rtl' ? 'الشحن' : 'Shipping';
      const totalLabel = formDirection === 'rtl' ? 'المجموع الكلي' : 'Total';
      
      html = `
        <div class="cart-summary-field" style="
          background: #f9fafb;
          border: 1px solid #e5e7eb;
          border-radius: 8px;
          padding: 16px;
          margin: 0px 0px 16px 0px;
          direction: ${formDirection};
          font-family: ${formDirection === 'rtl' ? 'Cairo, sans-serif' : 'Inter, sans-serif'};
        " data-field-id="${field.id}">
          ${showSubtotal ? `<div style="display: flex; justify-content: space-between; margin-bottom: 8px;"><span>${subtotalLabel}</span><span data-amount="subtotal">$0.00</span></div>` : ''}
          ${showDiscount ? `<div style="display: flex; justify-content: space-between; margin-bottom: 8px; display: none;" data-discount-row><span style="color: #dc2626;">${discountLabel}</span><span style="color: #dc2626;" data-amount="discount">-$0.00</span></div>` : ''}
          ${showShipping ? `<div style="display: flex; justify-content: space-between; margin-bottom: 8px; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;"><span>${shippingLabel}</span><span data-amount="shipping">Free</span></div>` : ''}
          ${showTotal ? `<div style="display: flex; justify-content: space-between;"><span style="font-size: 18px; font-weight: 600;">${totalLabel}</span><span style="font-size: 18px; font-weight: 600;" data-amount="total">$0.00</span></div>` : ''}
        </div>
      `;
      
      setTimeout(() => {
        if (window.codformCartSummary) {
          window.codformCartSummary.initialize(field, formStyle);
        }
      }, 100);
    }
    
    return html;
  }

  function renderWhatsAppField(field, formStyle) {
    const label = field.label || 'Send to WhatsApp';
    const phoneNumber = field.phoneNumber || '';
    const message = field.message || 'Hello!';
    const style = field.style || {};
    const backgroundColor = style.backgroundColor || '#25D366';
    const textColor = style.color || '#FFFFFF';
    
    return `
      <button type="button" onclick="sendToWhatsApp('${phoneNumber}', '${message}')" style="
        width: 100%;
        background-color: ${backgroundColor};
        color: ${textColor};
        border: none;
        border-radius: 8px;
        padding: 14px 20px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        margin: 10px 0;
        font-family: Cairo, sans-serif;
      ">${label}</button>
    `;
  }

  function renderCountdownField(field, formStyle, formLanguage) {
    const targetDate = field.targetDate || new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString();
    const style = field.style || {};
    
    return `
      <div class="countdown-timer" data-target="${targetDate}" style="
        text-align: center;
        padding: 20px;
        margin: 16px 0;
        background: ${style.backgroundColor || '#f9fafb'};
        border-radius: 8px;
        font-family: Cairo, sans-serif;
      ">
        <div style="font-size: 24px; font-weight: bold; color: ${style.textColor || '#1f2937'};">
          <span class="countdown-days">00</span>:
          <span class="countdown-hours">00</span>:
          <span class="countdown-minutes">00</span>:
          <span class="countdown-seconds">00</span>
        </div>
      </div>
    `;
  }

  const productId = getProductId();
  const shopDomain = getShopDomain();
  
  if (typeof window.renderCodform === 'function') {
    window.renderCodform(productId, shopDomain);
  }

})();

function sendToWhatsApp(phoneNumber, message) {
  const url = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
  window.open(url, '_blank');
}
</script>