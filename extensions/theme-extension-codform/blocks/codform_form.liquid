// Handle popup form submission
window.handlePopupFormSubmission = async function(event) {
  event.preventDefault();
  const form = event.target;
  const submitBtn = form.querySelector('.codform-submit-btn, button[type="submit"]');
  const popup = document.getElementById('codform-popup-modal');
  
  // Get form data from popup
  const formInputs = form.querySelectorAll('input, textarea, select');
  const formData = {};
  
  formInputs.forEach(input => {
    if (input.name || input.id) {
      const fieldKey = input.name || input.id;
      if (input.type === 'checkbox') {
        formData[fieldKey] = input.checked;
      } else if (input.type === 'radio') {
        if (input.checked) {
          formData[fieldKey] = input.value;
        }
      } else {
        formData[fieldKey] = input.value;
      }
    }
  });
  
  handleFormSubmissionPopup(formData, submitBtn, popup);
};

async function handleFormSubmissionPopup(formData, submitBtn, popup) {
  console.log('🚀 CODFORM: Popup form submission started', formData);
  
  try {
    const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || 'default';
    const shopDomain = getShopDomain();
    
    // Submit to edge function
    const response = await fetch('https://trlklwixfeaexhydzaue.supabase.co/functions/v1/api-submissions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        formId: productId,
        shopDomain: shopDomain,
        productId: productId,
        data: formData
      })
    });
    
    const result = await response.json();
    
    if (result.success) {
      console.log('✅ CODFORM: Popup submission successful');
      
      // Show success message
      if (submitBtn) {
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '✅ تم الإرسال بنجاح';
        submitBtn.style.backgroundColor = '#22c55e';
        
        setTimeout(() => {
          // Close popup after success
          popup.style.animation = 'fadeOut 0.3s ease';
          setTimeout(() => {
            document.body.removeChild(popup);
          }, 300);
        }, 2000);
      }
      
      // Redirect to thank you page if provided
      if (result.thankYouUrl) {
        setTimeout(() => {
          window.location.href = result.thankYouUrl;
        }, 2500);
      }
      
    } else {
      console.error('❌ CODFORM: Popup submission failed:', result.error);
      alert('خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى.');
    }
    
  } catch (error) {
    console.error('❌ CODFORM: Popup submission error:', error);
    alert('خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى.');
  }
}

