
{%- comment -%}
CODFORM - Form Block for Shopify Theme
Enhanced version with quantity offers support
{%- endcomment -%}

{%- liquid
  assign form_id = block.settings.form_id
  assign block_id = block.id
  assign product_id = product.id
  assign shop_domain = shop.permanent_domain
-%}

{%- if form_id != blank -%}
  <div id="codform-container-{{ block_id }}" 
       class="codform-form-container" 
       data-form-id="{{ form_id }}"
       data-block-id="{{ block_id }}"
       data-product-id="{{ product_id }}"
       data-shop="{{ shop_domain }}"
       style="width: 100%; max-width: 600px; margin: 0 auto; padding: 20px;">
    
    {%- comment -%} Loading placeholder {%- endcomment -%}
    <div id="codform-loading-{{ block_id }}" style="text-align: center; padding: 40px;">
      <div style="border: 2px solid #f3f3f3; border-top: 2px solid #3498db; border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite; margin: 0 auto 15px;"></div>
      <p style="color: #666; font-size: 14px;">Loading form...</p>
    </div>
    
    {%- comment -%} Form will be loaded here by JavaScript {%- endcomment -%}
    <div id="codform-form-{{ block_id }}" style="display: none;"></div>
    
    {%- comment -%} Error fallback {%- endcomment -%}
    <div id="codform-error-{{ block_id }}" style="display: none; text-align: center; padding: 20px; background: #ffebee; border: 1px solid #ffcdd2; border-radius: 8px; color: #c62828;">
      <p>⚠️ Unable to load form. Please refresh the page.</p>
    </div>
  </div>

  <style>
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    
    .codform-form-container {
      font-family: 'Cairo', system-ui, -apple-system, sans-serif;
    }
    
    .codform-form-container * {
      box-sizing: border-box;
    }
  </style>

  <script>
    (function() {
      'use strict';
      
      const blockId = '{{ block_id }}';
      const formId = '{{ form_id }}';
      const productId = '{{ product_id }}';
      const shopDomain = '{{ shop_domain }}';
      
      console.log('🚀 CODFORM - Initializing form:', { blockId, formId, productId, shopDomain });
      
      // Load form without quantity offers handling (handled by React component)
      async function loadForm() {
        try {
          const container = document.getElementById(`codform-container-${blockId}`);
          const loadingEl = document.getElementById(`codform-loading-${blockId}`);
          const formEl = document.getElementById(`codform-form-${blockId}`);
          const errorEl = document.getElementById(`codform-error-${blockId}`);
          
          if (!container) {
            console.error('❌ Container not found');
            return;
          }
          
          // API URL for form data
          const apiUrl = `https://trlklwixfeaexhydzaue.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shopDomain)}&product=${encodeURIComponent(productId)}&blockId=${encodeURIComponent(blockId)}`;
          
          console.log('📡 Loading form from:', apiUrl);
          
          const response = await fetch(apiUrl);
          
          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }
          
          const data = await response.json();
          
          if (data.success && data.form) {
            console.log('✅ Form loaded successfully');
            
            // Hide loading, show form
            if (loadingEl) loadingEl.style.display = 'none';
            if (formEl) {
              formEl.style.display = 'block';
              formEl.innerHTML = data.form.html || '<p>Form content not available</p>';
            }
            
            // Note: Quantity offers are handled by React component, not here
            console.log('ℹ️ Form loaded. Quantity offers handled by React component.');
            
          } else {
            throw new Error('Invalid form data received');
          }
          
        } catch (error) {
          console.error('❌ Error loading form:', error);
          
          // Show error
          const loadingEl = document.getElementById(`codform-loading-${blockId}`);
          const errorEl = document.getElementById(`codform-error-${blockId}`);
          
          if (loadingEl) loadingEl.style.display = 'none';
          if (errorEl) errorEl.style.display = 'block';
        }
      }
      
      // Initialize when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', loadForm);
      } else {
        loadForm();
      }
      
    })();
  </script>
{%- else -%}
  <div style="text-align: center; padding: 40px; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px;">
    <p style="color: #6c757d; margin: 0;">⚠️ Please configure the form ID in the block settings.</p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "COD Form",
  "target": "section",
  "available_if": "{{ app.metafields.codform.enabled }}",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "info": "Enter the form ID from your COD Form dashboard"
    }
  ]
}
{% endschema %}
