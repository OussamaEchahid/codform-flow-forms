{%- comment -%}
===============================================================================
Codform Form Block - Shopify Liquid Template (Optimized)
===============================================================================
{%- endcomment -%}

{% schema %}
{
  "name": "Codform Form",
  "target": "section",
  "settings": [
    {
      "id": "product_id",
      "type": "text",
      "label": "Product ID",
      "info": "Enter the product ID to load the form."
    }
  ]
}
{% endschema %}

{%- comment -%} EXTERNAL ASSETS {%- endcomment -%}
<link rel="stylesheet" href="{{ 'codform-styles.css' | asset_url }}">

{%- comment -%} EXTERNAL SCRIPTS {%- endcomment -%}
<script src="{{ 'codform-quantity-offers.js' | asset_url }}"></script>
<script src="{{ 'codform-icons.js' | asset_url }}"></script>
<script src="{{ 'codform-utilities.js' | asset_url }}"></script>
<script src="{{ 'codform-main.js' | asset_url }}"></script>
<script src="{{ 'codform-fields.js' | asset_url }}"></script>
<script src="{{ 'codform-popup.js' | asset_url }}"></script>

{%- comment -%} POPUP BUTTON CONTAINER {%- endcomment -%}
<div id="codform-popup-button-container" style="display: none;">
  <!-- Popup button will be rendered here -->
</div>

{%- comment -%} FORM CONTAINER {%- endcomment -%}
<div data-form-preview-id="form-preview-stable">
  <!-- Form content will be loaded here -->
</div>

<script>
(function() {
  'use strict';
  
  console.log('🚀 CODFORM: Form initialization started');
  
  // Set product and shop data for external scripts
  window.codformProductId = '{{ product.id }}' || '{{ product.variants.first.id }}' || '{{ block.settings.product_id }}' || 'auto-detect';
  window.codformShopDomain = '{{ shop.domain }}' || '{{ shop.permanent_domain }}' || 'auto-detect';
  
  // Product data for quantity offers
  window.getProductData = function() {
    return {
      id: window.codformProductId,
      price: parseFloat('{{ product.price | divided_by: 100.0 }}') || 0,
      comparePrice: parseFloat('{{ product.compare_at_price | divided_by: 100.0 }}') || 0,
      title: '{{ product.title }}' || 'منتج',
      image: '{{ product.featured_image | img_url: "400x400" }}' || '',
      currency: '{{ shop.currency }}' || 'SAR'
    };
  };
  
  // Generate block ID
  window.generateBlockId = function(productId) {
    return `codform-${productId || 'default'}-${Date.now()}`;
  };
  
  // Initialize form loading
  function initializeForm() {
    const productId = window.codformProductId;
    const shopDomain = window.codformShopDomain;
    
    if (!productId || productId === 'auto-detect') {
      console.error('❌ CODFORM: No product ID found');
      return;
    }
    
    // Load the form
    window.loadForm(productId, shopDomain);
  }
  
  // Start initialization
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeForm);
  } else {
    initializeForm();
  }
  
  // Initialize quantity offers after form load
  document.addEventListener('DOMContentLoaded', function() {
    const waitForFormLoad = setInterval(function() {
      const formContainer = document.querySelector('.codform-dynamic-form');
      if (formContainer && !formContainer.dataset.quantityOffersLoaded) {
        const productId = window.codformProductId;
        const shopDomain = window.codformShopDomain;
        const blockId = window.generateBlockId(productId);
        
        if (window.CodformQuantityOffers) {
          const formCurrency = window.currentFormData?.formStyle?.currency || 'SAR';
          const productData = window.getProductData();
          
          window.CodformQuantityOffers.loadAndDisplayOffers(blockId, productId, shopDomain, formCurrency, productData);
          formContainer.dataset.quantityOffersLoaded = 'true';
          clearInterval(waitForFormLoad);
        }
      }
    }, 100);
    
    setTimeout(() => clearInterval(waitForFormLoad), 10000);
  });

})();
</script>