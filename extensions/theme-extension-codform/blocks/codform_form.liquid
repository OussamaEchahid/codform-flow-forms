{% comment %}
  @name: CODFORM Form Block
  @description: Display a cash on delivery form for products
  @supports: product
  @by: OurTeam
{% endcomment %}

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان نجاح الإرسال",
      "default": "تم إرسال الطلب بنجاح"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "رسالة نجاح الإرسال",
      "default": "شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام."
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان رسالة الخطأ",
      "default": "حدث خطأ"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "رسالة الخطأ",
      "default": "حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى."
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    },
    {
      "type": "checkbox",
      "id": "enable_floating_button",
      "label": "تفعيل الزر العائم",
      "default": false
    },
    {
      "type": "text",
      "id": "floating_button_text",
      "label": "نص الزر العائم",
      "default": "اطلب الآن"
    },
    {
      "type": "select",
      "id": "floating_icon",
      "label": "أيقونة الزر العائم",
      "options": [
        { "value": "shopping-cart", "label": "عربة تسوق" },
        { "value": "package", "label": "طرد" },
        { "value": "truck", "label": "شاحنة" },
        { "value": "send", "label": "إرسال" },
        { "value": "none", "label": "بدون أيقونة" }
      ],
      "default": "shopping-cart"
    },
    {
      "type": "checkbox",
      "id": "floating_show_icon",
      "label": "إظهار الأيقونة",
      "default": true
    },
    {
      "type": "select",
      "id": "floating_animation",
      "label": "تأثير حركي للزر العائم",
      "options": [
        { "value": "none", "label": "بدون" },
        { "value": "pulse", "label": "نبض" },
        { "value": "shake", "label": "اهتزاز" },
        { "value": "bounce", "label": "قفز" },
        { "value": "wiggle", "label": "تمايل" },
        { "value": "flash", "label": "وميض" }
      ],
      "default": "pulse"
    },
    {
      "type": "color",
      "id": "floating_bg_color",
      "label": "لون خلفية الزر العائم",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "floating_text_color",
      "label": "لون نص الزر العائم",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "floating_border_radius",
      "label": "انحناء حواف الزر العائم",
      "default": "4px"
    },
    {
      "type": "text",
      "id": "floating_padding_y",
      "label": "تباعد عمودي للزر العائم",
      "default": "10px"
    },
    {
      "type": "text",
      "id": "floating_font_size",
      "label": "حجم خط الزر العائم",
      "default": "16px"
    },
    {
      "type": "text",
      "id": "floating_font_weight",
      "label": "وزن خط الزر العائم",
      "default": "500"
    },
    {
      "type": "text",
      "id": "floating_margin_bottom",
      "label": "هامش سفلي للزر العائم",
      "default": "20px"
    },
    {
      "type": "text",
      "id": "floating_border_width",
      "label": "عرض حدود الزر العائم",
      "default": "0px"
    },
    {
      "type": "color",
      "id": "floating_border_color",
      "label": "لون حدود الزر العائم",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "is_rtl",
      "label": "اتجاه النص من اليمين لليسار",
      "default": true
    }
  ]
}
{% endschema %}

<div 
  id="codform-container-{{ block.id }}" 
  class="codform-container" 
  data-product-id="{{ product.id }}"
  data-block-id="{{ block.id }}"
  data-hide-header="true"
  data-enable-icons="true"
>
  <div id="codform-form-loader-{{ block.id }}" class="codform-loader" style="display: flex; justify-content: center; padding: 20px;">
    <div class="codform-spinner"></div>
    <div style="margin-top: 10px;">{{ block.settings.loading_text }}</div>
  </div>
  
  <div id="codform-form-{{ block.id }}" class="codform-form-container" style="display: none;"></div>
  
  <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-success-icon">✓</div>
    <h3>{{ block.settings.success_title }}</h3>
    <p>{{ block.settings.success_message }}</p>
  </div>
  
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-error-icon">!</div>
    <h3>{{ block.settings.error_title }}</h3>
    <p>{{ block.settings.error_message }}</p>
    <button id="codform-retry-{{ block.id }}" class="codform-button">{{ block.settings.retry_button }}</button>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('codform-container-{{ block.id }}');
    const loader = document.getElementById('codform-form-loader-{{ block.id }}');
    const formContainer = document.getElementById('codform-form-{{ block.id }}');
    const errorContainer = document.getElementById('codform-error-{{ block.id }}');
    const successContainer = document.getElementById('codform-success-{{ block.id }}');
    const retryButton = document.getElementById('codform-retry-{{ block.id }}');
    
    if (container && loader) {
      loader.style.display = 'flex';
      
      // إضافة معالج حدث إعادة المحاولة
      if (retryButton) {
        retryButton.addEventListener('click', function() {
          errorContainer.style.display = 'none';
          loader.style.display = 'flex';
          fetchForm();
        });
      }
      
      // بدء تحميل النموذج
      fetchForm();
    }
    
    // وظيفة لجلب النموذج بناءً على معرف المنتج
    function fetchForm() {
      const productId = container.getAttribute('data-product-id');
      const blockId = container.getAttribute('data-block-id');
      const shop = Shopify.shop || window.location.hostname;
      
      if (!productId || !shop) {
        showError("بيانات المنتج أو المتجر غير متوفرة");
        console.error('Missing product ID or shop information');
        return;
      }
      
      // طباعة معلومات التصحيح
      console.log('Fetching form with productId:', productId, 'blockId:', blockId, 'shop:', shop);
      
      // استخدام عنوان URL الكامل مع https
      const apiUrl = `https://mtyfuwdsshlzqwjujavp.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shop)}&productId=${encodeURIComponent(productId)}&blockId=${encodeURIComponent(blockId)}`;
      
      console.log('Request URL:', apiUrl);
      
      // جلب تكوين النموذج
      fetch(apiUrl)
        .then(response => {
          if (!response.ok) {
            console.error('HTTP error:', response.status, response.statusText);
            throw new Error(`HTTP error ${response.status}`);
          }
          return response.json();
        })
        .then(data => {
          if (data && data.form) {
            console.log('Form data received successfully:', data);
            renderForm(data.form, blockId);
          } else {
            console.error('No form data received:', data);
            showError("لا يوجد نموذج متوفر لهذا المنتج");
          }
        })
        .catch(error => {
          console.error('Error fetching form:', error);
          showError("حدث خطأ أثناء تحميل النموذج");
        });
    }
    
    // وظيفة لعرض النموذج
    function renderForm(formData, blockId) {
      if (!formContainer) {
        console.error('Form container not found');
        return;
      }
      
      // إخفاء التحميل
      if (loader) {
        loader.style.display = 'none';
      }
      
      // إنشاء HTML للنموذج
      const formHtml = createFormHtml(formData, blockId);
      
      // عرض النموذج
      formContainer.innerHTML = formHtml;
      formContainer.style.display = 'block';
      
      // إعداد معالجات الأحداث
      setupFormHandlers(formData, blockId);
    }
    
    // وظيفة لإظهار رسالة الخطأ
    function showError(message) {
      if (loader) loader.style.display = 'none';
      if (formContainer) formContainer.style.display = 'none';
      if (successContainer) successContainer.style.display = 'none';
      
      if (errorContainer) {
        const errorMessage = errorContainer.querySelector('p');
        if (errorMessage && message) {
          errorMessage.textContent = message;
        }
        errorContainer.style.display = 'block';
      }
    }
    
    // وظيفة لإنشاء HTML للنموذج
    function createFormHtml(formData, blockId) {
      // دائمًا تفعيل خاصية إخفاء العنوان
      const hideHeader = true;
      const enableIcons = container.getAttribute('data-enable-icons') === 'true';
      const isRTL = formData.settings?.direction === 'rtl' || {{ block.settings.is_rtl | json }};
      let html = '';
      
      // بداية النموذج مع تحديد خلفية
      html += `<form id="codform-form-element-${blockId}" class="codform-form" style="direction: ${isRTL ? 'rtl' : 'ltr'}; background-color: #F5F5F5;">`;
      
      // إضافة الحقول
      if (formData.fields && formData.fields.length) {
        formData.fields.forEach(field => {
          if (field && field.type) {
            if (field.type === 'form-title') {
              html += createTitleField(field);
              return;
            }
            
            if (field.type === 'text' || field.type === 'email' || field.type === 'phone') {
              html += createInputField(field, isRTL, enableIcons);
            } else if (field.type === 'textarea') {
              html += createTextareaField(field, isRTL, enableIcons);
            } else if (field.type === 'radio') {
              html += createRadioField(field);
            } else if (field.type === 'checkbox') {
              html += createCheckboxField(field);
            } else if (field.type === 'submit') {
              html += createSubmitButton(field, formData.settings);
            } else if (field.type === 'text/html') {
              html += createHtmlContent(field);
            } else if (field.type === 'whatsapp') {
              html += createWhatsAppButton(field);
            } else if (field.type === 'image') {
              html += createImageField(field);
            } else if (field.type === 'title') {
              html += createTitleField(field);
            }
          }
        });
      } else {
        console.error('No fields found in form data', formData);
        html += '<div style="padding: 15px; text-align: center; color: #e32;">لا توجد حقول في هذا النموذج</div>';
      }
      
      // نهاية النموذج
      html += '</form>';
      
      return html;
    }
    
    // وظيفة لإعداد معالجات الأحداث للنموذج
    function setupFormHandlers(formData, blockId) {
      const form = document.getElementById(`codform-form-element-${blockId}`);
      
      if (form) {
        form.addEventListener('submit', function(event) {
          event.preventDefault();
          
          // جمع بيانات النموذج
          const formData = new FormData(form);
          const formDataObj = {};
          formData.forEach((value, key) => {
            formDataObj[key] = value;
          });
          
          console.log('Form submitted with data:', formDataObj);
          
          // تمرير بيانات النموذج إلى API
          submitFormData(formDataObj, blockId);
        });
      }
    }
    
    // وظيفة لإرسال بيانات النموذج
    function submitFormData(data, blockId) {
      const shop = Shopify.shop || window.location.hostname;
      const productId = container.getAttribute('data-product-id');
      
      // عرض حالة التحميل
      formContainer.classList.add('codform-loading');
      
      // إضافة معلومات السياق
      data.shop = shop;
      data.product_id = productId;
      data.form_id = blockId;
      
      // إرسال البيانات إلى API
      const apiUrl = `https://mtyfuwdsshlzqwjujavp.supabase.co/functions/v1/submit-cod-form`;
      
      fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      })
      .then(response => {
        if (!response.ok) {
          throw new Error(`HTTP error ${response.status}`);
        }
        return response.json();
      })
      .then(result => {
        // إظهار رسالة النجاح
        formContainer.style.display = 'none';
        formContainer.classList.remove('codform-loading');
        successContainer.style.display = 'block';
      })
      .catch(error => {
        // إظهار رسالة الخطأ
        console.error('Error submitting form:', error);
        formContainer.classList.remove('codform-loading');
        showError("حدث خطأ أثناء إرسال النموذج، يرجى المحاولة مرة أخرى.");
      });
    }
    
    // وظيفة لإنشاء حقل إدخال
    function createInputField(field, isRTL, enableIcons) {
      const hasIcon = enableIcons && field.icon && field.icon !== 'none' && field.style?.showIcon !== false;
      const fieldClassContainer = `codform-field ${hasIcon ? 'codform-field-with-icon' : ''} ${isRTL ? 'rtl' : ''}`;
      let iconSvg = '';
      
      // الحصول على SVG للأيقونة إذا لزم الأمر
      if (hasIcon) {
        iconSvg = getIconSvg(field.icon);
      }
      
      const translatedLabel = field.label || '';
      const translatedPlaceholder = field.placeholder || '';
      
      return `
        <div class="${fieldClassContainer}">
          <label for="codform-field-${field.id}">
            ${translatedLabel}
            ${field.required ? '<span class="codform-required">*</span>' : ''}
          </label>
          <div class="codform-field-wrapper">
            ${hasIcon ? `<div class="codform-field-icon">${iconSvg}</div>` : ''}
            <input 
              type="${field.type === 'email' ? 'email' : field.type === 'phone' ? 'tel' : 'text'}"
              id="codform-field-${field.id}"
              name="${field.id}"
              placeholder="${translatedPlaceholder}"
              ${field.required ? 'required' : ''}
              class="codform-input ${hasIcon ? 'with-icon' : ''}"
            />
          </div>
          ${field.helpText ? `<div class="codform-help-text">${field.helpText}</div>` : ''}
        </div>
      `;
    }
    
    // وظيفة لإنشاء منطقة نص
    function createTextareaField(field, isRTL, enableIcons) {
      const hasIcon = enableIcons && field.icon && field.icon !== 'none' && field.style?.showIcon !== false;
      const fieldClassContainer = `codform-field ${hasIcon ? 'codform-field-with-icon' : ''} ${isRTL ? 'rtl' : ''}`;
      let iconSvg = '';
      
      // الحصول على SVG للأيقونة إذا لزم الأمر
      if (hasIcon) {
        iconSvg = getIconSvg(field.icon);
      }
      
      const translatedLabel = field.label || '';
      const translatedPlaceholder = field.placeholder || '';
      
      return `
        <div class="${fieldClassContainer}">
          <label for="codform-field-${field.id}">
            ${translatedLabel}
            ${field.required ? '<span class="codform-required">*</span>' : ''}
          </label>
          <div class="codform-field-wrapper">
            ${hasIcon ? `<div class="codform-field-icon">${iconSvg}</div>` : ''}
            <textarea
              id="codform-field-${field.id}"
              name="${field.id}"
              placeholder="${translatedPlaceholder}"
              ${field.required ? 'required' : ''}
              rows="${field.rows || 4}"
              class="codform-textarea ${hasIcon ? 'with-icon' : ''}"
            ></textarea>
          </div>
          ${field.helpText ? `<div class="codform-help-text">${field.helpText}</div>` : ''}
        </div>
      `;
    }
    
    // وظيفة لإنشاء مجموعة أزرار راديو
    function createRadioField(field) {
      const translatedLabel = field.label || '';
      
      let html = `
        <div class="codform-field">
          <label>
            ${translatedLabel}
            ${field.required ? '<span class="codform-required">*</span>' : ''}
          </label>
          <div class="codform-radio-group">
      `;
      
      if (field.options && field.options.length) {
        field.options.forEach((option, index) => {
          const translatedOptionLabel = option.label || '';
          
          html += `
            <div class="codform-radio-container">
              <input
                type="radio"
                id="codform-field-${field.id}-${index}"
                name="${field.id}"
                value="${option.value || ''}"
                ${field.required && index === 0 ? 'required' : ''}
                ${option.selected ? 'checked' : ''}
              />
              <label for="codform-field-${field.id}-${index}">${translatedOptionLabel}</label>
            </div>
          `;
        });
      }
      
      html += `
          </div>
          ${field.helpText ? `<div class="codform-help-text">${field.helpText}</div>` : ''}
        </div>
      `;
      
      return html;
    }
    
    // وظيفة لإنشاء مجموعة مربعات اختيار
    function createCheckboxField(field) {
      const translatedLabel = field.label || '';
      
      let html = `
        <div class="codform-field" style="margin-bottom: 16px;">
          <label>
            ${translatedLabel}
            ${field.required ? '<span class="codform-required">*</span>' : ''}
          </label>
          <div class="codform-checkbox-group">
      `;
      
      if (field.options && field.options.length) {
        field.options.forEach((option, index) => {
          const translatedOptionLabel = option.label || '';
          
          html += `
            <div class="codform-checkbox-container">
              <input
                type="checkbox"
                id="codform-field-${field.id}-${index}"
                name="${field.id}[]"
                value="${option.value || ''}"
                ${option.selected ? 'checked' : ''}
              />
              <label for="codform-field-${field.id}-${index}">${translatedOptionLabel}</label>
            </div>
          `;
        });
      }
      
      html += `
          </div>
          ${field.helpText ? `<div class="codform-help-text">${field.helpText}</div>` : ''}
        </div>
      `;
      
      return html;
    }
    
    // وظيفة لإنشاء زر إرسال
    function createSubmitButton(field, formSettings) {
      const buttonStyle = field.style || {};
      const backgroundColor = buttonStyle.backgroundColor || formSettings?.primaryColor || '#9b87f5';
      const borderRadius = buttonStyle.borderRadius || '8px';
      const fontSize = buttonStyle.fontSize || '18px';
      const fontWeight = buttonStyle.fontWeight || '600';
      const color = buttonStyle.color || '#ffffff';
      const padding = buttonStyle.paddingY ? `${buttonStyle.paddingY} 20px` : '14px 20px';
      const borderWidth = buttonStyle.borderWidth || '0px';
      const borderColor = buttonStyle.borderColor || backgroundColor;
      
      // فئة الرسوم المتحركة
      const animationType = buttonStyle.animation && buttonStyle.animationType ? buttonStyle.animationType : 'none';
      const animationClass = animationType !== 'none' ? `${animationType}-animation` : '';
      
      // معالجة الأيقونة
      const showIcon = buttonStyle.showIcon !== false && buttonStyle.icon;
      let iconHtml = '';
      
      if (showIcon) {
        const iconSvg = getIconSvg(buttonStyle.icon || 'shopping-cart');
        iconHtml = `<span class="codform-icon" style="display: inline-flex; align-items: center; margin-${buttonStyle.iconPosition === 'right' ? 'right' : 'left'}: 8px;">${iconSvg}</span>`;
      }
      
      const translatedLabel = field.label || 'إرسال الطلب';
      
      return `
        <div class="codform-field" style="margin-top: 16px;">
          <button
            type="submit"
            class="codform-submit-btn ${animationClass}"
            style="
              background-color: ${backgroundColor};
              border-radius: ${borderRadius};
              font-size: ${fontSize};
              font-weight: ${fontWeight};
              color: ${color};
              padding: ${padding};
              border: ${borderWidth} solid ${borderColor};
              display: flex;
              align-items: center;
              justify-content: center;
              gap: 8px;
              width: 100%;
              cursor: pointer;
              margin-top: 14px;
            "
          >
            ${buttonStyle.iconPosition !== 'right' ? iconHtml : ''}
            <span>${translatedLabel}</span>
            ${buttonStyle.iconPosition === 'right' ? iconHtml : ''}
          </button>
        </div>
      `;
    }
    
    // وظيفة لإنشاء حقل العنوان
    function createTitleField(field) {
      const style = field.style || {};
      const backgroundColor = style.backgroundColor || '#9b87f5';
      const color = style.color || '#ffffff';
      const descriptionColor = style.descriptionColor || 'rgba(255, 255, 255, 0.9)';
      const fontSize = style.fontSize || (field.type === 'form-title' ? '24px' : '20px');
      const descriptionFontSize = style.descriptionFontSize || '14px';
      const textAlign = style.textAlign || 'right';
      const fontWeight = style.fontWeight || (field.type === 'form-title' ? 'bold' : 'medium');
      const fontFamily = style.fontFamily || 'inherit';
      
      const translatedLabel = field.label || '';
      const translatedHelp = field.helpText || '';
      
      return `
        <div class="codform-title-field">
          <div class="codform-title-container" style="background-color: ${backgroundColor}; padding: 16px; border-radius: 8px; margin-bottom: 16px; text-align: ${textAlign};">
            <h3 class="codform-form-title" style="margin: 0; color: ${color}; font-size: ${fontSize}; font-weight: ${fontWeight}; font-family: ${fontFamily};">
              ${translatedLabel}
            </h3>
            ${translatedHelp ? `<p class="codform-title-description" style="margin: 6px 0 0 0; color: ${descriptionColor}; opacity: 0.9; font-size: ${descriptionFontSize};">${translatedHelp}</p>` : ''}
          </div>
        </div>
      `;
    }
    
    // وظيفة لإنشاء محتوى HTML
    function createHtmlContent(field) {
      return `
        <div class="codform-field codform-html-content">
          ${field.content || ''}
        </div>
      `;
    }
    
    // وظيفة لإنشاء زر واتساب
    function createWhatsAppButton(field) {
      const style = field.style || {};
      const backgroundColor = style.backgroundColor || '#25D366';
      const color = style.color || '#ffffff';
      const borderRadius = style.borderRadius || '8px';
      const phone = field.whatsappNumber || '';
      const message = encodeURIComponent(field.message || '');
      
      const translatedLabel = field.label || 'واتساب';
      
