
{{ 'codform.css' | asset_url | stylesheet_tag }}
{{ 'codform-quantity-offers.js' | asset_url | script_tag }}

{% assign form_id = block.settings.form_id %}
{% assign block_id = block.id %}

{% if form_id == blank %}
  <div class="codform-error" style="padding: 20px; background-color: #fee; border: 1px solid #fcc; border-radius: 8px; color: #c00; text-align: center; font-family: system-ui, -apple-system, sans-serif;">
    <p style="margin: 0; font-size: 16px; font-weight: 600;">⚠️ معرف النموذج مطلوب</p>
    <p style="margin: 8px 0 0 0; font-size: 14px; opacity: 0.8;">يرجى إدخال معرف النموذج في إعدادات الكتلة</p>
  </div>
{% else %}
  <div 
    id="codform-container-{{ block_id }}" 
    class="codform-container"
    data-form-id="{{ form_id }}"
    data-block-id="{{ block_id }}"
    {% if product %}
      data-product-id="{{ product.id }}"
      data-product-title="{{ product.title | escape }}"
      data-product-price="{{ product.price | money_without_currency | remove: ',' }}"
      data-product-currency="{{ shop.currency }}"
      {% if product.featured_image %}
        data-product-image="{{ product.featured_image | img_url: '300x300' }}"
      {% endif %}
    {% endif %}
    data-shop="{{ shop.domain }}"
    style="width: 100%; margin: 20px 0; position: relative;"
  >
    
    <!-- Pre-created containers for quantity offers -->
    <div 
      id="quantity-offers-before-{{ block_id }}" 
      class="quantity-offers-container quantity-offers-before"
      style="display: none; width: 100%; margin: 15px 0;"
    ></div>
    
    <!-- Form wrapper -->
    <div class="codform-form-wrapper" style="width: 100%; position: relative;">
      
      <!-- Inside form offers container -->
      <div 
        id="quantity-offers-inside-{{ block_id }}" 
        class="quantity-offers-container quantity-offers-inside"
        style="display: none; width: 100%; margin: 15px 0;"
      ></div>
      
      <!-- Main form container -->
      <div 
        id="codform-form-{{ block_id }}" 
        class="codform-form"
        style="width: 100%; min-height: 200px; position: relative;"
      >
        <!-- Form will be loaded here by JavaScript -->
        <div class="codform-loading" style="
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 40px;
          color: #666;
          font-family: system-ui, -apple-system, sans-serif;
          font-size: 16px;
        ">
          <span style="margin-right: 10px;">جاري تحميل النموذج...</span>
          <div style="
            width: 20px;
            height: 20px;
            border: 2px solid #ddd;
            border-top: 2px solid #666;
            border-radius: 50%;
            animation: spin 1s linear infinite;
          "></div>
        </div>
      </div>
      
    </div>
    
    <!-- After form offers container -->
    <div 
      id="quantity-offers-after-{{ block_id }}" 
      class="quantity-offers-container quantity-offers-after"
      style="display: none; width: 100%; margin: 15px 0;"
    ></div>
    
  </div>

  <!-- Initialize form loading -->
  <script>
    (function() {
      const container = document.getElementById('codform-form-{{ block_id }}');
      const formData = {
        formId: '{{ form_id }}',
        blockId: '{{ block_id }}',
        {% if product %}
          productId: '{{ product.id }}',
          productData: {
            id: '{{ product.id }}',
            title: {{ product.title | json }},
            price: {{ product.price | money_without_currency | remove: ',' }},
            currency: '{{ shop.currency }}',
            {% if product.featured_image %}
              image: '{{ product.featured_image | img_url: "300x300" }}'
            {% endif %}
          },
        {% endif %}
        shop: '{{ shop.domain }}'
      };
      
      // Load the form
      if (window.CodformLoader) {
        window.CodformLoader.load(container, formData);
      } else {
        // Fallback: wait for loader to be available
        const checkLoader = setInterval(() => {
          if (window.CodformLoader) {
            clearInterval(checkLoader);
            window.CodformLoader.load(container, formData);
          }
        }, 100);
      }
      
      // Load quantity offers if product is available
      {% if product %}
        if (window.CodformQuantityOffers) {
          window.CodformQuantityOffers.load('{{ block_id }}', '{{ product.id }}', '{{ shop.domain }}');
        }
      {% endif %}
    })();
  </script>

  <!-- CSS for loading animation -->
  <style>
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    
    .quantity-offers-container {
      transition: all 0.3s ease;
    }
    
    .quantity-offer-item:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(0,0,0,0.15) !important;
    }
    
    .codform-form {
      transition: all 0.3s ease;
    }
    
    .codform-loading {
      transition: opacity 0.3s ease;
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "COD Form",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "info": "Enter the form ID from your CODFORM dashboard"
    },
    {
      "type": "select",
      "id": "offer_position",
      "label": "Quantity Offers Position",
      "options": [
        {
          "value": "inside_form",
          "label": "Inside Form"
        },
        {
          "value": "before_form",
          "label": "Before Form"
        },
        {
          "value": "after_form",
          "label": "After Form"
        }
      ],
      "default": "inside_form"
    }
  ]
}
{% endschema %}
