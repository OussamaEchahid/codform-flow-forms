{% schema %}
{
  "name": "Codform Form",
  "target": "section",
  "settings": [
    {
      "id": "product_id",
      "type": "text",
      "label": "Product ID",
      "info": "Enter the product ID to load the form."
    }
  ]
}
{% endschema %}

<!-- ============= STYLES & FONTS ============= -->
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  /* Arabic Text Styling */
  .codform-arabic-text,
  .codform-arabic-text *,
  [dir="rtl"],
  [dir="rtl"] *,
  .codform-field-wrapper[dir="rtl"],
  .codform-field-wrapper[dir="rtl"] * {
    font-family: 'Cairo', 'Noto Sans Arabic', 'Amiri', sans-serif !important;
  }
  
  [dir="rtl"] input,
  [dir="rtl"] textarea,
  [dir="rtl"] label,
  [dir="rtl"] button {
    font-family: 'Cairo', 'Noto Sans Arabic', 'Amiri', sans-serif !important;
    font-feature-settings: "liga" 1, "kern" 1;
    text-rendering: optimizeLegibility;
  }
  
  /* Submit Button Animations */
  @keyframes pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 0, 0, 0.3); }
    50% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(0, 0, 0, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 0, 0, 0); }
  }
  
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 90% { transform: translateX(-2px); }
    20%, 80% { transform: translateX(4px); }
    30%, 50%, 70% { transform: translateX(-6px); }
    40%, 60% { transform: translateX(6px); }
  }
  
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
  }
  
  @keyframes wiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-5deg); }
    50% { transform: rotate(0deg); }
    75% { transform: rotate(5deg); }
  }
  
  @keyframes flash {
    0%, 50%, 100% { opacity: 1; }
    25%, 75% { opacity: 0.5; }
  }
  
  .pulse-animation { animation: pulse 2s infinite !important; }
  .bounce-animation { animation: bounce 2s infinite !important; }
  .shake-animation { animation: shake 0.8s infinite !important; }
  .wiggle-animation { animation: wiggle 2s ease-in-out infinite !important; }
  .flash-animation { animation: flash 2s infinite !important; }
</style>

<!-- ============= FORM CONTAINER ============= -->
<div data-form-preview-id="form-preview-stable">
  <!-- Form content will be loaded here -->
</div>

<!-- ============= MAIN SCRIPT ============= -->
<script>
(function() {
  'use strict';
  
  console.log('🚀 CODFORM: Form initialization started');
  
  // ============= CONSTANTS ============= 
  const API_BASE_URL = 'https://lovable-forms-api.netlify.app/.netlify/functions/api-forms';
  const DEFAULT_PRODUCT_ID = 'default';

  // ============= UTILITY FUNCTIONS =============
  function getProductId() {
    try {
      const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || '{{ block.settings.product_id }}' || 'auto-detect';
      console.log('🔍 معرف المنتج المكتشف:', productId);
      return productId.trim();
    } catch (error) {
      console.error('❌ CODFORM: Error getting product ID:', error);
      return 'auto-detect';
    }
  }

  window.getShopDomain = function() {
    try {
      const shopDomain = '{{ shop.domain }}' || '{{ shop.permanent_domain }}' || 'auto-detect';
      console.log('🏪 CODFORM: Using shop domain:', shopDomain);
      return shopDomain;
    } catch (error) {
      console.error('❌ CODFORM: Error getting shop domain:', error);
      return 'auto-detect';
    }
  }

  function getStyleValue(style, property, fallback) {
    if (!style || typeof style !== 'object') return fallback;
    return style[property] || fallback;
  }

  // ============= FIELD RENDERING FUNCTIONS =============
  function renderField(field, formStyle, formLanguage) {
    if (!field || !field.type) return '';
    
    console.log('🎨 Rendering field:', field.type, field.id);
    
    // Form Direction Detection
    let formDirection = 'ltr';
    if (formStyle && formStyle.formDirection) {
      formDirection = formStyle.formDirection;
    } else if (formLanguage === 'ar') {
      formDirection = 'rtl';
    } else if (field.label && /[\u0600-\u06FF]/.test(field.label)) {
      formDirection = 'rtl';
    }
    
    // Base Styling Variables
    const baseFontSize = getStyleValue(formStyle, 'baseFontSize', '16px');
    const labelStyle = field.style || {};
    const showLabel = getStyleValue(labelStyle, 'showLabel', true);
    const isFloatingLabels = getStyleValue(formStyle, 'floatingLabels', false);
    
    let html = '';
    
    // Form Title Field
    if (field.type === 'form-title') {
      html = renderFormTitle(field, formStyle);
    }
    // Text Input Fields
    else if (['text', 'email', 'phone'].includes(field.type)) {
      html = renderTextInput(field, formStyle, formDirection, baseFontSize, isFloatingLabels);
    }
    // Textarea Field
    else if (field.type === 'textarea') {
      html = renderTextarea(field, formStyle, formDirection, baseFontSize, isFloatingLabels);
    }
    // Submit Button - FIXED
    else if (field.type === 'submit' || field.type === 'submit-button') {
      html = renderSubmitButton(field, formStyle, formDirection);
    }
    // Radio Group
    else if (field.type === 'radio-group') {
      html = renderRadioGroup(field, formStyle, formDirection, baseFontSize);
    }
    // Checkbox Group
    else if (field.type === 'checkbox-group') {
      html = renderCheckboxGroup(field, formStyle, formDirection, baseFontSize);
    }
    // HTML Content
    else if (field.type === 'html-content') {
      html = renderHtmlContent(field, formStyle);
    }
    // Image Field
    else if (field.type === 'image') {
      html = renderImageField(field, formStyle);
    }
    
    return html;
  }

  // ============= SPECIFIC FIELD RENDERERS =============
  function renderFormTitle(field, formStyle) {
    const title = field.label || 'Form Title';
    const titleColor = getStyleValue(field.style, 'color', '#000000');
    const titleFontSize = getStyleValue(field.style, 'fontSize', '24px');
    const titleFontWeight = getStyleValue(field.style, 'fontWeight', 'bold');
    const paddingTop = getStyleValue(field.style, 'paddingTop', '0px');
    const paddingBottom = getStyleValue(field.style, 'paddingBottom', '0px');
    const paddingLeft = getStyleValue(field.style, 'paddingLeft', '0px');
    const paddingRight = getStyleValue(field.style, 'paddingRight', '0px');
    
    return `
      <div class="form-title-field w-full" style="
        color: ${titleColor};
        font-size: ${titleFontSize};
        font-weight: ${titleFontWeight};
        font-family: Cairo, Tajawal, Arial, sans-serif;
        text-align: center;
        margin: 0px;
        line-height: 1.4;
        direction: ${formStyle.formDirection || 'ltr'};
        padding: ${paddingTop} ${paddingRight} ${paddingBottom} ${paddingLeft};
        width: 100%;
        display: block;
        background: none;
        border: none;
      ">
        ${title}
      </div>
    `;
  }

  function renderTextInput(field, formStyle, formDirection, baseFontSize, isFloatingLabels) {
    const label = field.label || 'Text Field';
    const placeholder = field.placeholder || '';
    const required = field.required || false;
    const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
    
    let inputType = 'text';
    if (field.type === 'email') inputType = 'email';
    if (field.type === 'phone') inputType = 'tel';
    
    const fieldStyle = field.style || {};
    const actualLabelColor = getStyleValue(fieldStyle, 'labelColor', '#333333');
    const actualLabelFontSize = getStyleValue(fieldStyle, 'labelFontSize', baseFontSize);
    const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
    const actualTextColor = getStyleValue(fieldStyle, 'color', 'rgb(31, 41, 55)');
    const actualBorderColor = getStyleValue(fieldStyle, 'borderColor', getStyleValue(formStyle, 'fieldBorderColor', 'rgb(209, 213, 219)'));
    const actualBorderWidth = getStyleValue(fieldStyle, 'borderWidth', getStyleValue(formStyle, 'fieldBorderWidth', '1px'));
    const actualFontSize = getStyleValue(fieldStyle, 'fontSize', baseFontSize);
    const actualBorderRadius = getStyleValue(fieldStyle, 'borderRadius', getStyleValue(formStyle, 'fieldBorderRadius', '8px'));
    const focusBorderColor = getStyleValue(formStyle, 'focusBorderColor', '#3b82f6');
    
    // Icon handling
    const hasIcon = field.icon && field.icon !== 'none' && field.icon !== '';
    const showIcon = getStyleValue(fieldStyle, 'showIcon', hasIcon) && getStyleValue(fieldStyle, 'showIconInPreview', hasIcon);
    
    let iconHtml = '';
    if (showIcon && hasIcon) {
      const iconPosition = formDirection === 'rtl' ? 'right' : 'left';
      const iconColor = getStyleValue(fieldStyle, 'iconColor', '#9b87f5');
      const iconSvg = getIconSvg(field.icon, iconColor);
      iconHtml = `
        <div style="
          position: absolute;
          ${iconPosition}: 12px;
          top: 50%;
          transform: translateY(-50%);
          color: ${iconColor};
          pointer-events: none;
          z-index: 2;
          display: flex;
          align-items: center;
          justify-content: center;
        ">
          ${iconSvg}
        </div>
      `;
    }
    
    const paddingLeft = formDirection === 'rtl' ? '12px' : (showIcon && hasIcon ? '40px' : '12px');
    const paddingRight = formDirection === 'rtl' ? (showIcon && hasIcon ? '40px' : '12px') : '12px';
    
    return `
      <div class="codform-field-wrapper" style="margin-bottom: 16px; direction: ${formDirection};">
        ${actualShowLabel && !isFloatingLabels ? `
          <label for="${fieldId}" style="
            display: block;
            color: ${actualLabelColor};
            font-size: ${actualLabelFontSize};
            font-weight: 600;
            margin-bottom: 8px;
            font-family: 'Cairo', sans-serif;
          ">
            ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
          </label>
        ` : ''}
        
        <div style="position: relative;">
          ${iconHtml}
          ${isFloatingLabels && actualShowLabel ? `
            <label for="${fieldId}" style="
              position: absolute;
              left: ${formDirection === 'rtl' ? 'auto' : (showIcon && hasIcon ? '40px' : '12px')};
              right: ${formDirection === 'rtl' ? (showIcon && hasIcon ? '40px' : '12px') : 'auto'};
              top: 50%;
              transform: translateY(-50%);
              color: #9CA3AF;
              font-size: ${actualLabelFontSize};
              font-family: 'Cairo', sans-serif;
              pointer-events: none;
              transition: all 0.2s ease;
              background: white;
              padding: 0 4px;
              z-index: 10;
            " class="floating-label">
              ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
            </label>
          ` : ''}
          <input
            type="${inputType}"
            id="${fieldId}"
            name="${fieldId}"
            placeholder="${isFloatingLabels ? '' : placeholder}"
            ${required ? 'required' : ''}
            style="
              width: 100%;
              background-color: #FFFFFF;
              border: ${actualBorderWidth} solid ${actualBorderColor};
              border-radius: ${actualBorderRadius};
              padding: 10px ${paddingRight} 10px ${paddingLeft};
              font-size: ${actualFontSize};
              color: ${actualTextColor};
              outline: none;
              transition: all 0.2s ease;
              box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
              min-height: 44px;
              box-sizing: border-box;
              direction: ${formDirection};
              text-align: ${formDirection === 'rtl' ? 'right' : 'left'};
            "
            onfocus="this.style.borderColor='${focusBorderColor}'; this.style.boxShadow='0 0 0 3px ${focusBorderColor}20'"
            onblur="this.style.borderColor='${actualBorderColor}'; this.style.boxShadow='rgba(0, 0, 0, 0.05) 0px 1px 2px'"
          />
        </div>
        
        ${field.helpText ? `
          <p style="
            margin-top: 6px;
            font-size: 14px;
            color: #6B7280;
            font-family: 'Cairo', inherit;
          ">${field.helpText}</p>
        ` : ''}
      </div>
    `;
  }

  function renderTextarea(field, formStyle, formDirection, baseFontSize, isFloatingLabels) {
    const label = field.label || 'Text Area';
    const placeholder = field.placeholder || '';
    const required = field.required || false;
    const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
    
    const fieldStyle = field.style || {};
    const actualLabelColor = getStyleValue(fieldStyle, 'labelColor', 'rgb(51, 65, 85)');
    const actualLabelFontSize = getStyleValue(fieldStyle, 'labelFontSize', baseFontSize);
    const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
    const actualTextColor = getStyleValue(fieldStyle, 'color', 'rgb(31, 41, 55)');
    const actualBorderColor = getStyleValue(fieldStyle, 'borderColor', getStyleValue(formStyle, 'fieldBorderColor', 'rgb(209, 213, 219)'));
    const actualBorderWidth = getStyleValue(fieldStyle, 'borderWidth', getStyleValue(formStyle, 'fieldBorderWidth', '1px'));
    const actualFontSize = getStyleValue(fieldStyle, 'fontSize', baseFontSize);
    const actualBorderRadius = getStyleValue(fieldStyle, 'borderRadius', getStyleValue(formStyle, 'fieldBorderRadius', '8px'));
    const focusBorderColor = getStyleValue(formStyle, 'focusBorderColor', '#3b82f6');
    const rows = getStyleValue(field, 'rows', 4);
    
    return `
      <div class="codform-field-wrapper" style="margin-bottom: 16px; direction: ${formDirection};">
        ${actualShowLabel && !isFloatingLabels ? `
          <label for="${fieldId}" style="
            display: block;
            color: ${actualLabelColor};
            font-size: ${actualLabelFontSize};
            font-weight: 600;
            margin-bottom: 8px;
            font-family: 'Cairo', sans-serif;
          ">
            ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
          </label>
        ` : ''}
        
        <div style="position: relative;">
          ${isFloatingLabels && actualShowLabel ? `
            <label for="${fieldId}" style="
              position: absolute;
              left: ${formDirection === 'rtl' ? 'auto' : '12px'};
              right: ${formDirection === 'rtl' ? '12px' : 'auto'};
              top: 20px;
              color: #9CA3AF;
              font-size: ${actualLabelFontSize};
              font-family: 'Cairo', sans-serif;
              pointer-events: none;
              transition: all 0.2s ease;
              background: white;
              padding: 0 4px;
              z-index: 10;
            " class="floating-label">
              ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
            </label>
          ` : ''}
          <textarea
            id="${fieldId}"
            name="${fieldId}"
            rows="${rows}"
            placeholder="${isFloatingLabels ? '' : placeholder}"
            ${required ? 'required' : ''}
            style="
              width: 100%;
              background-color: #FFFFFF;
              border: ${actualBorderWidth} solid ${actualBorderColor};
              border-radius: ${actualBorderRadius};
              padding: 12px;
              font-size: ${actualFontSize};
              color: ${actualTextColor};
              outline: none;
              transition: all 0.2s ease;
              box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
              box-sizing: border-box;
              direction: ${formDirection};
              text-align: ${formDirection === 'rtl' ? 'right' : 'left'};
              resize: vertical;
            "
            onfocus="this.style.borderColor='${focusBorderColor}'; this.style.boxShadow='0 0 0 3px ${focusBorderColor}20'"
            onblur="this.style.borderColor='${actualBorderColor}'; this.style.boxShadow='rgba(0, 0, 0, 0.05) 0px 1px 2px'"
          ></textarea>
        </div>
        
        ${field.helpText ? `
          <p style="
            margin-top: 6px;
            font-size: 14px;
            color: #6B7280;
            font-family: 'Cairo', inherit;
          ">${field.helpText}</p>
        ` : ''}
      </div>
    `;
  }

  function renderSubmitButton(field, formStyle, formDirection) {
    const label = field.label || 'Submit';
    const fieldStyle = field.style || {};
    
    const backgroundColor = getStyleValue(fieldStyle, 'backgroundColor', '#6366f1');
    const textColor = getStyleValue(fieldStyle, 'color', '#FFFFFF');
    const fontSize = getStyleValue(fieldStyle, 'fontSize', '16px');
    const borderRadius = getStyleValue(fieldStyle, 'borderRadius', '8px');
    const padding = getStyleValue(fieldStyle, 'padding', '12px 24px');
    const buttonAnimation = getStyleValue(fieldStyle, 'animation', 'none');
    
    let animationClass = '';
    if (buttonAnimation && buttonAnimation !== 'none') {
      animationClass = buttonAnimation + '-animation';
    }
    
    return `
      <div style="margin-bottom: 16px; text-align: center; direction: ${formDirection};">
        <button 
          type="submit" 
          class="codform-submit-btn ${animationClass}"
          style="
            background-color: ${backgroundColor};
            color: ${textColor};
            font-size: ${fontSize};
            font-weight: 600;
            padding: ${padding};
            border: none;
            border-radius: ${borderRadius};
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Cairo', sans-serif;
            min-width: 120px;
          "
          onmouseover="this.style.opacity='0.9'"
          onmouseout="this.style.opacity='1'"
        >
          ${label}
        </button>
      </div>
    `;
  }

  function renderRadioGroup(field, formStyle, formDirection, baseFontSize) {
    const label = field.label || 'Radio Group';
    const required = field.required || false;
    const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
    const options = field.options || [];
    
    const fieldStyle = field.style || {};
    const actualLabelColor = getStyleValue(fieldStyle, 'labelColor', '#333333');
    const actualLabelFontSize = getStyleValue(fieldStyle, 'labelFontSize', baseFontSize);
    const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
    
    let optionsHtml = '';
    options.forEach((option, index) => {
      const optionId = `${fieldId}-${index}`;
      optionsHtml += `
        <div style="margin-bottom: 8px;">
          <label for="${optionId}" style="
            display: flex;
            align-items: center;
            cursor: pointer;
            font-family: 'Cairo', sans-serif;
            direction: ${formDirection};
          ">
            <input 
              type="radio" 
              id="${optionId}" 
              name="${fieldId}" 
              value="${option.value || option.label}" 
              ${required ? 'required' : ''}
              style="margin-${formDirection === 'rtl' ? 'left' : 'right'}: 8px;"
            />
            ${option.label}
          </label>
        </div>
      `;
    });
    
    return `
      <div class="codform-field-wrapper" style="margin-bottom: 16px; direction: ${formDirection};">
        ${actualShowLabel ? `
          <label style="
            display: block;
            color: ${actualLabelColor};
            font-size: ${actualLabelFontSize};
            font-weight: 600;
            margin-bottom: 12px;
            font-family: 'Cairo', sans-serif;
          ">
            ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
          </label>
        ` : ''}
        
        <div style="padding-left: ${formDirection === 'rtl' ? '0' : '8px'}; padding-right: ${formDirection === 'rtl' ? '8px' : '0'};">
          ${optionsHtml}
        </div>
      </div>
    `;
  }

  function renderCheckboxGroup(field, formStyle, formDirection, baseFontSize) {
    const label = field.label || 'Checkbox Group';
    const required = field.required || false;
    const fieldId = field.id || 'field-' + Math.random().toString(36).substr(2, 9);
    const options = field.options || [];
    
    const fieldStyle = field.style || {};
    const actualLabelColor = getStyleValue(fieldStyle, 'labelColor', '#333333');
    const actualLabelFontSize = getStyleValue(fieldStyle, 'labelFontSize', baseFontSize);
    const actualShowLabel = fieldStyle.showLabel !== undefined ? fieldStyle.showLabel : true;
    
    let optionsHtml = '';
    options.forEach((option, index) => {
      const optionId = `${fieldId}-${index}`;
      optionsHtml += `
        <div style="margin-bottom: 8px;">
          <label for="${optionId}" style="
            display: flex;
            align-items: center;
            cursor: pointer;
            font-family: 'Cairo', sans-serif;
            direction: ${formDirection};
          ">
            <input 
              type="checkbox" 
              id="${optionId}" 
              name="${fieldId}[]" 
              value="${option.value || option.label}"
              style="margin-${formDirection === 'rtl' ? 'left' : 'right'}: 8px;"
            />
            ${option.label}
          </label>
        </div>
      `;
    });
    
    return `
      <div class="codform-field-wrapper" style="margin-bottom: 16px; direction: ${formDirection};">
        ${actualShowLabel ? `
          <label style="
            display: block;
            color: ${actualLabelColor};
            font-size: ${actualLabelFontSize};
            font-weight: 600;
            margin-bottom: 12px;
            font-family: 'Cairo', sans-serif;
          ">
            ${label}${required ? '<span style="color: #EF4444; margin-left: 4px;">*</span>' : ''}
          </label>
        ` : ''}
        
        <div style="padding-left: ${formDirection === 'rtl' ? '0' : '8px'}; padding-right: ${formDirection === 'rtl' ? '8px' : '0'};">
          ${optionsHtml}
        </div>
      </div>
    `;
  }

  function renderHtmlContent(field, formStyle) {
    const content = field.content || field.html || '';
    return `
      <div style="margin-bottom: 16px; direction: ${formStyle.formDirection || 'ltr'};">
        ${content}
      </div>
    `;
  }

  function renderImageField(field, formStyle) {
    const imageUrl = field.url || field.src || '';
    const altText = field.alt || 'Image';
    const width = field.width || '100%';
    const height = field.height || 'auto';
    
    if (!imageUrl) return '';
    
    return `
      <div style="margin-bottom: 16px; text-align: center; direction: ${formStyle.formDirection || 'ltr'};">
        <img 
          src="${imageUrl}" 
          alt="${altText}"
          style="
            width: ${width};
            height: ${height};
            max-width: 100%;
            border-radius: 8px;
            box-shadow: rgba(0, 0, 0, 0.1) 0px 2px 4px;
          "
        />
      </div>
    `;
  }

  // ============= ICON GENERATION =============
  function getIconSvg(iconName, color) {
    const icons = {
      'user': `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`,
      'mail': `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>`,
      'phone': `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`,
      'message-circle': `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`
    };
    return icons[iconName] || icons['user'];
  }

  // ============= FORM LOADING FUNCTIONS =============
  function loadCompleteForm() {
    console.log('🎯 CODFORM: Starting complete form load');
    
    const productId = getProductId();
    const shopDomain = getShopDomain();
    
    console.log('📦 CODFORM: Loading form for product:', productId, 'shop:', shopDomain);
    
    if (!productId || productId === 'auto-detect' || !shopDomain || shopDomain === 'auto-detect') {
      console.log('⚠️ CODFORM: Missing product ID or shop domain, hiding form');
      const container = document.querySelector('[data-form-preview-id="form-preview-stable"]');
      if (container) {
        container.style.display = 'none';
      }
      return;
    }
    
    loadFormWithValidation(productId, shopDomain);
  }
  
  function loadFormWithValidation(productId, shopDomain) {
    console.log('🔄 CODFORM: Loading validated form for product:', productId, 'shop:', shopDomain);
    
    // Get current product data from Shopify
    const currentProduct = {
      id: productId,
      price: parseFloat('{{ product.price | divided_by: 100.0 }}') || 0,
      comparePrice: parseFloat('{{ product.compare_at_price | divided_by: 100.0 }}') || 0,
      title: '{{ product.title }}' || 'منتج',
      image: '{{ product.featured_image | img_url: '400x400' }}' || '',
      currency: '{{ shop.currency }}' || 'SAR',
      variants: [
        {% for variant in product.variants %}
        {
          id: {{ variant.id }},
          price: {{ variant.price | divided_by: 100.0 }},
          comparePrice: {{ variant.compare_at_price | divided_by: 100.0 | default: 0 }},
          title: "{{ variant.title }}",
          available: {{ variant.available }}
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    };
    
    console.log('🛍️ CODFORM: معلومات المنتج:', currentProduct);
    
    // API URLs for form loading
    const apiUrls = [
      `https://trlklwixfeaexhydzaue.supabase.co/functions/v1/forms-product?shop=${shopDomain}&product=${productId}&blockId=ASFhDTFBYRlN3VDNFK__codform_cod_forms_codform_form_xM8Ec7`,
      `https://lovable-forms-api.netlify.app/.netlify/functions/api-forms?productId=${productId}`
    ];
    
    async function tryFetchForm() {
      for (let url of apiUrls) {
        try {
          console.log('🔄 CODFORM: Trying API:', url);
          const response = await fetch(url);
          if (response.ok) {
            const data = await response.json();
            console.log('✅ CODFORM: Success with:', url);
            return data;
          }
        } catch (error) {
          console.log('❌ CODFORM: Failed with:', url, error);
        }
      }
      throw new Error('All API endpoints failed');
    }
    
    tryFetchForm()
      .then(data => {
        console.log('✅ CODFORM: Form data received:', data);
        
        const container = document.querySelector('[data-form-preview-id="form-preview-stable"]');
        if (!container) {
          console.log('❌ CODFORM: Form container not found');
          return;
        }

        // Avoid reloading if form is already loaded
        if (container.dataset.formLoaded === 'true') {
          console.log('📝 CODFORM: Form already loaded, skipping reload');
          return;
        }

        // Apply form styling
        const formStyle = data.style || {};
        applyFormStyling(container, formStyle);

        // Generate form content
        const fieldsArray = parseFormFields(data);
        const formLanguage = detectFormLanguage(data, fieldsArray);
        
        // Apply Arabic styling if needed
        if (formLanguage === 'ar') {
          applyArabicStyling(container);
        }
        
        // Render form
        renderFormContent(container, fieldsArray, formStyle, formLanguage, productId);
        
        // Mark as loaded
        container.dataset.formLoaded = 'true';
        window.currentFormData = data;

        console.log('🎉 CODFORM: Form rendered successfully');
      })
      .catch(error => {
        console.error('❌ CODFORM: Error loading form:', error);
      });
  }

  // ============= HELPER FUNCTIONS =============
  function applyFormStyling(container, formStyle) {
    const formBackgroundColor = formStyle.backgroundColor || '#F9FAFB';
    const formBorderColor = formStyle.borderColor || '#9b87f5';
    const formBorderWidth = formStyle.borderWidth || '2px';
    const formBorderRadius = formStyle.borderRadius || '1.2rem';
    const formPaddingTop = formStyle.paddingTop || '20px';
    const formPaddingBottom = formStyle.paddingBottom || '20px';
    const formPaddingLeft = formStyle.paddingLeft || '20px';
    const formPaddingRight = formStyle.paddingRight || '20px';
    const formDirection = formStyle.formDirection || 'ltr';
    
    container.style.cssText = `
      background-color: ${formBackgroundColor};
      border: ${formBorderWidth} solid ${formBorderColor};
      border-radius: ${formBorderRadius};
      padding: ${formPaddingTop} ${formPaddingRight} ${formPaddingBottom} ${formPaddingLeft};
      box-shadow: rgba(0, 0, 0, 0.05) 0px 4px 6px;
      max-width: 500px;
      margin: 20px auto;
      font-family: inherit;
      direction: ${formDirection};
      box-sizing: border-box;
      position: relative;
      overflow: hidden;
    `;
  }

  function parseFormFields(data) {
    let fieldsArray = [];
    
    if (data.fields && Array.isArray(data.fields)) {
      fieldsArray = data.fields;
    } else if (data.form && data.form.fields && Array.isArray(data.form.fields)) {
      fieldsArray = data.form.fields;
    } else if (data.form && data.form.data && Array.isArray(data.form.data)) {
      fieldsArray = data.form.data.flatMap(step => step.fields || []);
    } else if (data.data && Array.isArray(data.data)) {
      fieldsArray = data.data.flatMap(step => step.fields || []);
    } else if (data.form && Array.isArray(data.form)) {
      fieldsArray = data.form;
    }
    
    console.log('🎯 CODFORM: Final fieldsArray:', fieldsArray, 'Length:', fieldsArray.length);
    return fieldsArray;
  }

  function detectFormLanguage(data, fieldsArray) {
    let formLanguage = 'en';
    
    if (data.form?.language === 'ar' || data.language === 'ar') {
      formLanguage = 'ar';
    } else if (data.form?.title && /[\u0600-\u06FF]/.test(data.form.title)) {
      formLanguage = 'ar';
    } else if (fieldsArray && fieldsArray.some(field => 
      field.label && /[\u0600-\u06FF]/.test(field.label)
    )) {
      formLanguage = 'ar';
    }
    
    console.log('🌐 CODFORM: Detected form language:', formLanguage);
    return formLanguage;
  }

  function applyArabicStyling(container) {
    const arabicStyle = document.createElement('style');
    arabicStyle.innerHTML = `
      .codform-arabic-form,
      .codform-arabic-form *,
      .codform-arabic-form input,
      .codform-arabic-form textarea,
      .codform-arabic-form label,
      .codform-arabic-form button {
        font-family: 'Cairo', 'Noto Sans Arabic', 'Amiri', sans-serif !important;
        font-feature-settings: "liga" 1, "kern" 1 !important;
        text-rendering: optimizeLegibility !important;
      }
    `;
    document.head.appendChild(arabicStyle);
    container.classList.add('codform-arabic-form');
  }

  function renderFormContent(container, fieldsArray, formStyle, formLanguage, productId) {
    let formContent = '';
    const blockId = `ASFhDTFBYRlN3VDNFK__codform_cod_forms_codform_form_${productId}`;
    
    // Container for quantity offers
    let completeFormHTML = `<div id="quantity-offers-before-${blockId}" style="display: none;"></div>`;
    
    if (fieldsArray && Array.isArray(fieldsArray)) {
      fieldsArray.forEach((field, index) => {
        console.log(`🎨 CODFORM: Processing field ${index}:`, field);
        formContent += renderField(field, formStyle, formLanguage);
      });
    }

    // Wrap in form element
    completeFormHTML += `
      <form class="codform-form-fields" style="background: transparent; margin: 0; padding: 0;" 
            id="codform-main-form" onsubmit="handleFormSubmission(event)">
        ${formContent}
      </form>
    `;

    container.innerHTML = `
      <div class="codform-dynamic-form">
        ${completeFormHTML}
      </div>
    `;
  }

  // ============= FORM SUBMISSION =============
  window.handleFormSubmission = async function(event) {
    event.preventDefault();
    
    console.log('🚀 CODFORM: Form submission started');
    
    const form = event.target;
    const formData = new FormData(form);
    const submissionData = {};
    
    // Convert FormData to object
    for (let [key, value] of formData.entries()) {
      submissionData[key] = value;
    }
    
    // Get data from all inputs
    const allInputs = form.querySelectorAll('input, textarea, select');
    allInputs.forEach(input => {
      if (input.name || input.id) {
        const fieldKey = input.name || input.id;
        if (input.type === 'checkbox') {
          submissionData[fieldKey] = input.checked;
        } else if (input.type === 'radio') {
          if (input.checked) {
            submissionData[fieldKey] = input.value;
          }
        } else {
          submissionData[fieldKey] = input.value;
        }
      }
    });
    
    console.log('📝 CODFORM: Collected form data:', submissionData);
    
    try {
      const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || DEFAULT_PRODUCT_ID;
      const shopDomain = getShopDomain();
      
      console.log('🏪 CODFORM: Submitting to shop:', shopDomain, 'product:', productId);
      
      const response = await fetch('https://trlklwixfeaexhydzaue.supabase.co/functions/v1/api-submissions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          formId: productId,
          shopDomain: shopDomain,
          productId: productId,
          data: submissionData
        })
      });
      
      const result = await response.json();
      
      if (result.success) {
        console.log('✅ CODFORM: Submission successful');
        
        // Show success message
        const submitBtn = form.querySelector('.codform-submit-btn');
        if (submitBtn) {
          const originalText = submitBtn.innerHTML;
          submitBtn.innerHTML = '✅ تم الإرسال بنجاح';
          submitBtn.style.backgroundColor = '#22c55e';
          
          setTimeout(() => {
            submitBtn.innerHTML = originalText;
            submitBtn.style.backgroundColor = '';
          }, 3000);
        }
        
        if (result.thankYouUrl) {
          setTimeout(() => {
            window.location.href = result.thankYouUrl;
          }, 1500);
        }
        
      } else {
        console.error('❌ CODFORM: Submission failed:', result.error);
        alert('خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى.');
      }
      
    } catch (error) {
      console.error('❌ CODFORM: Submission error:', error);
      alert('خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى.');
    }
  };

  // ============= INITIALIZATION =============
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(loadCompleteForm, 500);
    });
  } else {
    setTimeout(loadCompleteForm, 500);
  }
  
  window.addEventListener('load', () => {
    setTimeout(loadCompleteForm, 1000);
  });

})();

// ============= FLOATING LABELS =============
document.addEventListener('DOMContentLoaded', function() {
  const inputs = document.querySelectorAll('.codform-dynamic-form input, .codform-dynamic-form textarea');
  
  inputs.forEach(input => {
    const wrapper = input.closest('.codform-field-wrapper');
    const label = wrapper?.querySelector('.floating-label');
    
    if (label) {
      const updateLabel = () => {
        const isTextarea = input.tagName.toLowerCase() === 'textarea';
        if (input.value || input === document.activeElement) {
          label.style.top = isTextarea ? '8px' : '0px';
          label.style.fontSize = '12px';
          label.style.color = '#6366f1';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        } else {
          label.style.top = isTextarea ? '20px' : '50%';
          label.style.fontSize = input.style.fontSize || '16px';
          label.style.color = '#9CA3AF';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        }
      };
      
      input.addEventListener('focus', updateLabel);
      input.addEventListener('blur', updateLabel);
      input.addEventListener('input', updateLabel);
      updateLabel();
    }
  });
});
</script>

<!-- ============= QUANTITY OFFERS INTEGRATION ============= -->
<script src="{{ 'codform-quantity-offers.js' | asset_url }}" defer></script>
<script>
function generateBlockId(productId) {
  return `ASFhDTFBYRlN3VDNFK__codform_cod_forms_codform_form_${productId}`;
}

document.addEventListener('DOMContentLoaded', function() {
  const waitForFormLoad = setInterval(function() {
    const formContainer = document.querySelector('.codform-dynamic-form');
    if (formContainer && !formContainer.dataset.quantityOffersLoaded) {
      const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || 'default';
      const shopDomain = getShopDomain();
      const blockId = generateBlockId(productId);
      
      console.log("🎯 Loading quantity offers after form is ready:", { productId, shopDomain, blockId });
      
      if (window.CodformQuantityOffers) {
        const formCurrency = window.currentFormData?.formStyle?.currency || 'SAR';
        console.log("💰 Using form currency for quantity offers:", formCurrency);
        
        const productData = {
          id: productId,
          price: parseFloat('{{ product.price | divided_by: 100.0 }}') || 0,
          comparePrice: parseFloat('{{ product.compare_at_price | divided_by: 100.0 }}') || 0,
          title: '{{ product.title }}' || 'منتج',
          image: '{{ product.featured_image | img_url: '400x400' }}' || '',
          currency: '{{ shop.currency }}' || 'SAR'
        };
        
        window.CodformQuantityOffers.init({
          blockId: blockId,
          shopDomain: shopDomain,
          productData: productData,
          formCurrency: formCurrency
        });
        
        formContainer.dataset.quantityOffersLoaded = 'true';
        clearInterval(waitForFormLoad);
      }
    }
  }, 500);
  
  setTimeout(() => clearInterval(waitForFormLoad), 10000);
});
</script>