  // RADICAL FIX: Main script with enhanced error handling
  document.addEventListener('DOMContentLoaded', function() {
    console.log("🚀 RADICAL FIX - Codform block script started for block: {{ block.id }}");
    
    const container = document.getElementById('codform-container-' + blockId);
    const loader = document.getElementById('codform-form-loader-' + blockId);
    const formContainer = document.getElementById('codform-form-' + blockId);
    const errorContainer = document.getElementById('codform-error-' + blockId);
    const successContainer = document.getElementById('codform-success-' + blockId);
    const retryButton = document.getElementById('codform-retry-' + blockId);
    
    if (!container) {
      console.error("❌ Container not found for block:", blockId);
      return;
    }
    
    function showLoading() {
      if (loader) loader.style.display = 'flex';
      if (formContainer) formContainer.style.display = 'none';
      if (errorContainer) errorContainer.style.display = 'none';
      if (successContainer) successContainer.style.display = 'none';
    }
    
    function hideLoading() {
      if (loader) loader.style.display = 'none';
    }
    
    function hideError() {
      if (errorContainer) errorContainer.style.display = 'none';
    }
    
    function showErrorMessage(message) {
      hideLoading();
      if (formContainer) formContainer.style.display = 'none';
      if (successContainer) successContainer.style.display = 'none';
      
      if (errorContainer) {
        const errorMessage = errorContainer.querySelector('p');
        if (errorMessage && message) {
          errorMessage.textContent = message;
        }
        errorContainer.style.display = 'block';
      }
      
      console.error("❌ Error shown to user:", message);
    }
    
    showLoading();
    
    if (retryButton) {
      retryButton.addEventListener('click', function() {
        console.log("🔄 Retry button clicked");
        hideError();
        showLoading();
        setTimeout(fetchAndRenderForm, 100);
      });
    }
    
    
    setTimeout(() => {
      fetchAndRenderForm();
      // تحميل العروض الكمية مع الحل الشامل
      setTimeout(() => {
        if (window.CodformComprehensiveFix) {
          window.CodformComprehensiveFix.loadData(blockId);
        }
      }, 1000);
    }, 500);
    
    function fetchAndRenderForm() {
      const productId = container.getAttribute('data-product-id');
      const shop = (typeof Shopify !== 'undefined' && Shopify.shop) ? Shopify.shop : window.location.hostname;
      
      if (!productId || !shop) {
        showErrorMessage("بيانات المنتج أو المتجر غير متوفرة");
        console.error("❌ Missing product ID or shop information", { productId, shop });
        return;
      }
      
      console.log("📡 RADICAL FIX - Fetching form data...", { productId, shop, blockId });
      
      const apiUrl = `https://trlklwixfeaexhydzaue.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shop)}&product=${encodeURIComponent(productId)}&blockId=${encodeURIComponent(blockId)}`;
      
      const fetchOptions = {
        method: 'GET',
        mode: 'cors',
        cache: 'no-cache',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        }
      };
      
      let fetchAttempts = 0;
      const maxAttempts = 3;
      
      function attemptFetch() {
        fetchAttempts++;
        console.log(`📡 Fetch attempt ${fetchAttempts}/${maxAttempts}`);
        
        fetch(apiUrl, fetchOptions)
          .then(response => {
            console.log(`📨 Response received (attempt ${fetchAttempts}):`, response.status, response.statusText);
            if (!response.ok) {
              throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }
            return response.json();
          })
          .then(data => {
            console.log("📋 RADICAL FIX - Form data received:", data);
            
            if (data && data.form) {
              // عرض Quantity Offers إذا كانت موجودة
              if (data.quantity_offers) {
                console.log("🎁 Found quantity offers:", data.quantity_offers);
                renderQuantityOffers([data.quantity_offers]);
              }
              
              // تحويل البيانات من التنسيق الجديد إلى التنسيق المتوقع
              let formData = data.form;
              console.log("🔄 Processing API response. Original form data:", JSON.stringify(formData, null, 2));
              
              // إذا كانت البيانات بالتنسيق الجديد (fields مباشرة)
              if (formData.fields && !formData.data) {
                console.log("🔄 Converting API response from new format to expected format");
                formData = {
                  ...formData,
                  data: [{
                    id: "1",
                    title: "Main Step", 
                    fields: formData.fields
                  }]
                };
                // حذف الـ fields القديمة لتجنب التضارب
                delete formData.fields;
                console.log("✅ Converted API response to expected format:", JSON.stringify(formData, null, 2));
              }
              
              renderFormData(formData);
            } else if (data && data.success === false) {
              showErrorMessage(data.message || "لا يوجد نموذج متوفر لهذا المنتج");
            } else {
              showErrorMessage("استجابة غير صحيحة من الخادم");
            }
          })
          .catch(error => {
            console.error(`❌ Error in fetch attempt ${fetchAttempts}:`, error);
            
            if (fetchAttempts < maxAttempts) {
              console.log(`🔄 Retrying in ${fetchAttempts * 1000}ms...`);
              setTimeout(attemptFetch, fetchAttempts * 1000);
            } else {
              showErrorMessage("حدث خطأ أثناء تحميل النموذج: " + error.message);
            }
          });
      }
      
      attemptFetch();
    }
    
    // دالة تحميل وعرض العروض الكمية
    function fetchAndRenderQuantityOffers() {
      const productId = container.getAttribute('data-product-id');
      const shop = (typeof Shopify !== 'undefined' && Shopify.shop) ? Shopify.shop : window.location.hostname;
      
      if (!productId || !shop) {
        console.log("⚠️ Missing product ID or shop for quantity offers");
        return;
      }
      
      console.log("🎯 Fetching quantity offers...", { productId, shop });
      
      const apiUrl = `https://trlklwixfeaexhydzaue.supabase.co/functions/v1/api-forms/${blockId}?productId=${encodeURIComponent(productId)}&shop=${encodeURIComponent(shop)}`;
      
      fetch(apiUrl, {
        method: 'GET',
        mode: 'cors',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        }
      })
      .then(response => {
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        return response.json();
      })
      .then(data => {
        console.log("📦 Quantity offers data received:", data);
        
        if (data && data.quantityOffers && data.quantityOffers.length > 0) {
          renderQuantityOffers(data.quantityOffers);
        } else {
          console.log("📦 No quantity offers found for this product");
        }
      })
      .catch(error => {
        console.error("❌ Error fetching quantity offers:", error);
      });
    }
    
    // دالة عرض العروض الكمية
    function renderQuantityOffers(offers) {
      const beforeContainer = document.getElementById('quantity-offers-before-' + blockId);
      if (!beforeContainer || offers.length === 0) return;
      
      console.log("🎨 Rendering quantity offers:", offers);
      
      offers.forEach(offer => {
        if (offer.position === 'before_form' && offer.enabled && offer.offers.length > 0) {
          const offersContainer = document.createElement('div');
          offersContainer.className = 'quantity-offers-list';
          offersContainer.style.cssText = `
            margin-bottom: 20px;
            border-radius: 12px;
            padding: 16px;
            background: #f8f9fa;
            border: 1px solid #e9ecef;
          `;
          
          offer.offers.forEach((singleOffer, index) => {
            const offerElement = createQuantityOfferElement(singleOffer, offer.styling, index);
            offersContainer.appendChild(offerElement);
          });
          
          beforeContainer.appendChild(offersContainer);
          beforeContainer.style.display = 'block';
        }
      });
    }
    
    // دالة إنشاء عنصر عرض كمي واحد
    function createQuantityOfferElement(offer, styling, index) {
      const isHighlighted = index === 1; // تمييز العرض الثاني
      const basePrice = 100; // يجب الحصول على سعر المنتج الفعلي
      
      let totalPrice = basePrice * offer.quantity;
      if (offer.discountType === 'fixed' && offer.discountValue) {
        totalPrice = (basePrice * offer.quantity) - offer.discountValue;
      } else if (offer.discountType === 'percentage' && offer.discountValue) {
        totalPrice = (basePrice * offer.quantity) * (1 - offer.discountValue / 100);
      }
      
      const originalPrice = basePrice * offer.quantity;
      const isDiscounted = offer.discountType !== 'none' && offer.discountValue > 0;
      
      const offerDiv = document.createElement('div');
      offerDiv.className = 'quantity-offer-item';
      offerDiv.style.cssText = `
        padding: 12px;
        margin-bottom: 8px;
        border-radius: 8px;
        border: 2px solid ${isHighlighted ? '#22c55e' : '#e5e7eb'};
        background: ${isHighlighted ? '#f0f9ff' : '#ffffff'};
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        transition: all 0.2s ease;
      `;
      
      // الجانب الأيسر - المعلومات
      const leftSide = document.createElement('div');
      leftSide.style.cssText = 'display: flex; align-items: center; gap: 12px;';
      
      // أيقونة
      const icon = document.createElement('div');
      icon.style.cssText = `
        width: 40px;
        height: 40px;
        background: #f3f4f6;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
      `;
      icon.textContent = '📦';
      
      // النص والعلامة
      const textContainer = document.createElement('div');
      
      const offerText = document.createElement('div');
      offerText.style.cssText = `
        font-weight: 600;
        color: ${styling?.textColor || '#000000'};
        margin-bottom: 4px;
      `;
      offerText.textContent = offer.text || `اشتري ${offer.quantity} قطعة`;
      
      if (offer.tag) {
        const tag = document.createElement('span');
        tag.style.cssText = `
          background: ${styling?.tagColor || '#22c55e'};
          color: white;
          padding: 2px 8px;
          border-radius: 4px;
          font-size: 12px;
          font-weight: 500;
        `;
        tag.textContent = offer.tag;
        textContainer.appendChild(tag);
      }
      
      textContainer.insertBefore(offerText, textContainer.firstChild);
      leftSide.appendChild(icon);
      leftSide.appendChild(textContainer);
      
      // الجانب الأيمن - السعر
      const rightSide = document.createElement('div');
      rightSide.style.cssText = 'text-align: right;';
      
      if (isDiscounted) {
        const originalPriceElement = document.createElement('div');
        originalPriceElement.style.cssText = `
          text-decoration: line-through;
          color: #9ca3af;
          font-size: 14px;
        `;
        originalPriceElement.textContent = `$${originalPrice.toFixed(2)}`;
        rightSide.appendChild(originalPriceElement);
      }
      
      const finalPriceElement = document.createElement('div');
      finalPriceElement.style.cssText = `
        font-weight: bold;
        font-size: 18px;
        color: ${styling?.priceColor || '#ef4444'};
      `;
      finalPriceElement.textContent = `$${totalPrice.toFixed(2)}`;
      rightSide.appendChild(finalPriceElement);
      
      offerDiv.appendChild(leftSide);
      offerDiv.appendChild(rightSide);
      
      // إضافة hover effect
      offerDiv.addEventListener('mouseenter', function() {
        this.style.boxShadow = '0 4px 12px rgba(0,0,0,0.1)';
        this.style.transform = 'translateY(-2px)';
      });
      
      offerDiv.addEventListener('mouseleave', function() {
        this.style.boxShadow = 'none';
        this.style.transform = 'translateY(0)';
      });
      
      return offerDiv;
    }
    
    function renderFormData(formData) {
      console.log("🎨 RADICAL FIX - Starting form render...");
      hideLoading();
      
      try {
        const containerId = 'codform-form-' + blockId;
        console.log("🔧 Calling renderCodform with:", { formData, containerId });
        
        const success = renderCodform(formData, containerId);
        
        if (success) {
          if (formContainer) {
            formContainer.style.display = 'block';
          }
          console.log("✅ RADICAL FIX - Form rendered successfully");
        } else {
        console.log("❌ Form rendering failed. Detailed analysis:");
        console.log("- Form data provided:", JSON.stringify(formData, null, 2));
        console.log("- Container ID:", containerId);
        console.log("- Container exists:", !!document.getElementById(containerId));
        
        showErrorMessage("فشل في عرض النموذج - يرجى المحاولة مرة أخرى");
        }
        
      } catch (error) {
        console.error("❌ CRITICAL ERROR in renderFormData:", error);
        showErrorMessage("حدث خطأ أثناء عرض النموذج: " + error.message);
      }
    }
    
    // RADICAL FIX: Global error handler for unhandled errors
    window.addEventListener('error', function(event) {
      console.error('❌ Global error caught:', event.error);
    });
    
    window.addEventListener('unhandledrejection', function(event) {
      console.error('❌ Unhandled promise rejection:', event.reason);
    });
  });

  // RADICAL FIX: Enhanced postMessage handling
  if (typeof window !== 'undefined' && window.parent !== window) {
    try {
      window.addEventListener('message', function(event) {
        console.log('📨 Message received from parent:', event);
      });
    } catch (error) {
      console.warn('⚠️ Could not set up message listener:', error);
    }
  }

})();
</script>

