            <span class="codform-whatsapp-icon" style="
              display: inline-flex;
              align-items: center;
              justify-content: center;
              width: 18px;
              height: 18px;
            ">${whatsappIcon}</span>
            <span>${translatedLabel}</span>
          </a>
        </div>
      `;
    }
    
    // وظيفة لإنشاء حقل صورة
    function createImageField(field) {
      const style = field.style || {};
      const imageUrl = field.imageUrl || '';
      const altText = field.altText || field.label || 'صورة';
      const maxWidth = style.maxWidth || '100%';
      const borderRadius = style.borderRadius || '8px';
      
      return `
        <div class="codform-field codform-image-field">
          <div class="codform-image-container" style="max-width: ${maxWidth}; border-radius: ${borderRadius};">
            <img 
              src="${imageUrl}" 
              alt="${altText}" 
              class="codform-image" 
              style="border-radius: ${borderRadius}; width: 100%; height: auto;"
            />
          </div>
          ${field.label ? `<div class="codform-image-caption">${field.label}</div>` : ''}
        </div>
      `;
    }
    
