              display: flex;
              align-items: center;
              justify-content: center;
              gap: 10px;
              padding: 14px 20px;
              text-decoration: none;
              font-weight: 600;
              margin-top: 14px;
              margin-bottom: 8px;
              width: 100%;
              text-align: center;
            "
