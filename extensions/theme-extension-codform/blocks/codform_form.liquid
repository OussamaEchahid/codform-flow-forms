  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.codform-success-icon, .codform-error-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto 15px;
  border-radius: 50%;
  color: white;
  font-size: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.codform-success-icon {
  background-color: #34c759;
}

.codform-error-icon {
  background-color: #ff3b30;
}

/* التأثيرات المتحركة - مطابقة للمعاينة */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-10px); }
  60% { transform: translateY(-5px); }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 90% { transform: translateX(-2px); }
  20%, 80% { transform: translateX(4px); }
  30%, 50%, 70% { transform: translateX(-6px); }
  40%, 60% { transform: translateX(6px); }
}

@keyframes wiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-5deg); }
  50% { transform: rotate(0deg); }
  75% { transform: rotate(5deg); }
}

@keyframes flash {
  0%, 50%, 100% { opacity: 1; }
  25%, 75% { opacity: 0.5; }
}

.pulse-animation {
  animation: pulse 2s infinite ease-in-out !important;
}

.shake-animation {
  animation: shake 0.8s infinite ease-in-out !important;
}

.bounce-animation {
  animation: bounce 2s infinite ease-in-out !important;
}

.wiggle-animation {
  animation: wiggle 2s infinite ease-in-out !important;
}

.flash-animation {
  animation: flash 2s infinite ease-in-out !important;
}

.codform-clean-form {
  animation: fadeIn 0.5s ease-out;
}
</style>

