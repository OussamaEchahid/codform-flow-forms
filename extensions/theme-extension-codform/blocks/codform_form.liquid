{% comment %}
  @name: CODFORM Form Block
  @description: Display a cash on delivery form for products
  @supports: product
  @by: OurTeam
{% endcomment %}

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان نجاح الإرسال",
      "default": "تم إرسال الطلب بنجاح"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "رسالة نجاح الإرسال",
      "default": "شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام."
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان رسالة الخطأ",
      "default": "حدث خطأ"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "رسالة الخطأ",
      "default": "حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى."
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    },
    {
      "type": "checkbox",
      "id": "is_rtl",
      "label": "اتجاه النص من اليمين لليسار",
      "default": true
    }
  ]
}
{% endschema %}

<!-- تحميل ملف CSS -->
{{ 'codform.css' | asset_url | stylesheet_tag }}

<div 
  id="codform-container-{{ block.id }}" 
  class="codform-container" 
  data-product-id="{{ product.id }}"
  data-block-id="{{ block.id }}"
>
  <div id="codform-form-loader-{{ block.id }}" class="codform-loader" style="display: flex; justify-content: center; align-items: center; flex-direction: column; padding: 20px;">
    <div class="codform-spinner"></div>
    <div style="margin-top: 10px;">{{ block.settings.loading_text }}</div>
  </div>
  
  <div id="codform-form-{{ block.id }}" class="codform-form-container" style="display: none;"></div>
  
  <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-success-icon">✓</div>
    <h3>{{ block.settings.success_title }}</h3>
    <p>{{ block.settings.success_message }}</p>
  </div>
  
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-error-icon">!</div>
    <h3>{{ block.settings.error_title }}</h3>
    <p>{{ block.settings.error_message }}</p>
    <button id="codform-retry-{{ block.id }}" class="codform-button">{{ block.settings.retry_button }}</button>
  </div>
</div>

<script>
// دالة عرض النموذج بدون أي خلفيات أو حدود إضافية - تطابق المعاينة تماماً
function renderCodform(formData, containerId) {
  console.log("🎯 Rendering form to match preview exactly", { formData, containerId });
  
  try {
    const container = document.getElementById(containerId);
    if (!container) {
      console.error("❌ Container not found:", containerId);
      return false;
    }
    
    if (!formData || !formData.data) {
      console.error("❌ Invalid form data:", formData);
      container.innerHTML = '<div style="padding: 20px; text-align: center; color: #666;">خطأ في تحميل النموذج - البيانات غير صحيحة</div>';
      return false;
    }
    
    console.log("✅ Form data is valid, rendering clean form");
    container.innerHTML = "";
    
    const style = formData.style || {};
    const primaryColor = style.primaryColor || "#9b87f5";
    const borderRadius = style.borderRadius || "8px";
    const fontSize = style.fontSize || "16px";
    const formDirection = style.formDirection || "ltr";
    
    // تطبيق التنسيق للحاوية بدون أي خلفيات أو حدود إضافية
    container.style.cssText = `
      border-radius: ${borderRadius};
      font-size: ${fontSize};
      direction: ${formDirection};
      padding: 0;
      margin: 0;
      font-family: 'Cairo', system-ui, Arial, sans-serif;
      max-width: 100%;
      box-sizing: border-box;
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
    `;
    
    let allFields = [];
    if (Array.isArray(formData.data)) {
      formData.data.forEach(step => {
        if (step && step.fields && Array.isArray(step.fields)) {
          allFields = allFields.concat(step.fields);
        }
      });
    }
    
    console.log(`📝 Processing ${allFields.length} fields for clean rendering`);
    
    if (allFields.length === 0) {
      container.innerHTML = '<div style="padding: 20px; text-align: center; color: #666;">لا توجد حقول في النموذج</div>';
      return false;
    }
    
    const form = document.createElement("form");
    form.style.cssText = `
      width: 100%; 
      display: flex; 
      flex-direction: column; 
      gap: 12px; 
      background: transparent !important;
      padding: 0;
      margin: 0;
      border: none !important;
      box-shadow: none !important;
    `;
    form.classList.add('codform-clean-form');
    
    allFields.forEach((field, index) => {
      if (!field || !field.type) {
        console.warn("⚠️ Invalid field at index", index, field);
        return;
      }
      
      console.log(`🔧 Rendering clean field ${index + 1}: ${field.type}`);
      
      const fieldElement = createCleanFieldElement(field, formDirection, primaryColor);
      if (fieldElement) {
        form.appendChild(fieldElement);
      }
    });
    
    container.appendChild(form);
    
    // تطبيق التحسينات والتأثيرات
    applyCleanEffects(container);
    
    console.log("✅ Clean form rendered successfully - matches preview");
    return true;
    
  } catch (error) {
    console.error("❌ Error in renderCodform:", error);
    const container = document.getElementById(containerId);
    if (container) {
      container.innerHTML = '<div style="padding: 20px; text-align: center; color: #ff0000;">حدث خطأ في عرض النموذج: ' + error.message + '</div>';
    }
    return false;
  }
}

// دالة إنشاء عناصر الحقول بدون أي خلفيات إضافية - تطابق المعاينة
function createCleanFieldElement(field, direction, primaryColor) {
  switch (field.type) {
    case "form-title":
      return createCleanFormTitle(field, direction);
      
    case "text":
    case "email":
    case "phone":
      return createCleanTextInput(field, direction, primaryColor);
      
    case "textarea":
      return createCleanTextarea(field, direction, primaryColor);
      
    case "submit":
      return createCleanSubmitButton(field, primaryColor);
      
    case "text/html":
      return createCleanHtmlContent(field);
      
    default:
      console.warn("⚠️ Unknown field type:", field.type);
      const genericDiv = document.createElement("div");
      genericDiv.textContent = field.label || `حقل من نوع ${field.type}`;
      genericDiv.style.cssText = `
        padding: 0; 
        margin: 0; 
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
      `;
      return genericDiv;
  }
}

// دالة إنشاء عنوان النموذج بدون أي خلفية - نص خالص
function createCleanFormTitle(field, direction) {
  const titleText = field.content || field.label || "";
  if (!titleText) return null;
  
  const titleElement = document.createElement("div");
  titleElement.classList.add('codform-clean-title');
  
  const fieldStyle = field.style || {};
  const textColor = fieldStyle.color || "#000000";
  const fontSize = fieldStyle.fontSize || "1.5rem";
  const fontWeight = fieldStyle.fontWeight || "700";
  const textAlign = fieldStyle.textAlign || "center";
  
  titleElement.style.cssText = `
    color: ${textColor};
    font-size: ${fontSize};
    font-weight: ${fontWeight};
    text-align: ${textAlign};
    margin: 0 0 12px 0;
    line-height: 1.4;
    direction: ${direction};
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    width: 100%;
    display: block;
    font-family: 'Cairo', system-ui, Arial, sans-serif;
    box-shadow: none !important;
  `;
  
  titleElement.textContent = titleText;
  return titleElement;
}

// دالة إنشاء حقل إدخال نص بدون خلفية إضافية للحاوية
function createCleanTextInput(field, direction, primaryColor) {
  const wrapper = document.createElement("div");
  wrapper.classList.add('codform-clean-field');
  wrapper.style.cssText = `
    margin-bottom: 12px;
    width: 100%;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
    box-shadow: none !important;
  `;
  
  // إضافة تسمية الحقل
  if (field.label) {
    const label = document.createElement("label");
    label.textContent = field.label;
    if (field.required) {
      label.innerHTML += '<span style="color: #ef4444; margin-left: 4px;">*</span>';
    }
    label.style.cssText = `
      display: block;
      margin-bottom: 6px;
      font-weight: 600;
      color: #374151;
      font-size: 16px;
      font-family: 'Cairo', system-ui, Arial, sans-serif;
      background: transparent !important;
      padding: 0;
      border: none;
      box-shadow: none;
    `;
    wrapper.appendChild(label);
  }
  
  // حاوية الإدخال مع الأيقونة
  const inputContainer = document.createElement("div");
  inputContainer.classList.add('codform-clean-input-wrapper');
  inputContainer.style.cssText = `
    position: relative; 
    display: block; 
    background: transparent !important;
    padding: 0;
    margin: 0;
    border: none;
    box-shadow: none;
  `;
  
  // إضافة الأيقونة
  if (field.icon && field.style?.showIcon !== false) {
    const iconElement = document.createElement("div");
    iconElement.classList.add('codform-clean-icon');
    iconElement.style.cssText = `
      position: absolute;
      ${direction === 'rtl' ? 'right: 12px; left: auto;' : 'left: 12px; right: auto;'}
      top: 50%;
      transform: translateY(-50%);
      color: #9ca3af;
      width: 18px;
      height: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      z-index: 2;
      background: transparent !important;
    `;
    
    // رسم الأيقونة بـ SVG
    iconElement.innerHTML = getIconSVG(field.icon);
    inputContainer.appendChild(iconElement);
  }
  
  const input = document.createElement("input");
  
  if (field.type === "email") {
    input.type = "email";
  } else if (field.type === "phone") {
    input.type = "tel";
  } else {
    input.type = "text";
  }
  
  input.placeholder = field.placeholder || field.label || "";
  input.required = field.required || false;
  
  const hasIcon = field.icon && field.style?.showIcon !== false;
  
  input.style.cssText = `
    width: 100%;
    padding: 12px;
    ${direction === 'rtl' 
      ? `padding-right: ${hasIcon ? '40px' : '12px'}; padding-left: 12px;`
      : `padding-left: ${hasIcon ? '40px' : '12px'}; padding-right: 12px;`
    }
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 16px;
    transition: all 0.2s ease-in-out;
    font-family: 'Cairo', system-ui, Arial, sans-serif;
    background-color: #ffffff;
    color: #1f2937;
    box-sizing: border-box;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    direction: ${direction};
    outline: none;
  `;
  
  // تحسين تأثيرات التركيز
  input.addEventListener('focus', function() {
    this.style.borderColor = primaryColor;
    this.style.boxShadow = `0 0 0 3px rgba(155, 135, 245, 0.2)`;
  });
  
  input.addEventListener('blur', function() {
    this.style.borderColor = '#d1d5db';
    this.style.boxShadow = '0 1px 2px rgba(0, 0, 0, 0.05)';
  });
  
  inputContainer.appendChild(input);
  wrapper.appendChild(inputContainer);
  
  // إضافة نص المساعدة
  if (field.helpText) {
    const helpText = document.createElement("p");
    helpText.textContent = field.helpText;
    helpText.style.cssText = `
      font-size: 14px;
      color: #6b7280;
      margin-top: 4px;
      margin-bottom: 0;
      background: transparent !important;
      padding: 0;
      border: none;
      box-shadow: none;
    `;
    wrapper.appendChild(helpText);
  }
  
  return wrapper;
}

// دالة إنشاء منطقة نص بدون خلفية إضافية
function createCleanTextarea(field, direction, primaryColor) {
  const wrapper = document.createElement("div");
  wrapper.classList.add('codform-clean-field');
  wrapper.style.cssText = `
    margin-bottom: 12px;
    width: 100%;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
    box-shadow: none !important;
  `;
  
  // إضافة تسمية الحقل
  if (field.label) {
    const label = document.createElement("label");
    label.textContent = field.label;
    if (field.required) {
      label.innerHTML += '<span style="color: #ef4444; margin-left: 4px;">*</span>';
    }
    label.style.cssText = `
      display: block;
      margin-bottom: 6px;
      font-weight: 600;
      color: #374151;
      font-size: 16px;
      font-family: 'Cairo', system-ui, Arial, sans-serif;
      background: transparent !important;
      padding: 0;
      border: none;
      box-shadow: none;
    `;
    wrapper.appendChild(label);
  }
  
  const textarea = document.createElement("textarea");
  textarea.placeholder = field.placeholder || field.label || "";
  textarea.required = field.required || false;
  textarea.rows = 4;
  
  textarea.style.cssText = `
    width: 100%;
    padding: 12px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 16px;
    font-family: 'Cairo', system-ui, Arial, sans-serif;
    direction: ${direction};
    resize: vertical;
    box-sizing: border-box;
    transition: all 0.2s ease-in-out;
    background-color: #ffffff;
    color: #1f2937;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    outline: none;
  `;
  
  // تحسين تأثيرات التركيز
  textarea.addEventListener('focus', function() {
    this.style.borderColor = primaryColor;
    this.style.boxShadow = `0 0 0 3px rgba(155, 135, 245, 0.2)`;
  });
  
  textarea.addEventListener('blur', function() {
    this.style.borderColor = '#d1d5db';
    this.style.boxShadow = '0 1px 2px rgba(0, 0, 0, 0.05)';
  });
  
  wrapper.appendChild(textarea);
  return wrapper;
}

// دالة إنشاء زر الإرسال مع التأثيرات المطلوبة
function createCleanSubmitButton(field, primaryColor) {
  const wrapper = document.createElement("div");
  wrapper.style.cssText = `
    margin-top: 16px; 
    width: 100%; 
    background: transparent !important;
    padding: 0;
    border: none;
    box-shadow: none;
  `;
  
  const button = document.createElement("button");
  button.type = "submit";
  button.textContent = field.label || "إرسال";
  button.classList.add('codform-clean-submit');
  
  const buttonBg = field.style?.backgroundColor || primaryColor;
  const buttonColor = field.style?.color || "#ffffff";
  const animation = field.style?.animation;
  const animationType = field.style?.animationType || 'pulse';
  
  button.style.cssText = `
    background-color: ${buttonBg};
    color: ${buttonColor};
    border: none;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
    transition: all 0.3s ease;
    box-sizing: border-box;
    font-family: 'Cairo', system-ui, Arial, sans-serif;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    outline: none;
  `;
  
  // إضافة التأثيرات المتحركة
  if (animation && animationType) {
    applyButtonAnimation(button, animationType);
  }
  
  // تحسين تأثيرات التفاعل
  button.addEventListener('mouseenter', function() {
    this.style.opacity = '0.9';
    this.style.transform = 'translateY(-2px)';
    this.style.boxShadow = '0 6px 12px rgba(0, 0, 0, 0.15)';
  });
  
  button.addEventListener('mouseleave', function() {
    this.style.opacity = '1';
    this.style.transform = 'translateY(0)';
    this.style.boxShadow = '0 4px 6px rgba(0, 0, 0, 0.1)';
  });
  
  wrapper.appendChild(button);
  return wrapper;
}

// دالة إنشاء محتوى HTML
function createCleanHtmlContent(field) {
  const wrapper = document.createElement("div");
  wrapper.style.cssText = `
    margin-bottom: 12px; 
    width: 100%; 
    background: transparent !important;
    padding: 0;
    border: none;
    box-shadow: none;
  `;
  wrapper.innerHTML = field.content || "<p>محتوى HTML</p>";
  return wrapper;
}

// ... keep existing code (getIconSVG function)

// ... keep existing code (applyButtonAnimation function)

// دالة تطبيق التحسينات والتأثيرات العامة
function applyCleanEffects(container) {
  // إضافة تأثيرات CSS المتقدمة
  const style = document.createElement('style');
  style.textContent = `
    .codform-clean-form {
      animation: fadeIn 0.5s ease-out;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    
    @keyframes bounce {
      0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-10px); }
      60% { transform: translateY(-5px); }
    }
    
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      10%, 90% { transform: translateX(-2px); }
      20%, 80% { transform: translateX(4px); }
      30%, 50%, 70% { transform: translateX(-6px); }
      40%, 60% { transform: translateX(6px); }
    }
    
    @keyframes wiggle {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(-5deg); }
      50% { transform: rotate(0deg); }
      75% { transform: rotate(5deg); }
    }
    
    @keyframes flash {
      0%, 50%, 100% { opacity: 1; }
      25%, 75% { opacity: 0.5; }
    }
  `;
  
  if (!document.head.querySelector('style[data-codform-clean-animations]')) {
    style.setAttribute('data-codform-clean-animations', 'true');
    document.head.appendChild(style);
  }
}

// الكود الرئيسي للبلوك
document.addEventListener('DOMContentLoaded', function() {
  console.log("🚀 Enhanced Codform block script started for block: {{ block.id }}");
  
  const blockId = "{{ block.id }}";
  const container = document.getElementById('codform-container-' + blockId);
  const loader = document.getElementById('codform-form-loader-' + blockId);
  const formContainer = document.getElementById('codform-form-' + blockId);
  const errorContainer = document.getElementById('codform-error-' + blockId);
  const successContainer = document.getElementById('codform-success-' + blockId);
  const retryButton = document.getElementById('codform-retry-' + blockId);
  
  if (!container) {
    console.error("❌ Container not found for block:", blockId);
    return;
  }
  
  showLoading();
  
  if (retryButton) {
    retryButton.addEventListener('click', function() {
      console.log("🔄 Retry button clicked");
      hideError();
      showLoading();
      setTimeout(fetchAndRenderForm, 100);
    });
  }
  
  setTimeout(fetchAndRenderForm, 500);
  
  function fetchAndRenderForm() {
    const productId = container.getAttribute('data-product-id');
    const shop = Shopify.shop || window.location.hostname;
    
    if (!productId || !shop) {
      showError("بيانات المنتج أو المتجر غير متوفرة");
      console.error("❌ Missing product ID or shop information");
      return;
    }
    
    console.log("📡 Fetching enhanced form data...", { productId, shop, blockId });
    
    const apiUrl = `https://mtyfuwdsshlzqwjujavp.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shop)}&productId=${encodeURIComponent(productId)}&blockId=${encodeURIComponent(blockId)}`;
    
    fetch(apiUrl)
      .then(response => {
        console.log("📨 Response received:", response.status);
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        return response.json();
      })
      .then(data => {
        console.log("📋 Enhanced form data received:", data);
        
        if (data && data.form) {
          renderFormData(data.form);
        } else {
          showError("لا يوجد نموذج متوفر لهذا المنتج");
        }
      })
      .catch(error => {
        console.error("❌ Error fetching enhanced form:", error);
        showError("حدث خطأ أثناء تحميل النموذج: " + error.message);
      });
  }
  
  function renderFormData(formData) {
    console.log("🎨 Starting enhanced form render...");
    hideLoading();
    
    try {
      const containerId = 'codform-form-' + blockId;
      console.log("🔧 Calling enhanced renderCodform with:", { formData, containerId });
      
      const success = renderCodform(formData, containerId);
      
      if (success) {
        if (formContainer) {
          formContainer.style.display = 'block';
        }
        console.log("✅ Enhanced form rendered successfully");
      } else {
        showError("فشل في عرض النموذج");
      }
      
    } catch (error) {
      console.error("❌ Error calling enhanced renderCodform:", error);
      showError("حدث خطأ أثناء عرض النموذج: " + error.message);
    }
  }
  
  function showLoading() {
    if (loader) loader.style.display = 'flex';
    if (formContainer) formContainer.style.display = 'none';
    if (errorContainer) errorContainer.style.display = 'none';
    if (successContainer) successContainer.style.display = 'none';
  }
  
  function hideLoading() {
    if (loader) loader.style.display = 'none';
  }
  
  function hideError() {
    if (errorContainer) errorContainer.style.display = 'none';
  }
  
  function showError(message) {
    hideLoading();
    if (formContainer) formContainer.style.display = 'none';
    if (successContainer) successContainer.style.display = 'none';
    
    if (errorContainer) {
      const errorMessage = errorContainer.querySelector('p');
      if (errorMessage && message) {
        errorMessage.textContent = message;
      }
      errorContainer.style.display = 'block';
    }
    
    console.error("❌ Enhanced error shown to user:", message);
  }
});
</script>

<style>
.codform-container {
  font-family: 'Cairo', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  margin: 20px 0;
  max-width: 800px;
