        // Check multiple sources for Arabic language
        if (data.form?.language === 'ar' || data.language === 'ar') {
          formLanguage = 'ar';
        } else if (data.form?.title && /[\u0600-\u06FF]/.test(data.form.title)) {
          formLanguage = 'ar';
        } else if (fieldsArray && fieldsArray.some(field => 
          field.label && /[\u0600-\u06FF]/.test(field.label)
        )) {
          formLanguage = 'ar';
        }
        
        
        console.log('🌐 CODFORM: Detected form language:', formLanguage);
        
        // FIXED: Apply Cairo font immediately when Arabic is detected
        if (formLanguage === 'ar') {
          // Add Arabic-specific CSS dynamically
          const arabicStyle = document.createElement('style');
          arabicStyle.innerHTML = `
            .codform-arabic-form,
            .codform-arabic-form *,
            .codform-arabic-form input,
            .codform-arabic-form textarea,
            .codform-arabic-form label,
            .codform-arabic-form button {
              font-family: 'Cairo', 'Noto Sans Arabic', 'Amiri', sans-serif !important;
              font-feature-settings: "liga" 1, "kern" 1 !important;
              text-rendering: optimizeLegibility !important;
            }
          `;
          document.head.appendChild(arabicStyle);
          
          // Apply Arabic class to container
          if (container) {
            container.classList.add('codform-arabic-form');
          }
        }
        
        if (fieldsArray && Array.isArray(fieldsArray)) {
          fieldsArray.forEach((field, index) => {
            console.log(`🎨 CODFORM: Processing field ${index}:`, field);
            formContent += renderField(field, formStyle, formLanguage);
          });
        } else {
          console.log('❌ CODFORM: No valid fields array found');
        }

        // Wrap in form element with submission handler
        completeFormHTML += `
          <form class="codform-form-fields" style="background: transparent; margin: 0; padding: 0;" 
                id="codform-main-form" onsubmit="handleFormSubmission(event)">
            ${formContent}
          </form>
        `;

        // Set the complete HTML with offers container at top
        container.innerHTML = `
          <div class="codform-dynamic-form">
            ${completeFormHTML}
          </div>
        `;
        
        // Create popup button if enabled
        if (popupButton && popupButton.enabled) {
          createPopupButton(popupButton, formStyle, container);
        }
        
        // تحديد أن النموذج تم تحميله
        container.dataset.formLoaded = 'true';
        
        // حفظ بيانات النموذج مع العملة للاستخدام مع عروض الكمية
        window.currentFormData = data;

        console.log('🎉 CODFORM: Form rendered successfully with quantity offers container');
      })
      .catch(error => {
        console.error('❌ CODFORM: Error loading form:', error);
      });
  }

  // تحميل النموذج عند تحميل DOM
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(loadCompleteForm, 500);
    });
  } else {
    setTimeout(loadCompleteForm, 500);
  }
  
  // أيضاً عند تحميل النافذة
  window.addEventListener('load', () => {
    setTimeout(loadCompleteForm, 1000);
  });
  
  // Form submission handler
  window.handleFormSubmission = async function(event) {
    event.preventDefault();
    
    console.log('🚀 CODFORM: Form submission started');
    
    // Get form data
    const form = event.target;
    const formData = new FormData(form);
    const submissionData = {};
    
    // Convert FormData to regular object
    for (let [key, value] of formData.entries()) {
      submissionData[key] = value;
    }
    
    // Get additional form data from inputs
    const allInputs = form.querySelectorAll('input, textarea, select');
    allInputs.forEach(input => {
      if (input.name || input.id) {
        const fieldKey = input.name || input.id;
        if (input.type === 'checkbox') {
          submissionData[fieldKey] = input.checked;
        } else if (input.type === 'radio') {
          if (input.checked) {
            submissionData[fieldKey] = input.value;
          }
        } else {
          submissionData[fieldKey] = input.value;
        }
      }
    });
    
    console.log('📝 CODFORM: Collected form data:', submissionData);
    
    try {
      // Get current product info from page
      const productId = '{{ product.id }}' || '{{ product.variants.first.id }}' || DEFAULT_PRODUCT_ID;
      const shopDomain = getShopDomain(); // استخدام دالة لجلب المتجر الصحيح
      
      console.log('🏪 CODFORM: Submitting to shop:', shopDomain, 'product:', productId);
      
      // Submit to edge function
      const response = await fetch('https://trlklwixfeaexhydzaue.supabase.co/functions/v1/api-submissions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          formId: productId, // Use product ID as form ID
          shopDomain: shopDomain,
          productId: productId,
          data: submissionData
        })
      });
      
      const result = await response.json();
      
      if (result.success) {
        console.log('✅ CODFORM: Submission successful');
        
        // Show success message
        const submitBtn = form.querySelector('.codform-submit-btn');
        if (submitBtn) {
          const originalText = submitBtn.innerHTML;
          submitBtn.innerHTML = '✅ تم الإرسال بنجاح';
          submitBtn.style.backgroundColor = '#22c55e';
          
          setTimeout(() => {
            submitBtn.innerHTML = originalText;
            submitBtn.style.backgroundColor = '';
          }, 3000);
        }
        
        // Redirect to thank you page if provided
        if (result.thankYouUrl) {
          setTimeout(() => {
            window.location.href = result.thankYouUrl;
          }, 1500);
        }
        
      } else {
        console.error('❌ CODFORM: Submission failed:', result.error);
        alert('خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى.');
      }
      
    } catch (error) {
      console.error('❌ CODFORM: Submission error:', error);
      alert('خطأ في إرسال الطلب. يرجى المحاولة مرة أخرى.');
    }
  };
  
})();

// Popup Button Creation Function
function createPopupButton(popupConfig, formStyle, formContainer) {
  console.log('🎯 CODFORM: Creating popup button with config:', popupConfig);
  
  // Remove existing popup button if any
  const existingButton = document.querySelector('.codform-popup-button');
  if (existingButton) {
    existingButton.remove();
  }
  
  // Create popup button element
  const popupButton = document.createElement('button');
  popupButton.className = `codform-popup-button popup-${popupConfig.position || 'bottom-right'}`;
  
  // Add animation class if specified
  if (popupConfig.animation && popupConfig.animation !== 'none') {
    popupButton.classList.add(`${popupConfig.animation}-animation`);
  }
  
  // Set button text with optional icon
  let buttonText = popupConfig.text || 'Buy with Cash on Delivery';
  if (popupConfig.showIcon) {
    buttonText = '🛒 ' + buttonText;
  }
  popupButton.innerHTML = buttonText;
  
  // Apply styles
  popupButton.style.cssText = `
    background-color: ${popupConfig.backgroundColor || '#9b87f5'};
    color: ${popupConfig.textColor || '#ffffff'};
    border-color: ${popupConfig.borderColor || '#9b87f5'};
    border-width: ${popupConfig.borderWidth || '2px'};
    border-radius: ${popupConfig.borderRadius || '8px'};
    font-size: ${popupConfig.fontSize || '16px'};
    font-weight: ${popupConfig.fontWeight || '600'};
    padding: ${popupConfig.paddingY || '12px'} 24px;
  `;
  
  // Add click handler to scroll to form
  popupButton.addEventListener('click', function() {
    console.log('🎯 CODFORM: Popup button clicked, scrolling to form');
    
    // Find the form element
    const formElement = document.querySelector('.codform-dynamic-form');
    if (formElement) {
      formElement.scrollIntoView({ 
        behavior: 'smooth', 
        block: 'center' 
      });
      
      // Focus on first input after scroll
      setTimeout(() => {
        const firstInput = formElement.querySelector('input, textarea');
        if (firstInput) {
          firstInput.focus();
        }
      }, 500);
    }
  });
  
  // Add to document body
  document.body.appendChild(popupButton);
  
  console.log('✅ CODFORM: Popup button created and added to page');
}

// Floating labels functionality
document.addEventListener('DOMContentLoaded', function() {
  // Handle floating labels
  const inputs = document.querySelectorAll('.codform-dynamic-form input, .codform-dynamic-form textarea');
  
  inputs.forEach(input => {
    const wrapper = input.closest('.codform-field-wrapper');
    const label = wrapper?.querySelector('.floating-label');
    
    if (label) {
      // Function to update label position
      const updateLabel = () => {
        const isTextarea = input.tagName.toLowerCase() === 'textarea';
        if (input.value || input === document.activeElement) {
          label.style.top = isTextarea ? '8px' : '0px';
          label.style.fontSize = '12px';
          label.style.color = '#6366f1';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        } else {
          label.style.top = isTextarea ? '20px' : '50%';
          label.style.fontSize = input.style.fontSize || '16px';
          label.style.color = '#9CA3AF';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        }
      };
      
      // Add event listeners
      input.addEventListener('focus', updateLabel);
      input.addEventListener('blur', updateLabel);
      input.addEventListener('input', updateLabel);
      
      // Initial check
      updateLabel();
    }
  });
});
</script>

