
{% comment %}
  @name: CODFORM Form Block
  @description: Display a cash on delivery form for products
  @supports: product
  @by: OurTeam
{% endcomment %}

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان نجاح الإرسال",
      "default": "تم إرسال الطلب بنجاح"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "رسالة نجاح الإرسال",
      "default": "شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام."
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان رسالة الخطأ",
      "default": "حدث خطأ"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "رسالة الخطأ",
      "default": "حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى."
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    },
    {
      "type": "checkbox",
      "id": "enable_floating_button",
      "label": "تفعيل الزر العائم",
      "default": false
    },
    {
      "type": "text",
      "id": "floating_button_text",
      "label": "نص الزر العائم",
      "default": "اطلب الآن"
    },
    {
      "type": "select",
      "id": "floating_icon",
      "label": "أيقونة الزر العائم",
      "options": [
        { "value": "shopping-cart", "label": "عربة تسوق" },
        { "value": "package", "label": "طرد" },
        { "value": "truck", "label": "شاحنة" },
        { "value": "send", "label": "إرسال" },
        { "value": "none", "label": "بدون أيقونة" }
      ],
      "default": "shopping-cart"
    },
    {
      "type": "checkbox",
      "id": "floating_show_icon",
      "label": "إظهار الأيقونة",
      "default": true
    },
    {
      "type": "select",
      "id": "floating_animation",
      "label": "تأثير حركي للزر العائم",
      "options": [
        { "value": "none", "label": "بدون" },
        { "value": "pulse", "label": "نبض" },
        { "value": "shake", "label": "اهتزاز" },
        { "value": "bounce", "label": "قفز" },
        { "value": "wiggle", "label": "تمايل" },
        { "value": "flash", "label": "وميض" }
      ],
      "default": "pulse"
    },
    {
      "type": "color",
      "id": "floating_bg_color",
      "label": "لون خلفية الزر العائم",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "floating_text_color",
      "label": "لون نص الزر العائم",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "floating_border_radius",
      "label": "انحناء حواف الزر العائم",
      "default": "4px"
    },
    {
      "type": "text",
      "id": "floating_padding_y",
      "label": "تباعد عمودي للزر العائم",
      "default": "10px"
    },
    {
      "type": "text",
      "id": "floating_font_size",
      "label": "حجم خط الزر العائم",
      "default": "16px"
    },
    {
      "type": "text",
      "id": "floating_font_weight",
      "label": "وزن خط الزر العائم",
      "default": "500"
    },
    {
      "type": "text",
      "id": "floating_margin_bottom",
      "label": "هامش سفلي للزر العائم",
      "default": "20px"
    },
    {
      "type": "text",
      "id": "floating_border_width",
      "label": "عرض حدود الزر العائم",
      "default": "0px"
    },
    {
      "type": "color",
      "id": "floating_border_color",
      "label": "لون حدود الزر العائم",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "is_rtl",
      "label": "اتجاه النص من اليمين لليسار",
      "default": true
    }
  ]
}
{% endschema %}

<div 
  id="codform-container-{{ block.id }}" 
  class="codform-container" 
  data-product-id="{{ product.id }}"
  data-block-id="{{ block.id }}"
  data-hide-header="true"
  data-enable-icons="true"
>
  <div id="codform-form-loader-{{ block.id }}" class="codform-loader" style="display: flex; justify-content: center; padding: 20px;">
    <div class="codform-spinner"></div>
    <div style="margin-top: 10px;">{{ block.settings.loading_text }}</div>
  </div>
  
  <div id="codform-form-{{ block.id }}" class="codform-form-container" style="display: none;"></div>
  
  <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-success-icon">✓</div>
    <h3>{{ block.settings.success_title }}</h3>
    <p>{{ block.settings.success_message }}</p>
  </div>
  
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none; text-align: center; padding: 20px;">
    <div class="codform-error-icon">!</div>
    <h3>{{ block.settings.error_title }}</h3>
    <p>{{ block.settings.error_message }}</p>
    <button id="codform-retry-{{ block.id }}" class="codform-button">{{ block.settings.retry_button }}</button>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('codform-container-{{ block.id }}');
    const loader = document.getElementById('codform-form-loader-{{ block.id }}');
    const formContainer = document.getElementById('codform-form-{{ block.id }}');
    const errorContainer = document.getElementById('codform-error-{{ block.id }}');
    const successContainer = document.getElementById('codform-success-{{ block.id }}');
    const retryButton = document.getElementById('codform-retry-{{ block.id }}');
    
    if (container && loader) {
      loader.style.display = 'flex';
      
      // إضافة معالج حدث إعادة المحاولة
      if (retryButton) {
        retryButton.addEventListener('click', function() {
          errorContainer.style.display = 'none';
          loader.style.display = 'flex';
          fetchForm();
        });
      }
      
      // بدء تحميل النموذج
      fetchForm();
    }
    
    // وظيفة لجلب النموذج بناءً على معرف المنتج
    function fetchForm() {
      const productId = container.getAttribute('data-product-id');
      const blockId = container.getAttribute('data-block-id');
      const shop = Shopify.shop || window.location.hostname;
      
      if (!productId || !shop) {
        showError("بيانات المنتج أو المتجر غير متوفرة");
        console.error('Missing product ID or shop information');
        return;
      }
      
      // طباعة معلومات التصحيح
      console.log('Fetching form with productId:', productId, 'blockId:', blockId, 'shop:', shop);
      
      // استخدام عنوان URL الكامل مع https
      const apiUrl = `https://mtyfuwdsshlzqwjujavp.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shop)}&productId=${encodeURIComponent(productId)}&blockId=${encodeURIComponent(blockId)}`;
      
      console.log('Request URL:', apiUrl);
      
      // جلب تكوين النموذج
      fetch(apiUrl)
        .then(response => {
          if (!response.ok) {
            console.error('HTTP error:', response.status, response.statusText);
            throw new Error(`HTTP error ${response.status}`);
          }
          return response.json();
        })
        .then(data => {
          if (data && data.form) {
            console.log('Form data received successfully:', data);
            renderForm(data.form, blockId);
          } else {
            console.error('No form data received:', data);
            showError("لا يوجد نموذج متوفر لهذا المنتج");
          }
        })
        .catch(error => {
          console.error('Error fetching form:', error);
          showError("حدث خطأ أثناء تحميل النموذج");
        });
    }
    
    // وظيفة لعرض النموذج
    function renderForm(formData, blockId) {
      if (!formContainer) {
        console.error('Form container not found');
        return;
      }
      
      // إخفاء التحميل
      if (loader) {
        loader.style.display = 'none';
      }
      
      // إنشاء HTML للنموذج
      const formHtml = createFormHtml(formData, blockId);
      
      // عرض النموذج
      formContainer.innerHTML = formHtml;
      formContainer.style.display = 'block';
      
      // إعداد معالجات الأحداث
      setupFormHandlers(formData, blockId);
    }
    
    // وظيفة لإظهار رسالة الخطأ
    function showError(message) {
      if (loader) loader.style.display = 'none';
      if (formContainer) formContainer.style.display = 'none';
      if (successContainer) successContainer.style.display = 'none';
      
      if (errorContainer) {
        const errorMessage = errorContainer.querySelector('p');
        if (errorMessage && message) {
          errorMessage.textContent = message;
        }
        errorContainer.style.display = 'block';
      }
    }
    
    // وظيفة لإنشاء HTML للنموذج - تم تحديثها لتطابق هيكل المعاينة بالضبط ومع استخدام قيم ديناميكية
    function createFormHtml(formData, blockId) {
      // دائمًا تفعيل خاصية إخفاء العنوان
      const hideHeader = true;
      const enableIcons = container.getAttribute('data-enable-icons') === 'true';
      const isRTL = formData.settings?.direction === 'rtl' || {{ block.settings.is_rtl | json }};
      const primaryColor = formData.settings?.primaryColor || '#9b87f5';
      const borderRadius = formData.settings?.borderRadius || '0.5rem';
      const fontSize = formData.settings?.fontSize || '1rem';
      const buttonStyle = formData.settings?.buttonStyle || 'rounded';
      
      // إنشاء الحاوية الخارجية الكاملة للنموذج بنفس الأسلوب كما في المعاينة
      let html = `
      <div class="rounded-lg border shadow-sm overflow-hidden bg-white codform-form" 
           data-form-preview-id="form-preview-${Date.now()}" 
           data-primary-color="${primaryColor}" 
           data-border-radius="${borderRadius}" 
           data-font-size="${fontSize}" 
           data-button-style="${buttonStyle}" 
           style="font-size: ${fontSize}; --form-primary-color: ${primaryColor}; border-radius: ${borderRadius}; background-color: rgb(245, 245, 245);">
        <div class="p-3" 
             data-direction="${isRTL ? 'rtl' : 'ltr'}" 
             style="border-radius: 0px 0px ${borderRadius} ${borderRadius}; direction: ${isRTL ? 'rtl' : 'ltr'}; background-color: rgb(245, 245, 245);">
          <div class="space-y-2">
      `;
      
      // إضافة الأنماط للرسوم المتحركة
      html += `
      <style>
        @keyframes pulse-animation {
          0% { transform: scale(1); }
          50% { transform: scale(1.05); }
          100% { transform: scale(1); }
        }
        
        @keyframes shake-animation {
          0%, 100% { transform: translateX(0); }
          10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
          20%, 40%, 60%, 80% { transform: translateX(5px); }
        }
        
        @keyframes bounce-animation {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-8px); }
        }
        
        @keyframes wiggle-animation {
          0%, 100% { transform: rotate(0); }
          25% { transform: rotate(-3deg); }
          75% { transform: rotate(3deg); }
        }
        
        @keyframes flash-animation {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.6; }
        }
        
        .pulse-animation {
          animation: pulse-animation 2s infinite ease-in-out !important;
        }
        
        .shake-animation {
          animation: shake-animation 0.8s infinite ease-in-out !important;
        }
        
        .bounce-animation {
          animation: bounce-animation 2s infinite ease-in-out !important;
        }
        
        .wiggle-animation {
          animation: wiggle-animation 2s infinite ease-in-out !important;
        }
        
        .flash-animation {
          animation: flash-animation 2s infinite ease-in-out !important;
        }

        /* تنسيقات إضافية للنموذج */
        .codform-input, .codform-textarea {
          width: 100%;
          padding: 10px 12px;
          border: 1px solid #d1d5db;
          border-radius: 0.5rem;
          font-size: 16px;
          color: rgb(31, 41, 55);
          box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px;
          line-height: 1.5;
          font-family: inherit;
        }

        .codform-input.with-icon {
          padding-left: 36px !important;
        }

        label {
          color: rgb(51, 65, 85);
          font-size: 1rem;
          font-weight: 600;
          font-family: inherit;
          margin-bottom: 8px;
          display: block;
        }

        .codform-field-icon {
          position: absolute;
          left: 12px;
          top: 50%;
          transform: translateY(-50%);
          color: #9ca3af;
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 2;
          pointer-events: none;
        }

        .codform-required {
          color: #ef4444;
          margin-left: 4px;
        }
      </style>
      `;
      
      // إنشاء نموذج داخل الحاوية
      html += `<form id="codform-form-element-${blockId}" style="display: block;">`;
      
      // إضافة الحقول
      if (formData.fields && formData.fields.length) {
        formData.fields.forEach(field => {
          if (field && field.type) {
            // إنشاء عنصر العنوان بشكل ديناميكي باستخدام قيم من field.style
            if (field.type === 'form-title' || field.type === 'title') {
              const style = field.style || {};
              // استخدام القيم الديناميكية من field.style أو القيم الافتراضية إذا لم تكن محددة
              const titleAlign = style.textAlign || (isRTL ? 'right' : 'center');
              const bgColor = style.backgroundColor || primaryColor || '#9b87f5';
              const titleColor = style.color || '#ffffff';
              const descColor = style.descriptionColor || 'rgba(255, 255, 255, 0.9)';
              const titleFontSize = style.fontSize || '24px';
              const descFontSize = style.descriptionFontSize || '14px';
              const fontWeight = style.fontWeight || 'bold';
              const descFontWeight = style.descriptionFontWeight || 'normal';
              const fontFamily = style.fontFamily || 'inherit';
              
              html += `
              <div class="mb-4" data-field-type="${field.type}" data-field-id="${field.id}" data-has-icon="false" data-show-icon="false" data-icon="none" data-required="false">
                <style>
                  @keyframes pulse-animation {
                    0% { transform: scale(1); }
                    50% { transform: scale(1.05); }
                    100% { transform: scale(1); }
                  }
                  
                  @keyframes shake-animation {
                    0%, 100% { transform: translateX(0); }
                    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
                    20%, 40%, 60%, 80% { transform: translateX(5px); }
                  }
                  
                  @keyframes bounce-animation {
                    0%, 100% { transform: translateY(0); }
                    50% { transform: translateY(-8px); }
                  }
                  
                  @keyframes wiggle-animation {
                    0%, 100% { transform: rotate(0); }
                    25% { transform: rotate(-3deg); }
                    75% { transform: rotate(3deg); }
                  }
                  
                  @keyframes flash-animation {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0.6; }
                  }
                  
                  .pulse-animation {
                    animation: pulse-animation 2s infinite ease-in-out !important;
                  }
                  
                  .shake-animation {
                    animation: shake-animation 0.8s infinite ease-in-out !important;
                  }
                  
                  .bounce-animation {
                    animation: bounce-animation 2s infinite ease-in-out !important;
                  }
                  
                  .wiggle-animation {
                    animation: wiggle-animation 2s infinite ease-in-out !important;
                  }
                  
                  .flash-animation {
                    animation: flash-animation 2s infinite ease-in-out !important;
                  }
                </style>
                <div id="title-field-${field.id}-${Date.now()}" class="mb-4 ${field.type === 'form-title' ? 'codform-title' : ''}" dir="${isRTL ? 'rtl' : 'ltr'}" data-testid="title-field" data-title-align="${titleAlign}" data-has-bg="true" data-title-color="${titleColor}" data-bg-color="${bgColor}" data-font-family="${fontFamily}" data-field-type="${field.type}" data-font-size="${titleFontSize}" data-font-weight="${fontWeight}" data-desc-font-size="${descFontSize}" data-desc-color="${descColor}" data-desc-font-weight="${descFontWeight}">
                  <div class="codform-title-container" style="background-color: ${bgColor}; padding: 16px; border-radius: ${borderRadius}; width: 100%; box-sizing: border-box; margin-bottom: 16px; text-align: ${titleAlign};">
                    <h3 class="${field.type === 'form-title' ? 'codform-form-title' : ''}" style="color: ${titleColor}; font-size: ${titleFontSize}; text-align: ${titleAlign}; font-weight: ${fontWeight}; font-family: ${fontFamily}; margin: 0px; padding: 0px; line-height: 1.3; display: block;">
                      ${field.label || ''}
                    </h3>
                    ${field.helpText ? `
                    <p class="codform-title-description" style="color: ${descColor}; font-size: ${descFontSize}; margin: 6px 0px 0px; padding: 0px; text-align: ${titleAlign}; font-family: ${fontFamily}; font-weight: ${descFontWeight}; line-height: 1.5; opacity: 0.9;">
                      ${field.helpText}
                    </p>` : ''}
                  </div>
                </div>
              </div>`;
              return;
            }
            
            // حقول النص والإدخال
            if (field.type === 'text' || field.type === 'email' || field.type === 'phone') {
              const hasIcon = field.icon && field.icon !== 'none' && field.style?.showIcon !== false;
              let iconType = field.icon || 'user';
              if (field.type === 'email') iconType = 'mail';
              if (field.type === 'phone') iconType = 'phone';
              
              html += `
              <div class="mb-4" data-field-type="${field.type}" data-field-id="${field.id}" data-has-icon="${hasIcon ? 'true' : 'false'}" data-show-icon="${hasIcon ? 'true' : 'false'}" data-icon="${iconType}" data-required="${field.required ? 'true' : 'false'}">
                <style>
                  @keyframes pulse-animation {
                    0% { transform: scale(1); }
                    50% { transform: scale(1.05); }
                    100% { transform: scale(1); }
                  }
                  
                  @keyframes shake-animation {
                    0%, 100% { transform: translateX(0); }
                    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
                    20%, 40%, 60%, 80% { transform: translateX(5px); }
                  }
                  
                  @keyframes bounce-animation {
                    0%, 100% { transform: translateY(0); }
                    50% { transform: translateY(-8px); }
                  }
                  
                  @keyframes wiggle-animation {
                    0%, 100% { transform: rotate(0); }
                    25% { transform: rotate(-3deg); }
                    75% { transform: rotate(3deg); }
                  }
                  
                  @keyframes flash-animation {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0.6; }
                  }
                  
                  .pulse-animation {
                    animation: pulse-animation 2s infinite ease-in-out !important;
                  }
                  
                  .shake-animation {
                    animation: shake-animation 0.8s infinite ease-in-out !important;
                  }
                  
                  .bounce-animation {
                    animation: bounce-animation 2s infinite ease-in-out !important;
                  }
                  
                  .wiggle-animation {
                    animation: wiggle-animation 2s infinite ease-in-out !important;
                  }
                  
                  .flash-animation {
                    animation: flash-animation 2s infinite ease-in-out !important;
                  }
                </style>
                <div class="mb-4 p-3 bg-white rounded-lg border border-gray-200" data-component="TextInput" data-field-type="${field.type}" data-field-id="${field.id}" data-show-label="true" data-label-text="${field.label || ''}" data-has-icon="${hasIcon ? 'true' : 'false'}" data-show-icon="${hasIcon ? 'true' : 'false'}" data-icon-type="${iconType}" data-required="${field.required ? 'true' : 'false'}" data-font-family="inherit" data-font-size="1rem" data-border-radius="0.5rem" data-input-id="${field.id}-input" dir="${isRTL ? 'rtl' : 'ltr'}">
                  <label for="${field.id}-input" class="block mb-2 relative" data-label-text="${field.label || ''}" style="color: rgb(51, 65, 85); font-size: 1rem; font-weight: 600; font-family: inherit; margin-bottom: 8px;">
                    ${field.label || ''}
                    ${field.required ? '<span class="codform-required">*</span>' : ''}
                  </label>
                  <div class="relative">
                    ${hasIcon ? `<div class="codform-field-icon" data-icon-type="${iconType}" data-icon-visible="true" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #9ca3af; z-index: 2;">
                      ${getIconSvg(iconType)}
                    </div>` : ''}
                    <input 
                      type="${field.type === 'email' ? 'email' : field.type === 'phone' ? 'tel' : 'text'}" 
                      id="${field.id}-input" 
                      name="${field.id}" 
                      placeholder="${field.placeholder || ''}" 
                      aria-label="${field.label || ''}" 
                      class="codform-input ${hasIcon ? 'with-icon' : ''}" 
                      data-has-icon="${hasIcon ? 'true' : 'false'}" 
                      ${field.required ? 'required' : ''}
                    >
                  </div>
                </div>
              </div>`;
            } 
            // حقل المناطق النصية
            else if (field.type === 'textarea') {
              html += `
              <div class="mb-4" data-field-type="textarea" data-field-id="${field.id}" data-has-icon="false" data-show-icon="false" data-icon="none" data-required="${field.required ? 'true' : 'false'}">
                <style>
                  @keyframes pulse-animation {
                    0% { transform: scale(1); }
                    50% { transform: scale(1.05); }
                    100% { transform: scale(1); }
                  }
                  
                  @keyframes shake-animation {
                    0%, 100% { transform: translateX(0); }
                    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
                    20%, 40%, 60%, 80% { transform: translateX(5px); }
                  }
                  
                  @keyframes bounce-animation {
                    0%, 100% { transform: translateY(0); }
                    50% { transform: translateY(-8px); }
                  }
                  
                  @keyframes wiggle-animation {
                    0%, 100% { transform: rotate(0); }
                    25% { transform: rotate(-3deg); }
                    75% { transform: rotate(3deg); }
                  }
                  
                  @keyframes flash-animation {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0.6; }
                  }
                  
                  .pulse-animation {
                    animation: pulse-animation 2s infinite ease-in-out !important;
                  }
                  
                  .shake-animation {
                    animation: shake-animation 0.8s infinite ease-in-out !important;
                  }
                  
                  .bounce-animation {
                    animation: bounce-animation 2s infinite ease-in-out !important;
                  }
                  
                  .wiggle-animation {
                    animation: wiggle-animation 2s infinite ease-in-out !important;
                  }
                  
                  .flash-animation {
                    animation: flash-animation 2s infinite ease-in-out !important;
                  }
                </style>
                <div class="mb-4 p-3 bg-white rounded-lg border border-gray-200">
                  <label for="${field.id}" class="block mb-2 relative" style="color: rgb(51, 65, 85); font-size: 1rem; font-weight: 600; font-family: inherit; margin-bottom: 8px;">
                    ${field.label || ''}
                    ${field.required ? '<span class="codform-required">*</span>' : ''}
                  </label>
                  <textarea 
                    id="${field.id}" 
                    rows="${field.rows || 4}" 
                    placeholder="${field.placeholder || ''}" 
                    class="codform-textarea" 
                    ${field.required ? 'required' : ''}
                    name="${field.id}">
                  </textarea>
                </div>
              </div>`;
            } 
            // حقل الإرسال (الزر)
            else if (field.type === 'submit') {
              const style = field.style || {};
              const bgColor = style.backgroundColor || primaryColor;
              const borderRadius = style.borderRadius || '6px';
              const fontSize = style.fontSize || '19px';
              const fontWeight = style.fontWeight || '500';
              const textColor = style.color || '#ffffff';
              const padding = style.padding || '15px 24px';
              const borderWidth = style.borderWidth || '0px';
              const borderColor = style.borderColor || '#eaeaff';
              const animationType = style.animationType || 'shake';
              const iconPosition = style.iconPosition || 'left';
              const hasAnimation = style.animation !== false;
              const hasIcon = style.showIcon !== false;
              const iconType = style.icon || 'shopping-cart';
              
              html += `
              <div class="mt-0" data-field-type="submit" data-field-id="${field.id}" data-has-icon="${hasIcon ? 'true' : 'false'}" data-show-icon="${hasIcon ? 'true' : 'false'}" data-icon="${iconType}" data-required="false">
                <style>
                  @keyframes pulse-animation {
                    0% { transform: scale(1); }
                    50% { transform: scale(1.05); }
                    100% { transform: scale(1); }
                  }
                  
                  @keyframes shake-animation {
                    0%, 100% { transform: translateX(0); }
                    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
                    20%, 40%, 60%, 80% { transform: translateX(5px); }
                  }
                  
                  @keyframes bounce-animation {
                    0%, 100% { transform: translateY(0); }
                    50% { transform: translateY(-8px); }
                  }
                  
                  @keyframes wiggle-animation {
                    0%, 100% { transform: rotate(0); }
                    25% { transform: rotate(-3deg); }
                    75% { transform: rotate(3deg); }
                  }
                  
                  @keyframes flash-animation {
                    0%, 100% { opacity: 1; }
                    50% { opacity: 0.6; }
                  }
                  
                  .pulse-animation {
                    animation: pulse-animation 2s infinite ease-in-out !important;
                  }
                  
                  .shake-animation {
                    animation: shake-animation 0.8s infinite ease-in-out !important;
                  }
                  
                  .bounce-animation {
                    animation: bounce-animation 2s infinite ease-in-out !important;
                  }
                  
                  .wiggle-animation {
                    animation: wiggle-animation 2s infinite ease-in-out !important;
                  }
                  
                  .flash-animation {
                    animation: flash-animation 2s infinite ease-in-out !important;
                  }
                </style>
                <button 
                  type="submit" 
                  class="codform-submit-btn ${hasAnimation ? `${animationType}-animation` : ''}" 
                  dir="${isRTL ? 'rtl' : 'ltr'}" 
                  data-animation-type="${animationType}" 
                  data-button-style="rounded" 
                  data-has-animation="${hasAnimation ? 'true' : 'false'}" 
                  data-icon-position="${iconPosition}" 
                  data-has-icon="${hasIcon ? 'true' : 'false'}" 
                  data-bg-color="${bgColor}" 
                  data-text-color="${textColor}" 
                  data-font-size="${fontSize}" 
                  data-border-radius="${borderRadius}" 
                  style="background-color: ${bgColor}; color: ${textColor}; font-size: ${fontSize}; font-weight: ${fontWeight}; border-radius: ${borderRadius}; border-color: ${borderColor}; border-width: ${borderWidth}; border-style: solid; padding: ${padding}; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; font-family: inherit; cursor: pointer; transition: 0.2s; margin-top: 14px; box-shadow: rgba(0, 0, 0, 0.1) 0px 2px 4px; position: relative; overflow: hidden; text-align: center;">
                  ${iconPosition === 'left' && hasIcon ? `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="${textColor}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-${iconType}" style="width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center;"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>` : ''}
                  <span>${field.label || 'Buy with Cash on Delivery'}</span>
                  ${iconPosition === 'right' && hasIcon ? `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="${textColor}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-${iconType}" style="width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center;"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>` : ''}
                </button>
              </div>`;
            }
          }
        });
      } else {
        console.error('No fields found in form data', formData);
        html += '<div style="padding: 15px; text-align: center; color: #e32;">لا توجد حقول في هذا النموذج</div>';
      }
      
      // إغلاق عناصر النموذج
      html += `</form></div></div></div>`;
      
      return html;
    }
    
    // وظيفة لإعداد معالجات الأحداث للنموذج
    function setupFormHandlers(formData, blockId) {
      const formElement = document.querySelector(`#codform-form-element-${blockId}`);
      
      if (formElement) {
        formElement.addEventListener('submit', function(event) {
          event.preventDefault();
          
          // جمع بيانات النموذج
          const formData = new FormData(formElement);
          const formDataObj = {};
          formData.forEach((value, key) => {
            formDataObj[key] = value;
          });
          
          console.log('Form submitted with data:', formDataObj);
          
          // تمرير بيانات النموذج إلى API
          submitFormData(formDataObj, blockId);
        });
      }
    }
    
    // وظيفة لإرسال بيانات النموذج
    function submitFormData(data, blockId) {
      const shop = Shopify.shop || window.location.hostname;
      const productId = container.getAttribute('data-product-id');
      
      // عرض حالة التحميل
      formContainer.classList.add('codform-loading');
      
      // إضافة معلومات السياق
      data.shop = shop;
      data.product_id = productId;
      data.form_id = blockId;
      
      // إرسال البيانات إلى API
      const apiUrl = `https://mtyfuwdsshlzqwjujavp.supabase.co/functions/v1/submit-cod-form`;
      
      fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      })
      .then(response => {
        if (!response.ok) {
          throw new Error(`HTTP error ${response.status}`);
        }
        return response.json();
      })
      .then(result => {
        // إظهار رسالة النجاح
        formContainer.style.display = 'none';
        formContainer.classList.remove('codform-loading');
        successContainer.style.display = 'block';
      })
      .catch(error => {
        // إظهار رسالة الخطأ
        console.error('Error submitting form:', error);
        formContainer.classList.remove('codform-loading');
        showError("حدث خطأ أثناء إرسال النموذج، يرجى المحاولة مرة أخرى.");
      });
    }
    
    // وظيفة للحصول على SVG للأيقونة
    function getIconSvg(iconName) {
      // مجموعة من الأيقونات SVG الشائعة
      const icons = {
        'user': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>',
        'mail': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>',
        'phone': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>',
        'home': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-home"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>',
        'map-pin': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>',
        'city': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-building"><rect x="2" y="8" width="20" height="14" rx="2"></rect><path d="M6 2v6"></path><path d="M18 2v6"></path><path d="M6 14h12"></path><path d="M6 18h12"></path></svg>',
        'shopping-cart': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-cart"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 1-2 1.61h9.72a2 2 0 0 1 2-1.61L23 6H6"></path></svg>',
        'send': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-send"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>',
        'package': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>',
        'truck': '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-truck"><path d="M10 17h4V5H2v12h3"></path><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5v8h1"></path><circle cx="7.5" cy="17.5" r="2.5"></circle><circle cx="17.5" cy="17.5" r="2.5"></circle></svg>'
      };
      
      // إرجاع أيقونة SVG أو أيقونة المستخدم الافتراضية
      return icons[iconName] || icons['user'];
    }
  });
</script>

<style>
  /* تحديث أنماط CSS لضمان توافق العرض */
  .codform-container {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    margin: 20px 0;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
    width: 100%;
    font-size: 16px;
    line-height: 1.5;
  }
  
  /* أنماط الزر */
  .codform-button {
    background-color: #9b87f5;
    color: white;
    border: none;
    padding: 10px 15px;
    border-radius: 4px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .codform-button:hover {
    opacity: 0.9;
  }
  
  /* أيقونة التحميل */
  .codform-spinner {
    border: 4px solid rgba(0, 0, 0, 0.1);
    border-left-color: #9b87f5;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    animation: spin 1s linear infinite;
  }
  
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  /* أيقونات النجاح والخطأ */
  .codform-success-icon, .codform-error-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 15px;
    border-radius: 50%;
    color: white;
    font-size: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .codform-success-icon {
    background-color: #34c759;
  }
  
  .codform-error-icon {
    background-color: #ff3b30;
  }
  
  /* التحسينات النموذج */
  .codform-input, .codform-textarea {
    width: 100% !important;
    padding: 10px 12px !important;
    border: 1px solid #d1d5db !important;
    border-radius: 8px !important;
    font-size: 16px !important;
    color: rgb(31, 41, 55) !important;
    box-shadow: rgba(0, 0, 0, 0.05) 0px 1px 2px !important;
    line-height: 1.5 !important;
    font-family: inherit !important;
  }
  
  .codform-input.with-icon {
    padding-left: 36px !important;
  }
  
  .codform-field {
    position: relative !important;
    margin-bottom: 16px !important;
    background-color: #ffffff !important;
    border-radius: 8px !important;
    padding: 12px !important;
    border: 1px solid #e5e7eb !important;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05) !important;
  }
  
  .codform-field label {
    color: rgb(51, 65, 85) !important;
    font-size: 1rem !important;
    font-weight: 600 !important;
    font-family: inherit !important;
    margin-bottom: 8px !important;
    display: block !important;
  }
  
  .codform-field-icon {
    position: absolute !important;
    left: 12px !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    color: #9ca3af !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    z-index: 2 !important;
    pointer-events: none !important;
  }
  
  .codform-required {
    color: #ef4444 !important;
    margin-left: 4px !important;
  }
  
  /* أنماط رسومات متحركة */
  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 90% { transform: translateX(-2px); }
    20%, 80% { transform: translateX(4px); }
    30%, 50%, 70% { transform: translateX(-6px); }
    40%, 60% { transform: translateX(6px); }
  }
  
  .shake-animation {
    animation: shake 0.8s ease-in-out infinite !important;
  }
  
  .pulse-animation {
    animation: pulse 2s ease-in-out infinite !important;
  }
</style>

