      padding: `${popupConfig.paddingY || '16px'} 24px`,
      cursor: 'pointer',
      transition: 'all 0.3s ease',
      boxShadow: '0 4px 12px rgba(0, 0, 0, 0.15)',
      textAlign: 'center',
      whiteSpace: 'nowrap',
      minHeight: '60px',
      lineHeight: '1.2',
      fontFamily: 'inherit',
      margin: '20px 0'
    });

    // Add hover effects
    button.addEventListener('mouseenter', () => {
      button.style.transform = 'scale(1.02)';
      button.style.boxShadow = '0 6px 20px rgba(0, 0, 0, 0.2)';
    });

    button.addEventListener('mouseleave', () => {
      button.style.transform = 'scale(1)';
      button.style.boxShadow = '0 4px 12px rgba(0, 0, 0, 0.15)';
    });

    // Add click handler
    button.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      window.codformOpenPopup();
    });

    // Add animation if specified
    if (popupConfig.animation && popupConfig.animation !== 'none') {
      switch(popupConfig.animation) {
        case 'pulse':
          button.style.animation = 'pulse 2s infinite';
          break;
        case 'bounce':
          button.style.animation = 'bounce 1s infinite';
          break;
        case 'shake':
          button.style.animation = 'shake 0.5s infinite';
          break;
        case 'wiggle':
          button.style.animation = 'wiggle 1s infinite';
          break;
      }
    }
    
    // Replace form container content with popup button
    formContainer.innerHTML = '';
    formContainer.appendChild(button);
    formContainer.classList.add('popup-mode');
    
    console.log('✅ CODFORM: Popup button displayed in place of form');
  }
}

// Popup functionality
window.codformOpenPopup = function() {
  console.log('🎯 CODFORM: Opening popup modal');
  
  // Create overlay
  const overlay = document.createElement('div');
  overlay.className = 'codform-popup-overlay';
  Object.assign(overlay.style, {
    position: 'fixed',
    top: '0',
    left: '0',
    width: '100%',
    height: '100%',
    backgroundColor: 'rgba(0, 0, 0, 0.6)',
    zIndex: '10000',
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
    animation: 'fadeIn 0.3s ease-out'
  });

  // Create popup container
  const popup = document.createElement('div');
  popup.className = 'codform-popup-container';
  Object.assign(popup.style, {
    backgroundColor: 'white',
    borderRadius: '16px',
    padding: '24px',
    maxWidth: '600px',
    width: '95%',
    maxHeight: '90vh',
    overflowY: 'auto',
    position: 'relative',
    boxShadow: '0 25px 50px rgba(0, 0, 0, 0.25)',
    animation: 'slideUp 0.3s ease-out'
  });

  // Add CSS animations
  const style = document.createElement('style');
  style.textContent = `
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes slideUp {
      from { transform: translateY(30px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    @keyframes fadeOut {
      from { opacity: 1; }
      to { opacity: 0; }
    }
    @keyframes slideDown {
      from { transform: translateY(0); opacity: 1; }
      to { transform: translateY(30px); opacity: 0; }
    }
  `;
  document.head.appendChild(style);

  // Load the form content into popup - use original HTML directly
  console.log('🔍 CODFORM: Loading original form content into popup...');
  console.log('🔍 CODFORM: Available window.originalFormContent:', !!window.originalFormContent);
  console.log('🔍 CODFORM: Content length:', window.originalFormContent ? window.originalFormContent.length : 0);
  
  if (window.originalFormContent && window.originalFormContent.length > 0) {
    console.log('✅ CODFORM: Using stored original form content');
    console.log('📝 CODFORM: Content preview:', window.originalFormContent.substring(0, 300));
    
    const formDiv = document.createElement('div');
    formDiv.innerHTML = window.originalFormContent;
    formDiv.className = window.originalFormClasses || 'codform-dynamic-form';
    
    // Ensure the form container is styled properly for popup
    formDiv.style.cssText = `
      margin: 0;
      max-width: 100%;
      background-color: transparent;
      border: none;
      border-radius: 0;
      padding: 0;
      box-shadow: none;
    `;
    
    popup.appendChild(formDiv);
    console.log('✅ CODFORM: Original form content loaded successfully');
    console.log('📝 CODFORM: Popup content after adding form:', popup.innerHTML.length);
  } else {
    console.error('❌ CODFORM: No original form content available or content is empty');
    console.error('❌ CODFORM: window.originalFormContent:', window.originalFormContent);
    const errorDiv = document.createElement('div');
    errorDiv.innerHTML = '<p style="text-align: center; color: #666; padding: 20px;">خطأ في تحميل النموذج</p>';
    popup.appendChild(errorDiv);
  }
  
  // Add close button
  const closeButton = document.createElement('button');
  closeButton.innerHTML = '✕';
  Object.assign(closeButton.style, {
    position: 'absolute',
    top: '16px',
    right: '16px',
    background: '#f3f4f6',
    border: 'none',
    borderRadius: '50%',
    fontSize: '18px',
    cursor: 'pointer',
    color: '#6b7280',
    width: '32px',
    height: '32px',
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
    transition: 'all 0.2s ease',
    zIndex: '10001'
  });

  closeButton.addEventListener('mouseenter', () => {
    closeButton.style.backgroundColor = '#e5e7eb';
    closeButton.style.color = '#374151';
  });

  closeButton.addEventListener('mouseleave', () => {
    closeButton.style.backgroundColor = '#f3f4f6';
    closeButton.style.color = '#6b7280';
  });

  closeButton.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    overlay.style.animation = 'fadeOut 0.2s ease-out';
    popup.style.animation = 'slideDown 0.2s ease-out';
    setTimeout(() => {
      if (overlay.parentNode) {
        document.body.removeChild(overlay);
      }
    }, 200);
  });

  popup.appendChild(closeButton);
  overlay.appendChild(popup);
  document.body.appendChild(overlay);

  // Close on overlay click
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) {
      closeButton.click();
    }
  });

  // Close on Escape key
  const handleEscape = (e) => {
    if (e.key === 'Escape') {
      closeButton.click();
      document.removeEventListener('keydown', handleEscape);
    }
  };
  document.addEventListener('keydown', handleEscape);

  // Focus on first input
  setTimeout(() => {
    const firstInput = popup.querySelector('input, textarea');
    if (firstInput) {
      firstInput.focus();
    }
  }, 100);
  
  console.log('CODFORM: Popup form displayed');
};

window.codformClosePopup = function() {
  console.log('🎯 CODFORM: Closing popup modal');
  
  const modal = document.getElementById('codform-popup-modal');
  if (modal) {
    modal.classList.remove('active');
    document.body.style.overflow = ''; // Restore scroll
  }
};

// Close popup when clicking outside content
document.addEventListener('click', function(e) {
  const modal = document.getElementById('codform-popup-modal');
  if (e.target === modal) {
    window.codformClosePopup();
  }
});

// Close popup with Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    window.codformClosePopup();
  }
});

// Floating labels functionality
document.addEventListener('DOMContentLoaded', function() {
  // Handle floating labels
  const inputs = document.querySelectorAll('.codform-dynamic-form input, .codform-dynamic-form textarea');
  
  inputs.forEach(input => {
    const wrapper = input.closest('.codform-field-wrapper');
    const label = wrapper?.querySelector('.floating-label');
    
    if (label) {
      // Function to update label position
      const updateLabel = () => {
        const isTextarea = input.tagName.toLowerCase() === 'textarea';
        if (input.value || input === document.activeElement) {
          label.style.top = isTextarea ? '8px' : '0px';
          label.style.fontSize = '12px';
          label.style.color = '#6366f1';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        } else {
          label.style.top = isTextarea ? '20px' : '50%';
          label.style.fontSize = input.style.fontSize || '16px';
          label.style.color = '#9CA3AF';
          label.style.transform = isTextarea ? 'translateY(0)' : 'translateY(-50%)';
        }
      };
      
      // Add event listeners
      input.addEventListener('focus', updateLabel);
      input.addEventListener('blur', updateLabel);
      input.addEventListener('input', updateLabel);
      
      // Initial check
      updateLabel();
    }
  });
  
  // Add focus/blur handlers for form fields to maintain the same styling functionality
  const formInputs = document.querySelectorAll('.codform-dynamic-form input, .codform-dynamic-form textarea');
  formInputs.forEach(input => {
    const focusBorderColor = input.getAttribute('data-focus-border-color') || '#3b82f6';
    const blurBorderColor = input.getAttribute('data-blur-border-color') || '#d1d5db';
    
    input.addEventListener('focus', function() {
      this.style.borderColor = focusBorderColor;
      this.style.boxShadow = '0 0 0 3px ' + focusBorderColor + '20';
    });
    
    input.addEventListener('blur', function() {
      this.style.borderColor = blurBorderColor;
      this.style.boxShadow = 'rgba(0, 0, 0, 0.05) 0px 1px 2px';
    });
  });
});
</script>

