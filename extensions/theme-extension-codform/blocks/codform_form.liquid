{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "عنوان النموذج",
      "default": "طلب الدفع عند الاستلام"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "وصف النموذج",
      "default": "يرجى ملء النموذج التالي لطلب الدفع عند الاستلام"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان نجاح الإرسال",
      "default": "تم إرسال طلبك بنجاح"
    },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "رسالة نجاح الإرسال",
      "default": "سنقوم بالتواصل معك قريبًا لتأكيد طلبك"
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان خطأ الإرسال",
      "default": "حدث خطأ"
    },
    {
      "type": "textarea",
      "id": "error_message",
      "label": "رسالة خطأ الإرسال",
      "default": "حدث خطأ أثناء إرسال النموذج. يرجى المحاولة مرة أخرى"
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    },
    {
      "type": "text",
      "id": "form_id",
      "label": "معرف النموذج",
      "info": "معرف النموذج من لوحة تحكم CODFORM"
    }
  ]
}
{% endschema %}
