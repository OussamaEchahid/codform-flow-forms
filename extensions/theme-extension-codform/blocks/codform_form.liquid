
{% comment %}
  CODFORM - نماذج الدفع عند الاستلام

  هذا البلوك يضيف نموذج الدفع عند الاستلام إلى صفحة المنتج
  لاستخدام هذا النموذج، قم فقط بإضافة معرّف النموذج في إعدادات البلوك
{% endcomment %}

{% if product %}
<div id="codform-container-{{ block.id }}" class="codform-container" data-product-id="{{ product.id }}" data-form-id="{{ block.settings.form_id }}" data-hide-header="true">
  <div class="codform-form-container">
    <div id="codform-form-loader-{{ block.id }}" class="codform-loader">
      <div class="codform-spinner"></div>
      <p>جاري تحميل النموذج...</p>
    </div>

    <div id="codform-form-{{ block.id }}" class="codform-form" style="display: none;">
      <!-- النموذج سيتم تحميله ديناميكيًا هنا -->
    </div>

    <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none;">
      <div class="codform-success-icon">✓</div>
      <h4>تم إرسال الطلب بنجاح</h4>
      <p>شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام.</p>
    </div>

    <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none;">
      <div class="codform-error-icon">!</div>
      <h4>حدث خطأ</h4>
      <p id="codform-error-message-{{ block.id }}">حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى.</p>
      <small id="codform-error-details-{{ block.id }}" class="codform-error-details" style="display: none;"></small>
      <button id="codform-retry-{{ block.id }}" class="codform-button">إعادة المحاولة</button>
    </div>
  </div>
</div>

<!-- Enhanced inline JavaScript with better debugging and error handling -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const containerId = 'codform-container-{{ block.id }}';
    const formId = '{{ block.settings.form_id }}';
    const productId = '{{ product.id }}';
    const container = document.getElementById(containerId);
    const loader = document.getElementById('codform-form-loader-{{ block.id }}');
    const formContainer = document.getElementById('codform-form-{{ block.id }}');
    const errorContainer = document.getElementById('codform-error-{{ block.id }}');
    const errorMessage = document.getElementById('codform-error-message-{{ block.id }}');
    const errorDetails = document.getElementById('codform-error-details-{{ block.id }}');
    const retryButton = document.getElementById('codform-retry-{{ block.id }}');
    const successContainer = document.getElementById('codform-success-{{ block.id }}');
    
    // Debug info for tracking loading issues
    console.log(`CODFORM: Initializing form in container ${containerId} with formId: ${formId} for product: ${productId}`);
    
    // Display debug information if the form ID is missing
    if (!formId || formId.trim() === '') {
      console.error('CODFORM: Missing form ID in block settings');
      if (loader) loader.style.display = 'none';
      if (errorContainer) {
        errorContainer.style.display = 'block';
        if (errorMessage) errorMessage.textContent = 'لم يتم تعيين معرف النموذج. يرجى إضافة معرف النموذج في إعدادات البلوك.';
      }
      return;
    }

    // Enhanced form ID validation with clearer error message
    const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
    if (!uuidRegex.test(formId)) {
      console.error(`CODFORM: Invalid form ID format: ${formId}`);
      if (loader) loader.style.display = 'none';
      if (errorContainer) {
        errorContainer.style.display = 'block';
        if (errorMessage) errorMessage.textContent = 'صيغة معرف النموذج غير صحيحة. يجب أن يكون المعرف بتنسيق UUID.';
        if (errorDetails) {
          errorDetails.textContent = `المعرف المستخدم: ${formId}`;
          errorDetails.style.display = 'block';
        }
      }
      return;
    }

    // Track form loading attempts for debugging
    let loadAttempts = 0;
    const maxAttempts = 3;
    
    // Function to attempt form loading with retry mechanism
    function attemptLoadForm() {
      loadAttempts++;
      console.log(`CODFORM: Loading attempt ${loadAttempts} for form ${formId}`);
      
      if (loadAttempts > 1) {
        console.log('CODFORM: Retrying form load after previous failure');
      }
      
      // Show loader
      if (errorContainer) errorContainer.style.display = 'none';
      if (loader) loader.style.display = 'flex';
      
      // Set a timeout to detect if form loading takes too long
      const loadTimeout = setTimeout(() => {
        console.error('CODFORM: Form loading timed out after 10 seconds');
        handleLoadError('تجاوز وقت تحميل النموذج. قد تكون هناك مشكلة في الاتصال بالخادم.');
      }, 10000);
      
      // Try loading the form
      try {
        // Check if the codformCore library is loaded
        if (typeof window.codformCore === 'undefined' || !window.codformCore.loadForm) {
          console.error('CODFORM: Core library not loaded');
          
          // Try to load the script manually as fallback
          const script = document.createElement('script');
          script.src = '{{ "codform-core.js" | asset_url }}';
          script.onload = function() {
            console.log('CODFORM: Successfully loaded core script manually');
            clearTimeout(loadTimeout); // Clear the timeout since script loaded
            
            if (window.codformCore && window.codformCore.loadForm) {
              window.codformCore.loadForm(containerId, formId, productId);
            } else {
              handleLoadError('فشل تهيئة مكتبة النماذج بعد التحميل اليدوي.');
            }
          };
          script.onerror = function() {
            console.error('CODFORM: Failed to load core script manually');
            clearTimeout(loadTimeout); // Clear the timeout since we know it failed
            handleLoadError('فشل تحميل ملفات النموذج. يرجى تحديث الصفحة أو المحاولة لاحقًا.');
          };
          document.head.appendChild(script);
          
          // Don't proceed with normal loading since we're trying manual loading
          return;
        }
        
        // Normal loading path when library exists
        console.log(`CODFORM: Loading form ${formId} for product ${productId} in container ${containerId}`);
        window.codformCore.loadForm(containerId, formId, productId);
        clearTimeout(loadTimeout); // Clear timeout since we started loading
      } catch (e) {
        console.error('CODFORM: Error during form initialization:', e);
        clearTimeout(loadTimeout); // Clear timeout since we have an error
        handleLoadError(e.message || 'حدث خطأ أثناء تهيئة النموذج. يرجى تحديث الصفحة.');
      }
    }
    
    // Function to handle load errors with details
    function handleLoadError(message) {
      console.error(`CODFORM: Load error: ${message}`);
      
      if (loader) loader.style.display = 'none';
      if (errorContainer) {
        errorContainer.style.display = 'block';
        
        if (errorMessage) {
          errorMessage.textContent = message || 'حدث خطأ أثناء تحميل النموذج. يرجى المحاولة مرة أخرى.';
        }
        
        // Show technical details if this isn't the first attempt
        if (errorDetails && loadAttempts > 1) {
          errorDetails.textContent = `محاولة التحميل رقم ${loadAttempts}/${maxAttempts}. معرف النموذج: ${formId}`;
          errorDetails.style.display = 'block';
        }
        
        // Only show retry button if we haven't reached max attempts
        if (retryButton) {
          if (loadAttempts < maxAttempts) {
            retryButton.style.display = 'block';
            retryButton.textContent = `إعادة المحاولة (${loadAttempts}/${maxAttempts})`;
          } else {
            retryButton.textContent = 'تحديث الصفحة';
            retryButton.onclick = function() {
              window.location.reload();
            };
          }
        }
      }
    }
    
    // Add retry button functionality
    if (retryButton) {
      retryButton.addEventListener('click', function() {
        // If we've reached max attempts, reload the page instead
        if (loadAttempts >= maxAttempts) {
          window.location.reload();
          return;
        }
        
        attemptLoadForm();
      });
    }
    
    // Set up message listeners for form events
    window.addEventListener('message', function(event) {
      // Security check - only process messages from the form app origin
      if (event.origin !== 'https://codform-flow-forms.lovable.app' && 
          event.origin !== 'https://mtyfuwdsshlzqwjujavp.supabase.co') {
        return;
      }
      
      console.log('CODFORM: Received message from form:', event.data);
      
      // Process form events
      if (event.data.type === 'codform:loaded') {
        console.log('CODFORM: Form loaded successfully');
        if (loader) loader.style.display = 'none';
        if (formContainer) formContainer.style.display = 'block';
      }
      else if (event.data.type === 'codform:submitted') {
        console.log('CODFORM: Form submitted successfully');
        if (formContainer) formContainer.style.display = 'none';
        if (successContainer) successContainer.style.display = 'block';
      }
      else if (event.data.type === 'codform:error') {
        console.error('CODFORM: Form error received:', event.data.error);
        handleLoadError(event.data.error || 'حدث خطأ في النموذج');
      }
    });
    
    // Start initial form loading
    attemptLoadForm();
  });
</script>

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "stylesheet": "codform-styles.css",
  "javascript": "codform-core.js",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "معرّف النموذج",
      "info": "أدخل معرف النموذج بالتنسيق UUID الكامل مثل: 6942b35d-ad06-40fb-8f70-86230d20b0fd"
    }
  ]
}
{% endschema %}
