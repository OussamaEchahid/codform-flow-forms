// Function to recreate form from stored data
function createFormFromData(formData) {
  console.log('🔨 CODFORM: Recreating form from data:', formData);
  
  // Handle different data structures - check multiple possible sources for fields
  let fields = null;
  if (formData && formData.data && formData.data.fields) {
    fields = formData.data.fields;
  } else if (formData && formData.fields) {
    fields = formData.fields;
  } else if (formData && formData.data && formData.data.data && formData.data.data.fields) {
    fields = formData.data.data.fields;
  }
  
  if (!fields || !Array.isArray(fields) || fields.length === 0) {
    console.error('❌ CODFORM: No valid fields found in form data:', formData);
    return null;
  }
  
  console.log('✅ CODFORM: Found fields for recreation:', fields.length, 'fields');
  
  const container = document.createElement('div');
  container.className = 'codform-dynamic-form';
  container.style.cssText = `
    background-color: ${formData.style?.backgroundColor || '#FFFFFF'};
    padding: ${formData.style?.paddingTop || '20px'} ${formData.style?.paddingRight || '20px'} ${formData.style?.paddingBottom || '20px'} ${formData.style?.paddingLeft || '20px'};
    border: ${formData.style?.borderWidth || '2px'} solid ${formData.style?.borderColor || '#9b87f5'};
    border-radius: ${formData.style?.borderRadius || '1.5rem'};
    direction: ${formData.style?.formDirection || 'ltr'};
    font-family: 'Cairo', sans-serif;
    max-width: 500px;
    margin: 20px auto;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  `;
  
  // Add form fields
  fields.forEach(field => {
    const fieldHtml = renderField(field, formData.style, formData.language);
    if (fieldHtml) {
      const fieldDiv = document.createElement('div');
      fieldDiv.innerHTML = fieldHtml;
      container.appendChild(fieldDiv.firstElementChild);
    }
  });
  
  // Add submit button if exists
  if (fields.some(f => f.type === 'submit')) {
    const submitField = fields.find(f => f.type === 'submit');
    if (submitField) {
      const submitHtml = renderField(submitField, formData.style, formData.language);
      if (submitHtml) {
        const submitDiv = document.createElement('div');
        submitDiv.innerHTML = submitHtml;
        container.appendChild(submitDiv.firstElementChild);
      }
    }
  }
  
  console.log('✅ CODFORM: Form recreated successfully');
  return container;
}
  
