
{% comment %}
  CODFORM - نماذج الدفع عند الاستلام

  هذا البلوك يضيف نموذج الدفع عند الاستلام إلى صفحة المنتج
  لاستخدام هذا النموذج، قم فقط بإضافة معرّف النموذج في إعدادات البلوك
{% endcomment %}

{% if product %}
<div id="codform-container-{{ block.id }}" class="codform-container" data-product-id="{{ product.id }}" data-form-id="{{ block.settings.form_id }}" data-hide-header="true">
  <div class="codform-form-container">
    <div id="codform-form-loader-{{ block.id }}" class="codform-loader">
      <div class="codform-spinner"></div>
      <p>جاري تحميل النموذج...</p>
    </div>

    <div id="codform-form-{{ block.id }}" class="codform-form" style="display: none;">
      <!-- النموذج سيتم تحميله ديناميكيًا هنا -->
    </div>

    <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none;">
      <div class="codform-success-icon">✓</div>
      <h4>تم إرسال الطلب بنجاح</h4>
      <p>شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام.</p>
    </div>

    <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none;">
      <div class="codform-error-icon">!</div>
      <h4>حدث خطأ</h4>
      <p id="codform-error-message-{{ block.id }}">حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى.</p>
      <small id="codform-error-details-{{ block.id }}" class="codform-error-details" style="display: none;"></small>
      <button id="codform-retry-{{ block.id }}" class="codform-button">إعادة المحاولة</button>
    </div>
  </div>
</div>

<!-- تحسين كود جافا سكريبت لتجنب أخطاء العناصر غير الموجودة وضمان التحميل الصحيح -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // تعريف المتغيرات باستخدام معرف البلوك
    const blockId = '{{ block.id }}';
    const formId = '{{ block.settings.form_id }}';
    const productId = '{{ product.id }}';
    
    // تعريف المعرفات الكاملة للعناصر
    const containerId = 'codform-container-' + blockId;
    const loaderId = 'codform-form-loader-' + blockId;
    const formContainerId = 'codform-form-' + blockId;
    const errorContainerId = 'codform-error-' + blockId;
    const errorMessageId = 'codform-error-message-' + blockId;
    const errorDetailsId = 'codform-error-details-' + blockId;
    const retryButtonId = 'codform-retry-' + blockId;
    const successContainerId = 'codform-success-' + blockId;
    
    // البحث عن العناصر مع التحقق من وجودها
    const container = document.getElementById(containerId);
    const loader = document.getElementById(loaderId);
    const formContainer = document.getElementById(formContainerId);
    const errorContainer = document.getElementById(errorContainerId);
    const errorMessage = document.getElementById(errorMessageId);
    const errorDetails = document.getElementById(errorDetailsId);
    const successContainer = document.getElementById(successContainerId);
    
    // وظيفة لإضافة معلومات التصحيح إلى وحدة التحكم
    function logDebug(message, data) {
      console.log('CODFORM [' + blockId + ']: ' + message, data || '');
    }
    
    // وظيفة للتحقق من وجود عنصر
    function ensureElement(element, id) {
      if (!element) {
        logDebug('عنصر غير موجود: ' + id);
        return false;
      }
      return true;
    }
    
    // التحقق من وجود العنصر الرئيسي
    if (!ensureElement(container, containerId)) {
      console.error('CODFORM: فشل العثور على عنصر الحاوية الرئيسية، توقف التنفيذ');
      return;
    }
    
    // متابعة إنشاء بقية العناصر والتحقق من وجودها
    const retryButton = document.getElementById(retryButtonId) || createRetryButton();
    
    // إنشاء زر إعادة المحاولة إذا لم يكن موجودًا
    function createRetryButton() {
      logDebug('إنشاء زر إعادة المحاولة لأنه غير موجود');
      
      if (!errorContainer) {
        logDebug('لا يمكن إنشاء زر إعادة المحاولة لأن حاوية الخطأ غير موجودة');
        return null;
      }
      
      const button = document.createElement('button');
      button.id = retryButtonId;
      button.className = 'codform-button';
      button.textContent = 'إعادة المحاولة';
      errorContainer.appendChild(button);
      
      return button;
    }
    
    // التحقق من معرف النموذج
    logDebug('بدء تهيئة النموذج', { formId, productId });
    
    if (!formId || formId.trim() === '') {
      logDebug('معرف النموذج مفقود في إعدادات البلوك');
      handleFormError('لم يتم تعيين معرف النموذج. يرجى إضافة معرف النموذج في إعدادات البلوك.');
      return;
    }

    // التحقق من صحة تنسيق معرف النموذج
    const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
    if (!uuidRegex.test(formId)) {
      logDebug('تنسيق معرف النموذج غير صالح: ' + formId);
      handleFormError('صيغة معرف النموذج غير صحيحة. يجب أن يكون المعرف بتنسيق UUID.',
                     'المعرف المستخدم: ' + formId);
      return;
    }
    
    // تتبع محاولات تحميل النموذج للتصحيح
    let loadAttempts = parseInt(localStorage.getItem('codform_load_attempts_' + blockId) || '0');
    const maxAttempts = 3;
    
    // تحديث عداد المحاولات
    loadAttempts++;
    localStorage.setItem('codform_load_attempts_' + blockId, loadAttempts.toString());
    
    logDebug('محاولة تحميل النموذج رقم ' + loadAttempts);
    
    // إعادة ضبط عداد المحاولات بعد ساعة
    setTimeout(function() {
      localStorage.removeItem('codform_load_attempts_' + blockId);
    }, 60 * 60 * 1000);
    
    // التعامل مع خطأ تحميل النموذج
    function handleFormError(message, details) {
      logDebug('حدث خطأ: ' + message);
      
      if (ensureElement(loader, loaderId)) {
        loader.style.display = 'none';
      }
      
      if (ensureElement(errorContainer, errorContainerId)) {
        errorContainer.style.display = 'block';
        
        if (ensureElement(errorMessage, errorMessageId)) {
          errorMessage.textContent = message || 'حدث خطأ أثناء تحميل النموذج. يرجى المحاولة مرة أخرى.';
        }
        
        if (ensureElement(errorDetails, errorDetailsId) && details) {
          errorDetails.textContent = details;
          errorDetails.style.display = 'block';
        }
      }
      
      // إظهار زر إعادة المحاولة أو تحديث الصفحة
      if (retryButton) {
        if (loadAttempts < maxAttempts) {
          retryButton.textContent = 'إعادة المحاولة (' + loadAttempts + '/' + maxAttempts + ')';
          retryButton.style.display = 'inline-block';
        } else {
          retryButton.textContent = 'تحديث الصفحة';
        }
      }
    }
    
    // وظيفة لمحاولة تحميل النموذج
    function attemptLoadForm() {
      logDebug('بدء محاولة تحميل النموذج');
      
      // إظهار شاشة التحميل وإخفاء الأخطاء
      if (ensureElement(errorContainer, errorContainerId)) {
        errorContainer.style.display = 'none';
      }
      
      if (ensureElement(loader, loaderId)) {
        loader.style.display = 'flex';
      }
      
      // الحصول على عنوان النموذج
      const formAppUrl = "https://codform-flow-forms.lovable.app/embed";
      
      // إنشاء عنوان URL للنموذج
      const formUrl = formAppUrl + "/" + formId + "?productId=" + productId + "&embedded=true&hideHeader=true";
      
      // تعيين مهلة للكشف عن أخطاء التحميل
      const timeoutDuration = 15000; // 15 ثانية
      let loadTimeout = setTimeout(function() {
        logDebug('تجاوز وقت تحميل النموذج بعد ' + (timeoutDuration/1000) + ' ثواني');
        handleFormError('تجاوز وقت تحميل النموذج. قد تكون هناك مشكلة في الاتصال بالخادم.');
      }, timeoutDuration);
      
      // وظيفة نجاح تحميل النموذج
      function onFormLoaded() {
        clearTimeout(loadTimeout);
        logDebug('تم تحميل النموذج بنجاح');
        
        if (ensureElement(loader, loaderId)) {
          loader.style.display = 'none';
        }
        
        if (ensureElement(formContainer, formContainerId)) {
          formContainer.style.display = 'block';
        }
        
        // إعادة ضبط عداد المحاولات عند النجاح
        localStorage.removeItem('codform_load_attempts_' + blockId);
      }
      
      // محاولة تحميل النموذج
      try {
        // تحقق من وجود حاوية النموذج
        if (!ensureElement(formContainer, formContainerId)) {
          throw new Error('حاوية النموذج غير موجودة');
        }
        
        // إنشاء إطار iframe للنموذج
        const iframe = document.createElement('iframe');
        iframe.src = formUrl;
        iframe.style.width = '100%';
        iframe.style.height = '600px';
        iframe.style.border = 'none';
        iframe.style.overflowY = 'auto';
        iframe.setAttribute('title', 'نموذج الدفع عند الاستلام');
        iframe.setAttribute('id', 'codform-iframe-' + blockId);
        iframe.onload = onFormLoaded;
        
        // مسح المحتوى السابق وإضافة الإطار الجديد
        formContainer.innerHTML = '';
        formContainer.appendChild(iframe);
        
        // تسجيل معلومات التصحيح
        logDebug('تم إنشاء iframe للنموذج', formUrl);
      } catch (e) {
        clearTimeout(loadTimeout);
        logDebug('خطأ أثناء تهيئة النموذج:', e);
        handleFormError(e.message || 'حدث خطأ أثناء تهيئة النموذج');
      }
    }
    
    // إضافة مستمع أحداث لزر إعادة المحاولة
    if (retryButton) {
      retryButton.addEventListener('click', function() {
        logDebug('تم النقر على زر إعادة المحاولة');
        
        // إذا وصلنا للحد الأقصى من المحاولات، قم بتحديث الصفحة
        if (loadAttempts >= maxAttempts) {
          logDebug('تم الوصول إلى الحد الأقصى من المحاولات، جاري تحديث الصفحة');
          window.location.reload();
          return;
        }
        
        // محاولة إعادة تحميل النموذج
        attemptLoadForm();
      });
    }
    
    // إضافة مستمع لرسائل من النموذج
    window.addEventListener('message', function(event) {
      // التحقق من أمان المصدر - معالجة الرسائل فقط من مصادر موثوقة
      if (event.origin !== 'https://codform-flow-forms.lovable.app' && 
          event.origin !== 'https://mtyfuwdsshlzqwjujavp.supabase.co') {
        return;
      }
      
      logDebug('تم استلام رسالة من النموذج:', event.data);
      
      // معالجة أحداث النموذج
      if (event.data && event.data.type) {
        switch (event.data.type) {
          case 'codform:loaded':
            onFormLoaded();
            break;
            
          case 'codform:submitted':
            logDebug('تم إرسال النموذج بنجاح');
            
            if (ensureElement(formContainer, formContainerId)) {
              formContainer.style.display = 'none';
            }
            
            if (ensureElement(successContainer, successContainerId)) {
              successContainer.style.display = 'block';
            }
            break;
            
          case 'codform:error':
            logDebug('تم استلام خطأ من النموذج:', event.data.error);
            handleFormError(event.data.error || 'حدث خطأ في النموذج');
            break;
        }
      }
    });
    
    // ابدأ تحميل النموذج تلقائيًا
    attemptLoadForm();
  });
</script>

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "stylesheet": "codform-styles.css",
  "javascript": "codform-core.js",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "معرّف النموذج",
      "info": "أدخل معرف النموذج بالتنسيق UUID الكامل مثل: 6942b35d-ad06-40fb-8f70-86230d20b0fd"
    }
  ]
}
{% endschema %}
