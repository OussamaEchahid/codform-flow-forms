
{% comment %}
  @name: CODFORM Form Block
  @description: Display a cash on delivery form for products
  @supports: product
  @by: OurTeam
{% endcomment %}

{% schema %}
{
  "name": "نموذج الدفع عند الاستلام",
  "target": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_header",
      "label": "إخفاء عنوان النموذج",
      "default": false
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "نص التحميل",
      "default": "جاري تحميل النموذج..."
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "عنوان نجاح الإرسال",
      "default": "تم إرسال الطلب بنجاح"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "رسالة نجاح الإرسال",
      "default": "شكرًا لك، سنتواصل معك في أقرب وقت لإتمام عملية الدفع عند الاستلام."
    },
    {
      "type": "text",
      "id": "error_title",
      "label": "عنوان رسالة الخطأ",
      "default": "حدث خطأ"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "رسالة الخطأ",
      "default": "حدث خطأ أثناء تحميل النموذج، يرجى المحاولة مرة أخرى."
    },
    {
      "type": "text",
      "id": "retry_button",
      "label": "نص زر إعادة المحاولة",
      "default": "إعادة المحاولة"
    },
    {
      "type": "checkbox",
      "id": "enable_floating_button",
      "label": "تفعيل الزر العائم",
      "default": false
    },
    {
      "type": "text",
      "id": "floating_button_text",
      "label": "نص الزر العائم",
      "default": "اطلب الآن"
    },
    {
      "type": "select",
      "id": "floating_icon",
      "label": "أيقونة الزر العائم",
      "options": [
        { "value": "shopping-cart", "label": "عربة تسوق" },
        { "value": "package", "label": "طرد" },
        { "value": "truck", "label": "شاحنة" },
        { "value": "send", "label": "إرسال" },
        { "value": "none", "label": "بدون أيقونة" }
      ],
      "default": "shopping-cart"
    },
    {
      "type": "checkbox",
      "id": "floating_show_icon",
      "label": "إظهار الأيقونة",
      "default": true
    },
    {
      "type": "select",
      "id": "floating_animation",
      "label": "تأثير حركي للزر العائم",
      "options": [
        { "value": "none", "label": "بدون" },
        { "value": "pulse", "label": "نبض" },
        { "value": "shake", "label": "اهتزاز" },
        { "value": "bounce", "label": "قفز" },
        { "value": "wiggle", "label": "تمايل" },
        { "value": "flash", "label": "وميض" }
      ],
      "default": "pulse"
    },
    {
      "type": "color",
      "id": "floating_bg_color",
      "label": "لون خلفية الزر العائم",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "floating_text_color",
      "label": "لون نص الزر العائم",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "floating_border_radius",
      "label": "انحناء حواف الزر العائم",
      "default": "4px"
    },
    {
      "type": "text",
      "id": "floating_padding_y",
      "label": "تباعد عمودي للزر العائم",
      "default": "10px"
    },
    {
      "type": "text",
      "id": "floating_font_size",
      "label": "حجم خط الزر العائم",
      "default": "16px"
    },
    {
      "type": "text",
      "id": "floating_font_weight",
      "label": "وزن خط الزر العائم",
      "default": "500"
    },
    {
      "type": "text",
      "id": "floating_margin_bottom",
      "label": "هامش سفلي للزر العائم",
      "default": "20px"
    },
    {
      "type": "text",
      "id": "floating_border_width",
      "label": "عرض حدود الزر العائم",
      "default": "0px"
    },
    {
      "type": "color",
      "id": "floating_border_color",
      "label": "لون حدود الزر العائم",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "is_rtl",
      "label": "اتجاه النص من اليمين لليسار",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "نموذج الدفع عند الاستلام",
      "category": "نماذج"
    }
  ]
}
{% endschema %}

<div 
  id="codform-container-{{ block.id }}" 
  class="codform-container" 
  data-product-id="{{ product.id }}"
  data-block-id="{{ block.id }}"
  data-hide-header="{{ block.settings.hide_header }}"
  data-enable-icons="true"
>
  <div id="codform-form-loader-{{ block.id }}" class="codform-loader" style="display: flex; justify-content: center; padding: 20px;">
    <div class="codform-loader-spinner"></div>
  </div>
  
  <div id="codform-form-{{ block.id }}" class="codform-form-container" style="display: none;"></div>
  
  <div id="codform-success-{{ block.id }}" class="codform-success" style="display: none; text-align: center; padding: 20px;">
    <h3>تم إرسال الطلب بنجاح</h3>
    <p>سيتم التواصل معك قريباً</p>
  </div>
  
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none; text-align: center; padding: 20px;">
    <h3>حدث خطأ</h3>
    <p>يرجى المحاولة مرة أخرى</p>
    <button id="codform-retry-{{ block.id }}" class="codform-retry-button">إعادة المحاولة</button>
  </div>
</div>

<style>
  /* Basic styling for the form loader */
  .codform-loader-spinner {
    border: 4px solid rgba(0, 0, 0, 0.1);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border-left-color: #09f;
    animation: spin 1s linear infinite;
  }
  
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  .codform-retry-button {
    margin-top: 10px;
    padding: 8px 16px;
    background: #09f;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }
  
  .codform-form textarea,
  .codform-form input[type="text"],
  .codform-form input[type="email"],
  .codform-form input[type="tel"],
  .codform-form input[type="number"] {
    width: 100%;
    padding: 8px 12px;
    margin: 8px 0;
    border: 1px solid #ddd;
    border-radius: 4px;
  }
  
  .codform-form label {
    font-weight: 500;
    display: block;
    margin-bottom: 5px;
  }
  
  .codform-submit-button {
    padding: 10px 20px;
    margin-top: 15px;
    width: 100%;
    border: none;
    cursor: pointer;
    font-weight: 500;
    font-size: 16px;
    color: white;
  }
  
  .codform-required {
    color: #e32;
    margin-left: 4px;
  }

  .codform-field {
    margin-bottom: 15px;
  }
  
  .codform-field-with-icon input,
  .codform-field-with-icon textarea {
    padding-left: 36px !important;
  }
  
  .codform-field-with-icon.rtl input,
  .codform-field-with-icon.rtl textarea {
    padding-left: 12px !important;
    padding-right: 36px !important;
  }
  
  .codform-field-with-icon .codform-field-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: #6b7280;
  }
  
  .codform-field-with-icon.rtl .codform-field-icon {
    left: auto;
    right: 10px;
  }
  
  .codform-help-text {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 4px;
  }
  
  @keyframes pulse-animation {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  
  .pulse-animation {
    animation: pulse-animation 2s infinite ease-in-out;
  }
  
  @keyframes shake-animation {
    0% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
    20%, 40%, 60%, 80% { transform: translateX(5px); }
  }
  
  .shake-animation {
    animation: shake-animation 2s infinite ease-in-out;
  }
  
  @keyframes bounce-animation {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  
  .bounce-animation {
    animation: bounce-animation 2s infinite ease-in-out;
  }
  
  @keyframes wiggle-animation {
    0%, 100% { transform: rotate(0); }
    25% { transform: rotate(-3deg); }
    75% { transform: rotate(3deg); }
  }
  
  .wiggle-animation {
    animation: wiggle-animation 2s infinite ease-in-out;
  }
  
  @keyframes flash-animation {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  
  .flash-animation {
    animation: flash-animation 2s infinite ease-in-out !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('codform-container-{{ block.id }}');
    const loader = document.getElementById('codform-form-loader-{{ block.id }}');
    const formContainer = document.getElementById('codform-form-{{ block.id }}');
    const errorContainer = document.getElementById('codform-error-{{ block.id }}');
    const successContainer = document.getElementById('codform-success-{{ block.id }}');
    const retryButton = document.getElementById('codform-retry-{{ block.id }}');
    
    if (container && loader) {
      loader.style.display = 'flex';
      
      // إضافة معالج حدث إعادة المحاولة
      if (retryButton) {
        retryButton.addEventListener('click', function() {
          errorContainer.style.display = 'none';
          loader.style.display = 'flex';
          fetchForm();
        });
      }
      
      // بدء تحميل النموذج
      fetchForm();
    }
    
    // وظيفة لجلب النموذج بناءً على معرف المنتج
    function fetchForm() {
      const productId = container.getAttribute('data-product-id');
      const blockId = container.getAttribute('data-block-id');
      const shop = Shopify.shop || window.location.hostname;
      
      if (!productId || !shop) {
        showError("بيانات المنتج أو المتجر غير متوفرة");
        console.error('Missing product ID or shop information');
        return;
      }
      
      // طباعة معلومات التصحيح
      console.log('Fetching form with productId:', productId, 'blockId:', blockId, 'shop:', shop);
      
      // استخدام عنوان URL الكامل مع https - إصلاح خطأ حل DNS
      const apiUrl = `https://mtyfuwdsshlzqwjujavp.supabase.co/functions/v1/forms-product?shop=${encodeURIComponent(shop)}&productId=${encodeURIComponent(productId)}&blockId=${encodeURIComponent(blockId)}`;
      
      console.log('Request URL:', apiUrl);
      
      // جلب تكوين النموذج
      fetch(apiUrl)
        .then(response => {
          if (!response.ok) {
            console.error('HTTP error:', response.status, response.statusText);
            throw new Error(`HTTP error ${response.status}`);
          }
          return response.json();
        })
        .then(data => {
          if (data && data.form) {
            console.log('Form data received successfully:', data);
            renderForm(data.form, blockId);
          } else {
            console.error('No form data received:', data);
            showError("لا يوجد نموذج متوفر لهذا المنتج");
          }
        })
        .catch(error => {
          console.error('Error fetching form:', error);
          showError("حدث خطأ أثناء تحميل النموذج");
        });
    }
    
    // وظيفة لعرض النموذج
    function renderForm(formData, blockId) {
      if (!formContainer) {
        console.error('Form container not found');
        return;
      }
      
      // إخفاء التحميل
      if (loader) {
        loader.style.display = 'none';
      }
      
      // إنشاء HTML للنموذج
      const formHtml = createFormHtml(formData, blockId);
      
      // عرض النموذج
      formContainer.innerHTML = formHtml;
      formContainer.style.display = 'block';
      
      // إعداد معالجات الأحداث
      setupFormHandlers(formData, blockId);
    }
    
    // وظيفة لإظهار رسالة الخطأ
    function showError(message) {
      if (loader) loader.style.display = 'none';
      if (formContainer) formContainer.style.display = 'none';
      if (successContainer) successContainer.style.display = 'none';
      
      if (errorContainer) {
        const errorMessage = errorContainer.querySelector('p');
        if (errorMessage && message) {
          errorMessage.textContent = message;
        }
        errorContainer.style.display = 'block';
      }
    }
    
    // وظيفة لإنشاء HTML للنموذج
    function createFormHtml(formData, blockId) {
      const hideHeader = container.getAttribute('data-hide-header') === 'true';
      const enableIcons = container.getAttribute('data-enable-icons') === 'true';
      const isRTL = formData.settings?.direction === 'rtl';
      let html = '';
      
      // إضافة رأس النموذج إذا لم يتم إخفاؤه
      if (!hideHeader && formData.title) {
        html += `<div class="codform-header" style="background-color: ${formData.settings?.primaryColor || '#9b87f5'}; color: #ffffff; padding: 15px; border-radius: 8px 8px 0 0; margin-bottom: 15px;">
          <h3 style="margin: 0; font-size: 1.25rem;">${formData.title}</h3>
          ${formData.description ? `<p style="margin: 5px 0 0 0; font-size: 0.875rem;">${formData.description}</p>` : ''}
        </div>`;
      }
      
      // بداية النموذج
      html += `<form id="codform-form-element-${blockId}" class="codform-form" style="direction: ${isRTL ? 'rtl' : 'ltr'};">`;
      
      // إضافة الحقول
      if (formData.fields && formData.fields.length) {
        formData.fields.forEach(field => {
          if (field && field.type) {
            // تخطي حقل عنوان النموذج إذا تم عرض الرأس
            if (field.type === 'form-title') {
              if (!hideHeader) return;
              
              html += createTitleField(field);
              return;
            }
            
            if (field.type === 'text' || field.type === 'email' || field.type === 'phone') {
              html += createInputField(field, isRTL, enableIcons);
            } else if (field.type === 'textarea') {
              html += createTextareaField(field, isRTL, enableIcons);
            } else if (field.type === 'radio') {
              html += createRadioField(field);
            } else if (field.type === 'checkbox') {
              html += createCheckboxField(field);
            } else if (field.type === 'submit') {
              html += createSubmitButton(field, formData.settings);
            } else if (field.type === 'text/html') {
              html += createHtmlContent(field);
            } else if (field.type === 'whatsapp') {
              html += createWhatsAppButton(field);
            } else if (field.type === 'image') {
              html += createImageField(field);
            }
          }
        });
      } else {
        console.error('No fields found in form data', formData);
        html += '<div style="padding: 15px; text-align: center; color: #e32;">لا توجد حقول في هذا النموذج</div>';
      }
      
      // نهاية النموذج
      html += '</form>';
      
      return html;
    }
    
    // وظيفة لإعداد معالجات الأحداث للنموذج
    function setupFormHandlers(formData, blockId) {
      const form = document.getElementById(`codform-form-element-${blockId}`);
      
      if (form) {
        form.addEventListener('submit', function(event) {
          event.preventDefault();
          // معالجة إرسال النموذج - يمكن إضافة المزيد من المنطق هنا
          console.log('Form submitted');
          
          // هنا يمكن إضافة منطق إرسال البيانات إلى الخلفية
          
          // إظهار رسالة النجاح
          if (formContainer) formContainer.style.display = 'none';
          if (successContainer) successContainer.style.display = 'block';
        });
      }
    }
    
    // وظيفة لإنشاء حقل إدخال
    function createInputField(field, isRTL, enableIcons) {
      const hasIcon = enableIcons && field.icon && field.icon !== 'none' && field.style?.showIcon !== false;
      const fieldClassContainer = `codform-field ${hasIcon ? 'codform-field-with-icon' : ''} ${isRTL ? 'rtl' : ''}`;
      let iconSvg = '';
      
      // الحصول على SVG للأيقونة إذا لزم الأمر
      if (hasIcon) {
        iconSvg = getIconSvg(field.icon);
      }
      
      const translatedLabel = field.label || '';
      const translatedPlaceholder = field.placeholder || '';
      
      return `
        <div class="${fieldClassContainer}" style="position: relative;">
          <label for="codform-field-${field.id}">
            ${translatedLabel}
            ${field.required ? '<span class="codform-required">*</span>' : ''}
          </label>
          <div style="position: relative;">
            ${hasIcon ? `<div class="codform-field-icon">${iconSvg}</div>` : ''}
            <input 
              type="${field.type === 'email' ? 'email' : field.type === 'phone' ? 'tel' : 'text'}"
              id="codform-field-${field.id}"
              name="${field.id}"
              placeholder="${translatedPlaceholder}"
              ${field.required ? 'required' : ''}
              class="codform-input ${hasIcon ? 'with-icon' : ''}"
            />
          </div>
          ${field.helpText ? `<div class="codform-help-text">${field.helpText}</div>` : ''}
        </div>
      `;
    }
    
    // وظيفة لإنشاء منطقة نص
    function createTextareaField(field, isRTL, enableIcons) {
      const hasIcon = enableIcons && field.icon && field.icon !== 'none' && field.style?.showIcon !== false;
      const fieldClassContainer = `codform-field ${hasIcon ? 'codform-field-with-icon' : ''} ${isRTL ? 'rtl' : ''}`;
      let iconSvg = '';
      
      // الحصول على SVG للأيقونة إذا لزم الأمر
      if (hasIcon) {
        iconSvg = getIconSvg(field.icon);
      }
      
      const translatedLabel = field.label || '';
      const translatedPlaceholder = field.placeholder || '';
      
      return `
        <div class="${fieldClassContainer}" style="position: relative;">
          <label for="codform-field-${field.id}">
            ${translatedLabel}
            ${field.required ? '<span class="codform-required">*</span>' : ''}
          </label>
          <div style="position: relative;">
            ${hasIcon ? `<div class="codform-field-icon">${iconSvg}</div>` : ''}
            <textarea
              id="codform-field-${field.id}"
              name="${field.id}"
              placeholder="${translatedPlaceholder}"
              ${field.required ? 'required' : ''}
              rows="${field.rows || 4}"
              class="codform-textarea ${hasIcon ? 'with-icon' : ''}"
            ></textarea>
          </div>
          ${field.helpText ? `<div class="codform-help-text">${field.helpText}</div>` : ''}
        </div>
      `;
    }
    
    // وظيفة لإنشاء مجموعة أزرار راديو
    function createRadioField(field) {
      const translatedLabel = field.label || '';
      
      let html = `
        <div class="codform-field">
          <label>
            ${translatedLabel}
            ${field.required ? '<span class="codform-required">*</span>' : ''}
          </label>
          <div class="codform-radio-group">
      `;
      
      if (field.options && field.options.length) {
        field.options.forEach((option, index) => {
          const translatedOptionLabel = option.label || '';
          
          html += `
            <div class="codform-radio-option">
              <input
                type="radio"
                id="codform-field-${field.id}-${index}"
                name="${field.id}"
                value="${option.value || ''}"
                ${field.required && index === 0 ? 'required' : ''}
                ${option.selected ? 'checked' : ''}
              />
              <label for="codform-field-${field.id}-${index}">${translatedOptionLabel}</label>
            </div>
          `;
        });
      }
      
      html += `
          </div>
          ${field.helpText ? `<div class="codform-help-text">${field.helpText}</div>` : ''}
        </div>
      `;
      
      return html;
    }
    
    // وظيفة لإنشاء مجموعة مربعات اختيار
    function createCheckboxField(field) {
      const translatedLabel = field.label || '';
      
      let html = `
        <div class="codform-field">
          <label>
            ${translatedLabel}
            ${field.required ? '<span class="codform-required">*</span>' : ''}
          </label>
          <div class="codform-checkbox-group">
      `;
      
      if (field.options && field.options.length) {
        field.options.forEach((option, index) => {
          const translatedOptionLabel = option.label || '';
          
          html += `
            <div class="codform-checkbox-option">
              <input
                type="checkbox"
                id="codform-field-${field.id}-${index}"
                name="${field.id}[]"
                value="${option.value || ''}"
                ${option.selected ? 'checked' : ''}
              />
              <label for="codform-field-${field.id}-${index}">${translatedOptionLabel}</label>
            </div>
          `;
        });
      }
      
      html += `
          </div>
          ${field.helpText ? `<div class="codform-help-text">${field.helpText}</div>` : ''}
        </div>
      `;
      
      return html;
    }
    
    // وظيفة لإنشاء زر إرسال
    function createSubmitButton(field, formSettings) {
      const buttonStyle = field.style || {};
      const backgroundColor = buttonStyle.backgroundColor || formSettings?.primaryColor || '#9b87f5';
      const borderRadius = buttonStyle.borderRadius || '4px';
      const fontSize = buttonStyle.fontSize || '16px';
      const fontWeight = buttonStyle.fontWeight || '500';
      const color = buttonStyle.color || '#ffffff';
      const padding = buttonStyle.paddingY ? `${buttonStyle.paddingY} 20px` : '10px 20px';
      const borderWidth = buttonStyle.borderWidth || '0px';
      const borderColor = buttonStyle.borderColor || backgroundColor;
      
      // فئة الرسوم المتحركة
      const animationType = buttonStyle.animation && buttonStyle.animationType ? buttonStyle.animationType : 'none';
      const animationClass = animationType !== 'none' ? `${animationType}-animation` : '';
      
      // معالجة الأيقونة
      const showIcon = buttonStyle.showIcon !== false && buttonStyle.icon;
      let iconHtml = '';
      
      if (showIcon) {
        const iconSvg = getIconSvg(buttonStyle.icon || 'shopping-cart');
        iconHtml = `<span class="codform-button-icon" style="display: inline-flex; align-items: center; margin-${buttonStyle.iconPosition === 'right' ? 'left' : 'right'}: 8px;">${iconSvg}</span>`;
      }
      
      const translatedLabel = field.label || 'إرسال الطلب';
      
      return `
        <div class="codform-field">
          <button
            type="submit"
            class="codform-submit-button ${animationClass}"
            style="
              background-color: ${backgroundColor};
              border-radius: ${borderRadius};
              font-size: ${fontSize};
              font-weight: ${fontWeight};
              color: ${color};
              padding: ${padding};
              border: ${borderWidth} solid ${borderColor};
              display: flex;
              align-items: center;
              justify-content: center;
            "
          >
            ${buttonStyle.iconPosition !== 'right' ? iconHtml : ''}
            <span>${translatedLabel}</span>
            ${buttonStyle.iconPosition === 'right' ? iconHtml : ''}
          </button>
        </div>
      `;
    }
    
    // وظيفة لإنشاء حقل العنوان
    function createTitleField(field) {
      const style = field.style || {};
      const backgroundColor = style.backgroundColor || '#9b87f5';
      const color = style.color || '#ffffff';
      const descriptionColor = style.descriptionColor || '#ffffff';
      
      const translatedLabel = field.label || '';
      const translatedHelp = field.helpText || '';
      
      return `
        <div class="codform-field codform-title-field" style="background-color: ${backgroundColor}; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
          <h3 style="margin: 0; color: ${color}; font-size: ${style.fontSize || '1.25rem'}; font-weight: ${style.fontWeight || 'bold'}; text-align: ${style.textAlign || 'left'};">
            ${translatedLabel}
          </h3>
          ${translatedHelp ? `<p style="margin: 5px 0 0 0; color: ${descriptionColor}; font-size: ${style.descriptionFontSize || '0.875rem'};">${translatedHelp}</p>` : ''}
        </div>
      `;
    }
    
    // وظيفة لإنشاء محتوى HTML
    function createHtmlContent(field) {
      return `
        <div class="codform-field codform-html-content">
          ${field.content || ''}
        </div>
      `;
    }
    
    // وظيفة لإنشاء زر واتساب
    function createWhatsAppButton(field) {
      const style = field.style || {};
      const backgroundColor = style.backgroundColor || '#25D366';
      const color = style.color || '#ffffff';
      const borderRadius = style.borderRadius || '4px';
      const phone = field.phone || '';
      const message = encodeURIComponent(field.message || '');
      
      const translatedLabel = field.label || 'واتساب';
      
      // أيقونة واتساب SVG
      const whatsappIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;
      
      return `
        <div class="codform-field">
          <a 
            href="https://wa.me/${phone}${message ? `?text=${message}` : ''}"
            target="_blank"
            rel="noopener noreferrer"
            class="codform-whatsapp-button"
            style="
              display: flex;
              align-items: center;
              justify-content: center;
              background-color: ${backgroundColor};
              color: ${color};
              padding: 10px 20px;
              border-radius: ${borderRadius};
              text-decoration: none;
              font-weight: 500;
            "
          >
            <span style="display: inline-flex; align-items: center; margin-right: 8px;">${whatsappIcon}</span>
            <span>${translatedLabel}</span>
          </a>
        </div>
      `;
    }
    
    // وظيفة لإنشاء حقل صورة
    function createImageField(field) {
      const style = field.style || {};
      const imageUrl = field.imageUrl || '';
      const altText = field.altText || field.label || 'صورة';
      const maxWidth = style.maxWidth || '100%';
      const alignment = style.alignment || 'center';
      
      let alignmentStyle = 'margin: 0 auto;'; // للتوسيط افتراضيًا
      
      if (alignment === 'left') {
        alignmentStyle = 'margin-right: auto;';
      } else if (alignment === 'right') {
        alignmentStyle = 'margin-left: auto;';
      }
      
      return `
        <div class="codform-field">
          <img 
            src="${imageUrl}"
            alt="${altText}"
            class="codform-image"
            style="
              max-width: ${maxWidth};
              display: block;
              ${alignmentStyle}
              border-radius: ${style.borderRadius || '0'};
            "
          />
        </div>
      `;
    }
    
    // وظيفة للحصول على SVG للأيقونة
    function getIconSvg(iconName) {
      // تنفيذ الأيقونات الأساسية
      switch (iconName) {
        case 'user':
          return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>';
        case 'phone':
          return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>';
        case 'mail':
          return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>';
        case 'map-pin':
          return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>';
        case 'shopping-cart':
          return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>';
        default:
          return '';
      }
    }
  });
</script>

