{% schema %}
{
  "name": "CodForm",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "Order Form"
    }
  ]
}
{% endschema %}

<style>
.codform-container {
  max-width: 600px;
  margin: 0 auto;
  padding: 20px;
  font-family: Arial, sans-serif;
}

.codform-loading {
  text-align: center;
  padding: 40px 20px;
}

.codform-spinner {
  border: 4px solid #f3f3f3;
  border-top: 4px solid #3498db;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  animation: spin 2s linear infinite;
  margin: 0 auto 20px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.codform-error {
  background-color: #fee;
  border: 1px solid #fcc;
  color: #c33;
  padding: 15px;
  border-radius: 5px;
  text-align: center;
}
</style>

<!-- Quantity offers containers - keeping only inside container -->
<div id="quantity-offers-inside" style="display: none;"></div>

<!-- Form container -->
<div id="codform-container-{{ block.id }}" class="codform-container">
  <div id="codform-loading-{{ block.id }}" class="codform-loading">
    <div class="codform-spinner"></div>
    <p>جاري تحميل النموذج...</p>
  </div>
  <div id="codform-error-{{ block.id }}" class="codform-error" style="display: none;">
    <p>حدث خطأ في تحميل النموذج. يرجى المحاولة مرة أخرى.</p>
  </div>
  <div id="codform-form-{{ block.id }}" style="display: none;"></div>
</div>

<script>
(function() {
  const blockId = '{{ block.id }}';
  const productId = '{{ product.id }}';
  const productHandle = '{{ product.handle }}';
  const shopDomain = '{{ shop.domain }}';
  
  console.log('🚀 CODFORM: Starting form initialization', {
    blockId,
    productId,
    productHandle,
    shopDomain
  });

  // Form loading function
  async function loadForm() {
    const container = document.getElementById(`codform-container-${blockId}`);
    const loadingElement = document.getElementById(`codform-loading-${blockId}`);
    const errorElement = document.getElementById(`codform-error-${blockId}`);
    const formElement = document.getElementById(`codform-form-${blockId}`);

    if (!container || !loadingElement || !errorElement || !formElement) {
      console.error('❌ CODFORM: Required elements not found');
      return;
    }

    try {
      console.log('📡 CODFORM: Fetching form data...');
      
      // API call to get form data
      const response = await fetch(`https://zrgnqfqamaupflkpghfj.supabase.co/functions/v1/forms-product?product_id=${productId}&shop_domain=${shopDomain}`);
      
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const data = await response.json();
      console.log('✅ CODFORM: Form data received', data);

      if (!data.form || !data.form.fields) {
        throw new Error('No form configured for this product');
      }

      // Hide loading, show form
      loadingElement.style.display = 'none';
      formElement.style.display = 'block';
      
      // Create React root and render form
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/react@18/umd/react.production.min.js';
      script.onload = () => {
        const reactDomScript = document.createElement('script');
        reactDomScript.src = 'https://unpkg.com/react-dom@18/umd/react-dom.production.min.js';
        reactDomScript.onload = () => {
          // Form will be rendered by React with quantity offers inside
          renderReactForm(data, formElement);
        };
        document.head.appendChild(reactDomScript);
      };
      document.head.appendChild(script);

    } catch (error) {
      console.error('❌ CODFORM: Error loading form:', error);
      loadingElement.style.display = 'none';
      errorElement.style.display = 'block';
      errorElement.innerHTML = `
        <p>حدث خطأ في تحميل النموذج</p>
        <p style="font-size: 12px; color: #666;">${error.message}</p>
      `;
    }
  }

  // Render React form function
  function renderReactForm(data, container) {
    console.log('🎨 CODFORM: Rendering React form with quantity offers inside');
    
    // This will be handled by FormWithQuantityOffers.tsx
    // which correctly displays offers inside the form
    const formHTML = `
      <div id="react-form-root-${blockId}">
        <!-- React form will be mounted here -->
        <!-- Quantity offers will be rendered inside the form by FormWithQuantityOffers.tsx -->
      </div>
    `;
    
    container.innerHTML = formHTML;
    
    // Initialize React form rendering
    if (window.React && window.ReactDOM) {
      console.log('✅ CODFORM: React is ready, form will render with offers inside');
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadForm);
  } else {
    loadForm();
  }
})();
</script>
